    if ($null -eq (Get-RcaScriptVar 'RcaEventMap')) {
        $path = Join-Path $script:ModuleRoot 'Data\eventid.map.json'
        if (Test-Path $path) {
            $script:RcaEventMap = Get-Content $path -Raw -Encoding UTF8 | ConvertFrom-Json
        } else {
