    $ctl.dpDate.IsEnabled = $manual
    $ctl.txtTime.IsEnabled = $manual
}.GetNewClosure()
$ctl.chkAuto.Add_Checked($toggleTime)
$ctl.chkAuto.Add_Unchecked($toggleTime)

$ctl.btnBrowse.Add_Click({
    $dlg = New-Object System.Windows.Forms.FolderBrowserDialog
    if ($ctl.txtOut.Text -and (Test-Path $ctl.txtOut.Text)) { $dlg.SelectedPath = $ctl.txtOut.Text }
    if ($dlg.ShowDialog() -eq [System.Windows.Forms.DialogResult]::OK) { $ctl.txtOut.Text = $dlg.SelectedPath }
}.GetNewClosure())

$ctl.btnOpenFolder.Add_Click({
    if ($script:lastDir -and (Test-Path $script:lastDir)) { Invoke-Item $script:lastDir }
}.GetNewClosure())

$ctl.btnRun.Add_Click({
    # --- Gather + validate -------------------------------------------------
    $target = ($ctl.txtTarget.Text).Trim()
    if (-not $target) {
        [System.Windows.MessageBox]::Show('Enter a cluster name or one or more node names.', 'SQL Failover RCA', 'OK', 'Warning') | Out-Null
        return
    }

    $params = @{ OutputPath = $ctl.txtOut.Text }
    if ($ctl.rbCluster.IsChecked) {
        $params.ClusterName = $target
    } else {
        $params.Node = @($target -split '[,;]' | ForEach-Object { $_.Trim() } | Where-Object { $_ })
    }
    if ($ctl.txtSql.Text.Trim()) {
        $params.SqlInstance = @($ctl.txtSql.Text -split '[,;]' | ForEach-Object { $_.Trim() } | Where-Object { $_ })
    }

    if (-not $ctl.chkAuto.IsChecked) {
        if (-not $ctl.dpDate.SelectedDate) {
            [System.Windows.MessageBox]::Show('Pick an event date, or tick auto-detect.', 'SQL Failover RCA', 'OK', 'Warning') | Out-Null
            return
        }
        $t = [datetime]::Today
        if (-not [datetime]::TryParse($ctl.dpDate.SelectedDate.ToString('yyyy-MM-dd') + ' ' + $ctl.txtTime.Text, [ref]$t)) {
            [System.Windows.MessageBox]::Show('Time must be HH:mm (24-hour).', 'SQL Failover RCA', 'OK', 'Warning') | Out-Null
            return
        }
        $params.EventTime = $t
    }

    $b = 30; $a = 15
    [void][int]::TryParse($ctl.txtBefore.Text, [ref]$b)
    [void][int]::TryParse($ctl.txtAfter.Text,  [ref]$a)
    $params.WindowBefore = (New-TimeSpan -Minutes $b)
    $params.WindowAfter  = (New-TimeSpan -Minutes $a)

    if ($ctl.chkOpen.IsChecked) { $params.OpenReport = $true }

    if ($ctl.chkCred.IsChecked) {
        $cred = Get-Credential -Message 'Credentials for the target node(s)'
        if ($cred) { $params.Credential = $cred }
    }

    # --- Launch in a background runspace -----------------------------------
    Set-RunningState $true
    $ctl.txtStatus.Text = 'Running analysis...'
    $ctl.txtVerdict.Text = '--'
    $ctl.txtFindings.Text = ''
    $ctl.btnOpenFolder.IsEnabled = $false

    $script:psInst = [powershell]::Create()
    [void]$script:psInst.AddScript({
        param($manifest, $p)
        Import-Module $manifest -Force
        Invoke-FailoverRCA @p
    }).AddArgument($script:ModuleManifest).AddArgument($params)
    $script:async = $script:psInst.BeginInvoke()

    $script:timer = New-Object System.Windows.Threading.DispatcherTimer
    $script:timer.Interval = [TimeSpan]::FromMilliseconds(300)
    $script:timer.Add_Tick({
        if (-not $script:async.IsCompleted) { return }
        $script:timer.Stop()
        $result = $null; $err = $null
        try { $result = @($script:psInst.EndInvoke($script:async)) | Select-Object -Last 1 }
        catch { $err = $_.Exception.Message }
        finally { $script:psInst.Dispose() }

        Set-RunningState $false
        if ($err) {
            $ctl.txtStatus.Text = 'Failed.'
            $ctl.txtVerdict.Text = $err
            $ctl.txtVerdict.Foreground = [System.Windows.Media.Brushes]::Firebrick
            return
        }

        $script:lastDir = $result.EvidencePath
        $ctl.btnOpenFolder.IsEnabled = [bool]($script:lastDir -and (Test-Path $script:lastDir))
        $ctl.txtStatus.Text = "Done. $(@($result.Findings).Count) finding(s)."

        $pf = $result.PrimaryFinding
        if ($pf) {
            $ctl.txtVerdict.Text = "$($pf.Category)  -  $($pf.Confidence)% ($($pf.Severity))"
            $brush = switch ($pf.Severity) {
                'Critical' { 'Firebrick' } 'High' { 'Chocolate' } 'Medium' { 'DarkGoldenrod' } default { 'SlateGray' }
            }
            $ctl.txtVerdict.Foreground = [System.Windows.Media.Brushes].GetProperty($brush).GetValue($null)
        } else {
            $ctl.txtVerdict.Text = 'No fault root cause identified for this window.'
            $ctl.txtVerdict.Foreground = [System.Windows.Media.Brushes]::SlateGray
        }

        $lines = foreach ($f in @($result.Findings)) {
            "[{0,3}%] {1,-8} {2}{3}" -f $f.Confidence, $f.Severity, $f.Category, $(if ($f.IsPlanned) { ' (planned)' } else { '' })
        }
        $ctl.txtFindings.Text = ($lines -join "`r`n")
    }.GetNewClosure())
