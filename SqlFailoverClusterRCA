<#
    HTML reporter - a single self-contained file (inline CSS + a little vanilla JS, no
    external dependencies, works offline and is safe to email). Renders:
      - a verdict card (primary finding + confidence + remediation + evidence chain),
      - ranked findings with confidence bars and KB links,
      - a filterable, color-coded cross-node timeline (filter by text/source/severity/node),
      - per-source collection status.
    Phase 4. Public surface unchanged: New-HtmlReport -RcaResult <obj> -Path <file> -> path.
#>

function ConvertTo-RcaHtmlEncoded {
    param([string]$s)
    if ($null -eq $s) { return '' }
    [System.Net.WebUtility]::HtmlEncode($s)
}

# Lower-cased, HTML-safe token for use in a CSS class (never $null).
function Get-RcaCssToken {
    param([string]$s)
    if (-not $s) { return 'none' }
    ($s -replace '[^A-Za-z0-9]', '').ToLower()
}

function New-HtmlReport {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]$RcaResult,
        [Parameter(Mandatory)][string]$Path
    )
    $dir = Split-Path -Parent $Path
    if ($dir -and -not (Test-Path $dir)) { New-Item -ItemType Directory -Path $dir -Force | Out-Null }

    $enc = { param($x) ConvertTo-RcaHtmlEncoded $x }
    function Format-RcaTime { param($t)
        if (-not $t) { return '(no time)' }
        try { return ([datetime]$t).ToString('yyyy-MM-dd HH:mm:ss.fff') } catch { return "$t" }
    }

    # --- Verdict ------------------------------------------------------------
    $primary = $RcaResult.PrimaryFinding
    if ($primary) {
        $vClass = Get-RcaCssToken $primary.Severity
        $verdictHtml = @"
    <div class="v">$(& $enc $primary.Category) <span class="sev sev-$vClass">$(& $enc $primary.Severity)</span> <span class="conf">$($primary.Confidence)% confidence</span></div>
    <p class="explain">$(& $enc $primary.Explanation)</p>
    <p class="remediation"><b>Recommended action:</b> $(& $enc $primary.Remediation)$(if ($primary.KbRef) { " &nbsp;<a href=""$(& $enc $primary.KbRef)"">[reference]</a>" })</p>
"@
        $ev = @($primary.Evidence) | Select-Object -First 6
        if ($ev) {
            $evRows = foreach ($e in $ev) {
                "<li><code>$(& $enc (Format-RcaTime $e.Timestamp))</code> &middot; <b>$(& $enc $e.Node)</b> &middot; $(& $enc $e.Source) &middot; $(& $enc $e.Message)</li>"
            }
            $verdictHtml += @"
    <details open><summary>Evidence ($(@($primary.Evidence).Count))</summary><ul class="evidence">$($evRows -join "`n")</ul></details>
"@
        }
    } else {
        $verdictHtml = '<div class="v muted">No fault root cause identified for this window.</div>'
    }

    # --- Findings table -----------------------------------------------------
    $findingRows = foreach ($f in @($RcaResult.Findings)) {
        $sc = Get-RcaCssToken $f.Severity
        $planned = if ($f.IsPlanned) { ' <span class="tag">planned</span>' } else { '' }
        $kb = if ($f.KbRef) { "<a href=""$(& $enc $f.KbRef)"">KB</a>" } else { '' }
        @"
      <tr>
        <td><span class="sev sev-$sc">$(& $enc $f.Severity)</span></td>
        <td class="confcell"><div class="bar"><div class="fill fill-$sc" style="width:$([int]$f.Confidence)%"></div></div><span>$([int]$f.Confidence)%</span></td>
        <td><b>$(& $enc $f.Category)</b>$planned<br><span class="muted">$(& $enc $f.RuleId)</span></td>
        <td>$(& $enc $f.Explanation)</td>
        <td>$(& $enc $f.Remediation) $kb</td>
      </tr>
"@
    }
    if (-not $findingRows) { $findingRows = '<tr><td colspan="5" class="muted">No findings.</td></tr>' }

    # --- Timeline (filterable) ---------------------------------------------
    $tl = @($RcaResult.Timeline)
    $timelineRows = foreach ($e in $tl) {
        $sc = Get-RcaCssToken $e.Severity
        @"
      <tr data-source="$(& $enc $e.Source)" data-sev="$(& $enc $e.Severity)" data-node="$(& $enc $e.Node)">
        <td class="nowrap">$(& $enc (Format-RcaTime $e.Timestamp))</td>
        <td>$(& $enc $e.Node)</td>
        <td>$(& $enc $e.Source)</td>
        <td><span class="dot dot-$sc"></span>$(& $enc $e.Severity)</td>
        <td>$(& $enc $e.EventId)</td>
        <td>$(& $enc $e.Message)</td>
      </tr>
"@
    }
    if (-not $timelineRows) { $timelineRows = '<tr><td colspan="6" class="muted">No timeline events.</td></tr>' }

    $optionList = { param($values)
        ($values | Where-Object { $_ } | Sort-Object -Unique | ForEach-Object { "<option value=""$(& $enc $_)"">$(& $enc $_)</option>" }) -join ''
    }
    $srcOpts  = & $optionList ($tl | ForEach-Object { $_.Source })
    $sevOpts  = & $optionList ($tl | ForEach-Object { $_.Severity })
    $nodeOpts = & $optionList ($tl | ForEach-Object { $_.Node })

    # --- Collection status --------------------------------------------------
    $statusRows = foreach ($s in @($RcaResult.CollectionStatus)) {
        $st = Get-RcaCssToken $s.State
        @"
      <tr>
        <td>$(& $enc $s.Node)</td>
        <td>$(& $enc $s.Source)</td>
        <td class="state-$st">$(& $enc $s.State)</td>
        <td>$($s.ItemCount)</td>
        <td>$(& $enc $s.Detail)</td>
      </tr>
"@
    }
    if (-not $statusRows) { $statusRows = '<tr><td colspan="5" class="muted">No collection status.</td></tr>' }

    $genStamp = (Get-Date).ToString('yyyy-MM-dd HH:mm:ss zzz')

    $html = @"
<!DOCTYPE html>
<html lang="en"><head><meta charset="utf-8">
<title>Failover RCA - $(& $enc $RcaResult.ClusterName)</title>
<style>
  :root{--ink:#1b1f23;--accent:#0b3d61}
  *{box-sizing:border-box}
  body{font-family:Segoe UI,Arial,sans-serif;margin:0;background:#f4f6f8;color:var(--ink)}
  header{background:var(--accent);color:#fff;padding:18px 24px}
  header h1{margin:0;font-size:20px} header .sub{opacity:.85;font-size:13px;margin-top:6px;line-height:1.6}
