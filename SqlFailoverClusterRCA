<#
    Collector 3/6 - Windows Event logs (System, Application, FailoverClustering/Operational).
    Runs Get-WinEvent inside each node's PSSession for the analysis window, pulling the
    event IDs of interest (Data\eventid.map.json) plus all Warning+ FailoverClustering ops
    events. Returns @{ Events = [Rca.TimelineEvent[]]; Status = [Rca.CollectionStatus[]] }.
#>

function Get-WindowsEventData {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)][string[]]$Node,
        [hashtable]$Session = @{},
        [datetime]$WindowStart,
        [datetime]$WindowEnd,
        [pscredential]$Credential
    )
    $events = [System.Collections.Generic.List[object]]::new()
    $status = [System.Collections.Generic.List[object]]::new()
    $winIds = Get-RcaWindowsEventIds

    $remote = {
        param($start, $end, $ids)
        $out = [System.Collections.Generic.List[object]]::new()
        foreach ($log in 'System', 'Application') {
            try {
                Get-WinEvent -FilterHashtable @{ LogName = $log; Id = $ids; StartTime = $start; EndTime = $end } -ErrorAction Stop |
                    ForEach-Object {
                        $out.Add([pscustomobject]@{
                            TimeCreated = $_.TimeCreated; Id = $_.Id; Level = $_.LevelDisplayName
                            Provider = $_.ProviderName; Log = $log; Message = $_.Message })
                    }
            } catch { }
        }
        try {
            Get-WinEvent -FilterHashtable @{ LogName = 'Microsoft-Windows-FailoverClustering/Operational'; Level = 1, 2, 3; StartTime = $start; EndTime = $end } -ErrorAction Stop |
                ForEach-Object {
                    $out.Add([pscustomobject]@{
                        TimeCreated = $_.TimeCreated; Id = $_.Id; Level = $_.LevelDisplayName
                        Provider = $_.ProviderName; Log = 'FailoverClustering/Operational'; Message = $_.Message })
                }
        } catch { }
        $out.ToArray()
    }

    foreach ($n in $Node) {
        $sess = $Session[$n]
        if (-not $sess) {
            $status.Add((New-CollectionStatus -Node $n -Source 'WindowsEvent' -State 'Failed' -Detail 'No remote session (node unreachable).'))
            continue
        }
        try {
            $raw = @(Invoke-RcaRemote -Session $sess -ScriptBlock $remote -ArgumentList @($WindowStart, $WindowEnd, $winIds))
            foreach ($r in $raw) {
                $meaning = Get-RcaWindowsEventMeaning ([string]$r.Id)
                $msg = if ($meaning) { "[$($r.Id)] $meaning - $(Get-RcaFirstLine $r.Message)" } else { "[$($r.Id)] $(Get-RcaFirstLine $r.Message)" }
                $events.Add((New-TimelineEvent -Timestamp $r.TimeCreated -Node $n -Source 'WindowsEvent' `
                    -Severity (ConvertTo-RcaSeverity $r.Level) -EventId ([string]$r.Id) -Message $msg `
                    -Data @{ Provider = $r.Provider; Log = $r.Log }))
            }
            $status.Add((New-CollectionStatus -Node $n -Source 'WindowsEvent' -State 'Ok' -ItemCount $raw.Count -Detail "$($raw.Count) event(s) in window."))
        }
        catch {
            $status.Add((New-CollectionStatus -Node $n -Source 'WindowsEvent' -State 'Failed' -Detail $_.Exception.Message))
        }
    }

    @{ Events = $events.ToArray(); Status = $status.ToArray() }
}




