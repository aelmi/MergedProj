<#
    Normalizer - merges per-collector event arrays into one time-ordered timeline.
    Phase 0: simply concatenates and sorts; per-source parsing lives in the collectors.
#>

function ConvertTo-TimelineEvent {
    [CmdletBinding()]
    param(
        # One or more @{ Events = ...; Status = ... } collector results.
        [Parameter(Mandatory, ValueFromPipeline)]
        [object[]]$CollectorResult
    )
    begin { $all = [System.Collections.Generic.List[object]]::new() }
    process {
        foreach ($r in $CollectorResult) {
            # Collector results are hashtables; Get-RcaProp reads 'Events' from a hashtable
            # OR an object (PSObject.Properties does NOT expose hashtable keys).
            $ev = Get-RcaProp $r 'Events'
            if ($ev) { foreach ($e in $ev) { $all.Add($e) } }
        }
    }
    end {
        # Stable chronological order; null timestamps sink to the end.
        $all | Sort-Object @{ Expression = { if ($_.Timestamp) { $_.Timestamp } else { [datetime]::MaxValue } } }
    }
}




