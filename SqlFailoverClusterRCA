<#
    Collector 5/6 - SQL HA DMVs (read-only). Queries EACH replica instance directly and
    captures: per-replica role/health (sys.dm_hadr_availability_replica_states), per-database
    synchronization state and queues (sys.dm_hadr_database_replica_states), cluster/quorum
    (sys.dm_hadr_cluster), instance identity (SERVERPROPERTY), and FCI nodes/ownership
    (sys.dm_os_cluster_nodes). Hitting every replica means the surviving secondary's view is
    captured even when the former primary is down. All SELECTs flow through the read-only guard.
#>

function Get-SqlHaDmvData {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)][string[]]$Node,
        [string[]]$SqlInstance,
        [datetime]$WindowStart,
        [datetime]$WindowEnd,
        [pscredential]$Credential
    )
    $events = [System.Collections.Generic.List[object]]::new()
    $status = [System.Collections.Generic.List[object]]::new()
    $instances = if ($SqlInstance) { $SqlInstance } else { $Node }
    $stamp = $WindowEnd

    $qReplicas = @"
SELECT ag.name AS ag_name, ar.replica_server_name, ars.role_desc, ars.operational_state_desc,
       ars.connected_state_desc, ars.synchronization_health_desc, ars.recovery_health_desc
FROM sys.availability_groups ag
JOIN sys.availability_replicas ar ON ag.group_id = ar.group_id
JOIN sys.dm_hadr_availability_replica_states ars ON ar.replica_id = ars.replica_id
"@
    $qDbs = @"
SELECT ar.replica_server_name, DB_NAME(drs.database_id) AS db_name,
       drs.synchronization_state_desc, drs.synchronization_health_desc, drs.is_suspended,
       drs.last_commit_time, drs.log_send_queue_size, drs.redo_queue_size
FROM sys.dm_hadr_database_replica_states drs
JOIN sys.availability_replicas ar ON drs.replica_id = ar.replica_id
"@
    $qCluster  = "SELECT cluster_name, quorum_type_desc, quorum_state_desc FROM sys.dm_hadr_cluster"
    $qIdentity = "SELECT CAST(SERVERPROPERTY('ServerName') AS sysname) AS server_name, " +
                 "CAST(SERVERPROPERTY('IsClustered') AS int) AS is_clustered, " +
                 "CAST(SERVERPROPERTY('IsHadrEnabled') AS int) AS is_hadr, " +
                 "CAST(SERVERPROPERTY('ComputerNamePhysicalNetBIOS') AS sysname) AS physical_node"
    $qFci = "SELECT NodeName, status_description, is_current_owner FROM sys.dm_os_cluster_nodes"

    foreach ($inst in $instances) {
        $count = 0
        $errDetail = $null

        # Probe with the first query: if even this cannot run, the instance is unreachable -
        # record one Failed status and move on (no point trying the other four connections).
        $rep = @()
        try { $rep = @(Invoke-SqlReadOnly -ServerInstance $inst -Query $qReplicas -Credential $Credential) }
        catch {
            $status.Add((New-CollectionStatus -Node $inst -Source 'SqlHaDmv' -State 'Failed' -Detail $_.Exception.Message))
            continue
        }

        # Connection works; gather the rest. Each query is isolated so one missing DMV
        # (e.g. a non-FCI instance) does not lose the others.
        $res = @{}
        foreach ($qi in @(
            @{ k = 'db'; q = $qDbs }, @{ k = 'clu'; q = $qCluster },
            @{ k = 'idn'; q = $qIdentity }, @{ k = 'fci'; q = $qFci })) {
            try { $res[$qi.k] = @(Invoke-SqlReadOnly -ServerInstance $inst -Query $qi.q -Credential $Credential) }
            catch { $res[$qi.k] = @(); if (-not $errDetail) { $errDetail = $_.Exception.Message } }
        }
        $db = $res['db']; $clu = $res['clu']; $idn = $res['idn']; $fci = $res['fci']

        # Field reads go through Get-RcaProp: DMV column sets differ across SQL versions, and
        # under StrictMode a direct missing-property access would throw out of the collector.
        try {
            foreach ($r in $rep) {
                $health = "$(Get-RcaProp $r 'synchronization_health_desc')"
                $sev = if ($health -eq 'HEALTHY') { 'Info' } elseif ($health -eq 'PARTIALLY_HEALTHY') { 'Warning' } else { 'Error' }
                $replica = "$(Get-RcaProp $r 'replica_server_name')"
                $events.Add((New-TimelineEvent -Timestamp $stamp -Node $replica -Source 'SqlHaDmv' -Severity $sev `
                    -Message "AG '$(Get-RcaProp $r 'ag_name')' replica '$replica' role=$(Get-RcaProp $r 'role_desc') health=$health connected=$(Get-RcaProp $r 'connected_state_desc') op=$(Get-RcaProp $r 'operational_state_desc')" `
                    -Data @{ Kind = 'Replica'; Role = "$(Get-RcaProp $r 'role_desc')"; Health = $health })); $count++
            }
            foreach ($r in $db) {
                $health = "$(Get-RcaProp $r 'synchronization_health_desc')"
                $suspended = "$(Get-RcaProp $r 'is_suspended')"
                $bad = ($health -ne 'HEALTHY') -or ($suspended -eq '1' -or $suspended -eq 'True')
                $sev = if ($bad) { 'Error' } else { 'Info' }
                $replica = "$(Get-RcaProp $r 'replica_server_name')"
                $events.Add((New-TimelineEvent -Timestamp $stamp -Node $replica -Source 'SqlHaDmv' -Severity $sev `
                    -Message "DB '$(Get-RcaProp $r 'db_name')' on '$replica' sync=$(Get-RcaProp $r 'synchronization_state_desc') health=$health suspended=$suspended lastCommit=$(Get-RcaProp $r 'last_commit_time') sendQ=$(Get-RcaProp $r 'log_send_queue_size') redoQ=$(Get-RcaProp $r 'redo_queue_size')" `
                    -Data @{ Kind = 'Database'; Db = "$(Get-RcaProp $r 'db_name')" })); $count++
            }
            foreach ($r in $clu) {
                $qstate = "$(Get-RcaProp $r 'quorum_state_desc')"
                $sev = if ($qstate -match '(?i)normal') { 'Info' } else { 'Warning' }
                $events.Add((New-TimelineEvent -Timestamp $stamp -Node $inst -Source 'SqlHaDmv' -Severity $sev `
                    -Message "WSFC '$(Get-RcaProp $r 'cluster_name')' quorum=$(Get-RcaProp $r 'quorum_type_desc') state=$qstate" `
                    -Data @{ Kind = 'Cluster' })); $count++
            }
            foreach ($r in $idn) {
                $events.Add((New-TimelineEvent -Timestamp $stamp -Node $inst -Source 'SqlHaDmv' -Severity 'Info' `
                    -Message "Instance '$(Get-RcaProp $r 'server_name')' clustered=$(Get-RcaProp $r 'is_clustered') hadr=$(Get-RcaProp $r 'is_hadr') physicalNode=$(Get-RcaProp $r 'physical_node')" `
                    -Data @{ Kind = 'Identity'; PhysicalNode = "$(Get-RcaProp $r 'physical_node')" })); $count++
            }
            foreach ($r in $fci) {
                $st = "$(Get-RcaProp $r 'status_description')"
                $sev = if ($st -eq 'UP') { 'Info' } else { 'Warning' }
                $events.Add((New-TimelineEvent -Timestamp $stamp -Node $inst -Source 'SqlHaDmv' -Severity $sev `
                    -Message "FCI node '$(Get-RcaProp $r 'NodeName')' status=$st currentOwner=$(Get-RcaProp $r 'is_current_owner')" `
                    -Data @{ Kind = 'FciNode' })); $count++
            }
        }
        catch {
            if (-not $errDetail) { $errDetail = $_.Exception.Message }
        }

        $state = if ($errDetail) { 'Partial' } else { 'Ok' }
        $status.Add((New-CollectionStatus -Node $inst -Source 'SqlHaDmv' -State $state -ItemCount $count -Detail "$($rep.Count) replica(s), $($db.Count) db-replica row(s)."))
    }

    @{ Events = $events.ToArray(); Status = $status.ToArray() }
}




