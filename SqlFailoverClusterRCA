  evidence.json, and returns a time-ordered [Rca.TimelineEvent[]].
#>
function New-FailoverTimeline {
    [CmdletBinding(DefaultParameterSetName = 'Object')]
    param(
        [Parameter(Mandatory, ParameterSetName = 'Object', ValueFromPipeline)]
        $Evidence,

        [Parameter(Mandatory, ParameterSetName = 'Path')]
        [string]$EvidencePath
    )
    process {
        if ($PSCmdlet.ParameterSetName -eq 'Path') {
            $file = if (Test-Path $EvidencePath -PathType Container) { Join-Path $EvidencePath 'evidence.json' } else { $EvidencePath }
            if (-not (Test-Path $file)) { throw "Evidence file not found: $file" }
            $Evidence = Get-Content $file -Raw | ConvertFrom-Json
        }

        $events = if ($Evidence.PSObject.Properties['Timeline']) { $Evidence.Timeline } else { $Evidence }

        @($events) | Sort-Object @{ Expression = { if ($_.Timestamp) { [datetime]$_.Timestamp } else { [datetime]::MaxValue } } }
    }
}




