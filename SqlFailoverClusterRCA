<#
    Collector 2/6 - WSFC cluster state snapshot. Uses the FailoverClusters module inside
    each node's PSSession to capture node states/weights, group ownership, non-Online
    resources, and quorum config. These are current-state facts (timestamped 'as of now')
    that give the rules engine context about who owns what and whether quorum is healthy.
#>

function Get-WsfcStateData {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)][string[]]$Node,
        [hashtable]$Session = @{},
        [datetime]$WindowStart,
        [datetime]$WindowEnd,
        [pscredential]$Credential
    )
    $events = [System.Collections.Generic.List[object]]::new()
    $status = [System.Collections.Generic.List[object]]::new()

    $remote = {
        Import-Module FailoverClusters -ErrorAction Stop
        $nodes = Get-ClusterNode | ForEach-Object {
            [pscustomobject]@{ Name = $_.Name; State = "$($_.State)"; NodeWeight = $_.NodeWeight; DynamicWeight = $_.DynamicWeight }
        }
        $groups = Get-ClusterGroup | ForEach-Object {
            [pscustomobject]@{ Name = $_.Name; Owner = "$($_.OwnerNode)"; State = "$($_.State)" }
        }
        $res = Get-ClusterResource | Where-Object { "$($_.State)" -ne 'Online' } | ForEach-Object {
            [pscustomobject]@{ Name = $_.Name; Group = "$($_.OwnerGroup)"; Owner = "$($_.OwnerNode)"; State = "$($_.State)"; Type = "$($_.ResourceType)" }
        }
        $q = Get-ClusterQuorum
        [pscustomobject]@{
            Nodes        = $nodes
            Groups       = $groups
            ResourcesBad = $res
            QuorumType   = "$($q.QuorumType)"
            QuorumRes    = "$($q.QuorumResource)"
        }
    }

    foreach ($n in $Node) {
        $sess = $Session[$n]
        if (-not $sess) {
            $status.Add((New-CollectionStatus -Node $n -Source 'WsfcState' -State 'Failed' -Detail 'No remote session (node unreachable).'))
            continue
        }
        try {
            $snap = Invoke-RcaRemote -Session $sess -ScriptBlock $remote
            $stamp = $WindowEnd
            $count = 0

            foreach ($nd in @($snap.Nodes)) {
                $sev = if ($nd.State -ne 'Up') { 'Error' } else { 'Info' }
                $events.Add((New-TimelineEvent -Timestamp $stamp -Node $n -Source 'WsfcState' -Severity $sev `
                    -Message "Node '$($nd.Name)' state=$($nd.State) weight=$($nd.NodeWeight) dynamicWeight=$($nd.DynamicWeight)" `
                    -Data @{ Kind = 'Node'; Name = $nd.Name; State = $nd.State })); $count++
            }
            foreach ($g in @($snap.Groups)) {
                $sev = if ($g.State -notin 'Online', 'Offline') { 'Warning' } elseif ($g.State -eq 'Offline') { 'Error' } else { 'Info' }
                $events.Add((New-TimelineEvent -Timestamp $stamp -Node $n -Source 'WsfcState' -Severity $sev `
                    -Message "Group '$($g.Name)' owner=$($g.Owner) state=$($g.State)" `
                    -Data @{ Kind = 'Group'; Name = $g.Name; Owner = $g.Owner; State = $g.State })); $count++
            }
            foreach ($r in @($snap.ResourcesBad)) {
                $events.Add((New-TimelineEvent -Timestamp $stamp -Node $n -Source 'WsfcState' -Severity 'Error' `
                    -Message "Resource '$($r.Name)' ($($r.Type)) in group '$($r.Group)' state=$($r.State)" `
                    -Data @{ Kind = 'Resource'; Name = $r.Name; State = $r.State })); $count++
            }
            $events.Add((New-TimelineEvent -Timestamp $stamp -Node $n -Source 'WsfcState' -Severity 'Info' `
                -Message "Quorum type=$($snap.QuorumType) resource=$($snap.QuorumRes)" `
                -Data @{ Kind = 'Quorum'; Type = $snap.QuorumType })); $count++

            $status.Add((New-CollectionStatus -Node $n -Source 'WsfcState' -State 'Ok' -ItemCount $count -Detail "Snapshot: $($snap.Nodes.Count) node(s), $($snap.Groups.Count) group(s)."))
        }
        catch {
            $status.Add((New-CollectionStatus -Node $n -Source 'WsfcState' -State 'Failed' -Detail $_.Exception.Message))
        }
    }

    @{ Events = $events.ToArray(); Status = $status.ToArray() }
}




