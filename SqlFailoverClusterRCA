<#
    Rule engine - evaluates rule objects from Private/Analyze/Rules/ against the timeline
    and returns ranked [Rca.RootCauseFinding] objects.

    A rule is a hashtable: @{ Id; Category; Severity; Match={param($tl)..};
    Confidence={param($matches,$tl)..}; Explain; Remediation; KbRef; IsPlanned }.

    Phase 0: the Rules/ folder is empty, so this returns no findings - but the wiring,
    ranking, and primary-narrative selection are real and unit-tested via injected rules.
#>

# Strict-safe optional-field reader: rules are hashtables (keys may be absent) or objects.
function Get-RuleField {
    param($Rule, [string]$Name, $Default = $null)
    if ($Rule -is [hashtable]) {
        if ($Rule.ContainsKey($Name)) { return $Rule[$Name] } else { return $Default }
    }
    $p = $Rule.PSObject.Properties[$Name]
    if ($p) { return $p.Value } else { return $Default }
}

function Get-RcaRule {
    [CmdletBinding()]
    param([string]$RulesPath = (Join-Path $script:ModuleRoot 'Private\Analyze\Rules'))
    if (-not (Test-Path $RulesPath)) { return @() }
    Get-ChildItem -Path $RulesPath -Filter '*.ps1' -File | ForEach-Object {
        # Each rule file returns one or more rule hashtables.
        & $_.FullName
    }
}

function Invoke-RuleEngine {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [AllowEmptyCollection()]
        [object[]]$Timeline,

        # Optional rule injection (used by tests); defaults to loading from Rules/.
        [object[]]$Rule
    )

    if (-not $PSBoundParameters.ContainsKey('Rule')) { $Rule = @(Get-RcaRule) }

    $findings = foreach ($r in $Rule) {
        $ruleId = Get-RuleField $r 'Id' '(unnamed)'
        try {
            $matchBlock = Get-RuleField $r 'Match'
            $matches = & $matchBlock $Timeline
            if (-not $matches) { continue }
            $conf = [int](& (Get-RuleField $r 'Confidence') $matches $Timeline)

            # Human-facing metadata comes from Data\rules.catalog.json (looked up here, in
            # module scope) so rule files only carry Id/Explain/Match/Confidence. A rule may
            # still override any field inline - used by the injected test rules.
            $meta = Get-RcaRuleMeta $ruleId

            New-RootCauseFinding `
                -RuleId $ruleId -Category (Get-RuleField $r 'Category' $meta.category) `
                -Severity (Get-RuleField $r 'Severity' $meta.severity) -Confidence $conf `
                -Explanation (Get-RuleField $r 'Explain') `
                -Remediation (Get-RuleField $r 'Remediation' $meta.remediation) `
                -KbRef (Get-RuleField $r 'KbRef' $meta.kbRef) `
                -Evidence @($matches) -IsPlanned ([bool](Get-RuleField $r 'IsPlanned' $meta.isPlanned))
        }
        catch {
            Write-RcaLog "Rule '$ruleId' threw: $($_.Exception.Message)" -Level Warn
        }
    }

    # Rank by confidence desc, then severity weight desc.
    $sevRank = @{ Critical = 4; High = 3; Medium = 2; Low = 1 }
    @($findings) | Sort-Object `
        @{ Expression = { $_.Confidence }; Descending = $true }, `
        @{ Expression = { $sevRank[$_.Severity] }; Descending = $true }
}




