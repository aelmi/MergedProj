<#
    Shared remote-execution + mapping helpers used by the Windows-side collectors.
    Remote work runs in the per-node PSSession opened by Connect-ClusterNode.
#>

function Invoke-RcaRemote {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]$Session,
        [Parameter(Mandatory)][scriptblock]$ScriptBlock,
        [object[]]$ArgumentList = @()
    )
    if ($Session -is [System.Management.Automation.Runspaces.PSSession]) {
        Invoke-Command -Session $Session -ScriptBlock $ScriptBlock -ArgumentList $ArgumentList -ErrorAction Stop
    } else {
        # Local session sentinel (Rca.LocalSession): run in-process - used when the target is
        # this machine, so the tool works on a cluster node without WinRM loopback issues.
        & $ScriptBlock @ArgumentList
    }
}

# Map a Windows event LevelDisplayName (or any free text) to our timeline severity scale.
function ConvertTo-RcaSeverity {
    param([string]$Level)
    switch -Regex ("$Level") {
        'Critical' { return 'Critical' }
        'Error'    { return 'Error' }
        'Warn'     { return 'Warning' }
        default    { return 'Info' }
    }
}

# First non-empty line of a (possibly multi-line) event message, trimmed for the timeline.
function Get-RcaFirstLine {
    param([string]$Text, [int]$Max = 300)
    if (-not $Text) { return '' }
    $line = ($Text -split "`r?`n" | Where-Object { $_.Trim() } | Select-Object -First 1)
    if (-not $line) { $line = $Text }
    $line = $line.Trim()
    if ($line.Length -gt $Max) { $line = $line.Substring(0, $Max) + '...' }
    $line
}




