<#
    PSRemoting session management with throttling and a module-scoped cache. Opens (or
    reuses) one PSSession per node. Connection failures are NON-FATAL: the returned
    descriptor reports Connected=$false plus the error, so collectors can record a 'Failed'
    collection status and the run can continue with partial evidence.
#>

function Connect-ClusterNode {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)][string[]]$Node,
        [pscredential]$Credential,
        [int]$ThrottleLimit = 4,
        [int]$OpenTimeoutMs = 6000
    )

    $opt = New-PSSessionOption -OpenTimeout $OpenTimeoutMs -OperationTimeout 0 -IdleTimeout 900000
    $connErr = @()

    # Names that mean "this machine" - collected once for local-node detection.
    $localNames = @($env:COMPUTERNAME, 'localhost', '.', '127.0.0.1', '::1')
    try { $localNames += [System.Net.Dns]::GetHostEntry('').HostName } catch { }

    # Which nodes still need a live session? (Local nodes get an in-process sentinel.)
    $toOpen = @()
    foreach ($n in $Node) {
        $existing = $script:RcaSessions[$n]
        if ($existing) { continue }   # already have a session or local sentinel
        $isLocal = ($localNames -contains $n) -or ($n -like "$env:COMPUTERNAME.*")
        if ($isLocal) {
            $script:RcaSessions[$n] = [pscustomobject]@{ PSTypeName = 'Rca.LocalSession'; Node = $n; IsLocal = $true }
            Write-RcaLog "Connect-ClusterNode: '$n' is the local machine; using in-process execution." -Level Debug
            continue
        }
        $toOpen += $n
    }

    if ($toOpen.Count -gt 0) {
        $splat = @{
            ComputerName  = $toOpen
            ThrottleLimit = $ThrottleLimit
            SessionOption = $opt
            ErrorAction   = 'SilentlyContinue'
            ErrorVariable = '+connErr'
        }
        if ($Credential) { $splat.Credential = $Credential }
        Write-RcaLog "Opening PSSession(s) to: $($toOpen -join ', ')" -Level Debug
        $opened = New-PSSession @splat
        foreach ($s in @($opened)) { $script:RcaSessions[$s.ComputerName] = $s }
    }

    foreach ($n in $Node) {
        $s = $script:RcaSessions[$n]
        $isLocal = [bool]($s -and ($s.PSObject.TypeNames -contains 'Rca.LocalSession'))
        $connected = [bool]($isLocal -or ($s -is [System.Management.Automation.Runspaces.PSSession] -and $s.State -eq 'Opened'))
        $err = $null
        if (-not $connected) {
            $match = $connErr | Where-Object { "$_" -match [regex]::Escape($n) } | Select-Object -First 1
            $err = if ($match) { "$match" } else { 'connection failed' }
            Write-RcaLog "Connect-ClusterNode: '$n' not connected ($err)" -Level Warn
        }
        [pscustomobject]@{
            PSTypeName = 'Rca.NodeSession'
            Node       = $n
            Connected  = $connected
            Session    = $s
            Error      = $err
        }
    }
}

# Return the cached usable session for a node (open PSSession or local sentinel), else $null.
function Get-RcaSession {
    [CmdletBinding()]
    param([Parameter(Mandatory)][string]$Node)
    $s = $script:RcaSessions[$Node]
    if (-not $s) { return $null }
    if ($s.PSObject.TypeNames -contains 'Rca.LocalSession') { return $s }
    if ($s -is [System.Management.Automation.Runspaces.PSSession] -and $s.State -eq 'Opened') { return $s }
    $null
}

# Tear down cached sessions (all, or a specific set). Safe to call repeatedly.
function Disconnect-ClusterNode {
    [CmdletBinding()]
    param([string[]]$Node)
    $targets = if ($PSBoundParameters.ContainsKey('Node')) { $Node } else { @($script:RcaSessions.Keys) }
    foreach ($n in @($targets)) {
        $s = $script:RcaSessions[$n]
        if ($s) {
            if ($s -is [System.Management.Automation.Runspaces.PSSession]) {
                try { Remove-PSSession $s -ErrorAction SilentlyContinue } catch { }
            }
            [void]$script:RcaSessions.Remove($n)
        }
    }
}




