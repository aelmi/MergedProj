# Human-facing metadata (category/severity/remediation/KB) for a rule Id. Always returns
# an object with every field present so rule files can read them without strict-mode errors.
function Get-RcaRuleMeta {
    [CmdletBinding()]
    param([Parameter(Mandatory)][string]$Id)
    $cat = Get-RcaRuleCatalog
    if ($cat.ContainsKey($Id)) { return $cat[$Id] }
    [pscustomobject]@{ id = $Id; category = $Id; severity = 'Medium'; kbRef = ''; remediation = ''; isPlanned = $false }
}

# Confidence score: a base for the rule plus a bump per corroborating piece of evidence,
# clamped to [1,Max]. Keeps scoring consistent and tunable across all rules.
function Get-RcaConfidence {
    [CmdletBinding()]
    param(
        [int]$Base = 50,
        [int]$Corroborations = 0,
        [int]$Per = 12,
        [int]$Max = 98
    )
    $v = $Base + ($Corroborations * $Per)
    if ($v -gt $Max) { return $Max }
    if ($v -lt 1)    { return 1 }
    [int]$v
}




