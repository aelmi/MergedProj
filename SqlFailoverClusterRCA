<#
    Read-only SQL execution helper. Enforces the read-only contract (SPEC section 10) and
    then executes via System.Data.SqlClient (no external module dependency - keeps the tool
    agentless). Returns an array of pscustomobjects, one per row. Never issues write/DDL/
    control SQL: any statement that fails Test-RcaReadOnlySql is refused before connecting.
#>

# Tokens that must never appear as a statement verb in this tool.
$script:RcaForbiddenSql = @(
    'INSERT', 'UPDATE', 'DELETE', 'MERGE', 'TRUNCATE', 'DROP', 'CREATE', 'ALTER',
    'GRANT', 'REVOKE', 'DENY', 'EXEC', 'EXECUTE', 'BACKUP', 'RESTORE', 'KILL',
    'RECONFIGURE', 'SHUTDOWN', 'DBCC', 'WAITFOR', 'BEGIN TRAN', 'COMMIT', 'ROLLBACK'
)

# Read-only system stored procedures we genuinely need; allowed to pass the EXEC gate.
$script:RcaAllowedProcs = @('xp_readerrorlog', 'sp_readerrorlog')

function Test-RcaReadOnlySql {
    [CmdletBinding()]
    [OutputType([bool])]
    param([Parameter(Mandatory)][string]$Query)

    # Strip line/block comments before inspecting verbs.
    $stripped = [regex]::Replace($Query, '--[^\r\n]*', ' ')
    $stripped = [regex]::Replace($stripped, '/\*.*?\*/', ' ', 'Singleline')

    # Permit an EXEC of an allowlisted read-only proc by neutralizing ONLY that EXEC verb,
    # then re-checking: any OTHER forbidden verb (e.g. a piggy-backed DROP) still trips it.
    $probe = $stripped
    $procPattern = '(?i)\b(' + (($script:RcaAllowedProcs | ForEach-Object { [regex]::Escape($_) }) -join '|') + ')\b'
    if ($probe -match $procPattern) {
        $probe = [regex]::Replace($probe, '(?i)\bexec(ute)?\b', ' ')
    }

    foreach ($verb in $script:RcaForbiddenSql) {
        if ($probe -match "(?im)\b$([regex]::Escape($verb))\b") { return $false }
    }
    return $true
}

function Invoke-SqlReadOnly {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)][string]$ServerInstance,
        [Parameter(Mandatory)][string]$Query,
        [string]$Database = 'master',
        [pscredential]$Credential,
        [int]$TimeoutSeconds = 30,
        [int]$ConnectTimeoutSeconds = 5,
        # Validate the read-only contract without opening a connection (used by tests).
        [switch]$ValidateOnly
    )

    if (-not (Test-RcaReadOnlySql -Query $Query)) {
        throw "Invoke-SqlReadOnly: refused a non-read-only statement (read-only contract, SPEC section 10)."
    }
    if ($ValidateOnly) { return @() }

    $cs = "Server=$ServerInstance;Database=$Database;Application Name=SqlFailoverClusterRCA;" +
          "Connect Timeout=$ConnectTimeoutSeconds;TrustServerCertificate=True;"
    if ($Credential) {
        $cs += "User ID=$($Credential.UserName);Password=$($Credential.GetNetworkCredential().Password);"
    } else {
        $cs += "Integrated Security=SSPI;"
    }

    $conn = New-Object System.Data.SqlClient.SqlConnection $cs
    try {
        $conn.Open()
        $cmd = $conn.CreateCommand()
        $cmd.CommandText = $Query
        $cmd.CommandTimeout = $TimeoutSeconds
        $reader = $cmd.ExecuteReader()
        $rows = [System.Collections.Generic.List[object]]::new()
        do {
            while ($reader.Read()) {
                $o = [ordered]@{}
                for ($i = 0; $i -lt $reader.FieldCount; $i++) {
                    $name = $reader.GetName($i)
                    $val  = $reader.GetValue($i)
                    if ($val -is [System.DBNull]) { $val = $null }
                    $o[$name] = $val
                }
                $rows.Add([pscustomobject]$o)
            }
        } while ($reader.NextResult())
        $reader.Close()
        Write-RcaLog "Invoke-SqlReadOnly: $ServerInstance [$Database] returned $($rows.Count) row(s)." -Level Debug
        # Emit rows normally (no unary comma) - callers wrap in @() to normalize.
        $rows.ToArray()
    }
    finally {
        $conn.Dispose()
    }
}




