  .verdict{background:#fff;border-left:6px solid var(--accent);padding:16px 18px;margin-bottom:20px;border-radius:4px;box-shadow:0 1px 3px rgba(0,0,0,.08)}
  .verdict h2{margin:0 0 8px;font-size:13px;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:.05em}
  .verdict .v{font-size:19px;font-weight:600;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
  .verdict .conf{font-size:14px;color:#475569;font-weight:500}
  .verdict .explain{margin:10px 0 6px;line-height:1.5}
  .verdict .remediation{margin:6px 0;line-height:1.5}
  details{margin-top:10px} summary{cursor:pointer;font-weight:600;color:#475569}
  ul.evidence{margin:8px 0;padding-left:18px;font-size:13px;line-height:1.7} ul.evidence code{background:#eef2f6;padding:1px 5px;border-radius:3px}
  section{background:#fff;padding:16px 18px;margin-bottom:18px;border-radius:4px;box-shadow:0 1px 3px rgba(0,0,0,.08)}
  section h2{margin:0 0 12px;font-size:16px}
