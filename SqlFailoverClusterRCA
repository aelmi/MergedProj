<#  Rule: Always On lease / health-check timeout triggered the failover.  #>
@{
    Id         = 'AG-LEASE-TIMEOUT'
    Explain    = 'The AG lease expired or the health check timed out (SQL 19407/19421, or ERRORLOG lease / sp_server_diagnostics entries). The resource DLL stopped getting a healthy response from the primary instance within LeaseTimeout/HealthCheckTimeout and failed the AG over.'
    Match      = { param($tl)
        @($tl | Where-Object {
            ($_.EventId -in '19407', '19421') -or
            (($_.Source -in 'SqlErrorLog', 'SqlHaDmv', 'ClusterLog') -and $_.Message -match '(?i)lease|health\s*check|sp_server_diagnostics')
        })
    }
    Confidence = { param($m, $tl) Get-RcaConfidence -Base 58 -Corroborations (@($m).Count) }
}




