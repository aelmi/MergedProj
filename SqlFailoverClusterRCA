<#
    Collector 1/6 - WSFC cluster.log. Runs Get-ClusterLog per node inside its PSSession,
    pre-filters to interesting lines (errors/warnings + quorum/heartbeat/RHS/move/lease
    keywords), ships them back, and parses each into a timeline event scoped to the window.
    cluster.log is generated with -UseLocalTime so timestamps line up with the event logs.
#>

function Get-ClusterLogData {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)][string[]]$Node,
        [hashtable]$Session = @{},
        [datetime]$WindowStart,
        [datetime]$WindowEnd,
        [pscredential]$Credential
    )
    $events = [System.Collections.Generic.List[object]]::new()
    $status = [System.Collections.Generic.List[object]]::new()

    # Get-ClusterLog -TimeSpan is "last N minutes"; cover from window start to now + buffer.
    $spanMin = [int][math]::Ceiling(((Get-Date) - $WindowStart).TotalMinutes) + 15
    if ($spanMin -lt 5)    { $spanMin = 5 }
    if ($spanMin -gt 4320) { $spanMin = 4320 }   # cap at 3 days of log

    $remote = {
        param($spanMinutes)
        $dir = Join-Path $env:TEMP ('rca_clog_' + [guid]::NewGuid().ToString('N'))
        New-Item -ItemType Directory -Path $dir -Force | Out-Null
        try {
            Get-ClusterLog -Node $env:COMPUTERNAME -TimeSpan $spanMinutes -Destination $dir -UseLocalTime -ErrorAction Stop | Out-Null
            $f = Get-ChildItem $dir -Filter '*.log' | Sort-Object LastWriteTime -Descending | Select-Object -First 1
            if (-not $f) { return @() }
            $rx = '(?i)(\bERR\b|\bWARN\b|quorum|heartbeat|netft|IsAlive|LooksAlive|\bRHS\b|moved|move\b|online|offline|failed|lease|evict|arbitrat)'
            @(Get-Content $f.FullName | Where-Object { $_ -match $rx })
        }
        finally {
            Remove-Item $dir -Recurse -Force -ErrorAction SilentlyContinue
        }
    }

    $tsRx = [regex]'(\d{4})/(\d{2})/(\d{2})-(\d{2}):(\d{2}):(\d{2})\.(\d{3})'

    foreach ($n in $Node) {
        $sess = $Session[$n]
        if (-not $sess) {
            $status.Add((New-CollectionStatus -Node $n -Source 'ClusterLog' -State 'Failed' -Detail 'No remote session (node unreachable).'))
            continue
        }
        try {
            $lines = @(Invoke-RcaRemote -Session $sess -ScriptBlock $remote -ArgumentList @($spanMin))
            $kept = 0
            foreach ($line in $lines) {
                $m = $tsRx.Match($line)
                if (-not $m.Success) { continue }
                $ts = [datetime]::new([int]$m.Groups[1].Value, [int]$m.Groups[2].Value, [int]$m.Groups[3].Value,
                                       [int]$m.Groups[4].Value, [int]$m.Groups[5].Value, [int]$m.Groups[6].Value,
                                       [int]$m.Groups[7].Value)
                if ($ts -lt $WindowStart -or $ts -gt $WindowEnd) { continue }
                $sev = if ($line -match '(?i)\bERR\b') { 'Error' } elseif ($line -match '(?i)\bWARN\b') { 'Warning' } else { 'Info' }
                $text = $line.Substring($m.Index + $m.Length).Trim()
                $events.Add((New-TimelineEvent -Timestamp $ts -Node $n -Source 'ClusterLog' `
                    -Severity $sev -Message (Get-RcaFirstLine $text 400) -Data @{ Raw = $line }))
                $kept++
            }
            $state = if ($lines.Count -gt 0) { 'Ok' } else { 'Partial' }
            $status.Add((New-CollectionStatus -Node $n -Source 'ClusterLog' -State $state -ItemCount $kept -Detail "$kept line(s) in window (of $($lines.Count) candidate(s))."))
        }
        catch {
            $status.Add((New-CollectionStatus -Node $n -Source 'ClusterLog' -State 'Failed' -Detail $_.Exception.Message))
        }
    }

    @{ Events = $events.ToArray(); Status = $status.ToArray() }
}




