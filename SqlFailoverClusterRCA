<#
    SqlFailoverClusterRCA — root module.
    Dot-sources Private/ then Public/ scripts. Only Public/* functions are exported
    (per the manifest's FunctionsToExport). Data shapes are PSCustomObjects with a
    PSTypeName (see Private/Types.ps1) to avoid PowerShell class load-order issues.
#>

Set-StrictMode -Version Latest
$ErrorActionPreference = 'Stop'

$script:ModuleRoot = $PSScriptRoot
$script:RcaLogFile = $null   # set per-run by Invoke-FailoverRCA; null = verbose-only logging

# Module-scoped caches (populated lazily by the helpers in Private\Util).
$script:RcaSessions    = @{}     # node -> open PSSession (see Connect-ClusterNode)
$script:RcaEventMap    = $null   # Data\eventid.map.json (see Get-RcaData)
$script:RcaRuleCatalog = $null   # Data\rules.catalog.json (see Get-RcaData)

# Order matters: Types and shared helpers first (other files depend on their factories/
# helpers, and the Rules/*.ps1 files call Get-RcaRuleMeta/Get-RcaConfidence at load time).
$loadOrder = @(
    'Private\Types.ps1'
    'Private\Util\Write-RcaLog.ps1'
    'Private\Util\Get-RcaData.ps1'
    'Private\Util\Invoke-RcaRemote.ps1'
    'Private\Util\Connect-ClusterNode.ps1'
    'Private\Util\Invoke-SqlReadOnly.ps1'
)

$loaded = [System.Collections.Generic.HashSet[string]]::new()
foreach ($rel in $loadOrder) {
    $p = Join-Path $script:ModuleRoot $rel
    if (Test-Path $p) { . $p; [void]$loaded.Add($p) }
}

# Then everything else under Private/ and Public/.
foreach ($folder in @('Private', 'Public')) {
    $base = Join-Path $script:ModuleRoot $folder
    if (-not (Test-Path $base)) { continue }
    Get-ChildItem -Path $base -Recurse -Filter '*.ps1' -File |
        Where-Object { -not $loaded.Contains($_.FullName) -and $_.Name -notlike '*.Tests.ps1' } |
        ForEach-Object { . $_.FullName }
}




