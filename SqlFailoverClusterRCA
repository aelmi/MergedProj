<#
.SYNOPSIS
  End-to-end failover root-cause analysis: collect -> timeline -> analyze -> report.
.DESCRIPTION
  Primary entry point (SPEC section 8). Resolves the node set and time window, runs the
  collection -> normalize -> rules pipeline, builds an [Rca.RcaResult], selects the primary
  (highest-confidence, non-planned) finding, writes HTML + JSON, and returns the result.

  Phase 0: collectors are stubs, so a run completes and produces a valid (empty) report -
  this proves the wiring. -WhatIf walks the pipeline without performing collection or I/O.
.EXAMPLE
  Invoke-FailoverRCA -ClusterName SQLCLU01 -OpenReport
.EXAMPLE
  Invoke-FailoverRCA -Node W19A,W19B -EventTime '2026-06-15 02:14' -OutputPath C:\RCA
#>
function Invoke-FailoverRCA {
    [CmdletBinding(SupportsShouldProcess, DefaultParameterSetName = 'Cluster')]
    param(
        [Parameter(Mandatory, ParameterSetName = 'Cluster')]
        [string]$ClusterName,

        [Parameter(Mandatory, ParameterSetName = 'Node')]
        [string[]]$Node,

        [string]$AvailabilityGroup,
        [string[]]$SqlInstance,

        # Center of the analysis window. If omitted, Phase 1 auto-detects the latest failover.
        [datetime]$EventTime,
        [timespan]$WindowBefore = (New-TimeSpan -Minutes 30),
        [timespan]$WindowAfter  = (New-TimeSpan -Minutes 15),

        [pscredential]$Credential,
        [string]$OutputPath = (Join-Path (Get-Location) 'Output'),
        [switch]$OpenReport
    )

    # --- Resolve node set ----------------------------------------------------
    if ($PSCmdlet.ParameterSetName -eq 'Cluster') {
        $clusterLabel = $ClusterName
        if ($PSCmdlet.ShouldProcess($ClusterName, 'Resolve cluster member nodes')) {
            $nodes = Resolve-ClusterNode -ClusterName $ClusterName -Credential $Credential
        } else {
            $nodes = @($ClusterName)
        }
    } else {
        $nodes = $Node
        $clusterLabel = ($Node -join '+')
    }

    # --- Resolve time window -------------------------------------------------
    if (-not $PSBoundParameters.ContainsKey('EventTime')) {
        $detected = $null
        if ($PSCmdlet.ShouldProcess(($nodes -join ', '), 'Auto-detect most recent failover')) {
            $detected = Find-LatestFailover -Node $nodes -Credential $Credential
        }
        if ($detected) {
            $EventTime = $detected
            Write-RcaLog "Auto-detected failover at $EventTime." -Level Info
        } else {
            $EventTime = Get-Date
            Write-RcaLog "No -EventTime supplied and no failover auto-detected; centring the window on 'now'." -Level Warn
        }
    }
    $windowStart = $EventTime - $WindowBefore
    $windowEnd   = $EventTime + $WindowAfter

    # --- Run output folder + run log -----------------------------------------
    $runStamp = $EventTime.ToString('yyyyMMdd_HHmmss')
    $runDir   = Join-Path $OutputPath "RCA_${clusterLabel}_${runStamp}"
    if ($PSCmdlet.ShouldProcess($runDir, 'Create run output folder')) {
        if (-not (Test-Path $runDir)) { New-Item -ItemType Directory -Path $runDir -Force | Out-Null }
        $script:RcaLogFile = Join-Path $runDir 'run.log'
    }
    Write-RcaLog "=== Invoke-FailoverRCA: cluster='$clusterLabel' nodes='$($nodes -join ",")' window=[$windowStart -> $windowEnd] ===" -Level Info

    # --- Pipeline ------------------------------------------------------------
    $evParams = @{
        Node = $nodes; SqlInstance = $SqlInstance
        WindowStart = $windowStart; WindowEnd = $windowEnd
        Credential = $Credential; EvidencePath = $runDir
    }
    $evidence = Get-FailoverEvidence @evParams

    $timeline = @(New-FailoverTimeline -Evidence $evidence)
    $findings = @(Get-FailoverRootCause -Timeline $timeline)

    $result = New-RcaResult -ClusterName $clusterLabel -Nodes $nodes -AvailabilityGroup $AvailabilityGroup `
        -EventTime $EventTime -WindowStart $windowStart -WindowEnd $windowEnd `
        -Timeline $timeline -Findings $findings -CollectionStatus $evidence.Status -EvidencePath $runDir

    # Primary = highest-confidence finding that is NOT a planned/administrative move.
    $result.PrimaryFinding = $findings | Where-Object { -not $_.IsPlanned } | Select-Object -First 1

    # --- Report --------------------------------------------------------------
    if ($PSCmdlet.ShouldProcess($runDir, 'Write RCA report')) {
        $reportParams = @{ RcaResult = $result; OutputPath = $runDir; Format = 'Both' }
        if ($OpenReport) { $reportParams.OpenReport = $true }
        Export-FailoverReport @reportParams | Out-Null
    }

    Write-RcaLog "=== Done. Findings: $($findings.Count). Output: $runDir ===" -Level Info
    $result
}




