<#
.SYNOPSIS
  Windows (WPF) front-end for SqlFailoverClusterRCA. Enter a cluster or node(s), optionally a
  SQL instance and a time, click Run - it calls Invoke-FailoverRCA, shows the verdict, and
  opens the HTML report.
.DESCRIPTION
  Standalone launcher (not part of the module's exported surface). The analysis runs in a
  background runspace so the window stays responsive; results are marshalled back to the UI
  thread by a DispatcherTimer. Pure PowerShell + WPF - no install, no extra dependencies.
.EXAMPLE
  .\Show-FailoverRcaGui.ps1
#>
[CmdletBinding()]
param(
    # Build the window and validate wiring, then exit without showing it (for automated checks).
    [switch]$SelfTest
)

# --- WPF needs an STA thread; relaunch ourselves under -STA if we are not on one. ----------
if ([System.Threading.Thread]::CurrentThread.GetApartmentState() -ne 'STA') {
    $psExe = (Get-Process -Id $PID).Path
    if (-not $psExe) { $psExe = 'powershell.exe' }
    $fwd = @('-NoProfile', '-STA', '-ExecutionPolicy', 'Bypass', '-File', $PSCommandPath)
    if ($SelfTest) { $fwd += '-SelfTest' }
    & $psExe @fwd @args
    return
}

Add-Type -AssemblyName PresentationFramework, PresentationCore, WindowsBase, System.Xaml, System.Windows.Forms

