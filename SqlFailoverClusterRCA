# --- Helpers --------------------------------------------------------------------------------
function Set-RunningState {
    param([bool]$Running)
    $ctl.btnRun.IsEnabled = -not $Running
    $ctl.pb.Visibility = if ($Running) { 'Visible' } else { 'Collapsed' }
}

