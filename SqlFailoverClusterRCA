<#
    Collector 6/6 - node health snapshot via CIM inside each node's PSSession: last boot
    (a reboot inside the window is a prime failover cause), free physical memory, logical
    disk free space, pending-reboot flag, and clock skew vs the analysis host. Emits a
    timeline event only for notable conditions; always records a collection status.
#>

function Get-NodeHealthData {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)][string[]]$Node,
        [hashtable]$Session = @{},
        [datetime]$WindowStart,
        [datetime]$WindowEnd,
        [pscredential]$Credential
    )
    $events = [System.Collections.Generic.List[object]]::new()
    $status = [System.Collections.Generic.List[object]]::new()

    $remote = {
        $os = Get-CimInstance Win32_OperatingSystem
        $pending = [bool]((Test-Path 'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Component Based Servicing\RebootPending') -or
                          (Test-Path 'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\WindowsUpdate\Auto Update\RebootRequired'))
        $disks = Get-CimInstance Win32_LogicalDisk -Filter 'DriveType=3' | ForEach-Object {
            $pct = if ($_.Size) { [math]::Round(100.0 * $_.FreeSpace / $_.Size, 1) } else { 0 }
            [pscustomobject]@{ Drive = $_.DeviceID; FreePct = $pct; FreeGB = [math]::Round($_.FreeSpace / 1GB, 1) }
        }
        [pscustomobject]@{
            LastBoot  = $os.LastBootUpTime
            FreeMemMB = [math]::Round($os.FreePhysicalMemory / 1024)
            Now       = (Get-Date)
            Pending   = $pending
            Disks     = $disks
        }
    }

    foreach ($n in $Node) {
        $sess = $Session[$n]
        if (-not $sess) {
            $status.Add((New-CollectionStatus -Node $n -Source 'NodeHealth' -State 'Failed' -Detail 'No remote session (node unreachable).'))
            continue
        }
        try {
            $h = Invoke-RcaRemote -Session $sess -ScriptBlock $remote
            $count = 0

            if ($h.LastBoot -and $h.LastBoot -ge $WindowStart -and $h.LastBoot -le $WindowEnd) {
                $events.Add((New-TimelineEvent -Timestamp $h.LastBoot -Node $n -Source 'NodeHealth' -Severity 'Critical' `
                    -Message "Node '$n' booted at $($h.LastBoot.ToString('yyyy-MM-dd HH:mm:ss')) - a reboot occurred inside the analysis window." `
                    -Data @{ Kind = 'Reboot' })); $count++
            }
            $skew = [math]::Abs(((Get-Date) - $h.Now).TotalSeconds)
            if ($skew -gt 30) {
                $events.Add((New-TimelineEvent -Timestamp $WindowEnd -Node $n -Source 'NodeHealth' -Severity 'Warning' `
                    -Message "Clock skew vs analysis host is ~$([math]::Round($skew))s - can break cluster/AG health checks." `
                    -Data @{ Kind = 'ClockSkew'; SkewSeconds = $skew })); $count++
            }
            if ($h.FreeMemMB -lt 256) {
                $events.Add((New-TimelineEvent -Timestamp $WindowEnd -Node $n -Source 'NodeHealth' -Severity 'Warning' `
                    -Message "Low free physical memory: $($h.FreeMemMB) MB." -Data @{ Kind = 'Memory' })); $count++
            }
            foreach ($d in @($h.Disks)) {
                if ($d.FreePct -lt 10) {
                    $events.Add((New-TimelineEvent -Timestamp $WindowEnd -Node $n -Source 'NodeHealth' -Severity 'Warning' `
                        -Message "Low disk space on $($d.Drive): $($d.FreePct)% ($($d.FreeGB) GB) free." -Data @{ Kind = 'Disk'; Drive = $d.Drive })); $count++
                }
            }
            if ($h.Pending) {
                $events.Add((New-TimelineEvent -Timestamp $WindowEnd -Node $n -Source 'NodeHealth' -Severity 'Info' `
                    -Message "Node '$n' has a pending reboot." -Data @{ Kind = 'PendingReboot' })); $count++
            }

            $status.Add((New-CollectionStatus -Node $n -Source 'NodeHealth' -State 'Ok' -ItemCount $count -Detail "LastBoot=$($h.LastBoot); FreeMem=$($h.FreeMemMB)MB."))
        }
        catch {
            $status.Add((New-CollectionStatus -Node $n -Source 'NodeHealth' -State 'Failed' -Detail $_.Exception.Message))
        }
    }

    @{ Events = $events.ToArray(); Status = $status.ToArray() }
}




