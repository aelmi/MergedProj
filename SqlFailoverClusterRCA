<#
    Unit tests - prove the pipeline wiring, the read-only SQL guard, and the rule engine
    (both with injected rules and against the real Data\rules.catalog.json). The end-to-end
    test runs against unreachable placeholder nodes to prove the collectors degrade
    gracefully (status 'Failed', never throwing) and still produce a valid report.
    Run:  .\Invoke-Tests.ps1   (or)   Invoke-Pester -Path .\Tests\Unit
#>

BeforeAll {
    $script:ModulePath = Join-Path $PSScriptRoot '..\..\SqlFailoverClusterRCA.psd1' | Resolve-Path
    Import-Module $script:ModulePath -Force
    $script:OutDir = Join-Path ([System.IO.Path]::GetTempPath()) ("rca_test_" + [guid]::NewGuid().ToString('N'))
}

AfterAll {
    if (Test-Path $script:OutDir) { Remove-Item $script:OutDir -Recurse -Force -ErrorAction SilentlyContinue }
    Remove-Module SqlFailoverClusterRCA -Force -ErrorAction SilentlyContinue
}

Describe 'Module surface' {
    It 'exports exactly the five public cmdlets' {
        $expected = 'Invoke-FailoverRCA', 'Get-FailoverEvidence', 'New-FailoverTimeline', 'Get-FailoverRootCause', 'Export-FailoverReport'
        $actual = (Get-Command -Module SqlFailoverClusterRCA -CommandType Function).Name
        ($actual | Sort-Object) | Should -Be ($expected | Sort-Object)
    }
}

Describe 'Type factories' {
    It 'New-TimelineEvent tags the shape' {
        $e = & (Get-Module SqlFailoverClusterRCA) { New-TimelineEvent -Timestamp (Get-Date) -Node 'W19A' -Source 'ClusterLog' -Message 'x' }
        $e.PSTypeNames | Should -Contain 'Rca.TimelineEvent'
    }
    It 'New-RcaResult defaults to empty collections' {
        $r = & (Get-Module SqlFailoverClusterRCA) { New-RcaResult -ClusterName 'C1' }
        $r.Findings | Should -BeNullOrEmpty
        $r.PrimaryFinding | Should -BeNullOrEmpty
    }
}

Describe 'Read-only SQL guard' {
    It 'permits a SELECT / DMV read' {
        & (Get-Module SqlFailoverClusterRCA) { Test-RcaReadOnlySql 'SELECT * FROM sys.dm_hadr_availability_replica_states' } | Should -BeTrue
    }
    It 'permits an allowlisted read proc (xp_readerrorlog)' {
        & (Get-Module SqlFailoverClusterRCA) { Test-RcaReadOnlySql 'EXEC xp_readerrorlog 0, 1' } | Should -BeTrue
    }
    It 'still blocks a write piggy-backed after an allowed proc' {
        & (Get-Module SqlFailoverClusterRCA) { Test-RcaReadOnlySql 'EXEC xp_readerrorlog 0; DROP TABLE foo' } | Should -BeFalse
    }
    It 'refuses a write statement before connecting' {
        { & (Get-Module SqlFailoverClusterRCA) { Invoke-SqlReadOnly -ServerInstance 'x' -Query 'DROP TABLE foo' } } | Should -Throw
    }
    It 'ValidateOnly lets a read-only query pass without a connection' {
        { & (Get-Module SqlFailoverClusterRCA) { Invoke-SqlReadOnly -ServerInstance 'x' -Query 'SELECT 1' -ValidateOnly } } | Should -Not -Throw
    }
}

Describe 'Rule engine (injected rules)' {
    It 'ranks fired rules by confidence then severity, and skips non-matching rules' {
        $tl = @(
            & (Get-Module SqlFailoverClusterRCA) { New-TimelineEvent -Timestamp (Get-Date) -Node 'W19A' -Source 'SqlErrorLog' -Severity 'Error' -Message 'lease timeout' }
        )
        $rules = @(
            @{ Id = 'HIT-HI'; Category = 'AG lease / health timeout'; Severity = 'High'
               Match = { param($t) $t | Where-Object { $_.Message -match 'lease' } }
               Confidence = { param($m, $t) 80 }; Explain = 'e'; Remediation = 'r' }
            @{ Id = 'HIT-LO'; Category = 'Network heartbeat'; Severity = 'Medium'
               Match = { param($t) $t }
               Confidence = { param($m, $t) 40 }; Explain = 'e'; Remediation = 'r' }
            @{ Id = 'MISS'; Category = 'Storage / I/O'; Severity = 'Critical'
               Match = { param($t) $t | Where-Object { $_.Message -match 'NOPE' } }
               Confidence = { param($m, $t) 99 }; Explain = 'e'; Remediation = 'r' }
        )
        $findings = Get-FailoverRootCause -Timeline $tl -Rule $rules
        $findings.Count | Should -Be 2
        $findings[0].RuleId | Should -Be 'HIT-HI'   # 80 > 40, MISS did not fire
    }
}

Describe 'Rule engine (real catalog rules)' {
    BeforeAll {
        function script:New-Tl {
            param($Source, $Severity, $EventId, $Message)
            & (Get-Module SqlFailoverClusterRCA) {
                param($s, $sev, $id, $msg)
                New-TimelineEvent -Timestamp (Get-Date) -Node 'W19A' -Source $s -Severity $sev -EventId $id -Message $msg
            } -s $Source -sev $Severity -id $EventId -msg $Message
        }
    }

    It 'flags a node crash from a bugcheck event' {
        $tl = @(New-Tl 'WindowsEvent' 'Critical' '1001' 'The computer has rebooted from a bugcheck.')
        $f = Get-FailoverRootCause -Timeline $tl
        $f[0].RuleId | Should -Be 'NODE-CRASH-BUGCHECK'
        $f[0].Severity | Should -Be 'Critical'   # enriched from the catalog
        $f[0].IsPlanned | Should -BeFalse
    }
    It 'flags an AG lease/health-check timeout' {
        $tl = @(New-Tl 'SqlErrorLog' 'Error' '19421' 'Availability group health check timeout.')
        $f = Get-FailoverRootCause -Timeline $tl
        ($f.RuleId) | Should -Contain 'AG-LEASE-TIMEOUT'
    }
    It 'marks an administrative move as planned (no fault)' {
        $tl = @(New-Tl 'ClusterLog' 'Info' $null 'Move-ClusterGroup initiated by administrator')
        $f = Get-FailoverRootCause -Timeline $tl
        ($f | Where-Object { $_.RuleId -eq 'PLANNED-MOVE' }).IsPlanned | Should -BeTrue
    }
}

Describe 'Normalizer' {
    It 'merges Events from collector hashtables and sorts chronologically' {
        $merged = & (Get-Module SqlFailoverClusterRCA) {
            $e1 = New-TimelineEvent -Timestamp (Get-Date) -Node 'W19A' -Source 'WindowsEvent' -EventId '1001' -Message 'a'
            $e2 = New-TimelineEvent -Timestamp (Get-Date).AddMinutes(-5) -Node 'W19B' -Source 'SqlErrorLog' -Message 'b'
            @(@{ Events = @($e1); Status = @() }, @{ Events = @($e2); Status = @() }) | ConvertTo-TimelineEvent
        }
        $merged.Count | Should -Be 2          # guards the hashtable-key merge regression
        $merged[0].Node | Should -Be 'W19B'   # earlier timestamp sorts first
    }
}

Describe 'End-to-end pipeline (unreachable placeholder nodes)' {
    It 'Invoke-FailoverRCA -WhatIf runs without opening sessions or performing I/O' {
        { Invoke-FailoverRCA -Node 'W19A', 'W19B' -EventTime '2026-06-15 02:14' -OutputPath $script:OutDir -WhatIf } | Should -Not -Throw
    }

    It 'a real run degrades gracefully and still writes a valid HTML + JSON report' {
        $r = Invoke-FailoverRCA -Node 'W19A', 'W19B' -EventTime '2026-06-15 02:14' -OutputPath $script:OutDir
        $r.PSTypeNames | Should -Contain 'Rca.RcaResult'
        $r.Nodes | Should -Be @('W19A', 'W19B')
        # Six sources x two nodes/instances = 12 collection-status rows.
        $r.CollectionStatus.Count | Should -Be 12
        # Unreachable nodes => collectors record a status and never throw.
        $r.CollectionStatus.State | ForEach-Object { $_ | Should -BeIn @('Ok', 'Partial', 'Failed', 'Skipped') }

        $html = Get-ChildItem -Path $script:OutDir -Recurse -Filter '*.html'
        $json = Get-ChildItem -Path $script:OutDir -Recurse -Filter 'RCA_*.json'
        $html | Should -Not -BeNullOrEmpty
        $json | Should -Not -BeNullOrEmpty
    }
}
