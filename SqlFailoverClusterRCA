<#
    Collector 4/6 - SQL Server ERRORLOG. Reads the active log via xp_readerrorlog (read-only,
    allowed through the contract guard) bounded to the analysis window, on EACH replica
    instance directly. AG role changes, lease/health-check timeouts, I/O stalls (833) and
    other engine errors surface here with their original timestamps.
#>

function Get-SqlErrorLogData {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)][string[]]$Node,
        [string[]]$SqlInstance,
        [datetime]$WindowStart,
        [datetime]$WindowEnd,
        [pscredential]$Credential
    )
    $events = [System.Collections.Generic.List[object]]::new()
    $status = [System.Collections.Generic.List[object]]::new()

    # Each replica is queried directly; default to a default instance per node when not given.
    $instances = if ($SqlInstance) { $SqlInstance } else { $Node }

    $start = $WindowStart.ToString('yyyy-MM-dd HH:mm:ss.fff')
    $end   = $WindowEnd.ToString('yyyy-MM-dd HH:mm:ss.fff')
    $query = "EXEC sys.xp_readerrorlog 0, 1, NULL, NULL, '$start', '$end', N'ASC'"

    # Error numbers / phrases that denote a genuine fault (vs informational lines).
    $sevRx = '(?i)\b(error|fail|cannot|fatal|lease|timeout|stall|corrupt|severity:\s*1[6-9]|severity:\s*2[0-5])\b'
    $numRx = [regex]'(?i)Error:\s*(\d+)'

    foreach ($inst in $instances) {
        try {
            $rows = @(Invoke-SqlReadOnly -ServerInstance $inst -Query $query -Credential $Credential)
            foreach ($r in $rows) {
                $text = "$($r.Text)"
                $sev = if ($text -match $sevRx) { 'Error' } else { 'Info' }
                $eid = $null
                $nm = $numRx.Match($text)
                if ($nm.Success) {
                    $eid = $nm.Groups[1].Value
                    $meaning = Get-RcaSqlEventMeaning $eid
                    if ($meaning -and $sev -eq 'Info') { $sev = 'Warning' }
                    if ($meaning) { $text = "$meaning - $text" }
                }
                $events.Add((New-TimelineEvent -Timestamp ([datetime]$r.LogDate) -Node $inst -Source 'SqlErrorLog' `
                    -Severity $sev -EventId $eid -Message (Get-RcaFirstLine $text 400) `
