<#
    Runtime resolvers used by Invoke-FailoverRCA:
      - Resolve-ClusterNode : expand a cluster name into its member node names.
      - Find-LatestFailover : auto-detect the most recent failover time when -EventTime
                              is not supplied, by scanning FailoverClustering events.
    Both are best-effort and degrade gracefully (return a sensible fallback, never throw).
#>

function Resolve-ClusterNode {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)][string]$ClusterName,
        [pscredential]$Credential,
        [int]$OpenTimeoutMs = 6000
    )
    try {
        $opt = New-PSSessionOption -OpenTimeout $OpenTimeoutMs
        $splat = @{
            ComputerName  = $ClusterName
            SessionOption = $opt
            ErrorAction   = 'Stop'
            ScriptBlock   = { Import-Module FailoverClusters -ErrorAction Stop; (Get-ClusterNode).Name }
        }
        if ($Credential) { $splat.Credential = $Credential }
        $names = Invoke-Command @splat
        if ($names) {
            Write-RcaLog "Resolve-ClusterNode: '$ClusterName' -> $(@($names) -join ', ')" -Level Info
            return , @($names)
        }
    }
    catch {
        Write-RcaLog "Resolve-ClusterNode: could not expand '$ClusterName' ($($_.Exception.Message)); treating it as a single node." -Level Warn
    }
    , @($ClusterName)
}

function Find-LatestFailover {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)][string[]]$Node,
        [pscredential]$Credential,
        [int]$LookbackDays = 7,
        [int]$OpenTimeoutMs = 6000
    )
    $sb = {
        param($days)
        $start = (Get-Date).AddDays(-$days)
        # Ownership/role-change + membership/quorum events that mark a failover.
        $ids = 1135, 1146, 1069, 1177, 1201, 1205, 1206, 1635, 1641
        try {
            $e = Get-WinEvent -FilterHashtable @{
                LogName      = 'System'
                ProviderName = 'Microsoft-Windows-FailoverClustering'
                StartTime    = $start
            } -ErrorAction Stop | Where-Object { $ids -contains $_.Id } |
                Sort-Object TimeCreated -Descending | Select-Object -First 1
            if ($e) { $e.TimeCreated }
        } catch { $null }
    }

    foreach ($n in $Node) {
        try {
            $opt = New-PSSessionOption -OpenTimeout $OpenTimeoutMs
            $splat = @{
                ComputerName  = $n
                ScriptBlock   = $sb
                ArgumentList  = $LookbackDays
                SessionOption = $opt
                ErrorAction   = 'Stop'
            }
            if ($Credential) { $splat.Credential = $Credential }
            $t = Invoke-Command @splat
            if ($t) {
                Write-RcaLog "Find-LatestFailover: detected failover at $t (from $n)." -Level Info
                return [datetime]$t
            }
        }
        catch {
            Write-RcaLog "Find-LatestFailover: '$n' query failed ($($_.Exception.Message))." -Level Debug
            continue
        }
    }
