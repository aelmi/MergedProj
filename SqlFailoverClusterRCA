<#
.SYNOPSIS
  Run the collectors and return raw + normalized evidence (optionally persisted to disk).
.DESCRIPTION
  Stage 1 of the pipeline. Opens one throttled PSSession per node (reused across the four
  Windows-side collectors), runs all six collectors for the time window, merges their events
  into a single timeline, and returns the per-source CollectionStatus. The two SQL collectors
  connect directly to each replica instance over TDS, so a reachable secondary is still
  queried when the former primary is down. Sessions are always torn down on the way out.
  -WhatIf walks the stages without opening sessions or performing collection/I-O.
#>
function Get-FailoverEvidence {
    [CmdletBinding(SupportsShouldProcess)]
    param(
        [Parameter(Mandatory)][string[]]$Node,
        [string[]]$SqlInstance,
        [datetime]$WindowStart,
        [datetime]$WindowEnd,
        [pscredential]$Credential,
        [int]$ThrottleLimit = 4,
        [string]$EvidencePath
    )

    Write-RcaLog "Collecting evidence from $($Node -join ', ') [$WindowStart -> $WindowEnd]" -Level Info

    $sessions = @{}
    $opened = $false
    $results = @()
    try {
        if ($PSCmdlet.ShouldProcess(($Node -join ', '), 'Open remote sessions')) {
            $opened = $true
            foreach ($ns in (Connect-ClusterNode -Node $Node -Credential $Credential -ThrottleLimit $ThrottleLimit)) {
                if ($ns.Connected) { $sessions[$ns.Node] = $ns.Session }
            }
        }

        $winCommon = @{ Node = $Node; Session = $sessions; WindowStart = $WindowStart; WindowEnd = $WindowEnd; Credential = $Credential }
        $sqlCommon = @{ Node = $Node; SqlInstance = $SqlInstance; WindowStart = $WindowStart; WindowEnd = $WindowEnd; Credential = $Credential }

        if ($PSCmdlet.ShouldProcess(($Node -join ', '), 'Collect cluster.log'))     { $results += Get-ClusterLogData @winCommon }
        if ($PSCmdlet.ShouldProcess(($Node -join ', '), 'Collect WSFC state'))       { $results += Get-WsfcStateData @winCommon }
        if ($PSCmdlet.ShouldProcess(($Node -join ', '), 'Collect Windows events'))   { $results += Get-WindowsEventData @winCommon }
        if ($PSCmdlet.ShouldProcess(($Node -join ', '), 'Collect node health'))      { $results += Get-NodeHealthData @winCommon }
        if ($PSCmdlet.ShouldProcess(($Node -join ', '), 'Collect SQL ERRORLOG'))     { $results += Get-SqlErrorLogData @sqlCommon }
        if ($PSCmdlet.ShouldProcess(($Node -join ', '), 'Collect SQL HA DMVs'))      { $results += Get-SqlHaDmvData @sqlCommon }
    }
    finally {
        if ($opened) { Disconnect-ClusterNode -Node $Node }
    }

    $timeline = @($results | ConvertTo-TimelineEvent)
    $status   = @($results | ForEach-Object { $_.Status })

    if ($EvidencePath) {
        if (-not (Test-Path $EvidencePath)) { New-Item -ItemType Directory -Path $EvidencePath -Force | Out-Null }
        $evFile = Join-Path $EvidencePath 'evidence.json'
        if ($PSCmdlet.ShouldProcess($evFile, 'Persist evidence')) {
            [pscustomobject]@{ Timeline = $timeline; Status = $status } |
                ConvertTo-Json -Depth 12 | Set-Content -Path $evFile -Encoding UTF8
            Write-RcaLog "Persisted evidence: $evFile" -Level Info
        }
    }

    [pscustomobject]@{
        PSTypeName = 'Rca.Evidence'
        Timeline   = $timeline
        Status     = $status
        Node       = $Node
    }
}




