<#
    Internal diagnostic logging. Writes to the verbose stream and, if a run log path is
    set in $script:RcaLogFile, appends a timestamped line. Never throws.
#>

function Write-RcaLog {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [string]$Message,
        [ValidateSet('Debug', 'Info', 'Warn', 'Error')]
        [string]$Level = 'Info'
    )
    # Use UTC ISO-8601 for stable ordering across nodes in different time zones.
    $stamp = (Get-Date).ToUniversalTime().ToString('yyyy-MM-ddTHH:mm:ss.fffZ')
    $line = "{0} [{1}] {2}" -f $stamp, $Level.ToUpper(), $Message

    switch ($Level) {
        'Warn'  { Write-Warning $Message }
        'Error' { Write-Verbose $line }   # surfaced via findings/CollectionStatus, not thrown here
        default { Write-Verbose $line }
    }

    if ($script:RcaLogFile) {
        try { Add-Content -Path $script:RcaLogFile -Value $line -Encoding UTF8 -ErrorAction Stop }
        catch { Write-Warning "RcaLog: could not write to $script:RcaLogFile ($($_.Exception.Message))" }
    }
}




