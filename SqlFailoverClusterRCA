# Strict-safe property/key read from a row object or hashtable (returns $Default if absent).
# DMV column sets vary across SQL 2016-2022, so collectors read fields through this.
function Get-RcaProp {
    param($Obj, [Parameter(Mandatory)][string]$Name, $Default = $null)
    if ($null -eq $Obj) { return $Default }
    if ($Obj -is [hashtable]) {
        if ($Obj.ContainsKey($Name)) { return $Obj[$Name] } else { return $Default }
    }
    $p = $Obj.PSObject.Properties[$Name]
    if ($p) { $p.Value } else { $Default }
}

# Strict-safe read of a module-scope variable (returns $null if it has never been set).
function Get-RcaScriptVar {
    param([Parameter(Mandatory)][string]$Name)
    $v = Get-Variable -Name $Name -Scope Script -ErrorAction SilentlyContinue
    if ($v) { $v.Value } else { $null }
}

