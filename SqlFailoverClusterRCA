$reader = New-Object System.Xml.XmlNodeReader ([xml]$xaml)
$win = [System.Windows.Markup.XamlReader]::Load($reader)

# Resolve controls.
$ctl = @{}
foreach ($n in 'rbNode','rbCluster','txtTarget','txtSql','chkAuto','dpDate','txtTime','txtBefore','txtAfter','txtOut','btnBrowse','chkCred','chkOpen','btnRun','pb','txtStatus','txtVerdict','txtFindings','btnOpenFolder') {
