        }

        public PasswordDialog() : this("Enter Password", "Enter password:")
        {
        }

        public PasswordDialog(string title) : this(title, "Enter password:")
        {
        }

        public PasswordDialog(string title, string prompt)
        {
            InitializeComponent();

            this.Text = title;
            this.HeaderText = title;
            this.Prompt = prompt;
        }

