        {
            txtPassword.UseSystemPasswordChar = !chkShowPassword.Checked;
        }

        private void TxtPassword_KeyDown(object sender, KeyEventArgs e)
        {
            if (e.KeyCode == Keys.Enter)
            {
                btnOK.PerformClick();
                e.Handled = true;
                e.SuppressKeyPress = true;
            }
