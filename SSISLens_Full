using Microsoft.Extensions.Logging;
using SSISLens.Core;
using SSISLens.Export;
using SSISLens.Services;

if (args.Length == 0)
{
    Console.Error.WriteLine("Usage: ssislens-probe <path-to-dtsx-or-folder> [--no-enumerate] [--export <xlsx-path>]");
    return 2;
}

var path = args[0];
var enumerate = !args.Contains("--no-enumerate", StringComparer.OrdinalIgnoreCase);
var exportIdx = Array.FindIndex(args, a => a.Equals("--export", StringComparison.OrdinalIgnoreCase));
var exportPath = exportIdx >= 0 && exportIdx + 1 < args.Length ? args[exportIdx + 1] : null;

using var loggerFactory = LoggerFactory.Create(b => b.SetMinimumLevel(LogLevel.Warning).AddConsole());
var svc = new AnalysisService(loggerFactory.CreateLogger<AnalysisService>());

var opts = new AnalysisOptions { EnumerateAllDatabaseTables = enumerate };
var progress = new Progress<AnalysisProgress>(p => Console.Error.WriteLine($"... {p}"));

var result = await svc.AnalyzeAsync(path, opts, progress, CancellationToken.None);

Console.WriteLine();
Console.WriteLine($"Source:      {result.SourcePath}");
Console.WriteLine($"Packages:    {result.Packages.Count}");
Console.WriteLine($"Duration:    {result.Duration?.TotalSeconds:F1}s");
Console.WriteLine();

foreach (var pkg in result.Packages)
{
    Console.WriteLine($"== Package: {pkg.Name} ==");
    foreach (var conn in pkg.Connections)
    {
        Console.WriteLine($"  Connection: {conn.Name}  ({conn.Provider}, {conn.Server}/{conn.Database})");
        Console.WriteLine($"    Objects: {conn.Objects.Count}  (T={conn.Objects.Count(o => o.Type == DbObjectType.Table)} V={conn.Objects.Count(o => o.Type == DbObjectType.View)} P={conn.Objects.Count(o => o.Type == DbObjectType.StoredProcedure)} F={conn.Objects.Count(o => o.Type == DbObjectType.Function)})");
        foreach (var o in conn.Objects.OrderBy(o => o.Type).ThenByDescending(o => o.TableMetrics?.RowCount ?? 0).ThenBy(o => o.Name))
        {
            var m = o.TableMetrics;
            var size = m is null ? "" : $"  rows={m.RowCount,12:N0}  reserved={(m.TotalReservedKB / 1024.0):N1} MB";
            var schema = o.Columns.Count > 0 || o.Indexes.Count > 0 || o.ForeignKeys.Count > 0
                ? $"  cols={o.Columns.Count,3}  idx={o.Indexes.Count,2}  fk={o.ForeignKeys.Count,2}"
                : "";
            var fg = o.FileGroup is null ? "" : $"  fg={o.FileGroup}";
            Console.WriteLine($"      {("[" + o.Type + "]"),-20} {o.QualifiedName,-42}{size}{schema}{fg}");
        }
    }
}
if (exportPath is not null)
{
    Console.WriteLine();
    Console.WriteLine($"Exporting to {exportPath} …");
    IExportWriter writer = Path.GetExtension(exportPath).ToLowerInvariant() switch
    {
        ".html" or ".htm" => new HtmlExportWriter(),
        ".json"           => new JsonExportWriter(),
        ".csv"            => new CsvExportWriter(),
        _                 => new ExcelExportWriter()
    };
    await writer.WriteAsync(result, exportPath, CancellationToken.None);
    Console.WriteLine($"Done. {new FileInfo(exportPath).Length:N0} bytes");
}
return 0;




