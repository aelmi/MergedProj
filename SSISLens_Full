using Microsoft.Data.SqlClient;
using SSISLens.Core;

namespace SSISLens.Sql;

/// <summary>
/// Set-based size + partition collector. All metrics in a single pass over
/// sys.dm_db_partition_stats joined with sys.allocation_units and (optionally)
/// sys.partition_functions.
/// </summary>
public sealed class TableMetricsRepo
{
    private readonly SqlConnectionFactory _factory;

    public TableMetricsRepo(SqlConnectionFactory factory) => _factory = factory;

    private const string Query = @"
WITH au AS (
    SELECT p.object_id, p.partition_number, p.rows,
           SUM(a.total_pages) AS reserved_pages,
           SUM(a.used_pages)  AS used_pages,
           SUM(CASE WHEN a.type <> 1 THEN a.used_pages ELSE 0 END) AS index_used_pages,
           SUM(CASE WHEN a.type = 1 AND p.index_id IN (0,1) THEN a.data_pages ELSE 0 END) AS data_pages
    FROM sys.partitions p
    JOIN sys.allocation_units a ON a.container_id = p.partition_id
    GROUP BY p.object_id, p.partition_number, p.rows
)
SELECT
    s.name AS schema_name, t.name AS table_name,
    SUM(au.rows) AS rows_total,
    SUM(au.reserved_pages) * 8 AS reserved_kb,
    SUM(au.used_pages) * 8 AS used_kb,
    SUM(au.data_pages) * 8 AS data_kb,
    SUM(au.index_used_pages) * 8 AS index_kb,
    ds.type AS partition_type,
    pf.name AS partition_function,
    ps.name AS partition_scheme
FROM sys.tables t
JOIN sys.schemas s ON s.schema_id = t.schema_id
JOIN sys.indexes i ON i.object_id = t.object_id AND i.index_id IN (0,1)
JOIN sys.data_spaces ds ON ds.data_space_id = i.data_space_id
LEFT JOIN sys.partition_schemes ps ON ps.data_space_id = ds.data_space_id
LEFT JOIN sys.partition_functions pf ON pf.function_id = ps.function_id
LEFT JOIN au ON au.object_id = t.object_id
WHERE s.name = @s AND t.name = @n
GROUP BY s.name, t.name, ds.type, pf.name, ps.name;";

    private const string PartitionDetailQuery = @"
SELECT
    p.partition_number,
    CAST(prv.value AS NVARCHAR(MAX)) AS boundary_value,
    pf.boundary_value_on_right,
    p.rows,
    SUM(a.total_pages) * 8 AS total_kb,
    SUM(CASE WHEN a.type = 1 AND p.index_id IN (0,1) THEN a.data_pages ELSE 0 END) * 8 AS data_kb,
    SUM(CASE WHEN a.type <> 1 THEN a.used_pages ELSE 0 END) * 8 AS index_kb,
    fg.name AS filegroup_name
FROM sys.partitions p
JOIN sys.indexes i ON i.object_id = p.object_id AND i.index_id IN (0,1)
JOIN sys.allocation_units a ON a.container_id = p.partition_id
JOIN sys.partition_schemes ps ON ps.data_space_id = i.data_space_id
JOIN sys.partition_functions pf ON pf.function_id = ps.function_id
LEFT JOIN sys.partition_range_values prv ON prv.function_id = pf.function_id AND prv.boundary_id = p.partition_number
LEFT JOIN sys.destination_data_spaces dds ON dds.partition_scheme_id = ps.data_space_id AND dds.destination_id = p.partition_number
LEFT JOIN sys.filegroups fg ON fg.data_space_id = dds.data_space_id
WHERE p.object_id = OBJECT_ID(QUOTENAME(@s) + '.' + QUOTENAME(@n))
GROUP BY p.partition_number, prv.value, pf.boundary_value_on_right, p.rows, fg.name
ORDER BY p.partition_number;";

    public async Task<TableMetrics?> GetAsync(string server, string database,
        string schema, string name, CancellationToken ct)
    {
        await using var conn = await _factory.OpenAsync(server, database, ct).ConfigureAwait(false);
        TableMetrics? m = null;
        await using (var cmd = new SqlCommand(Query, conn) { CommandTimeout = _factory.CommandTimeoutSeconds })
        {
            cmd.Parameters.AddWithValue("@s", schema);
            cmd.Parameters.AddWithValue("@n", name);
            await using var r = await cmd.ExecuteReaderAsync(ct).ConfigureAwait(false);
            if (await r.ReadAsync(ct).ConfigureAwait(false))
            {
                var partType = r.IsDBNull(7) ? null : r.GetString(7);
                m = new TableMetrics
                {
                    RowCount         = r.IsDBNull(2) ? 0 : Convert.ToInt64(r.GetValue(2)),
                    TotalReservedKB  = r.IsDBNull(3) ? 0 : Convert.ToInt64(r.GetValue(3)),
                    DataKB           = r.IsDBNull(5) ? 0 : Convert.ToInt64(r.GetValue(5)),
                    IndexKB          = r.IsDBNull(6) ? 0 : Convert.ToInt64(r.GetValue(6)),
                    IsPartitioned    = partType == "PS",
                    PartitionFunction= r.IsDBNull(8) ? null : r.GetString(8),
                    PartitionScheme  = r.IsDBNull(9) ? null : r.GetString(9)
                };
                m.UnusedKB = Math.Max(0, m.TotalReservedKB - (r.IsDBNull(4) ? 0 : Convert.ToInt64(r.GetValue(4))));
            }
        }
        if (m is null) return null;

        if (m.IsPartitioned)
        {
            await using var cmd2 = new SqlCommand(@"SELECT c.name FROM sys.indexes i
JOIN sys.index_columns ic ON ic.object_id = i.object_id AND ic.index_id = i.index_id
JOIN sys.columns c ON c.object_id = ic.object_id AND c.column_id = ic.column_id
WHERE i.object_id = OBJECT_ID(QUOTENAME(@s) + '.' + QUOTENAME(@n))
  AND i.index_id IN (0,1) AND ic.partition_ordinal > 0;",
                conn) { CommandTimeout = _factory.CommandTimeoutSeconds };
            cmd2.Parameters.AddWithValue("@s", schema);
            cmd2.Parameters.AddWithValue("@n", name);
            var col = await cmd2.ExecuteScalarAsync(ct).ConfigureAwait(false);
            if (col is string cs) m.PartitionColumn = cs;
        }

        m.PartitionCount = 1;
        return m;
    }

    public async Task<List<PartitionInfo>> GetPartitionsAsync(string server, string database,
        string schema, string name, CancellationToken ct)
    {
        var list = new List<PartitionInfo>();
        await using var conn = await _factory.OpenAsync(server, database, ct).ConfigureAwait(false);
        await using var cmd = new SqlCommand(PartitionDetailQuery, conn) { CommandTimeout = _factory.CommandTimeoutSeconds };
        cmd.Parameters.AddWithValue("@s", schema);
        cmd.Parameters.AddWithValue("@n", name);
        await using var r = await cmd.ExecuteReaderAsync(ct).ConfigureAwait(false);
        while (await r.ReadAsync(ct).ConfigureAwait(false))
        {
            bool right = !r.IsDBNull(2) && r.GetBoolean(2);
            list.Add(new PartitionInfo
            {
                PartitionNumber    = r.GetInt32(0),
                BoundaryValue      = r.IsDBNull(1) ? null : r.GetString(1),
                BoundaryComparator = right ? "RIGHT" : "LEFT",
                RowCount           = r.IsDBNull(3) ? 0 : Convert.ToInt64(r.GetValue(3)),
                TotalKB            = r.IsDBNull(4) ? 0 : Convert.ToInt64(r.GetValue(4)),
                DataKB             = r.IsDBNull(5) ? 0 : Convert.ToInt64(r.GetValue(5)),
                IndexKB            = r.IsDBNull(6) ? 0 : Convert.ToInt64(r.GetValue(6)),
                FileGroup          = r.IsDBNull(7) ? null : r.GetString(7)
            });
        }
        return list;
    }
