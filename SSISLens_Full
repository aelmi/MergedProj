using System.Collections.Concurrent;
using Microsoft.Extensions.Logging;
using SSISLens.Core;
using SSISLens.Parsing;
using SSISLens.Sql;

namespace SSISLens.Services;

public sealed class AnalysisService
{
    private readonly ILogger<AnalysisService> _log;

    public AnalysisService(ILogger<AnalysisService> log) => _log = log;

    public async Task<AnalysisResult> AnalyzeAsync(string sourcePath,
        AnalysisOptions options,
        IProgress<AnalysisProgress>? progress = null,
        CancellationToken ct = default)
    {
        var sw = System.Diagnostics.Stopwatch.StartNew();
        var result = new AnalysisResult { SourcePath = sourcePath, Options = options };
        progress?.Report(new AnalysisProgress { Stage = "Parsing SSIS source" });

        var loader = new PackageSourceLoader(options);
        var packages = loader.Load(sourcePath, out var projectConns);
        result.Packages.AddRange(packages);

        var factory   = new SqlConnectionFactory(options.SqlCommandTimeoutSeconds);
        var serverRepo= new ServerConfigRepo(factory);
        var dbRepo    = new DatabaseInfoRepo(factory);
        var objRepo   = new ObjectMetadataRepo(factory);
        var tblRepo   = new TableMetricsRepo(factory);
        var idxRepo   = new IndexRepo(factory);
        var schemaRepo= new TableSchemaRepo(factory);
        var extractor = new SqlObjectExtractor();

        var sqlConnections = packages.SelectMany(p => p.Connections)
            .Where(c => c.IsSqlServer &&
                        !string.IsNullOrWhiteSpace(c.Server) &&
                        c.Status != ResolutionStatus.Unresolved)
            .ToList();

        var distinctServers = sqlConnections
            .Select(c => c.Server!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        progress?.Report(new AnalysisProgress { Stage = "Querying servers", Total = distinctServers.Count });
        var serverInfos = new ConcurrentDictionary<string, ServerInfo>(StringComparer.OrdinalIgnoreCase);
        var done = 0;
        await Parallel.ForEachAsync(distinctServers,
            new ParallelOptions { CancellationToken = ct, MaxDegreeOfParallelism = options.MaxParallelDatabaseQueries },
            async (srv, c) =>
            {
                var info = await serverRepo.GetAsync(srv, c).ConfigureAwait(false);
                serverInfos[srv] = info;
                progress?.Report(new AnalysisProgress
                {
                    Stage = "Querying servers",
                    Detail = srv,
                    Current = Interlocked.Increment(ref done),
                    Total = distinctServers.Count
                });
            }).ConfigureAwait(false);
        result.Servers.AddRange(serverInfos.Values);

        var distinctDbs = sqlConnections
            .Where(c => !string.IsNullOrWhiteSpace(c.Database))
            .Select(c => (c.Server!, c.Database!))
            .Distinct()
            .ToList();
        progress?.Report(new AnalysisProgress { Stage = "Querying databases", Total = distinctDbs.Count });
        var dbInfos = new ConcurrentDictionary<string, DatabaseInfo>(StringComparer.OrdinalIgnoreCase);
        done = 0;
        await Parallel.ForEachAsync(distinctDbs,
            new ParallelOptions { CancellationToken = ct, MaxDegreeOfParallelism = options.MaxParallelDatabaseQueries },
            async (pair, c) =>
            {
                var info = await dbRepo.GetAsync(pair.Item1, pair.Item2, c).ConfigureAwait(false);
                dbInfos[$"{pair.Item1}|{pair.Item2}"] = info;
                progress?.Report(new AnalysisProgress
                {
                    Stage = "Querying databases",
                    Detail = $"{pair.Item1}.{pair.Item2}",
                    Current = Interlocked.Increment(ref done),
                    Total = distinctDbs.Count
                });
            }).ConfigureAwait(false);
        result.Databases.AddRange(dbInfos.Values);

        progress?.Report(new AnalysisProgress { Stage = "Extracting SQL and resolving objects" });
        foreach (var pkg in packages)
        {
            foreach (var conn in pkg.Connections)
            {
                if (!conn.IsSqlServer) continue;
                var server = conn.Server;
                var database = conn.Database;
                if (string.IsNullOrWhiteSpace(server) || string.IsNullOrWhiteSpace(database)) continue;

                // Dedupe by schema.name only so the same table referenced via
                // INSERT/UPDATE/SELECT collapses to one node. Promote access to the
                // "strongest" kind seen (Ddl > Write > Execute > Read).
                var refs = new Dictionary<string, (SqlObjectRef Ref, List<string> Tasks)>(StringComparer.OrdinalIgnoreCase);
                foreach (var t in pkg.Tasks)
                {
                    if (!string.Equals(t.ConnectionName, conn.Name, StringComparison.OrdinalIgnoreCase)) continue;
                    if (string.IsNullOrWhiteSpace(t.Sql)) continue;
                    foreach (var r in extractor.Extract(t.Sql, out _))
                    {
                        var key = $"{r.Schema}.{r.Name}";
                        if (refs.TryGetValue(key, out var existing))
                        {
                            if (!existing.Tasks.Contains(t.Name)) existing.Tasks.Add(t.Name);
                            var stronger = StrongerAccess(existing.Ref.Access, r.Access);
                            if (stronger != existing.Ref.Access)
                                refs[key] = (existing.Ref with { Access = stronger }, existing.Tasks);
                        }
                        else
                            refs[key] = (r, new List<string> { t.Name });
                    }
                }

                foreach (var (_, (r, tasks)) in refs)
                {
                    var node = await BuildObjectNodeAsync(server, database!, r.Schema, r.Name, r.Access,
                        objRepo, tblRepo, idxRepo, schemaRepo, options, new HashSet<string>(), 0, new HashSet<string>(),
                        ct).ConfigureAwait(false);
                    if (node is not null)
                    {
                        foreach (var task in tasks) node.ReferencedByTasks.Add(task);
                        conn.Objects.Add(node);
                    }
                }
            }
        }

        if (options.EnumerateAllDatabaseTables)
        {
            progress?.Report(new AnalysisProgress { Stage = "Enumerating database tables" });
            await EnumerateAllTablesAsync(packages, schemaRepo, tblRepo, idxRepo, objRepo, options, progress, ct)
                .ConfigureAwait(false);
        }

        result.Duration = sw.Elapsed;
        progress?.Report(new AnalysisProgress { Stage = "Done", Detail = $"in {sw.Elapsed.TotalSeconds:F1}s" });
        return result;
    }

    private static AccessKind StrongerAccess(AccessKind a, AccessKind b)
    {
        static int Rank(AccessKind k) => k switch
        {
            AccessKind.Ddl     => 4,
            AccessKind.Write   => 3,
            AccessKind.Execute => 2,
            AccessKind.Read    => 1,
            _                  => 0
        };
        return Rank(a) >= Rank(b) ? a : b;
    }

    private static async Task EnumerateAllTablesAsync(
        IEnumerable<PackageInfo> packages,
        TableSchemaRepo schemaRepo,
        TableMetricsRepo tblRepo,
        IndexRepo idxRepo,
        ObjectMetadataRepo objRepo,
        AnalysisOptions options,
        IProgress<AnalysisProgress>? progress,
        CancellationToken ct)
    {
        // (server|db) → connections that target it
        var byDb = new Dictionary<string, List<ConnectionInfo>>(StringComparer.OrdinalIgnoreCase);
        foreach (var pkg in packages)
            foreach (var conn in pkg.Connections)
            {
                if (!conn.IsSqlServer ||
                    string.IsNullOrWhiteSpace(conn.Server) ||
                    string.IsNullOrWhiteSpace(conn.Database) ||
                    conn.Status == ResolutionStatus.Unresolved) continue;
                var key = $"{conn.Server}|{conn.Database}";
                if (!byDb.TryGetValue(key, out var list)) byDb[key] = list = new List<ConnectionInfo>();
                list.Add(conn);
            }

        var totalDbs = byDb.Count;
        var doneDbs  = 0;
        foreach (var (key, conns) in byDb)
        {
            var parts = key.Split('|', 2);
            var server = parts[0]; var database = parts[1];
            List<(string Schema, string Name)> tables;
            try
            {
                tables = await schemaRepo.ListTablesAsync(server, database, ct).ConfigureAwait(false);
            }
            catch (Exception ex)
            {
                foreach (var c in conns) c.Issues.Add($"Could not list tables in {database}: {ex.Message}");
                doneDbs++;
                continue;
            }

            progress?.Report(new AnalysisProgress
            {
                Stage = "Enumerating database tables",
                Detail = $"{server}.{database} ({tables.Count} tables)",
                Current = doneDbs,
                Total = totalDbs
            });

            // De-dupe against tables already added via task-SQL extraction.
            var primary = conns.First();
            var have = new HashSet<string>(
                primary.Objects.Select(o => $"{o.Schema}.{o.Name}".ToLowerInvariant()),
                StringComparer.OrdinalIgnoreCase);

            var tableNodes = new List<DbObjectNode>();
            await Parallel.ForEachAsync(tables,
                new ParallelOptions { CancellationToken = ct, MaxDegreeOfParallelism = options.MaxParallelDatabaseQueries },
                async (t, c) =>
                {
                    if (have.Contains($"{t.Schema}.{t.Name}".ToLowerInvariant())) return;
                    var node = new DbObjectNode
                    {
                        ServerName  = server,
                        DatabaseName = database,
                        Schema = t.Schema,
                        Name   = t.Name,
                        Type   = DbObjectType.Table,
                        AccessKind = AccessKind.Unknown
                    };
                    try
                    {
                        node.TableMetrics = await tblRepo.GetAsync(server, database, t.Schema, t.Name, c).ConfigureAwait(false);
                        node.Indexes.AddRange(await idxRepo.GetAsync(server, database, t.Schema, t.Name, c).ConfigureAwait(false));
                        node.Columns.AddRange(await schemaRepo.GetColumnsAsync(server, database, t.Schema, t.Name, c).ConfigureAwait(false));
                        node.ForeignKeys.AddRange(await schemaRepo.GetForeignKeysAsync(server, database, t.Schema, t.Name, c).ConfigureAwait(false));
                        node.FileGroup = await schemaRepo.GetFileGroupAsync(server, database, t.Schema, t.Name, c).ConfigureAwait(false);
                        if (node.TableMetrics is { IsPartitioned: true })
                            node.Partitions.AddRange(
                                await tblRepo.GetPartitionsAsync(server, database, t.Schema, t.Name, c).ConfigureAwait(false));
                    }
                    catch (Exception ex)
                    {
                        node.Issue = "Metrics error: " + ex.Message;
                    }
                    lock (tableNodes) tableNodes.Add(node);
                }).ConfigureAwait(false);

            tableNodes.Sort((a, b) => string.Compare(a.QualifiedName, b.QualifiedName, StringComparison.OrdinalIgnoreCase));

            // Also enrich existing task-driven tables with columns / FKs / filegroup if missing.
            foreach (var existing in primary.Objects.Where(o => o.Type == DbObjectType.Table))
            {
                try
                {
                    if (existing.Columns.Count == 0)
                        existing.Columns.AddRange(await schemaRepo.GetColumnsAsync(server, database, existing.Schema, existing.Name, ct).ConfigureAwait(false));
                    if (existing.ForeignKeys.Count == 0)
                        existing.ForeignKeys.AddRange(await schemaRepo.GetForeignKeysAsync(server, database, existing.Schema, existing.Name, ct).ConfigureAwait(false));
                    if (existing.FileGroup is null)
                        existing.FileGroup = await schemaRepo.GetFileGroupAsync(server, database, existing.Schema, existing.Name, ct).ConfigureAwait(false);
                }
                catch { /* best-effort enrichment */ }
            }

            // Programmable objects (views, sps, functions, sequences) for the same DB.
            var programmableNodes = new List<DbObjectNode>();
            try
            {
                var progs = await schemaRepo.ListProgrammableObjectsAsync(server, database, ct).ConfigureAwait(false);
                var existingProg = new HashSet<string>(
                    primary.Objects.Where(o => o.Type != DbObjectType.Table)
                                   .Select(o => $"{o.Schema}.{o.Name}".ToLowerInvariant()),
                    StringComparer.OrdinalIgnoreCase);

                await Parallel.ForEachAsync(progs,
                    new ParallelOptions { CancellationToken = ct, MaxDegreeOfParallelism = options.MaxParallelDatabaseQueries },
                    async (p, c) =>
                    {
                        if (existingProg.Contains($"{p.Schema}.{p.Name}".ToLowerInvariant())) return;
                        var node = new DbObjectNode
                        {
                            ServerName = server,
                            DatabaseName = database,
                            Schema = p.Schema,
                            Name   = p.Name,
                            Type   = ObjectMetadataRepo.MapType(p.TypeDesc),
                            AccessKind = AccessKind.Unknown
                        };
                        try
                        {
                            var identity = await objRepo.ResolveAsync(server, database, p.Schema, p.Name, c)
                                .ConfigureAwait(false);
                            if (identity is not null) node.Definition = identity.Definition;
                        }
                        catch { /* best-effort definition pull */ }
                        lock (programmableNodes) programmableNodes.Add(node);
                    }).ConfigureAwait(false);

                programmableNodes.Sort((a, b) =>
                {
                    var c = a.Type.CompareTo(b.Type);
                    return c != 0 ? c
                        : string.Compare(a.QualifiedName, b.QualifiedName, StringComparison.OrdinalIgnoreCase);
                });
            }
            catch (Exception ex)
            {
                foreach (var c in conns) c.Issues.Add($"Could not list programmable objects in {database}: {ex.Message}");
            }

            // Attach to *every* connection pointing at this DB, but dedup per-connection
            // so secondary connections that already have task-driven nodes don't double up.
            foreach (var c in conns)
            {
                var connHave = new HashSet<string>(
                    c.Objects.Select(o => $"{o.Schema}.{o.Name}".ToLowerInvariant()),
                    StringComparer.OrdinalIgnoreCase);
                foreach (var tn in tableNodes)
                    if (connHave.Add($"{tn.Schema}.{tn.Name}".ToLowerInvariant()))
                        c.Objects.Add(tn);
                foreach (var pn in programmableNodes)
                    if (connHave.Add($"{pn.Schema}.{pn.Name}".ToLowerInvariant()))
                        c.Objects.Add(pn);
            }
            doneDbs++;
        }
    }

    private async Task<DbObjectNode?> BuildObjectNodeAsync(
        string server, string database, string schema, string name,
        AccessKind access,
        ObjectMetadataRepo objRepo, TableMetricsRepo tblRepo, IndexRepo idxRepo,
        TableSchemaRepo schemaRepo,
        AnalysisOptions options,
        HashSet<string> recursionVisited,
        int currentDepth,
        HashSet<string> linkedServerHopsVisited,
        CancellationToken ct)
    {
        var nodeKey = $"{server}|{database}|{schema}|{name}".ToLowerInvariant();
        if (!recursionVisited.Add(nodeKey)) return null;

        var node = new DbObjectNode
        {
            ServerName = server,
            DatabaseName = database,
            Schema = schema,
            Name = name,
            AccessKind = access
        };

        ObjectMetadataRepo.ObjectIdentity? identity;
        try
        {
            identity = await objRepo.ResolveAsync(server, database, schema, name, ct).ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            node.Status = ResolutionStatus.Unreachable;
            node.Issue = ex.Message;
            return node;
        }

        if (identity is null)
        {
            node.Status = ResolutionStatus.NotFound;
            return node;
        }

        node.Type = identity.Type;
        node.Definition = identity.Definition;

        if (identity.Type == DbObjectType.Synonym && identity.Synonym is { } syn)
        {
            var targetServer = string.IsNullOrWhiteSpace(syn.Server) ? server : syn.Server!;
            var targetDb     = string.IsNullOrWhiteSpace(syn.Database) ? database : syn.Database!;
            var hopKey = targetServer.ToLowerInvariant();
            if (!targetServer.Equals(server, StringComparison.OrdinalIgnoreCase))
            {
                if (linkedServerHopsVisited.Count >= options.LinkedServerHopLimit)
                {
                    node.Issue = "Linked-server hop limit reached";
                    return node;
                }
                if (!linkedServerHopsVisited.Add(hopKey))
                {
                    node.Issue = "Linked-server cycle detected";
                    return node;
                }
            }
            try
            {
                node.SynonymTarget = await BuildObjectNodeAsync(targetServer, targetDb,
                    syn.Schema, syn.Name, access, objRepo, tblRepo, idxRepo, schemaRepo, options,
                    recursionVisited, currentDepth, linkedServerHopsVisited, ct).ConfigureAwait(false);
            }
            catch (Exception ex)
            {
                node.Issue = "Synonym target unreachable: " + ex.Message;
            }
            return node;
        }

        if (identity.Type == DbObjectType.Table)
        {
            try
            {
                node.TableMetrics = await tblRepo.GetAsync(server, database, schema, name, ct).ConfigureAwait(false);
                node.Indexes.AddRange(await idxRepo.GetAsync(server, database, schema, name, ct).ConfigureAwait(false));
                node.Columns.AddRange(await schemaRepo.GetColumnsAsync(server, database, schema, name, ct).ConfigureAwait(false));
                node.ForeignKeys.AddRange(await schemaRepo.GetForeignKeysAsync(server, database, schema, name, ct).ConfigureAwait(false));
                node.FileGroup = await schemaRepo.GetFileGroupAsync(server, database, schema, name, ct).ConfigureAwait(false);
                if (node.TableMetrics is { IsPartitioned: true })
                    node.Partitions.AddRange(
                        await tblRepo.GetPartitionsAsync(server, database, schema, name, ct).ConfigureAwait(false));
            }
            catch (Exception ex)
            {
                node.Issue = "Metrics error: " + ex.Message;
            }
        }
        else if (identity.Type is DbObjectType.View or DbObjectType.StoredProcedure or DbObjectType.Function)
        {
            var shouldRecurse = options.RecurseUntilFixedPoint ||
                                currentDepth + 1 < options.MaxRecursionDepth;
            if (shouldRecurse && !string.IsNullOrEmpty(identity.Definition))
            {
                var ex = new SqlObjectExtractor();
                foreach (var r in ex.Extract(identity.Definition, out _))
                {
                    var childServer = string.IsNullOrWhiteSpace(r.Server) ? server : r.Server!;
                    var childDb     = string.IsNullOrWhiteSpace(r.Database) ? database : r.Database!;
                    var child = await BuildObjectNodeAsync(childServer, childDb, r.Schema, r.Name,
                        r.Access, objRepo, tblRepo, idxRepo, schemaRepo, options,
                        new HashSet<string>(recursionVisited), currentDepth + 1,
                        new HashSet<string>(linkedServerHopsVisited), ct).ConfigureAwait(false);
                    if (child is not null) node.Children.Add(child);
                }
            }
        }
        return node;
    }
}




