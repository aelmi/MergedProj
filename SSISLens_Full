    public string Extension => ".xlsx";

    // Tab colors so the structure of the workbook reads at a glance:
    //   - Grouped/hierarchical sheets (drillable outline)  → deep blue
    //   - Flat reference sheets (simple grids for filter/pivot) → muted grey-blue
    private static readonly XLColor GroupedTabColor = XLColor.FromHtml("#0D47A1");
    private static readonly XLColor FlatTabColor    = XLColor.FromHtml("#90A4AE");

    public Task WriteAsync(AnalysisResult result, string path, CancellationToken ct = default)
    {
        // Anchor maps: lowercase "server|database|schema|name" → cell address.
        // Built while writing Schema and Definitions, consumed by Objects and Indexes.
        var schemaAnchors = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        var defAnchors    = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        using var wb = new XLWorkbook();

        // Workbook-level metadata — describes the analyzed content only.
        // Intentionally NO Author / Company so the output carries no tool footprint.
        var sourceName = string.IsNullOrEmpty(result.SourcePath)
            ? "(unknown)"
            : System.IO.Path.GetFileName(result.SourcePath.TrimEnd('/', '\\'));
        wb.Properties.Title    = $"SSIS analysis of {sourceName}";
        wb.Properties.Subject  = result.SourcePath ?? "";
        wb.Properties.Keywords = "SSIS, dtsx, analysis, dependencies";
        wb.Properties.Comments =
            $"Analyzed {result.Packages.Count} package(s), " +
            $"{result.AllConnections.Count()} connection(s), " +
            $"{result.AllObjects.Count()} object(s) in {result.Duration?.TotalSeconds:F1}s.";

        WriteServers(wb, result);
        WritePackages(wb, result);
        WriteSchemaGrouped(wb, result, schemaAnchors);
        WriteDatabases(wb, result);
        WriteConnections(wb, result);
        WriteDefinitions(wb, result, defAnchors);   // written early so Objects can link into it
        WriteObjects(wb, result, schemaAnchors, defAnchors);
        WriteIndexes(wb, result, schemaAnchors);
        WriteForeignKeys(wb, result);
        WritePartitions(wb, result);

        // Visible sheet order — Definitions slides to the end even though it was written earlier
        var order = new[] { "Servers", "Packages", "Schema", "Databases", "Connections",
                            "Objects", "Indexes", "ForeignKeys", "Partitions", "Definitions" };
        for (var i = 0; i < order.Length; i++)
            wb.Worksheet(order[i]).Position = i + 1;

        // Tab colors
        foreach (var name in new[] { "Packages", "Schema", "Objects", "Indexes" })
            wb.Worksheet(name).TabColor = GroupedTabColor;
        foreach (var name in new[] { "Servers", "Databases", "Connections",
                                     "ForeignKeys", "Partitions", "Definitions" })
            wb.Worksheet(name).TabColor = FlatTabColor;

        // Start the drillable sheets collapsed so users see the high-level structure first.
        // Levels: 0 = always visible header band (database / package / connection),
        //         1 = the headline objects (table / connection / package),
        //         2+ = sub-groups and items.
        CollapseToLevel(wb.Worksheet("Schema"),   maxVisibleLevel: 1);
        CollapseToLevel(wb.Worksheet("Packages"), maxVisibleLevel: 0);
        CollapseToLevel(wb.Worksheet("Objects"),  maxVisibleLevel: 1);

        wb.SaveAs(path);
        return Task.CompletedTask;
    }

    /// <summary>
    /// Hide every row whose OutlineLevel exceeds <paramref name="maxVisibleLevel"/>.
    /// Excel paints the gutter [+] button automatically on the visible summary row
    /// above each hidden group (we set SummaryVLocation = Top earlier).
    /// </summary>
    private static void CollapseToLevel(IXLWorksheet ws, int maxVisibleLevel)
    {
        foreach (var row in ws.RowsUsed())
            if (row.OutlineLevel > maxVisibleLevel)
                row.Hide();
    }

    private static string AnchorKey(string server, string database, string schema, string name) =>
        $"{server}|{database}|{schema}|{name}".ToLowerInvariant();

    private static string AnchorKey(DbObjectNode n) =>
        AnchorKey(n.ServerName, n.DatabaseName, n.Schema, n.Name);

    // ──────────────────────────────────────────────────────────────────────
    // Grouped (SSMS-style) sheet — Server → Database → Table → Columns/Indexes/FKs
    // Uses Excel Outline groups: a [-]/[+] button appears in the row gutter
    // next to each summary row. Top-summary so the parent row is above its detail.
    // ──────────────────────────────────────────────────────────────────────
    private static void WriteSchemaGrouped(XLWorkbook wb, AnalysisResult r,
        IDictionary<string, string> schemaAnchors)
    {
        var ws = wb.AddWorksheet("Schema");
        ws.Outline.SummaryVLocation = XLOutlineSummaryVLocation.Top;
        ws.Outline.SummaryHLocation = XLOutlineSummaryHLocation.Left;

        // Header — keep simple; columns are reused for every kind of row.
        var headers = new[]
        {
            "Name", "Kind", "Details", "Nullable",
            "Rows", "Reserved (MB)", "Data (MB)", "Index (MB)", "Unused (MB)",
            "FileGroup", "References / Default / Notes"
        };
        for (var i = 0; i < headers.Length; i++) ws.Cell(1, i + 1).Value = headers[i];
        var headerRange = ws.Range(1, 1, 1, headers.Length);
        headerRange.Style.Fill.BackgroundColor = XLColor.FromHtml("#0D47A1");
        headerRange.Style.Font.FontColor = XLColor.White;
        headerRange.Style.Font.Bold = true;
        ws.SheetView.FreezeRows(1);

        var row = 2;

        // Group rows under (server, database). The "all objects" iteration may
        // include the same table reached through multiple connections — dedupe
        // by (Server, Database, Schema, Name) to avoid showing it twice.
        var byDb = r.Packages
            .SelectMany(p => p.Connections)
            .SelectMany(c => c.Objects)
            .GroupBy(o => new { o.ServerName, o.DatabaseName });

        foreach (var dbg in byDb.OrderBy(g => g.Key.ServerName).ThenBy(g => g.Key.DatabaseName))
        {
            // ── Database row (level 0 — always visible) ─────────────────
            ws.Cell(row, 1).Value = $"[{dbg.Key.ServerName}].[{dbg.Key.DatabaseName}]";
            ws.Cell(row, 2).Value = "Database";
            ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.FromHtml("#E3F0FF");
            ws.Range(row, 1, row, headers.Length).Style.Font.Bold = true;
            row++;

            var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            var tables = dbg.Where(o => o.Type == DbObjectType.Table)
                            .Where(o => seen.Add($"{o.Schema}.{o.Name}"))
                            .OrderByDescending(o => o.TableMetrics?.RowCount ?? 0)
                            .ToList();
            foreach (var t in tables)
            {
                schemaAnchors[AnchorKey(t)] = $"Schema!A{row}";
                row = WriteTableBlock(ws, row, t);
            }

            // Programmable objects: views, sps, functions — definition as a child row
            seen.Clear();
            var progs = dbg.Where(o => o.Type is DbObjectType.View
                                           or DbObjectType.StoredProcedure
                                           or DbObjectType.Function
                                           or DbObjectType.Sequence)
                            .Where(o => seen.Add($"{o.Schema}.{o.Name}"))
                            .OrderBy(o => o.Type).ThenBy(o => o.QualifiedName)
                            .ToList();
            foreach (var p in progs)
            {
                schemaAnchors[AnchorKey(p)] = $"Schema!A{row}";
                row = WriteProgrammableBlock(ws, row, p);
            }
        }

        // Column widths — last col (definitions / notes) needs to be wide.
        ws.Column(1).Width = 50;
        ws.Column(2).Width = 16;
        ws.Column(3).Width = 28;
        ws.Column(4).Width = 10;
        for (var i = 5; i <= 9; i++) ws.Column(i).Width = 14;
        ws.Column(10).Width = 14;
        ws.Column(11).Width = 80;
        ws.Column(11).Style.Alignment.WrapText = true;
    }

    private static int WriteTableBlock(IXLWorksheet ws, int row, DbObjectNode t)
    {
        // Table summary row — Outline level 1, collapsed by default.
        var m = t.TableMetrics;
        ws.Cell(row, 1).Value = "  " + t.QualifiedName;
        ws.Cell(row, 2).Value = "Table";
        ws.Cell(row, 3).Value = $"{t.Columns.Count} cols · {t.Indexes.Count} idx · {t.ForeignKeys.Count} fk";
        ws.Cell(row, 5).Value = m?.RowCount ?? 0;
        ws.Cell(row, 6).Value = Math.Round((m?.TotalReservedKB ?? 0) / 1024.0, 1);
        ws.Cell(row, 7).Value = Math.Round((m?.DataKB ?? 0) / 1024.0, 1);
        ws.Cell(row, 8).Value = Math.Round((m?.IndexKB ?? 0) / 1024.0, 1);
        ws.Cell(row, 9).Value = Math.Round((m?.UnusedKB ?? 0) / 1024.0, 1);
        ws.Cell(row,10).Value = t.FileGroup ?? "";
        ws.Range(row, 1, row, 11).Style.Font.Bold = true;
        ws.Range(row, 1, row, 11).Style.Fill.BackgroundColor = XLColor.FromHtml("#F4F7FB");
        ws.Row(row).OutlineLevel = 1;
        var tableRow = row;
        row++;

        if (t.Columns.Count > 0)
        {
            ws.Cell(row, 1).Value = "      Columns";
            ws.Cell(row, 2).Value = "(group)";
            ws.Cell(row, 3).Value = $"{t.Columns.Count} columns";
            ws.Range(row, 1, row, 11).Style.Font.Italic = true;
            ws.Row(row).OutlineLevel = 2;
            row++;
            foreach (var c in t.Columns)
            {
                var tags = new List<string>();
                if (c.IsPrimaryKey) tags.Add("PK");
                if (c.IsIdentity)   tags.Add("IDENTITY");
                if (c.IsComputed)   tags.Add("COMPUTED");
                ws.Cell(row, 1).Value = "        " + c.Name;
                ws.Cell(row, 2).Value = "Column";
                ws.Cell(row, 3).Value = c.FormattedType + (tags.Count > 0 ? "  [" + string.Join(",", tags) + "]" : "");
                ws.Cell(row, 4).Value = c.IsNullable ? "yes" : "no";
                ws.Cell(row,11).Value =
                    (c.DefaultDefinition is null ? "" : "DEFAULT " + c.DefaultDefinition) +
                    (c.ComputedDefinition is null ? "" : (string.IsNullOrEmpty(c.DefaultDefinition) ? "" : " | ") + "COMPUTED " + c.ComputedDefinition) +
                    (c.Collation is null ? "" : "  collation: " + c.Collation);
                ws.Row(row).OutlineLevel = 3;
                row++;
            }
        }

        if (t.Indexes.Count > 0)
        {
            ws.Cell(row, 1).Value = "      Indexes";
            ws.Cell(row, 2).Value = "(group)";
            ws.Cell(row, 3).Value = $"{t.Indexes.Count} indexes";
            ws.Range(row, 1, row, 11).Style.Font.Italic = true;
            ws.Row(row).OutlineLevel = 2;
            row++;
            foreach (var i in t.Indexes)
            {
                ws.Cell(row, 1).Value = "        " + i.Name;
                ws.Cell(row, 2).Value = "Index";
                ws.Cell(row, 3).Value = i.Type
                    + (i.IsPrimaryKey ? "  [PK]" : i.IsUnique ? "  [UQ]" : "");
                ws.Cell(row, 5).Value = i.RowCount;
                ws.Cell(row, 6).Value = Math.Round(i.ReservedKB / 1024.0, 1);
                ws.Cell(row,11).Value = "key(" + string.Join(", ", i.KeyColumns) + ")"
                    + (i.IncludedColumns.Count > 0 ? "  include(" + string.Join(", ", i.IncludedColumns) + ")" : "")
                    + (string.IsNullOrEmpty(i.FilterDefinition) ? "" : "  WHERE " + i.FilterDefinition);
                ws.Row(row).OutlineLevel = 3;
                row++;
            }
        }

        if (t.ForeignKeys.Count > 0)
        {
            ws.Cell(row, 1).Value = "      Foreign Keys";
            ws.Cell(row, 2).Value = "(group)";
            ws.Cell(row, 3).Value = $"{t.ForeignKeys.Count} FKs";
            ws.Range(row, 1, row, 11).Style.Font.Italic = true;
            ws.Row(row).OutlineLevel = 2;
            row++;
            foreach (var fk in t.ForeignKeys)
            {
                ws.Cell(row, 1).Value = "        " + fk.Name;
                ws.Cell(row, 2).Value = "FK";
                ws.Cell(row, 3).Value = $"({string.Join(", ", fk.ParentColumns)}) → [{fk.ReferencedSchema}].[{fk.ReferencedTable}] ({string.Join(", ", fk.ReferencedColumns)})";
                ws.Cell(row,11).Value =
                    $"ON DELETE {fk.DeleteAction}, ON UPDATE {fk.UpdateAction}"
                    + (fk.IsDisabled ? "  DISABLED" : "")
                    + (fk.IsNotTrusted ? "  NOT TRUSTED" : "");
                ws.Row(row).OutlineLevel = 3;
                row++;
            }
        }

        if (t.Partitions.Count > 0)
        {
            ws.Cell(row, 1).Value = "      Partitions";
            ws.Cell(row, 2).Value = "(group)";
            ws.Cell(row, 3).Value = $"{t.Partitions.Count} partitions";
            ws.Range(row, 1, row, 11).Style.Font.Italic = true;
            ws.Row(row).OutlineLevel = 2;
            row++;
            foreach (var p in t.Partitions)
            {
                ws.Cell(row, 1).Value = $"        #{p.PartitionNumber}";
                ws.Cell(row, 2).Value = "Partition";
                ws.Cell(row, 3).Value = $"≤ {p.BoundaryValue ?? "(MAX)"}  [{p.BoundaryComparator}]";
                ws.Cell(row, 5).Value = p.RowCount;
                ws.Cell(row, 6).Value = Math.Round(p.TotalKB / 1024.0, 1);
                ws.Cell(row, 7).Value = Math.Round(p.DataKB / 1024.0, 1);
                ws.Cell(row, 8).Value = Math.Round(p.IndexKB / 1024.0, 1);
                ws.Cell(row,10).Value = p.FileGroup ?? "";
                ws.Row(row).OutlineLevel = 3;
                row++;
            }
        }

        return row;
    }

    private static int WriteProgrammableBlock(IXLWorksheet ws, int row, DbObjectNode o)
    {
        ws.Cell(row, 1).Value = "  " + o.QualifiedName;
        ws.Cell(row, 2).Value = o.Type.ToString();
        ws.Cell(row, 3).Value = o.ReferencedByTasks.Count > 0
            ? "used by: " + string.Join(", ", o.ReferencedByTasks)
            : "";
        ws.Range(row, 1, row, 11).Style.Font.Bold = true;
        ws.Range(row, 1, row, 11).Style.Fill.BackgroundColor = XLColor.FromHtml("#FFF8E1");
        ws.Row(row).OutlineLevel = 1;
        row++;

        if (!string.IsNullOrWhiteSpace(o.Definition))
        {
            ws.Cell(row, 1).Value = "      Definition";
            ws.Cell(row, 2).Value = "(group)";
            ws.Cell(row, 3).Value = $"{o.Definition.Length:N0} chars";
            ws.Range(row, 1, row, 11).Style.Font.Italic = true;
            ws.Row(row).OutlineLevel = 2;
            row++;

            var defChunks = ChunkForCell(o.Definition).ToList();
            for (var i = 0; i < defChunks.Count; i++)
            {
                if (i == 0)
                {
                    ws.Cell(row, 1).Value = "        SQL";
                    ws.Cell(row, 2).Value = "Definition";
                }
                ws.Cell(row, 11).Value = defChunks[i];
                ws.Cell(row, 11).Style.Alignment.WrapText = true;
                ws.Row(row).OutlineLevel = 3;
                ws.Row(row).Height = Math.Min(400, 20 * Math.Min(20, defChunks[i].Count(ch => ch == '\n') + 1));
                row++;
            }
        }

        return row;
    }

    // ──────────────────────────────────────────────────────────────────────
    // Flat sheets (kept for filter/pivot use)
    // ──────────────────────────────────────────────────────────────────────
    private static void WriteServers(XLWorkbook wb, AnalysisResult r)
    {
        var ws = wb.AddWorksheet("Servers");
        // #2: Status column removed
        var headers = new[] { "Server", "Version", "Edition", "MaxDOP", "CostThresholdParallelism", "Issue" };
        for (var i = 0; i < headers.Length; i++) ws.Cell(1, i + 1).Value = headers[i];
        var row = 2;
        foreach (var s in r.Servers)
        {
            ws.Cell(row, 1).Value = s.Name;
            ws.Cell(row, 2).Value = s.ProductVersion ?? "";
            ws.Cell(row, 3).Value = s.Edition ?? "";
            ws.Cell(row, 4).Value = s.MaxDop ?? 0;
            ws.Cell(row, 5).Value = s.CostThresholdForParallelism ?? 0;
            ws.Cell(row, 6).Value = s.Issue ?? "";
            row++;
        }
        Format(ws, headers.Length);
    }

    // #3: Packages sheet — one collapsible block per package with metadata,
    // parameters, variables, connections, and tasks (with full SQL text).
    private static void WritePackages(XLWorkbook wb, AnalysisResult r)
    {
        var ws = wb.AddWorksheet("Packages");
        ws.Outline.SummaryVLocation = XLOutlineSummaryVLocation.Top;

        var headers = new[] { "Item", "Kind", "Value / Detail", "Notes" };
        for (var i = 0; i < headers.Length; i++) ws.Cell(1, i + 1).Value = headers[i];
        var header = ws.Range(1, 1, 1, headers.Length);
        header.Style.Fill.BackgroundColor = XLColor.FromHtml("#0D47A1");
        header.Style.Font.FontColor = XLColor.White;
        header.Style.Font.Bold = true;
        ws.SheetView.FreezeRows(1);

        var row = 2;
        foreach (var p in r.Packages)
        {
            // Package header — always visible (level 0). Show just the file name; the
            // full path lives in the Source sub-group below.
            ws.Cell(row, 1).Value = p.Name;
            ws.Cell(row, 2).Value = "Package";
            ws.Cell(row, 3).Value = string.IsNullOrEmpty(p.Path)
                ? ""
                : System.IO.Path.GetFileName(p.Path);
            ws.Cell(row, 4).Value = $"{p.Connections.Count} connections · {p.Tasks.Count} tasks · {p.Parameters.Count} params · {p.Variables.Count} vars";
            ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.FromHtml("#E3F0FF");
            ws.Range(row, 1, row, headers.Length).Style.Font.Bold = true;
            row++;

            // Metadata sub-group
            ws.Cell(row, 1).Value = "    Metadata";
            ws.Cell(row, 2).Value = "(group)";
            ws.Range(row, 1, row, headers.Length).Style.Font.Italic = true;
            ws.Row(row).OutlineLevel = 1;
            row++;
            void Meta(string label, string? value)
            {
                ws.Cell(row, 1).Value = "        " + label;
                ws.Cell(row, 2).Value = "meta";
                ws.Cell(row, 3).Value = value ?? "";
                ws.Row(row).OutlineLevel = 2;
                row++;
            }
            Meta("Version",         p.Version);
            Meta("Creator",         p.CreatorName);
            Meta("Created",         p.CreationDate);
            Meta("ProtectionLevel", p.ProtectionLevel);

            if (p.Parameters.Count > 0)
            {
                ws.Cell(row, 1).Value = "    Parameters";
                ws.Cell(row, 2).Value = "(group)";
                ws.Cell(row, 3).Value = $"{p.Parameters.Count} parameters";
                ws.Range(row, 1, row, headers.Length).Style.Font.Italic = true;
                ws.Row(row).OutlineLevel = 1;
                row++;
                foreach (var pr in p.Parameters)
                {
                    ws.Cell(row, 1).Value = "        " + pr.Scope + "::" + pr.Name;
                    ws.Cell(row, 2).Value = pr.DataType ?? "";
                    ws.Cell(row, 3).Value = pr.Sensitive ? "********" : (pr.Value ?? "");
                    ws.Cell(row, 4).Value = pr.Sensitive ? "Sensitive" : "";
                    ws.Row(row).OutlineLevel = 2;
                    row++;
                }
            }

            if (p.Variables.Count > 0)
            {
                ws.Cell(row, 1).Value = "    Variables";
                ws.Cell(row, 2).Value = "(group)";
                ws.Cell(row, 3).Value = $"{p.Variables.Count} variables";
                ws.Range(row, 1, row, headers.Length).Style.Font.Italic = true;
                ws.Row(row).OutlineLevel = 1;
                row++;
                foreach (var v in p.Variables)
                {
                    ws.Cell(row, 1).Value = "        " + v.FullName;
                    ws.Cell(row, 2).Value = v.DataType ?? "";
                    ws.Cell(row, 3).Value = v.Value ?? "";
                    ws.Cell(row, 4).Value = v.Expression ?? "";
                    ws.Row(row).OutlineLevel = 2;
                    row++;
                }
            }

            if (p.Connections.Count > 0)
            {
                ws.Cell(row, 1).Value = "    Connections";
                ws.Cell(row, 2).Value = "(group)";
                ws.Cell(row, 3).Value = $"{p.Connections.Count} connections";
                ws.Range(row, 1, row, headers.Length).Style.Font.Italic = true;
                ws.Row(row).OutlineLevel = 1;
                row++;
                foreach (var c in p.Connections)
                {
                    ws.Cell(row, 1).Value = "        " + c.Name;
                    ws.Cell(row, 2).Value = c.Provider.ToString();
                    ws.Cell(row, 3).Value = $"{c.Server}/{c.Database}  [{c.Auth}]";
                    ws.Cell(row, 4).Value = c.MaskedConnectionString ?? "";
                    ws.Row(row).OutlineLevel = 2;
                    row++;
                }
            }

            if (p.Tasks.Count > 0)
            {
                ws.Cell(row, 1).Value = "    Tasks";
                ws.Cell(row, 2).Value = "(group)";
                ws.Cell(row, 3).Value = $"{p.Tasks.Count} tasks";
                ws.Range(row, 1, row, headers.Length).Style.Font.Italic = true;
                ws.Row(row).OutlineLevel = 1;
                row++;
                foreach (var t in p.Tasks)
                {
                    ws.Cell(row, 1).Value = "        " + t.Name;
                    ws.Cell(row, 2).Value = t.CreationName;
                    ws.Cell(row, 3).Value = t.ConnectionName ?? "";
                    ws.Row(row).OutlineLevel = 2;
                    row++;
                    if (!string.IsNullOrWhiteSpace(t.Sql))
                    {
                        var sqlChunks = ChunkForCell(t.Sql).ToList();
                        for (var i = 0; i < sqlChunks.Count; i++)
                        {
                            if (i == 0)
                            {
                                ws.Cell(row, 1).Value = "            SQL";
                                ws.Cell(row, 2).Value = "T-SQL";
                            }
                            ws.Cell(row, 3).Value = sqlChunks[i];
                            ws.Cell(row, 3).Style.Alignment.WrapText = true;
                            ws.Cell(row, 3).Style.Font.FontName = "Consolas";
                            ws.Row(row).Height = Math.Min(300, 18 * Math.Min(15, sqlChunks[i].Count(ch => ch == '\n') + 1));
                            ws.Row(row).OutlineLevel = 3;
                            row++;
                        }
                    }
                }
            }

            // Source — the actual .dtsx file content (XML). Lets you grep the full
            // package without leaving the export. Excel's 32 767 char cell limit
            // truncates very large packages.
            ws.Cell(row, 1).Value = "    Source";
            ws.Cell(row, 2).Value = "(group)";
            ws.Cell(row, 3).Value = "Path + raw .dtsx XML";
            ws.Range(row, 1, row, headers.Length).Style.Font.Italic = true;
            ws.Row(row).OutlineLevel = 1;
            row++;

            ws.Cell(row, 1).Value = "        Path";
            ws.Cell(row, 2).Value = "meta";
            ws.Cell(row, 3).Value = p.Path ?? "";
            ws.Row(row).OutlineLevel = 2;
            row++;

            try
            {
                if (!string.IsNullOrEmpty(p.Path) && System.IO.File.Exists(p.Path))
                {
                    var xml = System.IO.File.ReadAllText(p.Path);
                    var bytes = new System.IO.FileInfo(p.Path).Length;
                    var truncated = false;
                    const int maxCell = 32_000;
                    if (xml.Length > maxCell)
                    {
                        xml = xml.Substring(0, maxCell) + "\n\n… [truncated — file is " + bytes + " bytes total]";
                        truncated = true;
                    }
                    ws.Cell(row, 1).Value = "        XML";
                    ws.Cell(row, 2).Value = truncated ? "Source (truncated)" : "Source";
                    ws.Cell(row, 3).Value = xml;
                    ws.Cell(row, 3).Style.Alignment.WrapText = true;
                    ws.Cell(row, 3).Style.Alignment.Vertical = XLAlignmentVerticalValues.Top;
                    ws.Cell(row, 3).Style.Font.FontName = "Consolas";
                    ws.Cell(row, 4).Value = $"{bytes:N0} bytes";
                    ws.Row(row).Height = 400;
                    ws.Row(row).OutlineLevel = 2;
                    row++;
                }
                else
                {
                    ws.Cell(row, 1).Value = "        XML";
                    ws.Cell(row, 2).Value = "Source";
                    ws.Cell(row, 3).Value = "(source file not accessible)";
                    ws.Row(row).OutlineLevel = 2;
                    row++;
                }
            }
            catch (Exception ex)
            {
                ws.Cell(row, 1).Value = "        XML";
                ws.Cell(row, 2).Value = "Source";
                ws.Cell(row, 3).Value = "(could not read: " + ex.Message + ")";
                ws.Row(row).OutlineLevel = 2;
                row++;
            }
        }

        ws.Column(1).Width = 50;
        ws.Column(2).Width = 18;
        ws.Column(3).Width = 80;
        ws.Column(3).Style.Alignment.WrapText = true;
        ws.Column(4).Width = 40;
    }

    private static void WriteDatabases(XLWorkbook wb, AnalysisResult r)
    {
        var ws = wb.AddWorksheet("Databases");
        // Status column dropped
