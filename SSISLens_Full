    }

    private static void WriteDefinitions(XLWorkbook wb, AnalysisResult r,
        IDictionary<string, string> defAnchors)
    {
        var ws = wb.AddWorksheet("Definitions");
        var headers = new[] { "Server", "Database", "Schema", "Object", "Type", "Definition" };
        for (var i = 0; i < headers.Length; i++) ws.Cell(1, i + 1).Value = headers[i];
        var row = 2;
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var n in r.AllObjects)
        {
            if (string.IsNullOrWhiteSpace(n.Definition)) continue;
            var key = AnchorKey(n);
            if (!seen.Add(key)) continue;
            defAnchors[key] = $"Definitions!A{row}";
            var chunks = ChunkForCell(n.Definition).ToList();
            for (var i = 0; i < chunks.Count; i++)
            {
                if (i == 0)
                {
                    ws.Cell(row, 1).Value = n.ServerName;
                    ws.Cell(row, 2).Value = n.DatabaseName;
                    ws.Cell(row, 3).Value = n.Schema;
                    ws.Cell(row, 4).Value = n.Name;
                    ws.Cell(row, 5).Value = n.Type.ToString();
                }
                ws.Cell(row, 6).Value = chunks[i];
                ws.Cell(row, 6).Style.Alignment.WrapText = true;
                row++;
            }
        }
        Format(ws, headers.Length);
        ws.Column(6).Width = 100;
    }

    private static void Format(IXLWorksheet ws, int cols)
    {
        var headerRange = ws.Range(1, 1, 1, cols);
        headerRange.Style.Fill.BackgroundColor = XLColor.FromHtml("#0D47A1");
        headerRange.Style.Font.FontColor = XLColor.White;
        headerRange.Style.Font.Bold = true;
        ws.SheetView.FreezeRows(1);
        ws.RangeUsed()?.SetAutoFilter();
        ws.Columns().AdjustToContents();
    }

    // Excel hard-limits a cell to 32,767 chars. Split long text into chunks
    // that fit, breaking on the last newline within each window so SQL/XML
    // stays readable across rows. Callers write each chunk on its own row.
    private static IEnumerable<string> ChunkForCell(string text, int maxLen = 32_000)
    {
        var start = 0;
        while (start < text.Length)
        {
            var remaining = text.Length - start;
            if (remaining <= maxLen)
            {
                yield return text.Substring(start);
                yield break;
            }
            var lastNl = text.LastIndexOf('\n', start + maxLen - 1, maxLen);
            var len = (lastNl > start) ? (lastNl - start + 1) : maxLen;
            yield return text.Substring(start, len);
            start += len;
        }
    }

    private static IEnumerable<DbObjectNode> Flatten(IEnumerable<DbObjectNode> nodes)
    {
        foreach (var n in nodes)
        {
            yield return n;
            if (n.SynonymTarget is not null)
                foreach (var x in Flatten(new[] { n.SynonymTarget })) yield return x;
            foreach (var c in Flatten(n.Children)) yield return c;
        }
    }
