using System.Text;
using SSISLens.Core;

namespace SSISLens.UI;

internal static class DetailsRenderer
{
    public static (string Overview, string Indexes, string Partitions, string Definition, string Provenance)
        Render(object? tag, AnalysisResult result)
    {
        switch (tag)
        {
            case PackageInfo p:        return RenderPackage(p, result);
            case ConnectionInfo c:     return RenderConnection(c);
            case DbObjectNode o:       return RenderObject(o);
            case IndexInfo i:          return ("", FormatIndex(i), "", "", "");
            case PartitionInfo pi:     return ("", "", FormatPartition(pi), "", "");
            case ColumnInfo col:       return (FormatColumn(col), "", "", "", "");
            case ForeignKeyInfo fk:    return (FormatForeignKey(fk), "", "", "", "");
            default:                   return (RenderSummary(result), RenderAllIndexesGrouped(result.AllObjects), "", "", "");
        }
    }

    private static string RenderSummary(AnalysisResult r)
    {
        var sb = new StringBuilder();
        sb.AppendLine("=== SSISLens summary ===");
        sb.AppendLine($"Source:      {r.SourcePath}");
        sb.AppendLine($"Packages:    {r.Packages.Count}");
        sb.AppendLine($"Connections: {r.AllConnections.Count()}");
        sb.AppendLine($"Objects:     {r.AllObjects.Count()}");
        sb.AppendLine($"Servers:     {r.Servers.Count}");
        sb.AppendLine($"Databases:   {r.Databases.Count}");
        sb.AppendLine($"Duration:    {r.Duration?.TotalSeconds:F1}s");
        sb.AppendLine();
        sb.AppendLine("Servers");
        sb.AppendLine("-------");
        foreach (var s in r.Servers)
            sb.AppendLine($"  {s.Name,-30} {s.ProductVersion,-15} MaxDOP={s.MaxDop} CostThr={s.CostThresholdForParallelism}");
        sb.AppendLine();
        sb.AppendLine("Databases");
        sb.AppendLine("---------");
        foreach (var d in r.Databases)
            sb.AppendLine($"  {d.FullName,-50} Compat={d.CompatibilityLevel} {d.RecoveryModel}  {((d.TotalSizeKB ?? 0) / 1024):N0} MB");
        if (r.Warnings.Count > 0)
        {
            sb.AppendLine();
            sb.AppendLine("Warnings");
            foreach (var w in r.Warnings) sb.AppendLine("  " + w);
        }
        return sb.ToString();
    }

    private static (string, string, string, string, string) RenderPackage(PackageInfo p, AnalysisResult r)
    {
        var sb = new StringBuilder();
        sb.AppendLine($"Package:    {p.Name}");
        sb.AppendLine($"Path:       {p.Path}");
        sb.AppendLine($"Version:    {p.Version}");
        sb.AppendLine($"Protection: {p.ProtectionLevel}");
        sb.AppendLine($"Creator:    {p.CreatorName}  ({p.CreationDate})");
        sb.AppendLine();
        sb.AppendLine($"Parameters: {p.Parameters.Count}");
        foreach (var pr in p.Parameters) sb.AppendLine($"  {pr.Scope}::{pr.Name} = {(pr.Sensitive ? "****" : pr.Value)}");
        sb.AppendLine();
        sb.AppendLine($"Variables:  {p.Variables.Count}");
        foreach (var v in p.Variables) sb.AppendLine($"  {v.FullName} ({v.DataType}) = {v.Value}{(string.IsNullOrEmpty(v.Expression) ? "" : $"  expr: {v.Expression}")}");
        sb.AppendLine();
        sb.AppendLine($"Connections: {p.Connections.Count}");
        sb.AppendLine($"Tasks:       {p.Tasks.Count}");

        var allPkgObjects = p.Connections.SelectMany(c => c.Objects);
        return (sb.ToString(), RenderAllIndexesGrouped(allPkgObjects), "", "", "");
    }

    private static (string, string, string, string, string) RenderConnection(ConnectionInfo c)
    {
        var sb = new StringBuilder();
        sb.AppendLine($"Connection:   {c.Name}");
        sb.AppendLine($"CreationName: {c.CreationName}");
        sb.AppendLine($"Provider:     {c.Provider}");
        sb.AppendLine($"Server:       {c.Server}");
        sb.AppendLine($"Database:     {c.Database}");
        sb.AppendLine($"Auth:         {c.Auth}");
        sb.AppendLine($"Masked:       {c.MaskedConnectionString}");
        if (c.Issues.Count > 0)
        {
            sb.AppendLine();
            sb.AppendLine("Issues");
            foreach (var i in c.Issues) sb.AppendLine("  - " + i);
        }
        sb.AppendLine();
        sb.AppendLine($"Objects: {c.Objects.Count}  " +
            $"(T={c.Objects.Count(o => o.Type == DbObjectType.Table)} " +
            $"V={c.Objects.Count(o => o.Type == DbObjectType.View)} " +
            $"P={c.Objects.Count(o => o.Type == DbObjectType.StoredProcedure)} " +
            $"F={c.Objects.Count(o => o.Type == DbObjectType.Function)})");
        if (c.Objects.Count > 0)
        {
            var tables = c.Objects.Where(o => o.Type == DbObjectType.Table).ToList();
            if (tables.Count > 0)
            {
                sb.AppendLine();
                sb.AppendLine("Tables");
                sb.AppendLine($"{"Schema.Name",-50} {"Rows",14} {"Reserved (MB)",14} {"Data (MB)",12} {"Index (MB)",12}  FileGroup");
                sb.AppendLine(new string('-', 130));
                foreach (var t in tables.OrderByDescending(t => t.TableMetrics?.RowCount ?? 0))
                {
                    var m = t.TableMetrics;
                    sb.AppendLine(
                        $"{Truncate(t.QualifiedName,50),-50} " +
                        $"{m?.RowCount ?? 0,14:N0} " +
                        $"{(m?.TotalReservedKB ?? 0) / 1024.0,14:N1} " +
                        $"{(m?.DataKB ?? 0) / 1024.0,12:N1} " +
                        $"{(m?.IndexKB ?? 0) / 1024.0,12:N1}  " +
                        $"{t.FileGroup ?? ""}");
                }
            }

            var progs = c.Objects.Where(o => o.Type is DbObjectType.View
                                              or DbObjectType.StoredProcedure
                                              or DbObjectType.Function
                                              or DbObjectType.Sequence).ToList();
            if (progs.Count > 0)
            {
                sb.AppendLine();
                sb.AppendLine("Programmable objects");
                sb.AppendLine($"{"Type",-20} {"Schema.Name",-60}  Used by");
                sb.AppendLine(new string('-', 110));
                foreach (var po in progs.OrderBy(o => o.Type).ThenBy(o => o.QualifiedName))
                    sb.AppendLine(
                        $"{po.Type,-20} {Truncate(po.QualifiedName,60),-60}  " +
                        $"{(po.ReferencedByTasks.Count > 0 ? string.Join(", ", po.ReferencedByTasks) : "")}");
            }
        }
        var prov = new StringBuilder();
        prov.AppendLine($"{"Source",-25} {"Property",-25} Value/Note");
        prov.AppendLine(new string('-', 100));
        foreach (var s in c.ProvenanceTrail)
        {
            prov.AppendLine($"{s.Source,-25} {s.Property,-25} {ConnectionStringMasker.Mask(s.Value)}");
            if (!string.IsNullOrEmpty(s.Note)) prov.AppendLine($"{"",-25} {"",-25}   ↳ {s.Note}");
        }
        return (sb.ToString(), RenderAllIndexesGrouped(c.Objects), "", "", prov.ToString());
    }

    private static (string, string, string, string, string) RenderObject(DbObjectNode o)
    {
        var sb = new StringBuilder();
        sb.AppendLine($"Object:    {o.FullName}");
        sb.AppendLine($"Type:      {o.Type}");
        sb.AppendLine($"Access:    {o.AccessKind}");
        if (o.Issue is not null) sb.AppendLine($"Issue:     {o.Issue}");
        if (o.FileGroup is not null) sb.AppendLine($"FileGroup: {o.FileGroup}");
        if (o.ReferencedByTasks.Count > 0)
            sb.AppendLine($"Used by:   {string.Join(", ", o.ReferencedByTasks)}");
        if (o.SynonymTarget is not null)
            sb.AppendLine($"Synonym →  {o.SynonymTarget.FullName}");
        if (o.TableMetrics is { } m)
        {
            sb.AppendLine();
            sb.AppendLine("--- sp_spaceused ---");
            sb.AppendLine($"Rows:           {m.RowCount:N0}");
            sb.AppendLine($"Total reserved: {m.TotalReservedKB / 1024.0:N1} MB ({m.TotalReservedKB:N0} KB)");
            sb.AppendLine($"Data:           {m.DataKB / 1024.0:N1} MB ({m.DataKB:N0} KB)");
            sb.AppendLine($"Index size:     {m.IndexKB / 1024.0:N1} MB ({m.IndexKB:N0} KB)");
            sb.AppendLine($"Unused:         {m.UnusedKB / 1024.0:N1} MB ({m.UnusedKB:N0} KB)");
            sb.AppendLine($"Partitioned:    {m.IsPartitioned}{(m.IsPartitioned ? $"  (fn={m.PartitionFunction}, scheme={m.PartitionScheme}, col={m.PartitionColumn})" : "")}");
        }

        if (o.Columns.Count > 0)
        {
            sb.AppendLine();
            sb.AppendLine("--- Columns (sp_help) ---");
            sb.AppendLine($"{"#",3} {"Name",-32} {"Type",-22} {"Null",-5} {"Idn",-4} {"PK",-3}  {"Default",-20} Collation");
            sb.AppendLine(new string('-', 140));
            foreach (var col in o.Columns)
                sb.AppendLine(
                    $"{col.Ordinal,3} {Truncate(col.Name,32),-32} {Truncate(col.FormattedType,22),-22} " +
                    $"{(col.IsNullable ? "yes" : "no"),-5} {(col.IsIdentity ? "yes" : ""),-4} {(col.IsPrimaryKey ? "PK" : ""),-3}  " +
                    $"{Truncate(col.DefaultDefinition ?? "", 20),-20} {col.Collation ?? ""}");
        }

        if (o.ForeignKeys.Count > 0)
        {
            sb.AppendLine();
            sb.AppendLine("--- Foreign Keys ---");
            foreach (var fk in o.ForeignKeys)
            {
                sb.AppendLine($"  {fk.Name}  ({string.Join(", ", fk.ParentColumns)}) -> [{fk.ReferencedSchema}].[{fk.ReferencedTable}] ({string.Join(", ", fk.ReferencedColumns)})");
                if (!fk.DeleteAction.Equals("NO_ACTION", StringComparison.OrdinalIgnoreCase) ||
                    !fk.UpdateAction.Equals("NO_ACTION", StringComparison.OrdinalIgnoreCase))
                    sb.AppendLine($"    ON DELETE {fk.DeleteAction}, ON UPDATE {fk.UpdateAction}");
                if (fk.IsDisabled)   sb.AppendLine("    DISABLED");
                if (fk.IsNotTrusted) sb.AppendLine("    NOT TRUSTED");
            }
        }

        var idxText = new StringBuilder();
        if (o.Indexes.Count > 0)
        {
            idxText.AppendLine($"{"Name",-40} {"Type",-18} {"PK",3} {"UQ",3} {"Rows",12} {"ReservedKB",12}  Columns");
            idxText.AppendLine(new string('-', 120));
            foreach (var i in o.Indexes)
                idxText.AppendLine($"{Truncate(i.Name,40),-40} {i.Type,-18} {(i.IsPrimaryKey?"Y":""),3} {(i.IsUnique?"Y":""),3} {i.RowCount,12:N0} {i.ReservedKB,12:N0}  {string.Join(", ", i.KeyColumns)}{(i.IncludedColumns.Count > 0 ? " INCLUDE(" + string.Join(", ", i.IncludedColumns) + ")" : "")}");
        }
        var partText = new StringBuilder();
        if (o.Partitions.Count > 0)
        {
            partText.AppendLine($"{"#",4} {"Side",-6} {"Boundary",-30} {"Rows",14} {"DataKB",12} {"IndexKB",12} {"TotalKB",12}  FileGroup");
            partText.AppendLine(new string('-', 120));
            foreach (var p in o.Partitions)
                partText.AppendLine($"{p.PartitionNumber,4} {p.BoundaryComparator,-6} {Truncate(p.BoundaryValue ?? "(MAX)",30),-30} {p.RowCount,14:N0} {p.DataKB,12:N0} {p.IndexKB,12:N0} {p.TotalKB,12:N0}  {p.FileGroup}");
        }
        return (sb.ToString(), idxText.ToString(), partText.ToString(), o.Definition ?? "", "");
    }

    /// <summary>
    /// Grouped Indexes view: database → table → indexes. Used for connection/package/root selections.
    /// </summary>
    private static string RenderAllIndexesGrouped(IEnumerable<DbObjectNode> objects)
    {
        var sb = new StringBuilder();
        var tables = objects
            .Where(o => o.Type == DbObjectType.Table && o.Indexes.Count > 0)
            .ToList();
        if (tables.Count == 0) return "";

        var byDb = tables.GroupBy(t => t.DatabaseName, StringComparer.OrdinalIgnoreCase)
                         .OrderBy(g => g.Key, StringComparer.OrdinalIgnoreCase);
        foreach (var dbg in byDb)
        {
            sb.AppendLine($"═══ Database: {dbg.Key} ═══");
            foreach (var t in dbg.OrderBy(t => t.QualifiedName, StringComparer.OrdinalIgnoreCase))
            {
                sb.AppendLine();
                sb.AppendLine($"── Table: {t.QualifiedName}    ({t.Indexes.Count} indexes, {t.TableMetrics?.RowCount ?? 0:N0} rows)");
                sb.AppendLine($"    {"Name",-40} {"Type",-18} {"PK",3} {"UQ",3} {"Rows",14} {"ReservedKB",12}  Columns");
                sb.AppendLine("    " + new string('-', 122));
                foreach (var i in t.Indexes)
                    sb.AppendLine(
                        $"    {Truncate(i.Name,40),-40} {i.Type,-18} " +
                        $"{(i.IsPrimaryKey?"Y":""),3} {(i.IsUnique?"Y":""),3} " +
                        $"{i.RowCount,14:N0} {i.ReservedKB,12:N0}  " +
                        $"{string.Join(", ", i.KeyColumns)}" +
                        $"{(i.IncludedColumns.Count > 0 ? " INCLUDE(" + string.Join(", ", i.IncludedColumns) + ")" : "")}");
            }
            sb.AppendLine();
        }
        return sb.ToString();
    }

    private static string FormatIndex(IndexInfo i)
    {
        var sb = new StringBuilder();
        sb.AppendLine($"Index:       {i.Name}");
        sb.AppendLine($"Type:        {i.Type}");
        sb.AppendLine($"Unique:      {i.IsUnique}");
        sb.AppendLine($"Primary key: {i.IsPrimaryKey}");
        sb.AppendLine($"Disabled:    {i.IsDisabled}");
        sb.AppendLine($"Filter:      {i.FilterDefinition}");
        sb.AppendLine($"Rows:        {i.RowCount:N0}");
        sb.AppendLine($"Reserved:    {i.ReservedKB:N0} KB");
        sb.AppendLine($"Used:        {i.UsedKB:N0} KB");
        sb.AppendLine($"Key cols:    {string.Join(", ", i.KeyColumns)}");
        if (i.IncludedColumns.Count > 0)
            sb.AppendLine($"Included:    {string.Join(", ", i.IncludedColumns)}");
        return sb.ToString();
    }

    private static string FormatColumn(ColumnInfo c)
    {
        var sb = new StringBuilder();
        sb.AppendLine($"Column:        {c.Name}");
        sb.AppendLine($"Ordinal:       {c.Ordinal}");
        sb.AppendLine($"Type:          {c.FormattedType}");
        sb.AppendLine($"Nullable:      {c.IsNullable}");
        sb.AppendLine($"Identity:      {c.IsIdentity}");
        sb.AppendLine($"Computed:      {c.IsComputed}");
        sb.AppendLine($"Primary key:   {c.IsPrimaryKey}");
        if (c.Precision > 0 || c.Scale > 0)
            sb.AppendLine($"Precision:     {c.Precision},{c.Scale}");
        if (c.MaxLength != 0) sb.AppendLine($"Max length:    {c.MaxLength}");
        if (c.Collation is not null) sb.AppendLine($"Collation:     {c.Collation}");
        if (c.DefaultDefinition is not null)
            sb.AppendLine($"Default:       {c.DefaultDefinition}");
        if (c.ComputedDefinition is not null)
            sb.AppendLine($"Computed expr: {c.ComputedDefinition}");
        return sb.ToString();
    }

    private static string FormatForeignKey(ForeignKeyInfo fk)
    {
        var sb = new StringBuilder();
        sb.AppendLine($"Foreign Key:   {fk.Name}");
        sb.AppendLine($"Parent cols:   {string.Join(", ", fk.ParentColumns)}");
        sb.AppendLine($"References:    [{fk.ReferencedSchema}].[{fk.ReferencedTable}] ({string.Join(", ", fk.ReferencedColumns)})");
        sb.AppendLine($"ON DELETE:     {fk.DeleteAction}");
        sb.AppendLine($"ON UPDATE:     {fk.UpdateAction}");
        sb.AppendLine($"Disabled:      {fk.IsDisabled}");
        sb.AppendLine($"Not trusted:   {fk.IsNotTrusted}");
        return sb.ToString();
    }

    private static string FormatPartition(PartitionInfo p)
    {
        var sb = new StringBuilder();
        sb.AppendLine($"Partition #: {p.PartitionNumber}");
        sb.AppendLine($"Side:        {p.BoundaryComparator}");
        sb.AppendLine($"Boundary:    {p.BoundaryValue ?? "(MAX)"}");
        sb.AppendLine($"Rows:        {p.RowCount:N0}");
        sb.AppendLine($"Data:        {p.DataKB:N0} KB");
        sb.AppendLine($"Indexes:     {p.IndexKB:N0} KB");
        sb.AppendLine($"Total:       {p.TotalKB:N0} KB");
        sb.AppendLine($"File group:  {p.FileGroup}");
        return sb.ToString();
    }

    private static string Truncate(string s, int n) => s.Length <= n ? s : s.Substring(0, n - 1) + "…";
}




