using Microsoft.Data.SqlClient;
using SSISLens.Core;

namespace SSISLens.Sql;

/// <summary>
/// Lookups for object existence, type, definition, and synonym base target.
/// </summary>
public sealed class ObjectMetadataRepo
{
    private readonly SqlConnectionFactory _factory;

    public ObjectMetadataRepo(SqlConnectionFactory factory) => _factory = factory;

    public sealed record ObjectIdentity(
        DbObjectType Type,
        string Schema,
        string Name,
        string? Definition,
        SynonymTarget? Synonym);

    public sealed record SynonymTarget(
        string? Server, string? Database, string Schema, string Name);

    public async Task<ObjectIdentity?> ResolveAsync(string server, string database,
        string schema, string name, CancellationToken ct)
    {
        await using var conn = await _factory.OpenAsync(server, database, ct).ConfigureAwait(false);
        await using var cmd = new SqlCommand(@"
SELECT o.type, o.type_desc, s.name AS schema_name, o.name,
       OBJECT_DEFINITION(o.object_id) AS def,
       sy.base_object_name
FROM sys.objects o
JOIN sys.schemas s ON s.schema_id = o.schema_id
LEFT JOIN sys.synonyms sy ON sy.object_id = o.object_id
WHERE s.name = @s AND o.name = @n;", conn) { CommandTimeout = _factory.CommandTimeoutSeconds };
        cmd.Parameters.AddWithValue("@s", schema);
        cmd.Parameters.AddWithValue("@n", name);
        await using var r = await cmd.ExecuteReaderAsync(ct).ConfigureAwait(false);
        if (!await r.ReadAsync(ct).ConfigureAwait(false))
            return null;

        var typeDesc = r.GetString(1);
        var resolvedType = MapType(typeDesc);
        var def          = r.IsDBNull(4) ? null : r.GetString(4);
        SynonymTarget? syn = null;
        if (!r.IsDBNull(5))
            syn = ParseSynonym(r.GetString(5));

        return new ObjectIdentity(resolvedType, r.GetString(2), r.GetString(3), def, syn);
    }

    public static DbObjectType MapType(string typeDesc) => typeDesc switch
    {
        "USER_TABLE"               => DbObjectType.Table,
        "INTERNAL_TABLE"           => DbObjectType.Table,
        "VIEW"                     => DbObjectType.View,
        "SQL_STORED_PROCEDURE"     => DbObjectType.StoredProcedure,
        "EXTENDED_STORED_PROCEDURE"=> DbObjectType.StoredProcedure,
        "SQL_SCALAR_FUNCTION"      => DbObjectType.Function,
        "SQL_INLINE_TABLE_VALUED_FUNCTION" => DbObjectType.Function,
        "SQL_TABLE_VALUED_FUNCTION"=> DbObjectType.Function,
        "SYNONYM"                  => DbObjectType.Synonym,
        "SEQUENCE_OBJECT"          => DbObjectType.Sequence,
        _ => DbObjectType.Unknown
    };

    private static SynonymTarget? ParseSynonym(string baseName)
    {
        var parts = SplitQualified(baseName);
        return parts.Count switch
        {
            4 => new SynonymTarget(parts[0], parts[1], parts[2], parts[3]),
            3 => new SynonymTarget(null,     parts[0], parts[1], parts[2]),
            2 => new SynonymTarget(null,     null,     parts[0], parts[1]),
            1 => new SynonymTarget(null,     null,     "dbo",    parts[0]),
            _ => null
        };
    }

    private static List<string> SplitQualified(string s)
    {
        var result = new List<string>();
        var sb     = new System.Text.StringBuilder();
        var inBr   = false;
        foreach (var c in s)
        {
            if (c == '[') { inBr = true;  continue; }
            if (c == ']') { inBr = false; continue; }
            if (c == '.' && !inBr)
            {
                result.Add(sb.ToString());
                sb.Clear();
            }
            else sb.Append(c);
        }
        if (sb.Length > 0) result.Add(sb.ToString());
        return result;
    }
}




