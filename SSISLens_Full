using System.Data.Common;
using SSISLens.Core;

namespace SSISLens.Parsing;

public static class ConnectionStringClassifier
{
    public static (ConnectionProvider Provider, string? Server, string? Database, string? Auth)
        Parse(string? creationName, string? connectionString)
    {
        var provider = ClassifyByCreationName(creationName);
        if (string.IsNullOrWhiteSpace(connectionString))
            return (provider, null, null, null);

        try
        {
            var b = new DbConnectionStringBuilder { ConnectionString = connectionString };
            string? Get(params string[] keys)
            {
                foreach (var k in keys)
                    if (b.TryGetValue(k, out var v) && v is not null)
                        return v.ToString();
                return null;
            }

            var server = Get("Data Source", "Server", "Address", "Network Address");
            var db = Get("Initial Catalog", "Database");
            var integrated = Get("Integrated Security", "Trusted_Connection");
            var user = Get("User ID", "UID");
            var auth = integrated is not null &&
                       (integrated.Equals("SSPI", StringComparison.OrdinalIgnoreCase) ||
                        integrated.Equals("True", StringComparison.OrdinalIgnoreCase) ||
                        integrated.Equals("Yes", StringComparison.OrdinalIgnoreCase))
                ? "Windows"
                : (user is not null ? $"SQL ({user})" : "Unknown");

            if (provider == ConnectionProvider.Unknown && server is not null)
                provider = ConnectionProvider.OleDbSqlServer;

            return (provider, server, db, auth);
        }
        catch
        {
            return (provider, null, null, null);
        }
    }

    private static ConnectionProvider ClassifyByCreationName(string? creationName)
    {
        if (string.IsNullOrWhiteSpace(creationName)) return ConnectionProvider.Unknown;
        var c = creationName.ToUpperInvariant();
        if (c.Contains("OLEDB")) return ConnectionProvider.OleDbSqlServer;
        if (c.Contains("ADO.NET") || c.Contains("ADONET")) return ConnectionProvider.AdoNetSqlServer;
        if (c.Contains("ODBC")) return ConnectionProvider.OdbcSqlServer;
        if (c.Contains("FLATFILE")) return ConnectionProvider.FlatFile;
        if (c.Contains("EXCEL")) return ConnectionProvider.Excel;
        if (c.Contains("FTP")) return ConnectionProvider.Ftp;
        if (c.Contains("HTTP")) return ConnectionProvider.Http;
        if (c.Contains("FILE")) return ConnectionProvider.File;
        return ConnectionProvider.Other;
    }
}




