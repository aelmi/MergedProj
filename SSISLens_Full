using System.Text;
using SSISLens.Core;

namespace SSISLens.Export;

public sealed class CsvExportWriter : IExportWriter
{
    public string DisplayName => "CSV";
    public string Extension => ".csv";

    public async Task WriteAsync(AnalysisResult result, string path, CancellationToken ct = default)
    {
        var sb = new StringBuilder();
        sb.AppendLine("Package,Connection,Server,Database,Schema,Object,Type,Access,Status,Rows,TotalKB,IndexCount,IsPartitioned,PartitionCount");
        foreach (var pkg in result.Packages)
        {
            foreach (var conn in pkg.Connections)
            {
                foreach (var obj in conn.Objects)
                    AppendNode(sb, pkg.Name, conn.Name, obj);
            }
        }
        await File.WriteAllTextAsync(path, sb.ToString(), Encoding.UTF8, ct).ConfigureAwait(false);
    }

    private static void AppendNode(StringBuilder sb, string pkg, string conn, DbObjectNode n)
    {
        sb.Append(Q(pkg)).Append(',')
          .Append(Q(conn)).Append(',')
          .Append(Q(n.ServerName)).Append(',')
          .Append(Q(n.DatabaseName)).Append(',')
          .Append(Q(n.Schema)).Append(',')
          .Append(Q(n.Name)).Append(',')
          .Append(n.Type).Append(',')
          .Append(n.AccessKind).Append(',')
          .Append(n.Status).Append(',')
          .Append(n.TableMetrics?.RowCount ?? 0).Append(',')
          .Append(n.TableMetrics?.TotalReservedKB ?? 0).Append(',')
          .Append(n.Indexes.Count).Append(',')
          .Append(n.TableMetrics?.IsPartitioned == true ? "true" : "false").Append(',')
          .Append(n.Partitions.Count).AppendLine();
        foreach (var c in n.Children) AppendNode(sb, pkg, conn, c);
        if (n.SynonymTarget is not null) AppendNode(sb, pkg, conn, n.SynonymTarget);
    }

    private static string Q(string? s)
    {
        s ??= "";
        if (s.Contains(',') || s.Contains('"') || s.Contains('\n'))
            return "\"" + s.Replace("\"", "\"\"") + "\"";
        return s;
    }
}




