using SSISLens.Core;

namespace SSISLens.UI;

internal static class TreeBuilder
{
    public static void Populate(TreeView tree, AnalysisResult result)
    {
        tree.BeginUpdate();
        try
        {
            tree.Nodes.Clear();
            foreach (var pkg in result.Packages)
            {
                var pn = tree.Nodes.Add("pkg:" + pkg.Name, $"📦 {pkg.Name}");
                pn.Tag = pkg;
                foreach (var conn in pkg.Connections)
                {
                    var statusBadge = conn.Status switch
                    {
                        ResolutionStatus.Unresolved => " ⚠",
                        ResolutionStatus.PartiallyResolved => " ◔",
                        ResolutionStatus.Unreachable => " ✕",
                        ResolutionStatus.AccessDenied => " 🔒",
                        _ => ""
                    };
                    var cn = pn.Nodes.Add("conn:" + conn.Name, $"🔌 {conn.Name}{statusBadge}  ({conn.Provider})");
                    cn.Tag = conn;
                    foreach (var obj in conn.Objects)
                        AddObjectNode(cn, obj);
                }
            }
            if (tree.Nodes.Count > 0) tree.Nodes[0].Expand();
        }
        finally
        {
            tree.EndUpdate();
        }
    }

    private static void AddObjectNode(TreeNode parent, DbObjectNode obj)
    {
        var icon = obj.Type switch
        {
            DbObjectType.Table => "▦",
            DbObjectType.View => "◫",
            DbObjectType.StoredProcedure => "▶",
            DbObjectType.Function => "ƒ",
            DbObjectType.Synonym => "⇄",
            DbObjectType.Sequence => "↻",
            _ => "?"
        };
        var size = obj.TableMetrics is null
            ? ""
            : $"   [{obj.TableMetrics.RowCount:N0} rows · {(obj.TableMetrics.TotalReservedKB / 1024.0):N1} MB" +
              (obj.TableMetrics.IsPartitioned ? $" · {obj.Partitions.Count} parts" : "") + "]";
        var label = $"{icon} {obj.QualifiedName}{size}";
        if (obj.Status != ResolutionStatus.Resolved) label += $"   ⚠ {obj.Status}";
        var node = parent.Nodes.Add(obj.Key, label);
        node.Tag = obj;
        if (obj.SynonymTarget is not null)
        {
            var syn = parent.Nodes.Add("syn:" + obj.SynonymTarget.Key, $"   ↳ synonym→");
            syn.Tag = obj.SynonymTarget;
            AddObjectNode(syn, obj.SynonymTarget);
        }
        if (obj.Columns.Count > 0)
        {
            var cg = node.Nodes.Add(node.Name + "/cols", $"📋 Columns ({obj.Columns.Count})");
            foreach (var col in obj.Columns)
            {
                var tags = new List<string>();
                if (col.IsPrimaryKey) tags.Add("PK");
                if (col.IsIdentity)   tags.Add("IDENTITY");
                if (col.IsComputed)   tags.Add("COMPUTED");
                if (!col.IsNullable)  tags.Add("NOT NULL");
                var tagText = tags.Count > 0 ? "  [" + string.Join(", ", tags) + "]" : "";
                var n = cg.Nodes.Add($"{col.Name}  {col.FormattedType}{tagText}");
                n.Tag = col;
            }
        }
        if (obj.Indexes.Count > 0)
        {
            var ig = node.Nodes.Add(node.Name + "/indexes", $"📇 Indexes ({obj.Indexes.Count})");
            foreach (var idx in obj.Indexes)
            {
                var pk = idx.IsPrimaryKey ? " [PK]" : (idx.IsUnique ? " [UQ]" : "");
                var n = ig.Nodes.Add($"{idx.Name} {idx.Type}{pk}  {idx.ReservedKB / 1024:N1} MB");
                n.Tag = idx;
            }
        }
        if (obj.ForeignKeys.Count > 0)
        {
            var fg = node.Nodes.Add(node.Name + "/fks", $"🔗 Foreign Keys ({obj.ForeignKeys.Count})");
            foreach (var fk in obj.ForeignKeys)
            {
                var n = fg.Nodes.Add($"{fk.Name}  ({string.Join(", ", fk.ParentColumns)}) → {fk.ReferencedSchema}.{fk.ReferencedTable}");
                n.Tag = fk;
            }
        }
        if (obj.Partitions.Count > 0)
        {
            var pg = node.Nodes.Add(node.Name + "/parts", $"🧩 Partitions ({obj.Partitions.Count})");
            foreach (var p in obj.Partitions)
            {
                var n = pg.Nodes.Add($"#{p.PartitionNumber}  ≤{p.BoundaryValue ?? "(MAX)"}  {p.RowCount:N0} rows  {p.TotalKB / 1024:N1} MB");
                n.Tag = p;
            }
        }
        foreach (var c in obj.Children) AddObjectNode(node, c);
    }
}




