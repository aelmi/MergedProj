using System.Text.RegularExpressions;

namespace SSISLens.Parsing;

/// <summary>
/// Evaluates SSIS property expressions to the extent needed to resolve connection
/// strings and SQL statements. Supports variable/parameter substitution and the
/// common string-concatenation + literal cases, with conservative fall-back.
/// </summary>
public sealed class SsisExpressionEvaluator
{
    private readonly IReadOnlyDictionary<string, string?> _values;
    private static readonly Regex Token =
        new(@"@\[(?<scope>\$Project::|\$Package::|User::|System::)?(?<name>[^\]]+)\]",
            RegexOptions.Compiled);

    public SsisExpressionEvaluator(IReadOnlyDictionary<string, string?> values)
    {
        _values = values;
    }

    public bool TryEvaluate(string? expression, out string? result, out List<string> unresolved)
    {
        var unresolvedLocal = new List<string>();
        result = null;
        if (string.IsNullOrWhiteSpace(expression))
        {
            unresolved = unresolvedLocal;
            return false;
        }

        var substituted = Token.Replace(expression, m =>
        {
            var key = (m.Groups["scope"].Value + m.Groups["name"].Value).TrimEnd(':');
            if (_values.TryGetValue(NormalizeKey(m.Groups["scope"].Value, m.Groups["name"].Value),
                                    out var val) && val is not null)
            {
                return val;
            }
            unresolvedLocal.Add(key);
            return $"<<UNRESOLVED:{key}>>";
        });

        result = TryReduce(substituted);
        unresolved = unresolvedLocal;
        return unresolvedLocal.Count == 0;
    }

    private static string NormalizeKey(string scope, string name)
    {
        var s = scope.Trim();
        if (s.Equals("$Project::", StringComparison.OrdinalIgnoreCase)) return "$Project::" + name;
        if (s.Equals("$Package::", StringComparison.OrdinalIgnoreCase)) return "$Package::" + name;
        if (s.Equals("System::",   StringComparison.OrdinalIgnoreCase)) return "System::"   + name;
        return "User::" + name;
    }

    private static string TryReduce(string text)
    {
        text = Regex.Replace(text, @"\(DT_\w+(?:,\s*\d+)*\)", "", RegexOptions.IgnoreCase);
        var parts = SplitTopLevelByPlus(text);
        var sb = new System.Text.StringBuilder();
        foreach (var raw in parts)
        {
            var part = raw.Trim();
            if (part.Length >= 2 && part.StartsWith("\"") && part.EndsWith("\""))
                sb.Append(Unescape(part.Substring(1, part.Length - 2)));
            else
                sb.Append(part);
        }
        return sb.ToString();
    }

    private static IEnumerable<string> SplitTopLevelByPlus(string s)
    {
        var depth = 0;
        var inStr = false;
        var start = 0;
        for (var i = 0; i < s.Length; i++)
        {
            var c = s[i];
            if (c == '"' && (i == 0 || s[i - 1] != '\\')) inStr = !inStr;
            else if (!inStr)
            {
                if (c == '(') depth++;
                else if (c == ')') depth--;
                else if (c == '+' && depth == 0)
                {
                    yield return s.Substring(start, i - start);
                    start = i + 1;
                }
            }
        }
        yield return s.Substring(start);
    }

    private static string Unescape(string s) =>
        s.Replace("\\\"", "\"").Replace("\\\\", "\\").Replace("\\n", "\n").Replace("\\r", "\r").Replace("\\t", "\t");
}




