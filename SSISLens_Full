using Microsoft.Extensions.Logging;
using SSISLens.Core;
using SSISLens.Export;
using SSISLens.Services;

namespace SSISLens.UI;

public sealed partial class MainForm : Form
{
    private readonly AnalysisService _analyzer = null!;
    private readonly ILogger<MainForm> _log = null!;

    private AnalysisResult? _result;
    private CancellationTokenSource? _cts;
    private List<TreeNode>? _allLeafNodes;

    // Designer-only parameterless constructor (lets the VS WinForms designer load the form).
    public MainForm()
    {
        InitializeComponent();
    }

    public MainForm(AnalysisService analyzer, ILogger<MainForm> log) : this()
    {
        _analyzer = analyzer;
        _log = log;
        WireEvents();
    }

    private void WireEvents()
    {
        _openBtn.Click       += OnBrowse;
        _runBtn.Click        += OnRun;
        _cancelBtn.Click     += (_, __) => _cts?.Cancel();
        _exportBtn.Click     += OnExport;
        _searchBox.TextChanged += (_, __) => ApplyFilter(_searchBox.Text);
        _tree.AfterSelect    += OnTreeSelect;
    }

    private void OnBrowse(object? sender, EventArgs e)
    {
        using var dlg = new OpenFileDialog
        {
            Title = "Select SSIS source (.dtsx or .ispac) — or cancel and type a folder path",
            Filter = "SSIS sources|*.dtsx;*.ispac|All|*.*"
        };
        if (dlg.ShowDialog(this) == DialogResult.OK)
            _pathBox.Text = dlg.FileName;
    }

    private async void OnRun(object? sender, EventArgs e)
    {
        if (string.IsNullOrWhiteSpace(_pathBox.Text))
        {
            MessageBox.Show(this, "Select a .dtsx, .ispac, or folder first.", "SSISLens",
                MessageBoxButtons.OK, MessageBoxIcon.Information);
            return;
        }
        if (!File.Exists(_pathBox.Text) && !Directory.Exists(_pathBox.Text))
        {
            MessageBox.Show(this, "Path not found.", "SSISLens",
                MessageBoxButtons.OK, MessageBoxIcon.Error);
            return;
        }

        var opts = new AnalysisOptions
        {
            MaxRecursionDepth = (int)_depthBox.Value,
            RecurseUntilFixedPoint = _untilFixedPointBox.Checked,
            MaskPasswords = true
        };

        _runBtn.Enabled = false;
        _cancelBtn.Enabled = true;
        _exportBtn.Enabled = false;
        _openBtn.Enabled = false;
        _progress.Value = 0;
        _statusLabel.Text = "Analyzing…";
        _tree.Nodes.Clear();
        _allLeafNodes = null;

        _cts = new CancellationTokenSource();
        var progress = new Progress<AnalysisProgress>(p =>
        {
            _statusLabel.Text = p.ToString();
            if (p.Total > 0) _progress.Value = (int)(p.Fraction * 100);
        });

        try
        {
            _result = await Task.Run(() => _analyzer.AnalyzeAsync(_pathBox.Text, opts, progress, _cts.Token));
            TreeBuilder.Populate(_tree, _result);
            _allLeafNodes = CollectAllNodes(_tree.Nodes).ToList();
            var (ov, _, _, _, _) = DetailsRenderer.Render(null, _result);
            _overviewBox.Text = ov;
            _exportBtn.Enabled = true;
            _statusLabel.Text = $"Done. {_result.Packages.Count} packages, {_result.AllObjects.Count()} objects in {_result.Duration?.TotalSeconds:F1}s";
            _progress.Value = 100;
        }
        catch (OperationCanceledException)
        {
            _statusLabel.Text = "Cancelled.";
        }
        catch (Exception ex)
        {
            _log.LogError(ex, "Analysis failed");
            _statusLabel.Text = "Failed: " + ex.Message;
            MessageBox.Show(this, ex.ToString(), "SSISLens — analysis failed",
                MessageBoxButtons.OK, MessageBoxIcon.Error);
        }
        finally
        {
            _runBtn.Enabled = true;
            _cancelBtn.Enabled = false;
            _openBtn.Enabled = true;
            _cts?.Dispose();
            _cts = null;
        }
    }

    private void OnTreeSelect(object? sender, TreeViewEventArgs e)
    {
        if (_result is null) return;
        var (ov, idx, parts, def, prov) = DetailsRenderer.Render(e.Node?.Tag, _result);
        _overviewBox.Text   = ov;
        _indexesBox.Text    = idx;
        _partitionsBox.Text = parts;
        _definitionBox.Text = def;
        _provenanceBox.Text = prov;
    }

    private void ApplyFilter(string filter)
    {
        if (_allLeafNodes is null || _result is null) return;
        if (string.IsNullOrWhiteSpace(filter))
        {
            TreeBuilder.Populate(_tree, _result);
            _allLeafNodes = CollectAllNodes(_tree.Nodes).ToList();
            return;
        }
        _tree.BeginUpdate();
        try
        {
            foreach (var n in CollectAllNodes(_tree.Nodes))
                SetVisible(n, n.Text.Contains(filter, StringComparison.OrdinalIgnoreCase));
        }
        finally { _tree.EndUpdate(); }
    }

    private static void SetVisible(TreeNode n, bool match)
    {
        if (!match) return;
        var p = n.Parent;
        while (p is not null) { p.Expand(); p = p.Parent; }
    }

    private static IEnumerable<TreeNode> CollectAllNodes(TreeNodeCollection nodes)
    {
        foreach (TreeNode n in nodes)
        {
            yield return n;
            foreach (var c in CollectAllNodes(n.Nodes)) yield return c;
        }
    }

    private async void OnExport(object? sender, EventArgs e)
    {
        var result = _result;
        if (result is null) return;
        using var dlg = new SaveFileDialog
        {
            Filter = "JSON|*.json|CSV|*.csv|Excel|*.xlsx|HTML|*.html",
            FileName = (result.Packages.Count > 0
                            ? result.Packages[0].Name + "_"
                            : "analysis_")
                       + DateTime.Now.ToString("yyyyMMdd_HHmm")
        };
        if (dlg.ShowDialog(this) != DialogResult.OK) return;
        try
        {
            IExportWriter writer = dlg.FilterIndex switch
            {
                1 => new JsonExportWriter(),
                2 => new CsvExportWriter(),
                3 => new ExcelExportWriter(),
                4 => new HtmlExportWriter(),
                _ => new JsonExportWriter()
            };
            await writer.WriteAsync(result, dlg.FileName, CancellationToken.None);
            _statusLabel.Text = $"Exported to {dlg.FileName}";

            var size = new FileInfo(dlg.FileName).Length;
            var choice = MessageBox.Show(
                this,
                $"Exported to:\n{dlg.FileName}\n\nSize: {size:N0} bytes\n\nOpen the file now?",
                "SSISLens — export complete",
                MessageBoxButtons.YesNo,
                MessageBoxIcon.Information,
                MessageBoxDefaultButton.Button1);

            if (choice == DialogResult.Yes)
            {
                try
                {
                    System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo
                    {
                        FileName = dlg.FileName,
                        UseShellExecute = true
                    });
                }
                catch (Exception openEx)
                {
                    _log.LogWarning(openEx, "Could not open exported file");
                }
            }
        }
        catch (Exception ex)
        {
            _log.LogError(ex, "Export failed");
            MessageBox.Show(this, ex.Message, "SSISLens — export failed",
                MessageBoxButtons.OK, MessageBoxIcon.Error);
        }
    }
}




