            ws.Cell(row, 8).Value = p.PartitionNumber;
            ws.Cell(row, 9).Value = p.BoundaryValue ?? "";
            ws.Cell(row,10).Value = p.BoundaryComparator ?? "";
            ws.Cell(row,11).Value = p.RowCount;
            ws.Cell(row,12).Value = p.DataKB;
            ws.Cell(row,13).Value = p.IndexKB;
            ws.Cell(row,14).Value = p.TotalKB;
            ws.Cell(row,15).Value = p.FileGroup ?? "";
            row++;
