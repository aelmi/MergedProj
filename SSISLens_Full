using System.Net;
using System.Text;
using SSISLens.Core;

namespace SSISLens.Export;

/// <summary>
/// Self-contained, single-file HTML report. Same data layout as the Excel
/// exporter: same section order, same grouped/flat distinction, the same
/// cross-section hyperlinks, and the same "open at level 1, drill in" default.
/// </summary>
public sealed class HtmlExportWriter : IExportWriter
{
    public string DisplayName => "HTML";
    public string Extension => ".html";

    public Task WriteAsync(AnalysisResult result, string path, CancellationToken ct = default)
    {
        var sb = new StringBuilder(64 * 1024);
        WriteHead(sb, result);
        sb.AppendLine("<body>");

        WriteHero(sb, result);
        WriteNav(sb);

        sb.AppendLine("<main>");
        WriteServers(sb, result);
        WritePackages(sb, result);
        WriteSchema(sb, result);
        WriteDatabases(sb, result);
        WriteConnections(sb, result);
        WriteObjects(sb, result);
        WriteIndexes(sb, result);
        WriteForeignKeys(sb, result);
        WritePartitions(sb, result);
        WriteDefinitions(sb, result);
        sb.AppendLine("</main>");

        sb.AppendLine("</body></html>");
        return File.WriteAllTextAsync(path, sb.ToString(), Encoding.UTF8, ct);
    }

    // ──────────────────────────────────────────────────────────────────────
    // Head + nav + hero
    // ──────────────────────────────────────────────────────────────────────
    private static void WriteHead(StringBuilder sb, AnalysisResult r)
    {
        var sourceName = string.IsNullOrEmpty(r.SourcePath)
            ? "(unknown)"
            : Path.GetFileName(r.SourcePath.TrimEnd('/', '\\'));
        var title = $"SSIS analysis of {sourceName}";
        var description = $"Analyzed {r.Packages.Count} package(s), " +
                          $"{r.AllConnections.Count()} connection(s), " +
                          $"{r.AllObjects.Count()} object(s) in {r.Duration?.TotalSeconds:F1}s.";

        sb.AppendLine("<!doctype html>");
        sb.AppendLine("<html lang=\"en\"><head>");
        sb.AppendLine("<meta charset=\"utf-8\">");
        sb.AppendLine("<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">");
        sb.AppendLine($"<title>{Esc(title)}</title>");
        sb.AppendLine($"<meta name=\"description\" content=\"{Esc(description)}\">");
        sb.AppendLine("<meta name=\"keywords\" content=\"SSIS, dtsx, analysis, dependencies\">");
        sb.AppendLine("<style>");
        sb.AppendLine(Css);
        sb.AppendLine("</style></head>");
    }

    private static void WriteHero(StringBuilder sb, AnalysisResult r)
    {
        var tables   = r.AllObjects.Count(o => o.Type == DbObjectType.Table);
        var views    = r.AllObjects.Count(o => o.Type == DbObjectType.View);
        var procs    = r.AllObjects.Count(o => o.Type == DbObjectType.StoredProcedure);
        var rows     = r.AllObjects.Sum(o => o.TableMetrics?.RowCount ?? 0);
        var reserved = r.AllObjects.Sum(o => o.TableMetrics?.TotalReservedKB ?? 0);

        sb.AppendLine("<header class=\"hero\">");
        sb.AppendLine("<h1>SSIS analysis</h1>");
        sb.AppendLine("<div class=\"meta\">");
        sb.Append("  <div><b>Source:</b> <code>").Append(Esc(r.SourcePath ?? "")).Append("</code></div>");
        sb.Append("  <div><b>Analyzed:</b> ").Append(r.AnalyzedAtUtc.ToString("u")).Append(" by ").Append(Esc(r.AnalyzedBy)).Append("</div>");
        sb.Append("  <div><b>Duration:</b> ").Append(r.Duration?.TotalSeconds.ToString("F1") ?? "?").Append(" s</div>");
        sb.AppendLine("</div>");
        sb.AppendLine("<div class=\"stats\">");
        Stat(sb, "Packages",    r.Packages.Count.ToString("N0"));
        Stat(sb, "Connections", r.AllConnections.Count().ToString("N0"));
        Stat(sb, "Servers",     r.Servers.Count.ToString("N0"));
        Stat(sb, "Databases",   r.Databases.Count.ToString("N0"));
        Stat(sb, "Tables",      tables.ToString("N0"));
        Stat(sb, "Views",       views.ToString("N0"));
        Stat(sb, "Procs",       procs.ToString("N0"));
        Stat(sb, "Total rows",  rows.ToString("N0"));
        Stat(sb, "Reserved",    $"{reserved / 1024.0:N1} MB");
        sb.AppendLine("</div></header>");
    }

    private static void Stat(StringBuilder sb, string label, string value) =>
        sb.Append("  <div class=\"stat\"><span class=\"sv\">").Append(Esc(value))
          .Append("</span><span class=\"sl\">").Append(Esc(label)).Append("</span></div>");

    private static void WriteNav(StringBuilder sb)
    {
        sb.AppendLine("<nav class=\"topnav\">");
        sb.AppendLine("  <a href=\"#servers\" class=\"flat\">Servers</a>");
        sb.AppendLine("  <a href=\"#packages\" class=\"grouped\">Packages</a>");
        sb.AppendLine("  <a href=\"#schema\" class=\"grouped\">Schema</a>");
        sb.AppendLine("  <a href=\"#databases\" class=\"flat\">Databases</a>");
        sb.AppendLine("  <a href=\"#connections\" class=\"flat\">Connections</a>");
        sb.AppendLine("  <a href=\"#objects\" class=\"grouped\">Objects</a>");
        sb.AppendLine("  <a href=\"#indexes\" class=\"grouped\">Indexes</a>");
        sb.AppendLine("  <a href=\"#foreignkeys\" class=\"flat\">Foreign Keys</a>");
        sb.AppendLine("  <a href=\"#partitions\" class=\"flat\">Partitions</a>");
        sb.AppendLine("  <a href=\"#definitions\" class=\"flat\">Definitions</a>");
        sb.AppendLine("</nav>");
    }

    // ──────────────────────────────────────────────────────────────────────
    // Sections — same order and shape as the xlsx
    // ──────────────────────────────────────────────────────────────────────
    private static void WriteServers(StringBuilder sb, AnalysisResult r)
    {
        sb.AppendLine("<section id=\"servers\" class=\"flat\"><h2>Servers</h2>");
        sb.AppendLine("<table><thead><tr><th>Server</th><th>Version</th><th>Edition</th><th>MaxDOP</th><th>Cost threshold</th><th>Issue</th></tr></thead><tbody>");
        foreach (var s in r.Servers)
            Row(sb, s.Name, s.ProductVersion, s.Edition,
                s.MaxDop?.ToString(), s.CostThresholdForParallelism?.ToString(), s.Issue);
        sb.AppendLine("</tbody></table></section>");
    }

    private static void WritePackages(StringBuilder sb, AnalysisResult r)
    {
        sb.AppendLine("<section id=\"packages\" class=\"grouped\"><h2>Packages</h2>");
        foreach (var p in r.Packages)
        {
            sb.AppendLine("<details open class=\"card\">");
            sb.Append("<summary><span class=\"icon\">📦</span><span class=\"name\">").Append(Esc(p.Name))
              .Append("</span><span class=\"badge\">").Append(string.IsNullOrEmpty(p.Path) ? "" : Esc(Path.GetFileName(p.Path)))
              .Append("</span><span class=\"badge\">").Append(p.Connections.Count).Append(" conn</span>")
              .Append("<span class=\"badge\">").Append(p.Tasks.Count).Append(" tasks</span>")
              .Append("<span class=\"badge\">").Append(p.Parameters.Count).Append(" params</span>")
              .Append("<span class=\"badge\">").Append(p.Variables.Count).Append(" vars</span></summary>");

            sb.AppendLine("<details><summary>Metadata</summary><table><tbody>");
            Row(sb, "Version",         p.Version);
            Row(sb, "Creator",         p.CreatorName);
            Row(sb, "Created",         p.CreationDate);
            Row(sb, "ProtectionLevel", p.ProtectionLevel);
            sb.AppendLine("</tbody></table></details>");

            if (p.Parameters.Count > 0)
            {
                sb.AppendLine($"<details><summary>Parameters <span class=\"badge\">{p.Parameters.Count}</span></summary>");
                sb.AppendLine("<table><thead><tr><th>Name</th><th>Scope</th><th>Type</th><th>Value</th><th>Sensitive</th></tr></thead><tbody>");
                foreach (var par in p.Parameters)
                    Row(sb, par.Name, par.Scope, par.DataType,
                        par.Sensitive ? "********" : par.Value,
                        par.Sensitive ? "yes" : "");
                sb.AppendLine("</tbody></table></details>");
            }

            if (p.Variables.Count > 0)
            {
                sb.AppendLine($"<details><summary>Variables <span class=\"badge\">{p.Variables.Count}</span></summary>");
                sb.AppendLine("<table><thead><tr><th>Name</th><th>Type</th><th>Value</th><th>Expression</th></tr></thead><tbody>");
                foreach (var v in p.Variables)
                    Row(sb, v.FullName, v.DataType, v.Value, v.Expression);
                sb.AppendLine("</tbody></table></details>");
            }

            if (p.Connections.Count > 0)
            {
                sb.AppendLine($"<details><summary>Connections <span class=\"badge\">{p.Connections.Count}</span></summary>");
                sb.AppendLine("<table><thead><tr><th>Name</th><th>Provider</th><th>Server</th><th>Database</th><th>Auth</th><th>Masked</th></tr></thead><tbody>");
                foreach (var c in p.Connections)
                    Row(sb, c.Name, c.Provider.ToString(), c.Server, c.Database, c.Auth, c.MaskedConnectionString);
                sb.AppendLine("</tbody></table></details>");
            }

            if (p.Tasks.Count > 0)
            {
                sb.AppendLine($"<details><summary>Tasks <span class=\"badge\">{p.Tasks.Count}</span></summary>");
                foreach (var t in p.Tasks)
                {
                    sb.Append("<details><summary><span class=\"icon\">⚙</span><b>").Append(Esc(t.Name))
                      .Append("</b><span class=\"badge\">").Append(Esc(t.CreationName))
                      .Append("</span><span class=\"badge\">").Append(Esc(t.ConnectionName ?? "")).Append("</span></summary>");
                    if (!string.IsNullOrWhiteSpace(t.Sql))
                        sb.Append("<pre class=\"sql\">").Append(Esc(t.Sql)).Append("</pre>");
                    sb.AppendLine("</details>");
                }
                sb.AppendLine("</details>");
            }

            // Source — Path + full .dtsx XML
            sb.AppendLine("<details><summary>Source <span class=\"badge\">Path + raw .dtsx XML</span></summary>");
            sb.Append("<div class=\"kv\"><b>Path:</b> <code>").Append(Esc(p.Path ?? "")).Append("</code></div>");
            try
            {
                if (!string.IsNullOrEmpty(p.Path) && File.Exists(p.Path))
                {
                    var xml = File.ReadAllText(p.Path);
                    var bytes = new FileInfo(p.Path).Length;
                    sb.Append("<div class=\"kv\"><b>Size:</b> ").Append(bytes.ToString("N0")).Append(" bytes</div>");
                    sb.Append("<pre class=\"xml\">").Append(Esc(xml)).Append("</pre>");
                }
                else
                {
                    sb.Append("<div class=\"muted\">(source file not accessible)</div>");
                }
            }
            catch (Exception ex)
            {
                sb.Append("<div class=\"muted\">(could not read: ").Append(Esc(ex.Message)).Append(")</div>");
            }
            sb.AppendLine("</details>");

            sb.AppendLine("</details>");
        }
        sb.AppendLine("</section>");
    }

    private static void WriteSchema(StringBuilder sb, AnalysisResult r)
    {
        sb.AppendLine("<section id=\"schema\" class=\"grouped\"><h2>Schema</h2>");
        var byDb = r.Packages.SelectMany(p => p.Connections)
                             .SelectMany(c => c.Objects)
                             .GroupBy(o => new { o.ServerName, o.DatabaseName });
        foreach (var dbg in byDb.OrderBy(g => g.Key.ServerName).ThenBy(g => g.Key.DatabaseName))
        {
            sb.Append("<details open class=\"db\"><summary><span class=\"icon\">🗄</span><b>[")
              .Append(Esc(dbg.Key.ServerName)).Append("].[").Append(Esc(dbg.Key.DatabaseName)).Append("]</b></summary>");

            var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            var tables = dbg.Where(o => o.Type == DbObjectType.Table)
                            .Where(o => seen.Add($"{o.Schema}.{o.Name}"))
                            .OrderByDescending(o => o.TableMetrics?.RowCount ?? 0);

            foreach (var t in tables) WriteTableBlock(sb, t);

            seen.Clear();
            var progs = dbg.Where(o => o.Type is DbObjectType.View or DbObjectType.StoredProcedure
                                           or DbObjectType.Function or DbObjectType.Sequence)
                            .Where(o => seen.Add($"{o.Schema}.{o.Name}"))
                            .OrderBy(o => o.Type).ThenBy(o => o.QualifiedName);
            foreach (var p in progs) WriteProgrammableBlock(sb, p);

            sb.AppendLine("</details>");
        }
        sb.AppendLine("</section>");
    }

    private static void WriteTableBlock(StringBuilder sb, DbObjectNode t)
    {
        var m = t.TableMetrics;
        sb.Append("<details id=\"").Append(Anchor("schema", t)).Append("\" class=\"obj\"><summary>")
          .Append("<span class=\"icon table\">▦</span><b>").Append(Esc(t.QualifiedName)).Append("</b>")
          .Append("<span class=\"badge\">").Append((m?.RowCount ?? 0).ToString("N0")).Append(" rows</span>")
          .Append("<span class=\"badge\">").Append(((m?.TotalReservedKB ?? 0) / 1024.0).ToString("N1")).Append(" MB</span>")
          .Append("<span class=\"badge\">").Append(t.Columns.Count).Append(" cols</span>")
          .Append("<span class=\"badge\">").Append(t.Indexes.Count).Append(" idx</span>")
          .Append("<span class=\"badge\">").Append(t.ForeignKeys.Count).Append(" fk</span>");
        if (t.FileGroup is not null) sb.Append("<span class=\"badge\">").Append(Esc(t.FileGroup)).Append("</span>");
        sb.AppendLine("</summary>");

        if (t.Columns.Count > 0)
        {
            sb.AppendLine($"<details><summary>Columns <span class=\"badge\">{t.Columns.Count}</span></summary>");
            sb.AppendLine("<table><thead><tr><th>#</th><th>Name</th><th>Type</th><th>Null</th><th>Idn</th><th>PK</th><th>Default</th><th>Collation</th></tr></thead><tbody>");
            foreach (var c in t.Columns)
            {
                var pk  = c.IsPrimaryKey ? "PK" : "";
                var idn = c.IsIdentity ? "yes" : "";
                Row(sb, c.Ordinal.ToString(), c.Name, c.FormattedType,
                    c.IsNullable ? "yes" : "no", idn, pk,
                    c.DefaultDefinition, c.Collation);
            }
            sb.AppendLine("</tbody></table></details>");
        }

        if (t.Indexes.Count > 0)
        {
            sb.AppendLine($"<details><summary>Indexes <span class=\"badge\">{t.Indexes.Count}</span></summary>");
            sb.AppendLine("<table><thead><tr><th>Name</th><th>Type</th><th>PK</th><th>UQ</th><th>Rows</th><th>Reserved KB</th><th>Key cols</th><th>Included</th><th>Filter</th></tr></thead><tbody>");
            foreach (var i in t.Indexes)
                Row(sb, i.Name, i.Type, i.IsPrimaryKey ? "Y" : "", i.IsUnique ? "Y" : "",
                    i.RowCount.ToString("N0"), i.ReservedKB.ToString("N0"),
                    string.Join(", ", i.KeyColumns),
                    string.Join(", ", i.IncludedColumns),
                    i.FilterDefinition);
            sb.AppendLine("</tbody></table></details>");
        }

        if (t.ForeignKeys.Count > 0)
        {
            sb.AppendLine($"<details><summary>Foreign Keys <span class=\"badge\">{t.ForeignKeys.Count}</span></summary>");
            sb.AppendLine("<table><thead><tr><th>Name</th><th>Parent cols</th><th>References</th><th>Ref cols</th><th>On Delete</th><th>On Update</th><th>Disabled</th><th>Not trusted</th></tr></thead><tbody>");
            foreach (var fk in t.ForeignKeys)
                Row(sb, fk.Name, string.Join(", ", fk.ParentColumns),
                    $"[{fk.ReferencedSchema}].[{fk.ReferencedTable}]",
                    string.Join(", ", fk.ReferencedColumns),
                    fk.DeleteAction, fk.UpdateAction,
                    fk.IsDisabled ? "yes" : "", fk.IsNotTrusted ? "yes" : "");
            sb.AppendLine("</tbody></table></details>");
        }

        if (t.Partitions.Count > 0)
        {
            sb.AppendLine($"<details><summary>Partitions <span class=\"badge\">{t.Partitions.Count}</span></summary>");
            sb.AppendLine("<table><thead><tr><th>#</th><th>Boundary</th><th>Side</th><th>Rows</th><th>Total KB</th><th>FG</th></tr></thead><tbody>");
            foreach (var p in t.Partitions)
                Row(sb, p.PartitionNumber.ToString(), p.BoundaryValue, p.BoundaryComparator,
                    p.RowCount.ToString("N0"), p.TotalKB.ToString("N0"), p.FileGroup);
            sb.AppendLine("</tbody></table></details>");
        }
        sb.AppendLine("</details>");
    }

    private static void WriteProgrammableBlock(StringBuilder sb, DbObjectNode o)
    {
        var icon = IconFor(o.Type);
        sb.Append("<details id=\"").Append(Anchor("schema", o)).Append("\" class=\"obj prog\"><summary>")
          .Append("<span class=\"icon\">").Append(icon).Append("</span><b>").Append(Esc(o.QualifiedName)).Append("</b>")
          .Append("<span class=\"badge\">").Append(o.Type).Append("</span>");
        if (o.ReferencedByTasks.Count > 0)
            sb.Append("<span class=\"badge\">used by ").Append(Esc(string.Join(", ", o.ReferencedByTasks))).Append("</span>");
        sb.AppendLine("</summary>");

        if (!string.IsNullOrWhiteSpace(o.Definition))
        {
            sb.Append("<details id=\"").Append(Anchor("def", o)).Append("\"><summary>Definition <span class=\"badge\">")
              .Append(o.Definition.Length.ToString("N0")).Append(" chars</span></summary>");
            sb.Append("<pre class=\"sql\">").Append(Esc(o.Definition)).Append("</pre>");
            sb.AppendLine("</details>");
        }
        sb.AppendLine("</details>");
    }

    private static void WriteDatabases(StringBuilder sb, AnalysisResult r)
    {
        sb.AppendLine("<section id=\"databases\" class=\"flat\"><h2>Databases</h2>");
        sb.AppendLine("<table><thead><tr><th>Server</th><th>Database</th><th>Compat</th><th>Collation</th><th>Recovery</th><th>State</th><th>Size (MB)</th></tr></thead><tbody>");
        foreach (var d in r.Databases)
            Row(sb, d.ServerName, d.Name, d.CompatibilityLevel?.ToString(), d.Collation,
                d.RecoveryModel, d.State, ((d.TotalSizeKB ?? 0) / 1024).ToString("N0"));
        sb.AppendLine("</tbody></table></section>");
    }

    private static void WriteConnections(StringBuilder sb, AnalysisResult r)
    {
        sb.AppendLine("<section id=\"connections\" class=\"flat\"><h2>Connections</h2>");
        sb.AppendLine("<table><thead><tr><th>Package</th><th>Connection</th><th>Provider</th><th>Server</th><th>Database</th><th>Auth</th><th>Masked</th></tr></thead><tbody>");
        foreach (var pkg in r.Packages)
        foreach (var c in pkg.Connections)
            Row(sb, pkg.Name, c.Name, c.Provider.ToString(), c.Server, c.Database, c.Auth, c.MaskedConnectionString);
        sb.AppendLine("</tbody></table></section>");
    }

    private static void WriteObjects(StringBuilder sb, AnalysisResult r)
    {
        sb.AppendLine("<section id=\"objects\" class=\"grouped\"><h2>Objects</h2>");
        sb.AppendLine("<div class=\"hint\">Top-level objects open; click ▸ to drill into the dependency tree of each sp/view.</div>");

        foreach (var pkg in r.Packages)
        {
            sb.Append("<details open class=\"card\"><summary><span class=\"icon\">📦</span><b>")
              .Append(Esc(pkg.Name)).AppendLine("</b></summary>");
            foreach (var c in pkg.Connections)
            {
                if (c.Objects.Count == 0) continue;
                sb.Append("<details open class=\"conn\"><summary><span class=\"icon\">🔌</span><b>")
                  .Append(Esc(c.Name)).Append("</b><span class=\"badge\">").Append(Esc(c.Server ?? "")).Append("/")
                  .Append(Esc(c.Database ?? "")).Append("</span><span class=\"badge\">")
                  .Append(c.Objects.Count).AppendLine(" objects</span></summary>");
                foreach (var n in c.Objects) WriteObjectWithDeps(sb, n, top: true);
                sb.AppendLine("</details>");
            }
            sb.AppendLine("</details>");
        }
        sb.AppendLine("</section>");
    }

    private static void WriteObjectWithDeps(StringBuilder sb, DbObjectNode n, bool top)
    {
        var icon = IconFor(n.Type);
        var openAttr = top ? "" : "";  // children start collapsed
        sb.Append("<details").Append(openAttr).Append(" class=\"dep\"><summary>")
          .Append("<span class=\"icon\">").Append(icon).Append("</span>");

        // Hyperlink target: tables → Schema anchor, views/sps/functions → Definition anchor
        var hrefId = n.Type is DbObjectType.View or DbObjectType.StoredProcedure or DbObjectType.Function
            ? Anchor("def", n)
            : Anchor("schema", n);
        sb.Append("<a href=\"#").Append(hrefId).Append("\">").Append(Esc(n.QualifiedName)).Append("</a>");

        sb.Append("<span class=\"badge\">").Append(n.Type).Append("</span>");
        if (n.TableMetrics is { } m)
            sb.Append("<span class=\"badge\">").Append(m.RowCount.ToString("N0")).Append(" rows</span>")
              .Append("<span class=\"badge\">").Append((m.TotalReservedKB / 1024.0).ToString("N1")).Append(" MB</span>");
        if (n.ReferencedByTasks.Count > 0)
            sb.Append("<span class=\"badge muted\">used by ").Append(Esc(string.Join(", ", n.ReferencedByTasks))).Append("</span>");
        sb.AppendLine("</summary>");

        if (n.SynonymTarget is not null) WriteObjectWithDeps(sb, n.SynonymTarget, top: false);
        foreach (var c in n.Children) WriteObjectWithDeps(sb, c, top: false);

        sb.AppendLine("</details>");
    }

    private static void WriteIndexes(StringBuilder sb, AnalysisResult r)
    {
        sb.AppendLine("<section id=\"indexes\" class=\"grouped\"><h2>Indexes</h2>");
        var seenTbl = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var indexedTables = r.AllObjects
            .Where(o => o.Type == DbObjectType.Table && o.Indexes.Count > 0)
            .Where(o => seenTbl.Add($"{o.ServerName}|{o.DatabaseName}|{o.Schema}|{o.Name}"))
            .ToList();

        foreach (var dbg in indexedTables
            .GroupBy(o => new { o.ServerName, o.DatabaseName })
            .OrderBy(g => g.Key.ServerName).ThenBy(g => g.Key.DatabaseName))
        {
            sb.Append("<details open class=\"db\"><summary><span class=\"icon\">🗄</span><b>[")
              .Append(Esc(dbg.Key.ServerName)).Append("].[").Append(Esc(dbg.Key.DatabaseName)).AppendLine("]</b></summary>");

            foreach (var t in dbg.OrderBy(o => o.QualifiedName, StringComparer.OrdinalIgnoreCase))
            {
                sb.Append("<details class=\"obj\"><summary><a href=\"#").Append(Anchor("schema", t)).Append("\">")
                  .Append(Esc(t.QualifiedName)).Append("</a><span class=\"badge\">")
                  .Append(t.Indexes.Count).Append(" indexes</span><span class=\"badge\">")
                  .Append((t.TableMetrics?.RowCount ?? 0).ToString("N0")).Append(" rows</span></summary>");
                sb.AppendLine("<table><thead><tr><th>Name</th><th>Type</th><th>PK</th><th>UQ</th><th>Rows</th><th>Reserved KB</th><th>Key cols</th><th>Included</th><th>Filter</th></tr></thead><tbody>");
                foreach (var i in t.Indexes)
                    Row(sb, i.Name, i.Type, i.IsPrimaryKey ? "Y" : "", i.IsUnique ? "Y" : "",
                        i.RowCount.ToString("N0"), i.ReservedKB.ToString("N0"),
                        string.Join(", ", i.KeyColumns),
                        string.Join(", ", i.IncludedColumns),
                        i.FilterDefinition);
                sb.AppendLine("</tbody></table></details>");
            }
            sb.AppendLine("</details>");
        }
        sb.AppendLine("</section>");
    }

    private static void WriteForeignKeys(StringBuilder sb, AnalysisResult r)
    {
        sb.AppendLine("<section id=\"foreignkeys\" class=\"flat\"><h2>Foreign Keys</h2>");
        sb.AppendLine("<table><thead><tr><th>Server</th><th>Database</th><th>Schema</th><th>Table</th><th>FK</th><th>Parent cols</th><th>References</th><th>Ref cols</th><th>On Delete</th><th>On Update</th><th>Disabled</th><th>Not trusted</th></tr></thead><tbody>");
        foreach (var n in r.AllObjects.Where(o => o.ForeignKeys.Count > 0))
        foreach (var fk in n.ForeignKeys)
            Row(sb, n.ServerName, n.DatabaseName, n.Schema, n.Name, fk.Name,
                string.Join(", ", fk.ParentColumns),
                $"[{fk.ReferencedSchema}].[{fk.ReferencedTable}]",
                string.Join(", ", fk.ReferencedColumns),
                fk.DeleteAction, fk.UpdateAction,
                fk.IsDisabled ? "yes" : "", fk.IsNotTrusted ? "yes" : "");
        sb.AppendLine("</tbody></table></section>");
    }

    private static void WritePartitions(StringBuilder sb, AnalysisResult r)
    {
        sb.AppendLine("<section id=\"partitions\" class=\"flat\"><h2>Partitions</h2>");
        sb.AppendLine("<table><thead><tr><th>Server</th><th>Database</th><th>Schema</th><th>Table</th><th>#</th><th>Boundary</th><th>Side</th><th>Rows</th><th>Data KB</th><th>Index KB</th><th>Total KB</th><th>FG</th></tr></thead><tbody>");
        foreach (var n in r.AllObjects.Where(o => o.TableMetrics?.IsPartitioned == true))
        foreach (var p in n.Partitions)
            Row(sb, n.ServerName, n.DatabaseName, n.Schema, n.Name,
                p.PartitionNumber.ToString(), p.BoundaryValue, p.BoundaryComparator,
                p.RowCount.ToString("N0"), p.DataKB.ToString("N0"),
                p.IndexKB.ToString("N0"), p.TotalKB.ToString("N0"), p.FileGroup);
        sb.AppendLine("</tbody></table></section>");
    }

    private static void WriteDefinitions(StringBuilder sb, AnalysisResult r)
    {
        sb.AppendLine("<section id=\"definitions\" class=\"flat\"><h2>Definitions</h2>");
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var n in r.AllObjects)
        {
            if (string.IsNullOrWhiteSpace(n.Definition)) continue;
            var key = $"{n.ServerName}|{n.DatabaseName}|{n.Schema}|{n.Name}";
            if (!seen.Add(key)) continue;
            sb.Append("<details id=\"").Append(Anchor("def", n)).Append("\"><summary>")
              .Append("<span class=\"icon\">").Append(IconFor(n.Type)).Append("</span>")
              .Append("<b>[").Append(Esc(n.ServerName)).Append("].[").Append(Esc(n.DatabaseName)).Append("].")
              .Append(Esc(n.QualifiedName)).Append("</b><span class=\"badge\">").Append(n.Type).Append("</span></summary>");
            sb.Append("<pre class=\"sql\">").Append(Esc(n.Definition)).Append("</pre>");
            sb.AppendLine("</details>");
        }
        sb.AppendLine("</section>");
    }

    // ──────────────────────────────────────────────────────────────────────
    // Helpers
    // ──────────────────────────────────────────────────────────────────────
    private static string Esc(string? s) => s is null ? "" : WebUtility.HtmlEncode(s);

    private static string IconFor(DbObjectType t) => t switch
    {
        DbObjectType.Table           => "▦",
        DbObjectType.View            => "◫",
        DbObjectType.StoredProcedure => "▶",
        DbObjectType.Function        => "ƒ",
        DbObjectType.Synonym         => "⇄",
        DbObjectType.Sequence        => "↻",
        _ => "?"
    };

    private static string Anchor(string prefix, DbObjectNode n)
    {
        var raw = $"{prefix}-{n.ServerName}-{n.DatabaseName}-{n.Schema}-{n.Name}".ToLowerInvariant();
        var sb = new StringBuilder(raw.Length);
        foreach (var c in raw)
            sb.Append(char.IsLetterOrDigit(c) || c == '-' ? c : '_');
        return sb.ToString();
    }

    private static void Row(StringBuilder sb, params string?[] cells)
    {
        sb.Append("<tr>");
        foreach (var c in cells)
            sb.Append("<td>").Append(Esc(c)).Append("</td>");
        sb.AppendLine("</tr>");
    }

