using System.Xml.Linq;
using SSISLens.Core;
using static SSISLens.Parsing.SsisNamespaces;

namespace SSISLens.Parsing;

/// <summary>
/// Reads a single .dtsx file and produces a PackageInfo with resolved connections
/// and a list of SQL fragments per task.
/// </summary>
public sealed class DtsxPackageReader
{
    private readonly AnalysisOptions _options;

    public DtsxPackageReader(AnalysisOptions options) => _options = options;

    public PackageInfo Read(string path,
                            IReadOnlyDictionary<string, string?> projectScopedValues)
    {
        var doc = XDocument.Load(path);
        var root = doc.Root ?? throw new InvalidDataException("Empty .dtsx");

        var pkg = new PackageInfo
        {
            Name = Path.GetFileNameWithoutExtension(path),
            Path = path,
            Version = root.DtsAttr("VersionBuild") ?? root.DtsAttr("ExecutableType"),
            CreatorName = root.DtsAttr("CreatorName"),
            CreationDate = root.DtsAttr("CreationDate"),
            ProtectionLevel = root.DtsAttr("ProtectionLevel")
        };

        ReadParameters(root, pkg);
        ReadVariables(root, pkg);

        var allValues = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase);
        foreach (var kv in projectScopedValues) allValues[kv.Key] = kv.Value;
        foreach (var v in pkg.Variables)   allValues[v.FullName]            = v.Value;
        foreach (var p in pkg.Parameters)
            allValues[$"$Package::{p.Name}"] = p.Value;
        foreach (var kv in _options.VariableOverrides)
            allValues[kv.Key] = kv.Value;

        var evaluator = new SsisExpressionEvaluator(allValues);

        ReadConnections(root, pkg, evaluator);
        ReadTasks(root, pkg);
        ResolveTaskConnectionReferences(pkg);

        return pkg;
    }

    /// <summary>
    /// SSDT-generated packages reference connections from tasks by DTSID (a GUID like
    /// {E1100002-…}). Map those back to ObjectName so downstream matching by name works.
    /// </summary>
    private static void ResolveTaskConnectionReferences(PackageInfo pkg)
    {
        var byDtsid = pkg.Connections
            .Where(c => !string.IsNullOrEmpty(c.Dtsid))
            .ToDictionary(c => NormalizeDtsid(c.Dtsid!), c => c.Name, StringComparer.OrdinalIgnoreCase);

        foreach (var t in pkg.Tasks)
        {
            if (string.IsNullOrEmpty(t.ConnectionName)) continue;
            var norm = NormalizeDtsid(t.ConnectionName);
            if (byDtsid.TryGetValue(norm, out var name))
                t.ConnectionName = name;
        }
    }

    private static string NormalizeDtsid(string s) =>
        s.Trim().TrimStart('{').TrimEnd('}');

    private static void ReadParameters(XElement root, PackageInfo pkg)
    {
        foreach (var p in root.DtsElements("PackageParameter").Concat(root.DtsElements("ProjectParameter")))
        {
            var name = p.DtsAttr("ObjectName") ?? "";
            if (string.IsNullOrEmpty(name)) continue;
            var prop = p.Descendants().FirstOrDefault(x => x.Name.LocalName == "Property" &&
                                                            x.DtsAttr("Name") == "ParameterValue");
            pkg.Parameters.Add(new SsisParameter
            {
                Name = name,
                Scope = p.Name.LocalName == "ProjectParameter" ? "$Project" : "$Package",
                DataType = p.DtsAttr("DataType"),
                Value = prop?.Value,
                Sensitive = string.Equals(p.DtsAttr("Sensitive"), "1", StringComparison.Ordinal)
            });
        }
    }

    private static void ReadVariables(XElement root, PackageInfo pkg)
    {
        foreach (var v in root.DtsElements("Variable"))
        {
            var name = v.DtsAttr("ObjectName") ?? "";
            if (string.IsNullOrEmpty(name)) continue;
            var valueEl = v.Descendants().FirstOrDefault(x => x.Name.LocalName == "VariableValue");
            var exprEl  = v.Descendants().FirstOrDefault(x => x.Name.LocalName == "Expression");
            pkg.Variables.Add(new SsisVariable
            {
                Namespace = v.DtsAttr("Namespace") ?? "User",
                Name = name,
                DataType = valueEl?.DtsAttr("DataType"),
                Value = valueEl?.Value,
                Expression = exprEl?.Value
            });
        }
    }

    private void ReadConnections(XElement root, PackageInfo pkg, SsisExpressionEvaluator evaluator)
    {
        // Only top-level ConnectionManager elements (children of <ConnectionManagers>)
        // — the inner <ConnectionManager> nested in <ObjectData> is the design-time
        // payload, not a separate connection.
        foreach (var cm in root.DtsElements("ConnectionManager")
                                .Where(x => x.Parent?.Name.LocalName == "ConnectionManagers"))
        {
            var name = cm.DtsAttr("ObjectName") ?? "(unnamed)";
            var creation = cm.DtsAttr("CreationName");
            var ci = new ConnectionInfo
            {
                Name = name,
                Dtsid = cm.DtsAttr("DTSID"),
                CreationName = creation
            };

            string? designConnStr = null;
            var objData = cm.Descendants().FirstOrDefault(x => x.Name.LocalName == "ObjectData");
            if (objData is not null)
            {
                var inner = objData.Descendants().FirstOrDefault(x => x.Name.LocalName == "ConnectionManager");
                designConnStr = inner?.DtsAttr("ConnectionString") ?? inner?.Attributes()
                    .FirstOrDefault(a => a.Name.LocalName == "ConnectionString")?.Value;
            }
            designConnStr ??= cm.DtsAttr("ConnectionString");

            if (designConnStr is not null)
            {
                ci.ProvenanceTrail.Add(new ResolutionStep
                {
                    Source = "DesignTime",
                    Property = "ConnectionString",
                    Value = designConnStr
                });
                ci.RawConnectionString = designConnStr;
            }

            foreach (var expr in cm.DtsElements("PropertyExpression"))
            {
                var prop = expr.DtsAttr("Name") ?? "";
                var rawExpr = expr.Value;
                var step = new ResolutionStep
                {
                    Source = "PropertyExpression",
                    Property = prop,
                    Value = rawExpr
                };
                evaluator.TryEvaluate(rawExpr, out var evaluated, out var unresolved);
                if (unresolved.Count > 0)
                {
                    step.Note = "Unresolved: " + string.Join(", ", unresolved);
                    ci.Issues.Add($"{prop}: unresolved {string.Join(", ", unresolved)}");
                }
                ci.ProvenanceTrail.Add(step);
                if (prop.Equals("ConnectionString", StringComparison.OrdinalIgnoreCase) && evaluated is not null)
                {
                    ci.RawConnectionString = evaluated;
                    if (unresolved.Count > 0) ci.Status = ResolutionStatus.PartiallyResolved;
                }
            }

            var (prov, server, db, auth) =
                ConnectionStringClassifier.Parse(creation, ci.RawConnectionString);
            ci.Provider = prov;
            ci.Server   = server;
            ci.Database = db;
            ci.Auth     = auth;
            ci.MaskedConnectionString = ConnectionStringMasker.Mask(ci.RawConnectionString);
            if (ci.RawConnectionString is { Length: > 0 } &&
                ci.RawConnectionString.Contains("<<UNRESOLVED:", StringComparison.Ordinal))
            {
                ci.Status = ResolutionStatus.Unresolved;
            }

            pkg.Connections.Add(ci);
        }
    }

    private static void ReadTasks(XElement root, PackageInfo pkg)
    {
        foreach (var exec in root.DtsElements("Executable"))
        {
            var creation = exec.DtsAttr("CreationName") ?? "";
            var name = exec.DtsAttr("ObjectName") ?? "(unnamed)";
            var task = new TaskRef
            {
                Name = name,
                CreationName = creation
            };

            var sqlTask = exec.Descendants().FirstOrDefault(x =>
                x.Name.LocalName == "SqlTaskData" || x.Name.LocalName == "SqlTask");
            if (sqlTask is not null)
            {
                task.Sql = sqlTask.Attributes()
                    .FirstOrDefault(a => a.Name.LocalName == "SqlStatementSource")?.Value;
                task.ConnectionName = sqlTask.Attributes()
                    .FirstOrDefault(a => a.Name.LocalName == "Connection")?.Value;
            }

            foreach (var comp in exec.Descendants().Where(x => x.Name.LocalName == "component"))
            {
                foreach (var prop in comp.Descendants().Where(x => x.Name.LocalName == "property"))
                {
                    var pname = prop.Attribute("name")?.Value;
                    if (pname is "SqlCommand" or "SqlCommandVariable" or "OpenRowset" or "OpenRowsetVariable")
                    {
                        var val = prop.Value;
                        if (!string.IsNullOrWhiteSpace(val))
                        {
                            if (task.Sql is null) task.Sql = val;
                            else task.Sql += ";\n" + val;
                        }
                    }
                }
                foreach (var cn in comp.Descendants().Where(x => x.Name.LocalName == "connection"))
                {
                    var cName = cn.Attribute("name")?.Value;
                    if (!string.IsNullOrWhiteSpace(cName) && task.ConnectionName is null)
                        task.ConnectionName = cName;
                }
            }

            if (task.Sql is not null || task.ConnectionName is not null)
                pkg.Tasks.Add(task);
        }
    }
}




