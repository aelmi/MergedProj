        var errors = new List<string>();
        parseErrors = errors;
        if (string.IsNullOrWhiteSpace(sql)) return Array.Empty<SqlObjectRef>();

        var parser = new TSql160Parser(initialQuotedIdentifiers: true);
        IList<ParseError> errs;
        TSqlFragment fragment;
        using (var reader = new StringReader(sql))
            fragment = parser.Parse(reader, out errs);

        foreach (var e in errs)
            errors.Add($"L{e.Line}:{e.Column} {e.Message}");

        var visitor = new Visitor();
        fragment.Accept(visitor);
        return visitor.Results;
    }

    private sealed class Visitor : TSqlFragmentVisitor
    {
        private readonly Dictionary<string, SqlObjectRef> _dedup = new(StringComparer.OrdinalIgnoreCase);
        public IReadOnlyList<SqlObjectRef> Results => _dedup.Values.ToList();

        public override void ExplicitVisit(NamedTableReference node)
        {
            Add(node.SchemaObject, AccessKind.Read);
            base.ExplicitVisit(node);
        }

        public override void ExplicitVisit(InsertSpecification node)
        {
            if (node.Target is NamedTableReference ntr) Add(ntr.SchemaObject, AccessKind.Write);
            base.ExplicitVisit(node);
        }

        public override void ExplicitVisit(UpdateSpecification node)
        {
            if (node.Target is NamedTableReference ntr) Add(ntr.SchemaObject, AccessKind.Write);
            base.ExplicitVisit(node);
        }

        public override void ExplicitVisit(DeleteSpecification node)
        {
            if (node.Target is NamedTableReference ntr) Add(ntr.SchemaObject, AccessKind.Write);
            base.ExplicitVisit(node);
        }

        public override void ExplicitVisit(MergeSpecification node)
        {
            if (node.Target is NamedTableReference ntr) Add(ntr.SchemaObject, AccessKind.Write);
            base.ExplicitVisit(node);
        }

        public override void ExplicitVisit(ExecuteSpecification node)
        {
            if (node.ExecutableEntity is ExecutableProcedureReference p &&
                p.ProcedureReference?.ProcedureReference?.Name is { } n)
            {
                Add(n, AccessKind.Execute);
            }
            base.ExplicitVisit(node);
        }

        public override void ExplicitVisit(CreateTableStatement node)
        {
            Add(node.SchemaObjectName, AccessKind.Ddl);
            base.ExplicitVisit(node);
        }

        public override void ExplicitVisit(DropTableStatement node)
        {
            foreach (var o in node.Objects) Add(o, AccessKind.Ddl);
            base.ExplicitVisit(node);
        }

        public override void ExplicitVisit(TruncateTableStatement node)
        {
            Add(node.TableName, AccessKind.Write);
            base.ExplicitVisit(node);
        }

        public override void ExplicitVisit(BulkInsertStatement node)
        {
            Add(node.To, AccessKind.Write);
            base.ExplicitVisit(node);
        }

        private void Add(SchemaObjectName? n, AccessKind access)
        {
            if (n is null) return;
            string? server = n.ServerIdentifier?.Value;
            string? database = n.DatabaseIdentifier?.Value;
            string schema = n.SchemaIdentifier?.Value ?? "dbo";
            string name = n.BaseIdentifier?.Value ?? "";
            if (string.IsNullOrWhiteSpace(name)) return;
            var key = $"{server}|{database}|{schema}|{name}|{access}".ToLowerInvariant();
            _dedup.TryAdd(key, new SqlObjectRef(server, database, schema, name, access));
        }
    }
}




