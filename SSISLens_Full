using System.Drawing.Drawing2D;
using System.Runtime.InteropServices;

namespace SSISLens.UI;

/// <summary>
/// Flat rounded-rectangle button with hover / pressed / disabled states.
/// Native WinForms only — no external dependencies.
/// </summary>
internal class ModernButton : Button
{
    public int Radius { get; set; } = 8;
    public Color HoverBackColor { get; set; } = Color.Empty;
    public Color HoverForeColor { get; set; } = Color.Empty;
    public Color HoverBorderColor { get; set; } = Color.Empty;
    public Color PressedBackColor { get; set; } = Color.Empty;
    public Color DisabledBackColorOverride { get; set; } = Color.Empty;
    public Color DisabledForeColorOverride { get; set; } = Color.Empty;
    public Color BorderColor { get; set; } = Color.Empty;
    public int BorderSize { get; set; } = 0;
    public int ShadowDepth { get; set; } = 0;

    private bool _hovering;
    private bool _pressed;

    public ModernButton()
    {
        SetStyle(ControlStyles.OptimizedDoubleBuffer
               | ControlStyles.AllPaintingInWmPaint
               | ControlStyles.ResizeRedraw
               | ControlStyles.UserPaint
               | ControlStyles.SupportsTransparentBackColor, true);
        FlatStyle = FlatStyle.Flat;
        FlatAppearance.BorderSize = 0;
        FlatAppearance.MouseOverBackColor = Color.Transparent;
        FlatAppearance.MouseDownBackColor = Color.Transparent;
        Cursor = Cursors.Hand;
        BackColor = Color.Transparent;
    }

    protected override void OnMouseEnter(EventArgs e) { _hovering = true; Invalidate(); base.OnMouseEnter(e); }
    protected override void OnMouseLeave(EventArgs e) { _hovering = false; _pressed = false; Invalidate(); base.OnMouseLeave(e); }
    protected override void OnMouseDown(MouseEventArgs mevent) { _pressed = true; Invalidate(); base.OnMouseDown(mevent); }
    protected override void OnMouseUp(MouseEventArgs mevent) { _pressed = false; Invalidate(); base.OnMouseUp(mevent); }
    protected override void OnEnabledChanged(EventArgs e) { Invalidate(); base.OnEnabledChanged(e); }

    protected override void OnPaintBackground(PaintEventArgs pevent)
    {
        // Mask any default Button border by painting the parent's color across the whole client rect.
        var bg = Parent?.BackColor ?? SystemColors.Control;
        using var brush = new SolidBrush(bg);
        pevent.Graphics.FillRectangle(brush, ClientRectangle);
    }

    protected override void OnPaint(PaintEventArgs pevent)
    {
        var g = pevent.Graphics;
        g.SmoothingMode = SmoothingMode.AntiAlias;
        g.PixelOffsetMode = PixelOffsetMode.HighQuality;
        g.TextRenderingHint = System.Drawing.Text.TextRenderingHint.ClearTypeGridFit;

        var bg = !Enabled && DisabledBackColorOverride != Color.Empty ? DisabledBackColorOverride
               : _pressed && PressedBackColor != Color.Empty           ? PressedBackColor
               : _hovering && HoverBackColor != Color.Empty            ? HoverBackColor
               : BackColor == Color.Transparent ? (Parent?.BackColor ?? SystemColors.Control) : BackColor;
        var fg = !Enabled && DisabledForeColorOverride != Color.Empty ? DisabledForeColorOverride
               : _hovering && HoverForeColor != Color.Empty           ? HoverForeColor
               : ForeColor;
        var border = !Enabled                                        ? Color.Empty
                   : _hovering && HoverBorderColor != Color.Empty    ? HoverBorderColor
                   : BorderColor;

        var rect = new Rectangle(0, 0, Width - 1, Height - 1 - ShadowDepth);

        if (Enabled && ShadowDepth > 0)
        {
            var shadow = new Rectangle(0, ShadowDepth, Width - 1, Height - 1 - ShadowDepth);
            using var shadowPath = RoundedPath(shadow, Radius);
            using var shadowBrush = new SolidBrush(Color.FromArgb(35, 0, 0, 0));
            g.FillPath(shadowBrush, shadowPath);
        }

        using var path = RoundedPath(rect, Radius);
        using (var brush = new SolidBrush(bg)) g.FillPath(brush, path);
        if (BorderSize > 0 && border != Color.Empty)
            using (var pen = new Pen(border, BorderSize)) g.DrawPath(pen, path);

        var textRect = rect;
        textRect.Inflate(-6, -2);
        TextRenderer.DrawText(g, Text, Font, textRect, fg,
            TextFormatFlags.HorizontalCenter | TextFormatFlags.VerticalCenter | TextFormatFlags.SingleLine | TextFormatFlags.EndEllipsis);
    }

    internal static GraphicsPath RoundedPath(Rectangle r, int radius)
    {
        var path = new GraphicsPath();
        if (radius <= 0 || r.Width <= 0 || r.Height <= 0) { path.AddRectangle(r); return path; }
        int d = Math.Min(radius * 2, Math.Min(r.Width, r.Height));
        path.AddArc(r.X, r.Y, d, d, 180, 90);
        path.AddArc(r.Right - d, r.Y, d, d, 270, 90);
        path.AddArc(r.Right - d, r.Bottom - d, d, d, 0, 90);
        path.AddArc(r.X, r.Bottom - d, d, d, 90, 90);
        path.CloseFigure();
        return path;
    }
}

/// <summary>Panel with an optional 1px border and optional rounded corners.</summary>
internal class CardPanel : Panel
{
    public Color BorderColor { get; set; } = Color.Empty;
    public int Radius { get; set; } = 0;

    public CardPanel()
    {
        SetStyle(ControlStyles.OptimizedDoubleBuffer
               | ControlStyles.AllPaintingInWmPaint
               | ControlStyles.ResizeRedraw
               | ControlStyles.UserPaint, true);
        DoubleBuffered = true;
    }

    protected override void OnPaintBackground(PaintEventArgs e)
    {
        if (Radius <= 0) { base.OnPaintBackground(e); return; }
        // Paint the parent's background across the whole rect so rounded corners show through.
        var parentBg = Parent?.BackColor ?? BackColor;
        using var brush = new SolidBrush(parentBg);
        e.Graphics.FillRectangle(brush, ClientRectangle);
    }

    protected override void OnPaint(PaintEventArgs e)
    {
        var g = e.Graphics;
        g.SmoothingMode = SmoothingMode.AntiAlias;
        var rect = new Rectangle(0, 0, Width - 1, Height - 1);
        using var path = ModernButton.RoundedPath(rect, Radius);
        using (var brush = new SolidBrush(BackColor)) g.FillPath(brush, path);
        if (BorderColor != Color.Empty)
            using (var pen = new Pen(BorderColor)) g.DrawPath(pen, path);
    }
}

/// <summary>
/// TextBox with a Placeholder string property (applied via Win32 cue banner).
/// Designer-friendly: VS Designer can set Placeholder like any other property.
/// </summary>
internal class PlaceholderTextBox : TextBox
{
    private const int EM_SETCUEBANNER = 0x1501;

    [DllImport("user32.dll", CharSet = CharSet.Unicode)]
    private static extern IntPtr SendMessage(IntPtr hWnd, int msg, IntPtr wParam, string lParam);

    private string _placeholder = string.Empty;

    public string Placeholder
    {
        get => _placeholder;
        set
        {
            _placeholder = value ?? string.Empty;
            if (IsHandleCreated) Apply();
        }
    }

    protected override void OnHandleCreated(EventArgs e)
    {
        base.OnHandleCreated(e);
        if (!string.IsNullOrEmpty(_placeholder)) Apply();
    }

    private void Apply() => SendMessage(Handle, EM_SETCUEBANNER, (IntPtr)1, _placeholder);
}




