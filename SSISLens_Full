using Microsoft.Data.SqlClient;
using SSISLens.Core;

namespace SSISLens.Sql;

public sealed class IndexRepo
{
    private readonly SqlConnectionFactory _factory;

    public IndexRepo(SqlConnectionFactory factory) => _factory = factory;

    private const string Query = @"
WITH stats AS (
    SELECT p.object_id, p.index_id,
           SUM(p.rows) AS rows_total,
           SUM(a.total_pages) * 8 AS reserved_kb,
           SUM(a.used_pages)  * 8 AS used_kb
    FROM sys.partitions p
    JOIN sys.allocation_units a ON a.container_id = p.partition_id
    GROUP BY p.object_id, p.index_id
)
SELECT
    i.name, i.type_desc, i.is_unique, i.is_primary_key, i.is_disabled, i.filter_definition,
    s.rows_total, s.reserved_kb, s.used_kb,
    STUFF((
        SELECT ', ' + c.name
        FROM sys.index_columns ic
        JOIN sys.columns c ON c.object_id = ic.object_id AND c.column_id = ic.column_id
        WHERE ic.object_id = i.object_id AND ic.index_id = i.index_id AND ic.is_included_column = 0
        ORDER BY ic.key_ordinal
        FOR XML PATH(''), TYPE).value('.', 'NVARCHAR(MAX)'), 1, 2, '') AS key_cols,
    STUFF((
        SELECT ', ' + c.name
        FROM sys.index_columns ic
        JOIN sys.columns c ON c.object_id = ic.object_id AND c.column_id = ic.column_id
        WHERE ic.object_id = i.object_id AND ic.index_id = i.index_id AND ic.is_included_column = 1
        ORDER BY ic.key_ordinal
        FOR XML PATH(''), TYPE).value('.', 'NVARCHAR(MAX)'), 1, 2, '') AS inc_cols
FROM sys.indexes i
LEFT JOIN stats s ON s.object_id = i.object_id AND s.index_id = i.index_id
WHERE i.object_id = OBJECT_ID(QUOTENAME(@s) + '.' + QUOTENAME(@n))
  AND i.type > 0
ORDER BY i.is_primary_key DESC, i.is_unique DESC, i.name;";

    public async Task<List<IndexInfo>> GetAsync(string server, string database,
        string schema, string name, CancellationToken ct)
    {
        var list = new List<IndexInfo>();
        await using var conn = await _factory.OpenAsync(server, database, ct).ConfigureAwait(false);
        await using var cmd = new SqlCommand(Query, conn) { CommandTimeout = _factory.CommandTimeoutSeconds };
        cmd.Parameters.AddWithValue("@s", schema);
        cmd.Parameters.AddWithValue("@n", name);
        await using var r = await cmd.ExecuteReaderAsync(ct).ConfigureAwait(false);
        while (await r.ReadAsync(ct).ConfigureAwait(false))
        {
            var idx = new IndexInfo
            {
                Name           = r.IsDBNull(0) ? "" : r.GetString(0),
                Type           = r.IsDBNull(1) ? "" : r.GetString(1),
                IsUnique       = !r.IsDBNull(2) && r.GetBoolean(2),
                IsPrimaryKey   = !r.IsDBNull(3) && r.GetBoolean(3),
                IsDisabled     = !r.IsDBNull(4) && r.GetBoolean(4),
                FilterDefinition = r.IsDBNull(5) ? null : r.GetString(5),
                RowCount       = r.IsDBNull(6) ? 0 : Convert.ToInt64(r.GetValue(6)),
                ReservedKB     = r.IsDBNull(7) ? 0 : Convert.ToInt64(r.GetValue(7)),
                UsedKB         = r.IsDBNull(8) ? 0 : Convert.ToInt64(r.GetValue(8))
            };
            var keyCols = r.IsDBNull(9)  ? "" : r.GetString(9);
            var incCols = r.IsDBNull(10) ? "" : r.GetString(10);
            foreach (var c in keyCols.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                idx.KeyColumns.Add(c);
            foreach (var c in incCols.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                idx.IncludedColumns.Add(c);
            list.Add(idx);
        }
        return list;
    }
}




