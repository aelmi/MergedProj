using System.IO.Compression;
using System.Xml.Linq;
using SSISLens.Core;
using static SSISLens.Parsing.SsisNamespaces;

namespace SSISLens.Parsing;

public sealed class IspacReader
{
    public sealed record ProjectContext(
        Dictionary<string, string?> ProjectValues,
        List<(string PackageName, string ExtractedPath)> Packages,
        string TempDir,
        List<ConnectionInfo> ProjectConnections);

    private readonly AnalysisOptions _options;

    public IspacReader(AnalysisOptions options) => _options = options;

    public ProjectContext ExtractAndRead(string ispacPath)
    {
        var tempDir = Path.Combine(Path.GetTempPath(), "SSISLens_" + Guid.NewGuid().ToString("N"));
        Directory.CreateDirectory(tempDir);
        ZipFile.ExtractToDirectory(ispacPath, tempDir);

        var projectValues = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase);
        var projectConns  = new List<ConnectionInfo>();

        foreach (var paramsFile in Directory.GetFiles(tempDir, "Project.params", SearchOption.AllDirectories))
        {
            var doc = XDocument.Load(paramsFile);
            foreach (var p in doc.Descendants().Where(x => x.Name.LocalName == "Parameter"))
            {
                var name = p.Attributes().FirstOrDefault(a => a.Name.LocalName == "Name")?.Value;
                var val  = p.Descendants().FirstOrDefault(x => x.Name.LocalName == "Value")?.Value;
                if (!string.IsNullOrEmpty(name))
                    projectValues["$Project::" + name] = val;
            }
        }

        foreach (var conmgr in Directory.GetFiles(tempDir, "*.conmgr", SearchOption.AllDirectories))
        {
            try
            {
                var doc = XDocument.Load(conmgr);
                var cm = doc.Descendants().FirstOrDefault(x => x.Name.LocalName == "ConnectionManager");
                if (cm is null) continue;
                var name = cm.DtsAttr("ObjectName") ?? Path.GetFileNameWithoutExtension(conmgr);
                var creation = cm.DtsAttr("CreationName");
                var inner = cm.Descendants().FirstOrDefault(x => x.Name.LocalName == "ConnectionManager");
                var connStr = inner?.Attributes().FirstOrDefault(a => a.Name.LocalName == "ConnectionString")?.Value
                              ?? cm.DtsAttr("ConnectionString");
                var (prov, server, db, auth) = ConnectionStringClassifier.Parse(creation, connStr);
                var ci = new ConnectionInfo
                {
                    Name = name,
                    CreationName = creation,
                    Provider = prov,
                    Server = server,
                    Database = db,
                    Auth = auth,
                    RawConnectionString = connStr,
                    MaskedConnectionString = ConnectionStringMasker.Mask(connStr)
                };
                ci.ProvenanceTrail.Add(new ResolutionStep
                {
                    Source = "ProjectConnectionManager",
                    Property = "ConnectionString",
                    Value = connStr
                });
                projectConns.Add(ci);
            }
            catch { /* skip bad conmgr */ }
        }

        var pkgs = Directory.GetFiles(tempDir, "*.dtsx", SearchOption.AllDirectories)
            .Select(f => (Path.GetFileNameWithoutExtension(f), f))
            .ToList();

        return new ProjectContext(projectValues, pkgs, tempDir, projectConns);
    }
}




