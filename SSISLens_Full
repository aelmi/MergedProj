    public List<DatabaseInfo> Databases { get; } = new();
    public List<string> Warnings { get; } = new();
    public TimeSpan? Duration { get; set; }

    public IEnumerable<ConnectionInfo> AllConnections =>
        Packages.SelectMany(p => p.Connections);

    public IEnumerable<DbObjectNode> AllObjects =>
        AllConnections.SelectMany(c => Flatten(c.Objects));

    private static IEnumerable<DbObjectNode> Flatten(IEnumerable<DbObjectNode> nodes)
    {
        foreach (var n in nodes)
        {
            yield return n;
            foreach (var child in Flatten(n.Children))
                yield return child;
        }
    }
}




