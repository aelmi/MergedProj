        => _commandTimeoutSeconds = commandTimeoutSeconds;

    public int CommandTimeoutSeconds => _commandTimeoutSeconds;

    public async Task<SqlConnection> OpenAsync(string server, string? database, CancellationToken ct)
    {
        var b = new SqlConnectionStringBuilder
        {
            DataSource = server,
            IntegratedSecurity = true,
            TrustServerCertificate = true,
            Encrypt = false,
            ConnectTimeout = 10,
            ApplicationName = "SSISLens"
        };
        if (!string.IsNullOrWhiteSpace(database))
            b.InitialCatalog = database!;

        var conn = new SqlConnection(b.ConnectionString);
        await conn.OpenAsync(ct).ConfigureAwait(false);
        return conn;
    }
}




