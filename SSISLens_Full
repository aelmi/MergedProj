using Microsoft.Data.SqlClient;
using SSISLens.Core;

namespace SSISLens.Sql;

/// <summary>
/// sp_help-style schema reads: tables list, columns, foreign keys, and table filegroup.
/// All queries are set-based per-DB to keep latency low on wide schemas.
/// </summary>
public sealed class TableSchemaRepo
{
    private readonly SqlConnectionFactory _factory;

    public TableSchemaRepo(SqlConnectionFactory factory) => _factory = factory;

    public async Task<List<(string Schema, string Name)>> ListTablesAsync(
        string server, string database, CancellationToken ct)
    {
        var list = new List<(string, string)>();
        await using var conn = await _factory.OpenAsync(server, database, ct).ConfigureAwait(false);
        await using var cmd = new SqlCommand(@"
SELECT s.name AS schema_name, t.name AS table_name
FROM sys.tables t
JOIN sys.schemas s ON s.schema_id = t.schema_id
WHERE t.is_ms_shipped = 0
ORDER BY s.name, t.name;", conn) { CommandTimeout = _factory.CommandTimeoutSeconds };
        await using var r = await cmd.ExecuteReaderAsync(ct).ConfigureAwait(false);
        while (await r.ReadAsync(ct).ConfigureAwait(false))
            list.Add((r.GetString(0), r.GetString(1)));
        return list;
    }

    /// <summary>Lists user views, stored procedures, scalar/inline/TVFs in one DB.</summary>
    public async Task<List<(string Schema, string Name, string TypeDesc)>> ListProgrammableObjectsAsync(
        string server, string database, CancellationToken ct)
    {
        var list = new List<(string, string, string)>();
        await using var conn = await _factory.OpenAsync(server, database, ct).ConfigureAwait(false);
        await using var cmd = new SqlCommand(@"
SELECT s.name AS schema_name, o.name AS obj_name, o.type_desc
FROM sys.objects o
JOIN sys.schemas s ON s.schema_id = o.schema_id
WHERE o.is_ms_shipped = 0
  AND o.type IN ('V','P','FN','IF','TF','SO')   -- view, proc, scalar/inline/TVF, sequence
ORDER BY s.name, o.name;", conn) { CommandTimeout = _factory.CommandTimeoutSeconds };
        await using var r = await cmd.ExecuteReaderAsync(ct).ConfigureAwait(false);
        while (await r.ReadAsync(ct).ConfigureAwait(false))
            list.Add((r.GetString(0), r.GetString(1), r.GetString(2)));
        return list;
    }

    public async Task<List<ColumnInfo>> GetColumnsAsync(
        string server, string database, string schema, string name, CancellationToken ct)
    {
        var list = new List<ColumnInfo>();
        await using var conn = await _factory.OpenAsync(server, database, ct).ConfigureAwait(false);
        await using var cmd = new SqlCommand(@"
SELECT
    c.column_id,
    c.name,
    ty.name AS type_name,
    c.max_length,
    c.precision,
    c.scale,
    c.is_nullable,
    c.is_identity,
    c.is_computed,
    c.collation_name,
    OBJECT_DEFINITION(dc.object_id) AS default_def,
    cc.definition AS computed_def,
    CASE WHEN EXISTS (
        SELECT 1
        FROM sys.indexes i
        JOIN sys.index_columns ic ON ic.object_id = i.object_id AND ic.index_id = i.index_id
        WHERE i.is_primary_key = 1
          AND i.object_id = c.object_id
          AND ic.column_id = c.column_id
    ) THEN 1 ELSE 0 END AS is_pk
FROM sys.columns c
JOIN sys.types ty ON ty.user_type_id = c.user_type_id
LEFT JOIN sys.default_constraints dc ON dc.parent_object_id = c.object_id AND dc.parent_column_id = c.column_id
LEFT JOIN sys.computed_columns cc ON cc.object_id = c.object_id AND cc.column_id = c.column_id
WHERE c.object_id = OBJECT_ID(QUOTENAME(@s) + '.' + QUOTENAME(@n))
ORDER BY c.column_id;",
            conn)
        { CommandTimeout = _factory.CommandTimeoutSeconds };
        cmd.Parameters.AddWithValue("@s", schema);
        cmd.Parameters.AddWithValue("@n", name);
        await using var r = await cmd.ExecuteReaderAsync(ct).ConfigureAwait(false);
        while (await r.ReadAsync(ct).ConfigureAwait(false))
        {
            list.Add(new ColumnInfo
            {
                Ordinal            = r.GetInt32(0),
                Name               = r.GetString(1),
                DataType           = r.GetString(2),
                MaxLength          = r.GetInt16(3),
                Precision          = r.GetByte(4),
                Scale              = r.GetByte(5),
                IsNullable         = r.GetBoolean(6),
                IsIdentity         = r.GetBoolean(7),
                IsComputed         = r.GetBoolean(8),
                Collation          = r.IsDBNull(9) ? null : r.GetString(9),
                DefaultDefinition  = r.IsDBNull(10) ? null : r.GetString(10),
                ComputedDefinition = r.IsDBNull(11) ? null : r.GetString(11),
                IsPrimaryKey       = r.GetInt32(12) == 1
            });
        }
        return list;
    }

    public async Task<List<ForeignKeyInfo>> GetForeignKeysAsync(
        string server, string database, string schema, string name, CancellationToken ct)
    {
        await using var conn = await _factory.OpenAsync(server, database, ct).ConfigureAwait(false);
        await using var cmd = new SqlCommand(@"
SELECT
    fk.name AS fk_name,
    pc.name AS parent_col,
    rs.name AS ref_schema,
    rt.name AS ref_table,
    rc.name AS ref_col,
    fk.delete_referential_action_desc,
    fk.update_referential_action_desc,
    fk.is_disabled,
    fk.is_not_trusted,
    fkc.constraint_column_id
FROM sys.foreign_keys fk
JOIN sys.foreign_key_columns fkc ON fkc.constraint_object_id = fk.object_id
JOIN sys.tables pt ON pt.object_id = fk.parent_object_id
JOIN sys.schemas ps ON ps.schema_id = pt.schema_id
JOIN sys.columns pc ON pc.object_id = fkc.parent_object_id AND pc.column_id = fkc.parent_column_id
JOIN sys.tables rt ON rt.object_id = fk.referenced_object_id
JOIN sys.schemas rs ON rs.schema_id = rt.schema_id
JOIN sys.columns rc ON rc.object_id = fkc.referenced_object_id AND rc.column_id = fkc.referenced_column_id
WHERE ps.name = @s AND pt.name = @n
ORDER BY fk.name, fkc.constraint_column_id;",
            conn)
        { CommandTimeout = _factory.CommandTimeoutSeconds };
        cmd.Parameters.AddWithValue("@s", schema);
        cmd.Parameters.AddWithValue("@n", name);

        var byName = new Dictionary<string, ForeignKeyInfo>(StringComparer.OrdinalIgnoreCase);
        await using var r = await cmd.ExecuteReaderAsync(ct).ConfigureAwait(false);
        while (await r.ReadAsync(ct).ConfigureAwait(false))
        {
            var fkName = r.GetString(0);
            if (!byName.TryGetValue(fkName, out var fk))
            {
                fk = new ForeignKeyInfo
                {
                    Name             = fkName,
                    ReferencedSchema = r.GetString(2),
                    ReferencedTable  = r.GetString(3),
                    DeleteAction     = r.GetString(5),
                    UpdateAction     = r.GetString(6),
                    IsDisabled       = r.GetBoolean(7),
                    IsNotTrusted     = r.GetBoolean(8)
                };
                byName[fkName] = fk;
            }
            fk.ParentColumns.Add(r.GetString(1));
            fk.ReferencedColumns.Add(r.GetString(4));
        }
        return byName.Values.ToList();
    }

    public async Task<string?> GetFileGroupAsync(
        string server, string database, string schema, string name, CancellationToken ct)
    {
        await using var conn = await _factory.OpenAsync(server, database, ct).ConfigureAwait(false);
        await using var cmd = new SqlCommand(@"
SELECT TOP (1) COALESCE(fg.name, ps.name)
FROM sys.indexes i
JOIN sys.data_spaces ds ON ds.data_space_id = i.data_space_id
LEFT JOIN sys.filegroups fg ON fg.data_space_id = ds.data_space_id
LEFT JOIN sys.partition_schemes ps ON ps.data_space_id = ds.data_space_id
WHERE i.object_id = OBJECT_ID(QUOTENAME(@s) + '.' + QUOTENAME(@n))
  AND i.index_id IN (0, 1);",
            conn)
        { CommandTimeout = _factory.CommandTimeoutSeconds };
        cmd.Parameters.AddWithValue("@s", schema);
        cmd.Parameters.AddWithValue("@n", name);
        var v = await cmd.ExecuteScalarAsync(ct).ConfigureAwait(false);
        return v is string s ? s : null;
    }
}




