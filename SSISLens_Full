using SSISLens.Core;

namespace SSISLens.Parsing;

/// <summary>
/// Front door for the parsing layer: takes a file/folder path and returns a list
/// of parsed PackageInfo objects. Handles .dtsx, folders of .dtsx, and .ispac.
/// </summary>
public sealed class PackageSourceLoader
{
    private readonly AnalysisOptions _options;

    public PackageSourceLoader(AnalysisOptions options) => _options = options;

    public IReadOnlyList<PackageInfo> Load(string path, out List<ConnectionInfo> projectConnections)
    {
        projectConnections = new List<ConnectionInfo>();
        if (Directory.Exists(path))
        {
            var pkgs = new List<PackageInfo>();
            var reader = new DtsxPackageReader(_options);
            foreach (var f in Directory.GetFiles(path, "*.dtsx", SearchOption.AllDirectories))
                pkgs.Add(reader.Read(f, EmptyDict));
            return pkgs;
        }

        if (!File.Exists(path))
            throw new FileNotFoundException("Source not found", path);

        var ext = Path.GetExtension(path).ToLowerInvariant();
        if (ext == ".ispac")
        {
            var ispac = new IspacReader(_options);
            var ctx = ispac.ExtractAndRead(path);
            projectConnections.AddRange(ctx.ProjectConnections);
            var reader = new DtsxPackageReader(_options);
            var pkgs = new List<PackageInfo>();
            foreach (var (_, p) in ctx.Packages)
                pkgs.Add(reader.Read(p, ctx.ProjectValues));

            foreach (var pkg in pkgs)
            {
                foreach (var pc in ctx.ProjectConnections)
                {
                    if (!pkg.Connections.Any(c => c.Name.Equals(pc.Name, StringComparison.OrdinalIgnoreCase)))
                        pkg.Connections.Add(pc);
                }
            }
            return pkgs;
        }

        if (ext == ".dtsx")
        {
            var reader = new DtsxPackageReader(_options);
            return new[] { reader.Read(path, EmptyDict) };
        }

        throw new NotSupportedException($"Unsupported source: {ext}");
    }

    private static readonly Dictionary<string, string?> EmptyDict =
        new(StringComparer.OrdinalIgnoreCase);
}




