    // Objects sheet — Package → Connection → Object, with nested dependency tree
    // (sps/views drill into the tables/views they reference via Children + SynonymTarget).
    // Top-level objects visible; each dependency level collapsible under its parent.
    private static void WriteObjects(XLWorkbook wb, AnalysisResult r,
        IDictionary<string, string> schemaAnchors,
        IDictionary<string, string> defAnchors)
    {
        var ws = wb.AddWorksheet("Objects");
        ws.Outline.SummaryVLocation = XLOutlineSummaryVLocation.Top;

        var headers = new[] { "Object", "Type", "Access", "Server", "Database", "Schema", "Name",
                              "Rows", "Total (MB)", "Columns", "Indexes", "FKs", "FileGroup", "ReferencedBy" };
        for (var i = 0; i < headers.Length; i++) ws.Cell(1, i + 1).Value = headers[i];
        var hr = ws.Range(1, 1, 1, headers.Length);
        hr.Style.Fill.BackgroundColor = XLColor.FromHtml("#0D47A1");
        hr.Style.Font.FontColor = XLColor.White;
        hr.Style.Font.Bold = true;
        ws.SheetView.FreezeRows(1);

        var row = 2;
        foreach (var pkg in r.Packages)
        {
            // Level 0 — package band (always visible)
            ws.Cell(row, 1).Value = "📦 " + pkg.Name;
            ws.Cell(row, 2).Value = "Package";
            ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.FromHtml("#E3F0FF");
            ws.Range(row, 1, row, headers.Length).Style.Font.Bold = true;
            row++;

            foreach (var c in pkg.Connections)
            {
                if (c.Objects.Count == 0) continue;
                // Level 1 — connection band
                ws.Cell(row, 1).Value = "    🔌 " + c.Name;
                ws.Cell(row, 2).Value = "Connection";
                ws.Cell(row, 4).Value = c.Server ?? "";
                ws.Cell(row, 5).Value = c.Database ?? "";
                ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.FromHtml("#F4F7FB");
                ws.Range(row, 1, row, headers.Length).Style.Font.Bold = true;
                ws.Row(row).OutlineLevel = 1;
                row++;

                foreach (var n in c.Objects)
                    row = WriteObjectWithDeps(ws, row, n, depth: 2, schemaAnchors, defAnchors);
            }
        }

        ws.Column(1).Width = 50;
        for (var i = 2; i <= headers.Length; i++) ws.Column(i).Width = 14;
        ws.Column(7).Width = 24; // Name
        ws.Column(14).Width = 30; // ReferencedBy
    }

    private static int WriteObjectWithDeps(IXLWorksheet ws, int row, DbObjectNode n, int depth,
        IDictionary<string, string> schemaAnchors,
        IDictionary<string, string> defAnchors)
    {
        var icon = n.Type switch
        {
            DbObjectType.Table => "▦",
            DbObjectType.View => "◫",
            DbObjectType.StoredProcedure => "▶",
            DbObjectType.Function => "ƒ",
            DbObjectType.Synonym => "⇄",
            DbObjectType.Sequence => "↻",
            _ => "?"
        };
        var indent = new string(' ', depth * 4);
        var nameCell = ws.Cell(row, 1);
        nameCell.Value = indent + icon + " " + n.QualifiedName;

        // Hyperlink target: tables → Schema sheet row; views/sps/functions → Definitions row
        // (fall back to Schema row if no definition was captured).
        var key = AnchorKey(n);
        string? target = null;
        if (n.Type is DbObjectType.View or DbObjectType.StoredProcedure or DbObjectType.Function)
            defAnchors.TryGetValue(key, out target);
        if (target is null) schemaAnchors.TryGetValue(key, out target);
        if (target is not null)
        {
            nameCell.SetHyperlink(new XLHyperlink(target));
            nameCell.Style.Font.FontColor = XLColor.FromHtml("#0D47A1");
            nameCell.Style.Font.Underline = XLFontUnderlineValues.Single;
        }

        ws.Cell(row, 2).Value = n.Type.ToString();
        ws.Cell(row, 3).Value = n.AccessKind.ToString();
        ws.Cell(row, 4).Value = n.ServerName;
        ws.Cell(row, 5).Value = n.DatabaseName;
        ws.Cell(row, 6).Value = n.Schema;
        ws.Cell(row, 7).Value = n.Name;
        ws.Cell(row, 8).Value = n.TableMetrics?.RowCount ?? 0;
        ws.Cell(row, 9).Value = Math.Round((n.TableMetrics?.TotalReservedKB ?? 0) / 1024.0, 1);
        ws.Cell(row,10).Value = n.Columns.Count;
        ws.Cell(row,11).Value = n.Indexes.Count;
        ws.Cell(row,12).Value = n.ForeignKeys.Count;
        ws.Cell(row,13).Value = n.FileGroup ?? "";
        ws.Cell(row,14).Value = string.Join(", ", n.ReferencedByTasks);
        ws.Row(row).OutlineLevel = depth;
        row++;

        // Synonym target — same depth+1 (one extra hop)
        if (n.SynonymTarget is not null)
            row = WriteObjectWithDeps(ws, row, n.SynonymTarget, depth + 1, schemaAnchors, defAnchors);

        // Children = objects this view/sp/function references
        foreach (var child in n.Children)
            row = WriteObjectWithDeps(ws, row, child, depth + 1, schemaAnchors, defAnchors);

        return row;
    }

    // (#6) WriteColumns removed — every column is already nested under its table
    // in the Schema sheet; the flat duplicate isn't worth carrying.

    // Indexes — grouped: Database (level 0) → Schema.Table (level 1) → individual indexes (level 2)
    private static void WriteIndexes(XLWorkbook wb, AnalysisResult r,
        IDictionary<string, string> schemaAnchors)
    {
        var ws = wb.AddWorksheet("Indexes");
        ws.Outline.SummaryVLocation = XLOutlineSummaryVLocation.Top;

        var headers = new[] { "Database / Table / Index", "Type", "Unique", "PK",
                              "KeyCols", "IncludedCols", "Rows", "ReservedKB", "UsedKB", "Filter" };
        for (var i = 0; i < headers.Length; i++) ws.Cell(1, i + 1).Value = headers[i];
        var hr = ws.Range(1, 1, 1, headers.Length);
        hr.Style.Fill.BackgroundColor = XLColor.FromHtml("#0D47A1");
        hr.Style.Font.FontColor = XLColor.White;
        hr.Style.Font.Bold = true;
        ws.SheetView.FreezeRows(1);

        var row = 2;

        // Group all indexed tables by (Server, Database) then Schema.Table
        var seenTbl = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var indexedTables = r.AllObjects
            .Where(o => o.Type == DbObjectType.Table && o.Indexes.Count > 0)
            .Where(o => seenTbl.Add($"{o.ServerName}|{o.DatabaseName}|{o.Schema}|{o.Name}"))
            .ToList();

        foreach (var dbg in indexedTables
            .GroupBy(o => new { o.ServerName, o.DatabaseName })
            .OrderBy(g => g.Key.ServerName).ThenBy(g => g.Key.DatabaseName))
        {
            // Level 0 — Database band
            ws.Cell(row, 1).Value = $"[{dbg.Key.ServerName}].[{dbg.Key.DatabaseName}]";
            ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.FromHtml("#E3F0FF");
            ws.Range(row, 1, row, headers.Length).Style.Font.Bold = true;
            row++;

            foreach (var t in dbg.OrderBy(o => o.QualifiedName, StringComparer.OrdinalIgnoreCase))
            {
                // Level 1 — Table band (hyperlink → Schema sheet block)
                var nameCell = ws.Cell(row, 1);
                nameCell.Value = "    " + t.QualifiedName;
                if (schemaAnchors.TryGetValue(AnchorKey(t), out var target))
                {
                    nameCell.SetHyperlink(new XLHyperlink(target));
                    nameCell.Style.Font.FontColor = XLColor.FromHtml("#0D47A1");
                    nameCell.Style.Font.Underline = XLFontUnderlineValues.Single;
                }
                ws.Cell(row, 2).Value = "Table";
                ws.Cell(row, 7).Value = t.TableMetrics?.RowCount ?? 0;
                ws.Cell(row, 8).Value = (t.TableMetrics?.TotalReservedKB ?? 0);
                ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.FromHtml("#F4F7FB");
                ws.Range(row, 1, row, headers.Length).Style.Font.Bold = true;
                ws.Row(row).OutlineLevel = 1;
                row++;

                foreach (var idx in t.Indexes)
                {
                    ws.Cell(row, 1).Value = "        " + idx.Name;
                    ws.Cell(row, 2).Value = idx.Type;
                    ws.Cell(row, 3).Value = idx.IsUnique;
                    ws.Cell(row, 4).Value = idx.IsPrimaryKey;
                    ws.Cell(row, 5).Value = string.Join(", ", idx.KeyColumns);
                    ws.Cell(row, 6).Value = string.Join(", ", idx.IncludedColumns);
                    ws.Cell(row, 7).Value = idx.RowCount;
                    ws.Cell(row, 8).Value = idx.ReservedKB;
                    ws.Cell(row, 9).Value = idx.UsedKB;
                    ws.Cell(row,10).Value = idx.FilterDefinition ?? "";
                    ws.Row(row).OutlineLevel = 2;
                    row++;
                }
            }
        }

        ws.Column(1).Width = 50;
        ws.Column(5).Width = 40;
        ws.Column(6).Width = 40;
        for (var i = 2; i <= headers.Length; i++)
            if (i != 5 && i != 6) ws.Column(i).Width = 14;
    }

    private static void WriteForeignKeys(XLWorkbook wb, AnalysisResult r)
    {
        var ws = wb.AddWorksheet("ForeignKeys");
        var headers = new[] { "Server", "Database", "Schema", "Table", "FK", "ParentCols", "ReferencedSchema", "ReferencedTable", "ReferencedCols", "OnDelete", "OnUpdate", "Disabled", "NotTrusted" };
        for (var i = 0; i < headers.Length; i++) ws.Cell(1, i + 1).Value = headers[i];
        var row = 2;
        foreach (var n in r.AllObjects.Where(o => o.ForeignKeys.Count > 0))
        foreach (var fk in n.ForeignKeys)
        {
            ws.Cell(row, 1).Value = n.ServerName;
            ws.Cell(row, 2).Value = n.DatabaseName;
            ws.Cell(row, 3).Value = n.Schema;
            ws.Cell(row, 4).Value = n.Name;
            ws.Cell(row, 5).Value = fk.Name;
            ws.Cell(row, 6).Value = string.Join(", ", fk.ParentColumns);
            ws.Cell(row, 7).Value = fk.ReferencedSchema;
            ws.Cell(row, 8).Value = fk.ReferencedTable;
            ws.Cell(row, 9).Value = string.Join(", ", fk.ReferencedColumns);
            ws.Cell(row,10).Value = fk.DeleteAction;
            ws.Cell(row,11).Value = fk.UpdateAction;
            ws.Cell(row,12).Value = fk.IsDisabled;
            ws.Cell(row,13).Value = fk.IsNotTrusted;
            row++;
        }
        Format(ws, headers.Length);
    }

    private static void WritePartitions(XLWorkbook wb, AnalysisResult r)
    {
        var ws = wb.AddWorksheet("Partitions");
        var headers = new[] { "Server", "Database", "Schema", "Table", "PartitionFn", "PartitionScheme", "PartitionColumn", "Partition#", "Boundary", "Side", "Rows", "DataKB", "IndexKB", "TotalKB", "FileGroup" };
        for (var i = 0; i < headers.Length; i++) ws.Cell(1, i + 1).Value = headers[i];
        var row = 2;
        foreach (var n in r.AllObjects.Where(o => o.TableMetrics?.IsPartitioned == true))
        foreach (var p in n.Partitions)
