using Microsoft.Extensions.DependencyInjection;
using Microsoft.Extensions.Logging;
using Serilog;
using SSISLens.Services;

namespace SSISLens.UI;

internal static class Program
{
    public static IServiceProvider Services { get; private set; } = null!;

    [STAThread]
    private static void Main()
    {
        var logDir = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData), "SSISLens");
        Directory.CreateDirectory(logDir);
        Log.Logger = new LoggerConfiguration()
            .MinimumLevel.Information()
            .WriteTo.File(Path.Combine(logDir, "ssislens-.log"), rollingInterval: RollingInterval.Day)
            .CreateLogger();

        var sc = new ServiceCollection();
        sc.AddLogging(b => b.AddSerilog(Log.Logger, dispose: true));
        sc.AddSingleton<AnalysisService>();
        sc.AddTransient<MainForm>();
        Services = sc.BuildServiceProvider();

        ApplicationConfiguration.Initialize();
        Application.SetHighDpiMode(HighDpiMode.PerMonitorV2);
        Application.Run(Services.GetRequiredService<MainForm>());
    }
}




