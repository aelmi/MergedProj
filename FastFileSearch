using System;
using System.Collections.Generic;
using System.IO;
using System.Text.Json;
using System.Text.Json.Serialization;

namespace FastFileSearch;

/// <summary>
/// JSON-backed user preferences, persisted at
/// <c>%LocalAppData%\FastFileSearch\settings.json</c>. Single shared instance loaded
/// once at startup; mutated in place; saved on form close (and whenever the user
/// toggles a control that wants to persist immediately).
///
/// Forward-compatible: unknown JSON fields are tolerated on load; missing fields
/// fall back to the C# defaults below.
/// </summary>
public sealed class Settings
{
    public string Theme { get; set; } = "Dark";              // "Dark" | "Light"
    public bool PreviewVisible { get; set; } = false;

    /// <summary>
    /// Hard cap on the total number of entries kept in memory across all volumes.
    /// 0 (default) = unlimited. When exceeded, the least-recently-touched entries
    /// are evicted by <see cref="Indexing.FileIndex.TrimTo"/>.
    /// </summary>
    public long MaxIndexEntries { get; set; } = 0;

    /// <summary>
    /// Path-fragment patterns excluded from indexing (case-insensitive substring
    /// match against the resolved full path). Applied at index build time on every
    /// volume — entries whose path contains any of these segments are dropped.
    /// </summary>
    public List<string> GlobalIgnoredPathSegments { get; set; } = new()
    {
        @"\$Recycle.Bin\",
        @"\System Volume Information\",
        @"\Windows\WinSxS\",
        @"\Windows\Installer\",
        @"\node_modules\",
        @"\.git\objects\",
    };

    /// <summary>UNC and \\wsl$\ paths the user has added as searchable roots.</summary>
    public List<string> ExtraRoots { get; set; } = new();

    /// <summary>Auto-index removable drives when plugged in (WM_DEVICECHANGE).</summary>
    public bool AutoIndexRemovable { get; set; } = true;

    // ---------- Persistence ----------

    [JsonIgnore]
    public static string FilePath =>
        Path.Combine(
            Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData),
            "FastFileSearch", "settings.json");

    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        WriteIndented = true,
        PropertyNameCaseInsensitive = true,
    };

    public static Settings Load()
    {
        try
        {
            if (!File.Exists(FilePath)) return new Settings();
            var json = File.ReadAllText(FilePath);
            return JsonSerializer.Deserialize<Settings>(json, JsonOptions) ?? new Settings();
        }
        catch
        {
            // Corrupt file → start fresh; previous file gets overwritten on next save.
            return new Settings();
        }
    }

    public void Save()
    {
        try
        {
            var dir = Path.GetDirectoryName(FilePath)!;
            Directory.CreateDirectory(dir);
            File.WriteAllText(FilePath, JsonSerializer.Serialize(this, JsonOptions));
        }
        catch { /* best-effort */ }
    }
}




