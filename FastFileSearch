using System;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Windows.Forms;
using FastFileSearch.Indexing;
using FastFileSearch.Native;

namespace FastFileSearch.Ui;

/// <summary>
/// Code-behind for the IndexStatsDialog. The visual layout lives in
/// <c>IndexStatsDialog.Designer.cs</c> so VS Forms Designer can render it. This
/// file holds only the runtime wiring: data sources, the refresh tick, theme
/// subscription, and the keyboard shortcut.
/// </summary>
internal sealed partial class IndexStatsDialog : Form
{
    private IndexManager? _manager;
    private FileIndex? _index;
    private readonly System.Windows.Forms.Timer _refresh;

    /// <summary>
    /// Designer-friendly parameterless constructor. The form opens with placeholder
    /// content; live data only flows after <see cref="Attach"/> is called (or use the
    /// other constructor at runtime).
    /// </summary>
    public IndexStatsDialog()
    {
        InitializeComponent();

        _refresh = new System.Windows.Forms.Timer { Interval = 750 };
        _refresh.Tick += (_, __) => RefreshContent();
        FormClosed += (_, __) => _refresh.Stop();

        Shown += (_, __) => { ShellApi.SetTitleBarDark(Handle, !Theme.IsLight); RefreshContent(); _refresh.Start(); };
        KeyDown += (_, e) => { if (e.KeyCode == Keys.Escape) Close(); };

        ApplyTheme();
        Theme.OnChange(this, ApplyTheme);
        _closeButton.Click += (_, __) => Close();
    }

    /// <summary>Runtime constructor — pulls live data from the manager + index.</summary>
    public IndexStatsDialog(IndexManager manager, FileIndex index) : this()
    {
        Attach(manager, index);
    }

    /// <summary>Bind live data sources after the form has been constructed.</summary>
    public void Attach(IndexManager manager, FileIndex index)
    {
        _manager = manager;
        _index = index;
        RefreshContent();
    }

    /// <summary>
    /// Rebuild the body label from the current FileIndex + Settings snapshot.
    /// Public so the designer's preview can call it; safe to call before <see cref="Attach"/>.
    /// </summary>
    public void RefreshContent()
    {
        if (_index is null)
        {
            _bodyLabel.Text = "(not attached to an index — designer preview)";
            return;
        }

        var stats = _index.GetAllStats().OrderBy(s => s.DriveLetter).ToList();
        var sb = new StringBuilder();
        sb.AppendLine($"Total entries:    {_index.ApproximateCount:N0}");
        sb.AppendLine($"Estimated memory: {EstimateRam(_index.ApproximateCount)}");
        sb.AppendLine($"Volumes:          {stats.Count}");
        sb.AppendLine();
        sb.AppendLine("Per volume");
        sb.AppendLine("──────────────────────────────────────────────────────────");
        if (stats.Count == 0)
        {
            sb.AppendLine("  (none registered yet)");
        }
        else
        {
            foreach (var s in stats)
            {
                sb.AppendLine($"  {s.PathPrefix}");
                sb.AppendLine($"     kind:        {s.Kind}");
                sb.AppendLine($"     entries:     {s.EntryCount:N0}");
                sb.AppendLine($"     last USN:    {s.LastUsn}");
                sb.AppendLine($"     journal ID:  {(s.JournalId == 0 ? "(none — no USN journal)" : s.JournalId.ToString())}");
                sb.AppendLine();
            }
        }

        sb.AppendLine("Settings");
        sb.AppendLine("──────────────────────────────────────────────────────────");
        var cfg = Program.Settings;
        sb.AppendLine($"  Theme:               {cfg.Theme}");
        sb.AppendLine($"  Max entries (cap):   {(cfg.MaxIndexEntries == 0 ? "unlimited" : cfg.MaxIndexEntries.ToString("N0"))}");
        sb.AppendLine($"  Auto-index USB:      {cfg.AutoIndexRemovable}");
        sb.AppendLine($"  Ignored segments:    {cfg.GlobalIgnoredPathSegments.Count}");
        sb.AppendLine($"  Extra roots (UNC):   {cfg.ExtraRoots.Count}");

        _bodyLabel.Text = sb.ToString();
    }

    /// <summary>
    /// Apply Dark/Light palette. Called from the constructor and whenever
    /// <see cref="Theme.Changed"/> fires. Designed to be a no-op safe to invoke even
    /// while the form is still being constructed (controls are field-initialised).
    /// </summary>
    private void ApplyTheme()
    {
        BackColor = Theme.Background;
        ForeColor = Theme.TextPrimary;

        _titleLabel.BackColor = Theme.Background;
        _titleLabel.ForeColor = Theme.Accent;

        _bodyLabel.BackColor = Theme.Background;
        _bodyLabel.ForeColor = Theme.TextPrimary;

        _closeButton.BackColor = Theme.SurfaceElevated;
        _closeButton.ForeColor = Theme.TextPrimary;
        _closeButton.FlatAppearance.BorderColor = Theme.Divider;

        if (IsHandleCreated) ShellApi.SetTitleBarDark(Handle, !Theme.IsLight);
        Invalidate(true);
    }

    private static string EstimateRam(long entries)
    {
        // ~100 bytes per entry (FRN, parent FRN, attrs, ticks, size, name overhead).
        long bytes = entries * 100;
        string[] u = { "B", "KB", "MB", "GB", "TB" };
        double v = bytes; int i = 0;
        while (v >= 1024 && i < u.Length - 1) { v /= 1024; i++; }
        return $"{v:0.##} {u[i]}";
    }
}




