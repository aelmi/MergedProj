using System;
using System.Buffers;
using System.Collections.Concurrent;
using System.Collections.Generic;
using System.Text;
using System.Threading;

namespace FastFileSearch.Indexing;

/// <summary>
/// Internal index entry. A class (not struct) because we need reference equality for
/// atomic swaps in ConcurrentDictionary and the 8-byte header overhead is amortized
/// across ~100 bytes of payload per entry.
/// </summary>
public sealed class IndexEntry
{
    public ulong FileReferenceNumber;
    public ulong ParentFileReferenceNumber;
    public string FileName = string.Empty;
    public uint Attributes;
    public long LastModifiedTicks;
    public long Size;

    /// <summary>
    /// Coarse "last touched by a query" timestamp (ticks). Used by
    /// <see cref="FileIndex.TrimTo"/> to evict cold entries when a memory cap is
    /// configured. Updated by <see cref="FileIndex.ResolveFullPath"/> on the result
    /// path — cheap, lossy, and good enough for LRU-ish eviction.
    /// </summary>
    public long LastTouchedTicks;

    public bool IsDirectory => (Attributes & 0x10) != 0;
}

/// <summary>
/// Thread-safe, in-memory file index optimized for:
///   1. Add/Update/Remove from the indexing pipeline (single writer per volume).
///   2. Concurrent substring scans from the search engine (many readers).
///
/// Memory model: ~100 bytes per entry at 24-char average name. 1M files ~= 100MB.
///
/// Path strategy: we do NOT store full paths. We store parent FRN -> entry and walk
/// up the chain when a full path is requested. Saves ~80MB per million files at the
/// cost of one O(depth) walk per result returned.
/// </summary>
public sealed class FileIndex
{
    private sealed class VolumeIndex
    {
        public readonly char DriveLetter;
        public readonly ConcurrentDictionary<ulong, IndexEntry> ByFrn = new();
        public long LastUsn;
        public ulong JournalId;
        /// <summary>
        /// Path root used when materialising full paths. For NTFS letter drives this
        /// is "C:\". For UNC / WSL roots it is the share path, e.g. "\\\\server\\share\\".
        /// </summary>
        public string PathPrefix;
        /// <summary>Source kind, used by the stats panel and removable-drive eviction logic.</summary>
        public VolumeKind Kind;
        public VolumeIndex(char d, string prefix, VolumeKind kind)
        {
            DriveLetter = d;
            PathPrefix = prefix;
            Kind = kind;
        }
    }

    public enum VolumeKind { Ntfs, Removable, Network }

    /// <summary>Public snapshot of one volume's runtime state, for the stats panel.</summary>
    public readonly struct VolumeStats
    {
        public readonly char DriveLetter;
        public readonly string PathPrefix;
        public readonly VolumeKind Kind;
        public readonly long EntryCount;
        public readonly long LastUsn;
        public readonly ulong JournalId;
        public VolumeStats(char d, string p, VolumeKind k, long n, long usn, ulong jid)
        { DriveLetter = d; PathPrefix = p; Kind = k; EntryCount = n; LastUsn = usn; JournalId = jid; }
    }

    /// <summary>
    /// Register a volume's root with a synthetic key. Called by network/WSL indexing
    /// paths before they start adding entries. Idempotent — re-registration updates
    /// the prefix/kind without losing existing entries.
    /// </summary>
    public void RegisterVolume(char key, string pathPrefix, VolumeKind kind)
    {
        var vol = _volumes.GetOrAdd(key, k => new VolumeIndex(k, pathPrefix, kind));
        vol.PathPrefix = pathPrefix;
        vol.Kind = kind;
    }

    public string GetPathPrefix(char key) =>
        _volumes.TryGetValue(key, out var v) ? v.PathPrefix : key + @":\";

    public VolumeKind GetVolumeKind(char key) =>
        _volumes.TryGetValue(key, out var v) ? v.Kind : VolumeKind.Ntfs;

    /// <summary>Snapshot of every registered volume's stats.</summary>
    public IReadOnlyList<VolumeStats> GetAllStats()
    {
        var list = new List<VolumeStats>(_volumes.Count);
        foreach (var kv in _volumes)
            list.Add(new VolumeStats(
                kv.Key, kv.Value.PathPrefix, kv.Value.Kind,
                kv.Value.ByFrn.Count, kv.Value.LastUsn, kv.Value.JournalId));
        return list;
    }

    /// <summary>Remove an entire volume from the index. Used when a removable drive is ejected.</summary>
    public void RemoveVolume(char key)
    {
        if (_volumes.TryRemove(key, out var vol))
            Interlocked.Add(ref _approxCount, -vol.ByFrn.Count);
    }

    /// <summary>
    /// Evict cold entries when the total entry count exceeds <paramref name="maxEntries"/>.
    /// Eviction order: oldest <see cref="IndexEntry.LastTouchedTicks"/> first; directories
    /// are evicted last because removing them breaks ancestry chains for any non-evicted
    /// descendants. No-op when <paramref name="maxEntries"/> is 0 or already under cap.
    /// Returns the number of entries removed.
    /// </summary>
    public int TrimTo(long maxEntries)
    {
        if (maxEntries <= 0) return 0;
        long over = ApproximateCount - maxEntries;
        if (over <= 0) return 0;

        // Collect victims: non-directories, sorted by access time ascending. Allocating
        // a flat list of all candidates lets us pick the bottom N with O(N) partial
        // sort via OrderBy().Take() — Linq is fine, we're already in a slow path.
        var candidates = new List<(char Drive, ulong Frn, long Ts)>();
        foreach (var kv in _volumes)
        {
            char d = kv.Key;
            foreach (var e in kv.Value.ByFrn.Values)
            {
                if (e.IsDirectory) continue;
                candidates.Add((d, e.FileReferenceNumber, e.LastTouchedTicks));
            }
        }

        candidates.Sort((a, b) => a.Ts.CompareTo(b.Ts));
        int removed = 0;
        for (int i = 0; i < candidates.Count && removed < over; i++)
        {
            var c = candidates[i];
            if (_volumes.TryGetValue(c.Drive, out var vol) &&
                vol.ByFrn.TryRemove(c.Frn, out _))
            {
                Interlocked.Decrement(ref _approxCount);
                removed++;
            }
        }
        return removed;
    }

    private readonly ConcurrentDictionary<char, VolumeIndex> _volumes = new();

    /// <summary>O(1) accurate count. ConcurrentDictionary.Count locks every bucket;
    /// we cannot afford that on the hot path, so maintain our own counter.</summary>
    private long _approxCount;
    public long ApproximateCount => Interlocked.Read(ref _approxCount);

    // -------- Mutation --------

    public void AddOrUpdate(char drive, IndexEntry entry)
    {
        var vol = _volumes.GetOrAdd(drive, d => new VolumeIndex(d, d + @":\", VolumeKind.Ntfs));
        if (vol.ByFrn.TryAdd(entry.FileReferenceNumber, entry))
            Interlocked.Increment(ref _approxCount);
        else
            vol.ByFrn[entry.FileReferenceNumber] = entry;
    }

    public void Remove(char drive, ulong frn)
    {
        if (_volumes.TryGetValue(drive, out var vol) && vol.ByFrn.TryRemove(frn, out _))
            Interlocked.Decrement(ref _approxCount);
    }

    public void SetLastUsn(char drive, long usn)
    {
        var vol = _volumes.GetOrAdd(drive, d => new VolumeIndex(d, d + @":\", VolumeKind.Ntfs));
        vol.LastUsn = usn;
    }

    public long GetLastUsn(char drive) =>
        _volumes.TryGetValue(drive, out var vol) ? vol.LastUsn : 0;

    public void SetJournalId(char drive, ulong journalId)
    {
        var vol = _volumes.GetOrAdd(drive, d => new VolumeIndex(d, d + @":\", VolumeKind.Ntfs));
        vol.JournalId = journalId;
    }

    public ulong GetJournalId(char drive) =>
        _volumes.TryGetValue(drive, out var vol) ? vol.JournalId : 0;

    /// <summary>
    /// Populate a volume from a deserialized cache. Callers must invoke this before
    /// any concurrent readers are running for the volume (i.e. during startup, before
    /// search threads start). Uses TryAdd so a partially-rehydrated index can still
    /// be safely topped up by a USN replay.
    /// </summary>
    public void BulkLoad(char drive, ulong journalId, long lastUsn, IEnumerable<IndexEntry> entries)
    {
        var vol = _volumes.GetOrAdd(drive, d => new VolumeIndex(d, d + @":\", VolumeKind.Ntfs));
        long added = 0;
        foreach (var e in entries)
            if (vol.ByFrn.TryAdd(e.FileReferenceNumber, e)) added++;
        vol.LastUsn = lastUsn;
        vol.JournalId = journalId;
        if (added != 0) Interlocked.Add(ref _approxCount, added);
    }

    /// <summary>Live snapshot of one volume's entries, for persistence.</summary>
    public IEnumerable<IndexEntry> EnumerateVolume(char drive) =>
        _volumes.TryGetValue(drive, out var vol)
            ? vol.ByFrn.Values
            : Array.Empty<IndexEntry>();

    // -------- Read access --------

    /// <summary>
    /// Snapshot enumeration across all volumes. Yielded entries are live references —
    /// search code treats them as read-only.
    /// </summary>
    public IEnumerable<(char Drive, IndexEntry Entry)> EnumerateAll()
    {
        foreach (var kv in _volumes)
        {
            char d = kv.Key;
            foreach (var entry in kv.Value.ByFrn.Values)
                yield return (d, entry);
        }
    }

    /// <summary>
    /// Walk parents to construct the full path. Returns string.Empty if ancestry breaks.
    ///
    /// Allocation note: We need a small temporary buffer of string references to hold
    /// path segments while we collect them. <c>stackalloc</c> would be ideal but it
    /// only accepts unmanaged types — strings are managed, so we rent from
    /// <see cref="ArrayPool{T}"/>. Returning with <c>clearArray: true</c> is essential:
    /// it nulls our string references in the pooled array so we don't keep paths
    /// alive after the array gets handed out to the next caller.
    /// </summary>
    public string ResolveFullPath(char drive, IndexEntry entry)
    {
        if (!_volumes.TryGetValue(drive, out var vol)) return string.Empty;
        // Stamp access — lazy LRU bookkeeping used by TrimTo when a cap is configured.
        // Plain non-atomic write is fine: this is advisory, races just lose precision.
        entry.LastTouchedTicks = DateTime.UtcNow.Ticks;

        const int MaxDepth = 256;
        string[] segments = ArrayPool<string>.Shared.Rent(MaxDepth);
        try
        {
            int count = 0;
            IndexEntry? cur = entry;
            while (cur is not null && count < MaxDepth)
            {
                segments[count++] = cur.FileName;
                ulong parent = cur.ParentFileReferenceNumber;
                if (parent == cur.FileReferenceNumber) break; // root self-reference
                if (!vol.ByFrn.TryGetValue(parent, out cur)) break;
            }

            string prefix = vol.PathPrefix;
            int totalLen = prefix.Length;
            for (int i = 0; i < count; i++) totalLen += segments[i].Length + 1;

            var sb = new StringBuilder(totalLen);
            sb.Append(prefix);
            if (prefix.Length > 0 && prefix[^1] != '\\') sb.Append('\\');
            for (int i = count - 1; i >= 0; i--)
            {
                sb.Append(segments[i]);
                if (i > 0) sb.Append('\\');
            }
            return sb.ToString();
        }
        finally
        {
            ArrayPool<string>.Shared.Return(segments, clearArray: true);
        }
    }
}




