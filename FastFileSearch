[Flags]
public enum MatchMode
{
    Substring     = 0,
    Wildcard      = 1 << 0,  // * and ?
    Regex         = 1 << 1,
    CaseSensitive = 1 << 2,
    MatchPath     = 1 << 3,  // match against full path, not just file name
    Fuzzy         = 1 << 4,  // bounded Levenshtein per term
}

public sealed class FilterCriteria
{
    /// <summary>Restrict to these extensions (no dot, lowercase). Empty = any.</summary>
    public List<string> Extensions { get; set; } = new();

    public long? MinSize { get; set; }
    public long? MaxSize { get; set; }

    public long? ModifiedAfterTicks { get; set; }
    public long? ModifiedBeforeTicks { get; set; }

    public string PathContains { get; set; } = string.Empty;

    /// <summary>
    /// Path-fragment substrings the *full path* must NOT contain (case-insensitive).
    /// Populated by the <c>-path:&lt;value&gt;</c> operator and the user's persistent
    /// ignore list. Applied per-entry in the search engine.
    /// </summary>
    public List<string> ExcludePathContains { get; set; } = new();

    public bool? OnlyDirectories { get; set; }
    public bool? OnlyFiles { get; set; }
}

/// <summary>
