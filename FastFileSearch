using System;
using System.Drawing;
using System.Drawing.Drawing2D;
using System.Drawing.Text;
using System.Windows.Forms;

namespace FastFileSearch.Ui;

/// <summary>
/// Modern search input: rounded background, embedded search icon on the left,
/// inline clear (X) button on the right when text is present, and an accent
/// border that lights up on focus.
///
/// Internally just a host Panel painted via OnPaint plus a borderless TextBox
/// positioned to leave room for the icons.
/// </summary>
internal sealed class SearchBox : UserControl
{
    private readonly TextBox _inner;
    private bool _hoverClear;
    private bool _focused;

    public event EventHandler? QueryChanged;

    public string Query
    {
        get => _inner.Text;
        set => _inner.Text = value;
    }

    public string Placeholder { get; set; } = "Search files…";

    public SearchBox()
    {
        SetStyle(ControlStyles.AllPaintingInWmPaint
               | ControlStyles.OptimizedDoubleBuffer
               | ControlStyles.ResizeRedraw
               | ControlStyles.UserPaint, true);
        BackColor = Theme.Background;

        // IMPORTANT: build the inner TextBox BEFORE the first size change.
        // Setting Height below fires OnResize → LayoutInner, which dereferences _inner.
        // If we initialised _inner after that, the resize hook would NRE.
        _inner = new TextBox
        {
            BorderStyle = BorderStyle.None,
            BackColor   = Theme.SurfaceElevated,
            ForeColor   = Theme.TextPrimary,
            Font        = Theme.UiFont(12f),
        };
        _inner.TextChanged += (_, __) => { QueryChanged?.Invoke(this, EventArgs.Empty); Invalidate(); };
        _inner.GotFocus    += (_, __) => { _focused = true;  Invalidate(); };
        _inner.LostFocus   += (_, __) => { _focused = false; Invalidate(); };
        Controls.Add(_inner);

        // Now safe to trigger OnResize → LayoutInner.
        Height = Theme.SearchHeight;

        MouseMove += (s, e) => { var was = _hoverClear; _hoverClear = ClearRect().Contains(e.Location); if (was != _hoverClear) Invalidate(); Cursor = _hoverClear ? Cursors.Hand : Cursors.IBeam; };
        MouseLeave += (s, e) => { if (_hoverClear) { _hoverClear = false; Invalidate(); } };
        Click += (s, e) =>
        {
            if (e is MouseEventArgs me && ClearRect().Contains(me.Location))
            {
                _inner.Text = string.Empty;
                _inner.Focus();
            }
            else _inner.Focus();
        };

        Theme.OnChange(this, () =>
        {
            BackColor = Theme.Background;
            _inner.BackColor = Theme.SurfaceElevated;
            _inner.ForeColor = Theme.TextPrimary;
            Invalidate();
        });
    }

    public void FocusInput() => _inner.Focus();

    protected override void OnResize(EventArgs e)
    {
        base.OnResize(e);
        LayoutInner();
    }

    private void LayoutInner()
    {
        // Defensive: this method can be invoked from base UserControl/Control plumbing
        // (e.g. an initial OnResize during construction, the designer host, or a Font
        // change). If _inner hasn't been built yet, there's nothing to lay out.
        if (_inner is null) return;

        // Leave room: 44px icon area on left, 36px clear area on right.
        const int leftPad = 44;
        const int rightPad = 36;
        // Use the inner TextBox's own Font (which we own and set in the constructor)
        // rather than allocating a fresh Font via Theme.UiFont() on every resize —
        // the old code leaked a Font instance per call.
        int innerHeight = _inner.Font.Height + 2;
        _inner.Bounds = new Rectangle(
            leftPad,
            (Height - innerHeight) / 2,
            Math.Max(0, Width - leftPad - rightPad),
            innerHeight);
    }

    private Rectangle ClearRect() =>
        new(Width - 32, (Height - 24) / 2, 24, 24);

    protected override void OnPaint(PaintEventArgs e)
    {
        var g = e.Graphics;
        g.SmoothingMode = SmoothingMode.AntiAlias;
        g.TextRenderingHint = TextRenderingHint.ClearTypeGridFit;

        // Background pill.
        var pill = new Rectangle(0, 0, Width - 1, Height - 1);
        using (var path = Rounded(pill, Height / 2))
        using (var brush = new SolidBrush(Theme.SurfaceElevated))
        {
            g.FillPath(brush, path);
            using var pen = new Pen(_focused ? Theme.Accent : Theme.Divider, _focused ? 1.5f : 1f);
            g.DrawPath(pen, path);
        }

        // Search icon (left).
        using (var iconFont = Theme.IconFont(14f))
        using (var iconBrush = new SolidBrush(_focused ? Theme.Accent : Theme.TextSecondary))
        {
            var iconRect = new Rectangle(12, 0, 28, Height);
            DrawCenteredText(g, Glyphs.Search, iconFont, iconBrush, iconRect);
        }

        // Placeholder when empty.
        if (string.IsNullOrEmpty(_inner.Text))
        {
            using var ph = new SolidBrush(Theme.TextTertiary);
            using var font = Theme.UiFont(12f);
            var phRect = _inner.Bounds;
            // GDI TextRenderer for crisp text at the same offset as the inner TextBox.
            TextRenderer.DrawText(g, Placeholder, font, phRect, Theme.TextTertiary,
                TextFormatFlags.Left | TextFormatFlags.VerticalCenter | TextFormatFlags.NoPrefix);
        }

        // Clear (X) button when text present.
        if (!string.IsNullOrEmpty(_inner.Text))
        {
            var rect = ClearRect();
            if (_hoverClear)
            {
                using var hover = new SolidBrush(Theme.HoverOverlay);
                using var hp = Rounded(rect, rect.Height / 2);
                g.FillPath(hover, hp);
            }
            using var iconFont = Theme.IconFont(10f);
            using var brush = new SolidBrush(_hoverClear ? Theme.TextPrimary : Theme.TextSecondary);
            DrawCenteredText(g, Glyphs.Clear, iconFont, brush, rect);
        }
    }

    private static GraphicsPath Rounded(Rectangle r, int radius)
    {
        var path = new GraphicsPath();
        int d = radius * 2;
        path.AddArc(r.X, r.Y, d, d, 180, 90);
        path.AddArc(r.Right - d, r.Y, d, d, 270, 90);
        path.AddArc(r.Right - d, r.Bottom - d, d, d, 0, 90);
        path.AddArc(r.X, r.Bottom - d, d, d, 90, 90);
        path.CloseFigure();
        return path;
    }

    private static void DrawCenteredText(Graphics g, string text, Font font, Brush brush, Rectangle r)
    {
        var size = g.MeasureString(text, font);
        var x = r.X + (r.Width - size.Width) / 2f;
        var y = r.Y + (r.Height - size.Height) / 2f;
        g.DrawString(text, font, brush, x, y);
    }
}




