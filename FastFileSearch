using System;
using System.Drawing;
using System.Drawing.Drawing2D;
using System.Windows.Forms;

namespace FastFileSearch.Ui;

/// <summary>
/// Custom-painted status strip. Three things visually:
///   - Left: status text
///   - Right: result count + duration
///   - Top: 1px divider line
///   - During indexing: shimmer animation in the divider
/// </summary>
internal sealed class StatusPanel : Control
{
    private string _left = "Starting...";
    private string _right = "";
    private bool _indexing;
    private float _shimmerOffset;
    private readonly System.Windows.Forms.Timer _shimmer;

    public StatusPanel()
    {
        SetStyle(ControlStyles.AllPaintingInWmPaint
               | ControlStyles.OptimizedDoubleBuffer
               | ControlStyles.ResizeRedraw
               | ControlStyles.UserPaint, true);
        Height = Theme.StatusHeight;
        BackColor = Theme.Background;

        _shimmer = new System.Windows.Forms.Timer { Interval = 30 };
        _shimmer.Tick += (_, __) =>
        {
            _shimmerOffset = (_shimmerOffset + 0.012f) % 1f;
            Invalidate();
        };

        Theme.OnChange(this, () => { BackColor = Theme.Background; Invalidate(); });
    }

    public void SetStatus(string left, string right = "")
    {
        _left = left ?? string.Empty;
        _right = right ?? string.Empty;
        Invalidate();
    }

    public void SetIndexing(bool indexing)
    {
        if (_indexing == indexing) return;
        _indexing = indexing;
        if (indexing) _shimmer.Start(); else _shimmer.Stop();
        Invalidate();
    }

    protected override void OnPaint(PaintEventArgs e)
    {
        var g = e.Graphics;
        g.SmoothingMode = SmoothingMode.AntiAlias;

        // Top divider — animated gradient when indexing, solid otherwise.
        var dividerRect = new Rectangle(0, 0, Width, 1);
        if (_indexing)
        {
            // Sweeping gradient along the top edge.
            float w = Width;
            float pos = w * _shimmerOffset;
            using var lg = new LinearGradientBrush(
                new Rectangle(0, 0, Width, 1),
                Theme.Divider, Theme.Accent, 0f);
            var blend = new ColorBlend(4)
            {
                Positions = new[] { 0f, Math.Max(0.001f, _shimmerOffset - 0.08f), _shimmerOffset, Math.Min(0.999f, _shimmerOffset + 0.08f) },
                Colors = new[] { Theme.Divider, Theme.Divider, Theme.Accent, Theme.Divider },
            };
            // Anchor blend to gradient endpoints, sorted.
            var positions = new System.Collections.Generic.List<float> { 0f, Math.Max(0.001f, _shimmerOffset - 0.08f), _shimmerOffset, Math.Min(0.999f, _shimmerOffset + 0.08f), 1f };
            positions.Sort();
            blend.Positions = positions.ToArray();
            blend.Colors = new[] { Theme.Divider, Theme.Divider, Theme.Accent, Theme.Divider, Theme.Divider };
            lg.InterpolationColors = blend;
            g.FillRectangle(lg, dividerRect);
        }
        else
        {
            using var pen = new Pen(Theme.Divider);
            g.DrawLine(pen, 0, 0, Width, 0);
        }

        // Left text.
        var leftRect = new Rectangle(Theme.Padding, 0, Width - 200 - Theme.Padding, Height);
        TextRenderer.DrawText(g, _left, Theme.UiFont(9f), leftRect,
            Theme.TextSecondary,
            TextFormatFlags.VerticalCenter | TextFormatFlags.Left | TextFormatFlags.NoPrefix | TextFormatFlags.EndEllipsis);

        // Right text.
        var rightRect = new Rectangle(Width - 300 - Theme.Padding, 0, 300, Height);
        TextRenderer.DrawText(g, _right, Theme.UiFont(9f), rightRect,
            Theme.TextSecondary,
            TextFormatFlags.VerticalCenter | TextFormatFlags.Right | TextFormatFlags.NoPrefix);
    }
}
