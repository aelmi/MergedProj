using System;
using System.Drawing;
using System.Drawing.Drawing2D;
using System.Drawing.Text;
using System.Windows.Forms;
using FastFileSearch.Models;

namespace FastFileSearch.Ui;

/// <summary>
/// Five sortable columns + one invisible "filler" column that swallows the leftover
/// width to the right of "Type". Without the filler, the area beyond the last column
/// is painted by the native ListView header using the system theme — which on dark
/// Windows still renders as a white strip. Owner-draw can't reach that area, but
/// adding another column whose width tracks the remaining client space puts that
/// region under our paint control.
/// </summary>
internal sealed class ResultsListView : ListView
{
    public const int ColName = 0;
    public const int ColPath = 1;
    public const int ColSize = 2;
    public const int ColModified = 3;
    public const int ColType = 4;
    public const int ColFiller = 5;

    /// <summary>Fires when a real (non-filler) header is clicked. Arg = column index.</summary>
    public event EventHandler<int>? HeaderClicked;

    private readonly IconCache _icons;
    private int _hoverIndex = -1;
    private int _sortColumn = ColName;
    private SortDirection _sortDirection = SortDirection.Ascending;
    private bool _adjustingFiller;  // guard against ColumnWidthChanged recursion

    public ResultsListView(IconCache icons)
    {
        _icons = icons;

        View          = View.Details;
        OwnerDraw     = true;
        FullRowSelect = true;
        VirtualMode   = true;
        HeaderStyle   = ColumnHeaderStyle.Clickable;
        BorderStyle   = BorderStyle.None;
        BackColor     = Theme.Background;
        ForeColor     = Theme.TextPrimary;
        Font          = Theme.UiFont(9.5f);
        DoubleBuffered = true;

        var spacer = new ImageList { ImageSize = new Size(1, Theme.RowHeight) };
        spacer.Images.Add("spacer", new Bitmap(1, Theme.RowHeight));
        SmallImageList = spacer;

        Columns.Add("Name",     300, HorizontalAlignment.Left);
        Columns.Add("Path",     440, HorizontalAlignment.Left);
        Columns.Add("Size",      90, HorizontalAlignment.Right);
        Columns.Add("Modified", 140, HorizontalAlignment.Left);
        Columns.Add("Type",     140, HorizontalAlignment.Left);
        Columns.Add("",           1, HorizontalAlignment.Left);  // filler; width set dynamically

        DrawColumnHeader += OnDrawColumnHeader;
        DrawItem         += OnDrawRow;
        DrawSubItem      += (s, e) => { e.DrawDefault = false; };
        ColumnClick      += (s, e) =>
        {
            if (e.Column == ColFiller) return; // ignore clicks on the filler
            HeaderClicked?.Invoke(this, e.Column);
        };
        ColumnWidthChanged += (_, e) =>
        {
            // When the user resizes any real column, the filler must shrink/grow to compensate.
            if (e.ColumnIndex != ColFiller) AdjustFiller();
        };
        Resize     += (_, __) => AdjustFiller();
        MouseMove  += OnTrackHover;
        MouseLeave += (_, __) =>
        {
            if (_hoverIndex >= 0) { var i = _hoverIndex; _hoverIndex = -1; InvalidateRow(i); }
        };

        Theme.OnChange(this, () =>
        {
            BackColor = Theme.Background;
            ForeColor = Theme.TextPrimary;
            Invalidate();
        });
    }

    protected override void OnHandleCreated(EventArgs e)
    {
        base.OnHandleCreated(e);
        AdjustFiller();
    }

    private void AdjustFiller()
    {
        if (_adjustingFiller || Columns.Count <= ColFiller) return;
        int taken = 0;
        for (int i = 0; i < ColFiller; i++) taken += Columns[i].Width;
        int remaining = Math.Max(1, ClientSize.Width - taken);
        if (Columns[ColFiller].Width == remaining) return;
        _adjustingFiller = true;
        try { Columns[ColFiller].Width = remaining; }
        finally { _adjustingFiller = false; }
    }

    public void SetSortIndicator(int columnIndex, SortDirection dir)
    {
        _sortColumn = columnIndex;
        _sortDirection = dir;
        Invalidate(new Rectangle(0, 0, ClientSize.Width, 24));
    }

    private void InvalidateRow(int index)
    {
        if (index < 0 || index >= VirtualListSize) return;
        var r = GetItemRect(index);
        Invalidate(r);
    }

    private void OnTrackHover(object? sender, MouseEventArgs e)
    {
        var info = HitTest(e.Location);
        int newIndex = info?.Item?.Index ?? -1;
        if (newIndex == _hoverIndex) return;
        int old = _hoverIndex;
        _hoverIndex = newIndex;
        InvalidateRow(old);
        InvalidateRow(newIndex);
    }

    // -------- Header --------

    private void OnDrawColumnHeader(object? sender, DrawListViewColumnHeaderEventArgs e)
    {
        var g = e.Graphics;
        var r = e.Bounds;

        // Always paint our dark background, including the filler column.
        using (var bg = new SolidBrush(Theme.Background)) g.FillRectangle(bg, r);
        using (var pen = new Pen(Theme.Divider)) g.DrawLine(pen, r.Left, r.Bottom - 1, r.Right, r.Bottom - 1);

        if (e.ColumnIndex == ColFiller) return; // nothing more to draw for the spacer

        bool isSortCol = e.ColumnIndex == _sortColumn;
        int glyphWidth = isSortCol ? 16 : 0;

        var alignFlag = e.Header!.TextAlign == HorizontalAlignment.Right
            ? TextFormatFlags.Right
            : TextFormatFlags.Left;
        var textRect = new Rectangle(r.X + 10, r.Y, r.Width - 20 - glyphWidth, r.Height);

        TextRenderer.DrawText(g, e.Header.Text, Theme.UiFont(9f, FontStyle.Bold),
            textRect,
            isSortCol ? Theme.TextPrimary : Theme.TextSecondary,
            TextFormatFlags.VerticalCenter | alignFlag | TextFormatFlags.NoPrefix);

        if (isSortCol)
        {
            string glyph = _sortDirection == SortDirection.Ascending ? "▲" : "▼";
            var glyphRect = new Rectangle(r.Right - 18, r.Y, 14, r.Height);
            TextRenderer.DrawText(g, glyph, Theme.UiFont(8f, FontStyle.Bold), glyphRect,
                Theme.Accent,
                TextFormatFlags.VerticalCenter | TextFormatFlags.HorizontalCenter | TextFormatFlags.NoPrefix);
        }
    }

    // -------- Rows --------

    private void OnDrawRow(object? sender, DrawListViewItemEventArgs e)
    {
        var g = e.Graphics;
        g.SmoothingMode    = SmoothingMode.AntiAlias;
        g.TextRenderingHint = TextRenderingHint.ClearTypeGridFit;

        var bounds = e.Bounds;
        var meta = e.Item.Tag as FileMetadata;

        Color bg;
        if      (e.Item.Selected)             bg = Focused ? Theme.Selected : Theme.SelectedInactive;
        else if (e.ItemIndex == _hoverIndex)  bg = Theme.HoverOverlay;
        else if ((e.ItemIndex & 1) == 1)      bg = Theme.SurfaceAlt;
        else                                   bg = Theme.Background;

        using (var brush = new SolidBrush(bg)) g.FillRectangle(brush, bounds);

        if (meta is null) return;

        Color textColor   = e.Item.Selected ? Theme.TextOnAccent : Theme.TextPrimary;
        Color subtleColor = e.Item.Selected ? Color.FromArgb(0xCF, 0xE7, 0xFA) : Theme.TextSecondary;
        var font = Theme.UiFont(9.5f);

        int x = bounds.X;

        // Name
        int nameW = Columns[ColName].Width;
        DrawNameCell(g, new Rectangle(x, bounds.Y, nameW, bounds.Height), meta, font, textColor);
        x += nameW;

        // Path
        int pathW = Columns[ColPath].Width;
        var pathRect = new Rectangle(x + 8, bounds.Y, pathW - 16, bounds.Height);
        TextRenderer.DrawText(g, meta.FullPath, font, pathRect, subtleColor,
            TextFormatFlags.VerticalCenter | TextFormatFlags.Left | TextFormatFlags.PathEllipsis | TextFormatFlags.NoPrefix);
        x += pathW;

        // Size
        int sizeW = Columns[ColSize].Width;
        var sizeRect = new Rectangle(x, bounds.Y, sizeW - 12, bounds.Height);
        TextRenderer.DrawText(g, meta.IsDirectory ? string.Empty : FormatSize(meta.Size),
            font, sizeRect, subtleColor,
            TextFormatFlags.VerticalCenter | TextFormatFlags.Right | TextFormatFlags.NoPrefix);
        x += sizeW;

        // Modified
        int modW = Columns[ColModified].Width;
        var modRect = new Rectangle(x + 8, bounds.Y, modW - 16, bounds.Height);
        string modText = meta.LastModifiedTicks > 0
            ? new DateTime(meta.LastModifiedTicks, DateTimeKind.Utc).ToLocalTime().ToString("yyyy-MM-dd HH:mm")
            : string.Empty;
        TextRenderer.DrawText(g, modText, font, modRect, subtleColor,
            TextFormatFlags.VerticalCenter | TextFormatFlags.Left | TextFormatFlags.NoPrefix);
        x += modW;

        // Type
        int typeW = Columns[ColType].Width;
        var typeRect = new Rectangle(x + 8, bounds.Y, typeW - 16, bounds.Height);
        string typeText = _icons.GetTypeName(meta.FileName, meta.IsDirectory);
        TextRenderer.DrawText(g, typeText, font, typeRect, subtleColor,
            TextFormatFlags.VerticalCenter | TextFormatFlags.Left | TextFormatFlags.EndEllipsis | TextFormatFlags.NoPrefix);

        // (Filler column area falls under bounds and is already covered by the bg fill.)

        using (var pen = new Pen(Color.FromArgb(0x12, 0xFF, 0xFF, 0xFF)))
            g.DrawLine(pen, bounds.Left, bounds.Bottom - 1, bounds.Right, bounds.Bottom - 1);
    }

    private void DrawNameCell(Graphics g, Rectangle cell, FileMetadata meta, Font font, Color textColor)
    {
        var icon = _icons.GetForFile(meta.FileName, meta.IsDirectory);
        int iconSize = 16;
        int iconX = cell.X + 8;
        int iconY = cell.Y + (cell.Height - iconSize) / 2;
        if (icon is not null)
            g.DrawIcon(icon, new Rectangle(iconX, iconY, iconSize, iconSize));

        int textX = iconX + iconSize + 8;
        var textRect = new Rectangle(textX, cell.Y, cell.Right - textX - 4, cell.Height);
        TextRenderer.DrawText(g, meta.FileName, font, textRect, textColor,
            TextFormatFlags.VerticalCenter | TextFormatFlags.Left | TextFormatFlags.EndEllipsis | TextFormatFlags.NoPrefix);
    }

    private static string FormatSize(long bytes)
    {
        if (bytes <= 0) return string.Empty;
        string[] units = { "B", "KB", "MB", "GB", "TB" };
        double v = bytes;
        int u = 0;
        while (v >= 1024 && u < units.Length - 1) { v /= 1024; u++; }
        return $"{v:0.##} {units[u]}";
    }
}




