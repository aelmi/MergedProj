        ShellApi.SetWindowCornerPreference(Handle, ShellApi.DwmWindowCornerPreference.Round);
    }

    // -------- Theme toggle --------

    private void ToggleTheme()
    {
        var next = Theme.IsLight ? Theme.Variant.Dark : Theme.Variant.Light;
        Theme.SetVariant(next);
        Program.Settings.Theme = Theme.VariantName;
        Program.Settings.Save();
    }

    // -------- Index stats (Ctrl+I) --------

    private void ShowStats()
    {
        if (_indexManager is null) return;
        using var dlg = new IndexStatsDialog(_indexManager, _index);
        dlg.ShowDialog(this);
    }

    // -------- Indexing --------

    private async Task StartIndexingAsync()
    {
        try { PrivilegeHelper.EnableForCurrentProcess(msg => Debug.WriteLine(msg)); }
        catch (Exception ex)
        {
            _status.SetStatus($"Privilege error: {ex.Message}");
            MessageBox.Show(this, "Must run as Administrator to read the NTFS Master File Table.\n\n" + ex.Message,
                "Privilege error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            return;
        }

        _status.SetIndexing(true);
        _empty.SetMessage("Indexing your drives…", "Search will work as soon as the first entries are ready");

        var progress = new Progress<IndexingProgress>(p =>
        {
            _status.SetStatus(p.StatusMessage, $"{p.FilesIndexed:N0} entries");
            if (p.IsComplete && _empty.Visible)
                ShowRecentFilesInEmptyState();
        });

        _indexManager = new IndexManager(_index, _mftReader, _usnMonitor, progress,
            log: m => Debug.WriteLine($"[Indexer] {m}"));
        _indexManager.JournalReset += (_, msg) =>
        {
            if (IsDisposed) return;
            BeginInvoke(() => _status.SetStatus(msg));
        };

        var drives = DiscoverNtfsDrives().ToList();
        if (drives.Count == 0)
        {
            _status.SetStatus("No NTFS drives found.");
            _status.SetIndexing(false);
            return;
        }
        _indexedDrives = drives;

        _ = _indexManager.StartAsync(drives, _appShutdown.Token).ContinueWith(_ =>
        {
            if (IsDisposed) return;
            BeginInvoke(() =>
            {
                _indexComplete = true;
                _status.SetIndexing(false);
                _status.SetStatus("Monitoring file changes", $"{_index.ApproximateCount:N0} entries");
                // If the user hasn't typed anything yet, populate the empty state with recents.
                if (_empty.Visible) ShowRecentFilesInEmptyState();
            });
        }, TaskScheduler.Default);

        // Fire-and-forget enumeration of user-added UNC roots + auto-discovered WSL
        // distros. Runs alongside the main MFT scan so search results show up across
        // every reachable root as soon as it's done walking.
        _ = Task.Run(() => IndexExtraRootsAsync(_appShutdown.Token), _appShutdown.Token);

        await Task.CompletedTask;
    }

    private async Task IndexExtraRootsAsync(CancellationToken ct)
    {
        if (_indexManager is null) return;

        // Settings-defined roots — user-added UNC / mapped paths.
        foreach (var root in Program.Settings.ExtraRoots.ToArray())
        {
            if (ct.IsCancellationRequested) return;
            try { await _indexManager.AddEnumerationRootAsync(root, FileIndex.VolumeKind.Network, ct); }
            catch (Exception ex) { Debug.WriteLine($"[ExtraRoot {root}] {ex.Message}"); }
        }

        // Auto-discover WSL distros — \\wsl$\<distro>\ shows up only when the distro
        // is running. Add each as a Network volume.
        foreach (var wsl in IndexManager.DiscoverWslRoots())
        {
            if (ct.IsCancellationRequested) return;
            try { await _indexManager.AddEnumerationRootAsync(wsl, FileIndex.VolumeKind.Network, ct); }
            catch (Exception ex) { Debug.WriteLine($"[WSL {wsl}] {ex.Message}"); }
        }
    }

    private static IEnumerable<char> DiscoverNtfsDrives()
    {
        foreach (var di in DriveInfo.GetDrives())
            if (di.DriveType == DriveType.Fixed && di.IsReady &&
                string.Equals(di.DriveFormat, "NTFS", StringComparison.OrdinalIgnoreCase))
                yield return di.Name[0];
    }

    // -------- Smart empty state — recently used files --------

    private void ShowRecentFilesInEmptyState()
    {
        // Run on a thread pool task so we don't block the UI on COM + disk.
        Task.Run(() =>
        {
            try
            {
                var recents = RecentFilesProvider.Load(50);
                if (IsDisposed) return;
                BeginInvoke(() =>
                {
                    if (recents.Count == 0) return;
                    _empty.Visible = false;
                    _currentResults = recents;
                    _itemCache = null;
                    _results.VirtualListSize = recents.Count;
                    _results.Invalidate();
                    _status.SetStatus(
                        _indexComplete ? "Monitoring file changes" : "Indexing…",
                        $"Recent files · {recents.Count}");
                });
            }
            catch (Exception ex) { Debug.WriteLine($"[Recents] {ex.Message}"); }
        });
    }

    // -------- Search --------

    private async Task RunSearchAsync(string text)
    {
        string queryText = text ?? string.Empty;
        // Prepend the chip's filter syntax if a category is active.
        string chip = QuickFilterBar.FilterToQueryFragment(_quickFilters.Active);
        string combined = chip.Length > 0
            ? (queryText.Length > 0 ? chip + " " + queryText : chip)
            : queryText;

        // Empty query + no chip → show recents (or true empty state).
        if (string.IsNullOrWhiteSpace(combined))
        {
            try { _inFlightSearch?.Cancel(); } catch { }
            _currentResults = new List<FileMetadata>();
            _itemCache = null;
            _results.VirtualListSize = 0;
            _results.Invalidate();
            if (_indexComplete) ShowRecentFilesInEmptyState();
            else _empty.Visible = true;
            _status.SetStatus(_indexComplete ? "Monitoring file changes" : "Indexing…",
                $"{_index.ApproximateCount:N0} entries");
            _preview.Show(null);
            return;
        }

        try { _inFlightSearch?.Cancel(); } catch { }
        var cts = CancellationTokenSource.CreateLinkedTokenSource(_appShutdown.Token);
        _inFlightSearch = cts;

        // The advanced syntax parser extracts ext:/size:/dm:/path: operators plus free-text terms.
        var query = QueryParser.Parse(combined);
        query.MaxResults = 50_000;

        try
        {
            var result = await _searchEngine.ExecuteAsync(query, cts.Token);
            if (result is null) return;
            ApplyResults(result);
        }
        catch (Exception ex) { _status.SetStatus($"Search error: {ex.Message}"); }
    }

    private void ApplyResults(SearchResults r)
    {
        _currentResults = r.Files;
        SortCurrentResults();
        _itemCache = null;
        _cacheStart = 0;
        _empty.Visible = false;
        _results.VirtualListSize = _currentResults.Count;
        _results.Invalidate();
        _status.SetStatus(
            _indexComplete ? "Monitoring file changes" : "Indexing…",
            $"{r.TotalMatches:N0} results · {r.SearchDurationMs} ms");
        // If preview pane is open, show whatever's now top of the list.
        if (_previewVisible && _currentResults.Count > 0 && _results.SelectedIndices.Count == 0)
        {
            _preview.Show(_currentResults[0]);
        }
    }

    // -------- Sorting --------

    private void OnHeaderClicked(int columnIndex)
    {
        if (columnIndex == _sortColumn)
            _sortDirection = _sortDirection == SortDirection.Ascending ? SortDirection.Descending : SortDirection.Ascending;
        else
        {
            _sortColumn = columnIndex;
            _sortDirection = SortDirection.Ascending;
        }
        SortCurrentResults();
        _itemCache = null;
        _results.SetSortIndicator(_sortColumn, _sortDirection);
        _results.Invalidate();
    }

    private void SortCurrentResults()
    {
        if (_currentResults.Count == 0) return;
        bool asc = _sortDirection == SortDirection.Ascending;
        Comparison<FileMetadata> cmp = _sortColumn switch
        {
            ResultsListView.ColName     => (a, b) => Cmp(asc, string.Compare(a.FileName, b.FileName, StringComparison.OrdinalIgnoreCase)),
            ResultsListView.ColPath     => (a, b) => Cmp(asc, string.Compare(a.FullPath, b.FullPath, StringComparison.OrdinalIgnoreCase)),
            ResultsListView.ColSize     => (a, b) => Cmp(asc, a.Size.CompareTo(b.Size)),
            ResultsListView.ColModified => (a, b) => Cmp(asc, a.LastModifiedTicks.CompareTo(b.LastModifiedTicks)),
            ResultsListView.ColType     => (a, b) => Cmp(asc, string.Compare(GetExt(a.FileName), GetExt(b.FileName), StringComparison.OrdinalIgnoreCase)),
            _ => (a, b) => 0,
        };
        _currentResults.Sort(cmp);
    }

    private static int Cmp(bool asc, int r) => asc ? r : -r;
    private static string GetExt(string n) { int d = n.LastIndexOf('.'); return d >= 0 ? n.Substring(d + 1) : string.Empty; }

    // -------- VirtualMode --------

    private void Results_RetrieveVirtualItem(object? sender, RetrieveVirtualItemEventArgs e)
    {
        if (_itemCache is not null && e.ItemIndex >= _cacheStart && e.ItemIndex < _cacheStart + _itemCache.Length)
        { e.Item = _itemCache[e.ItemIndex - _cacheStart]; return; }
        e.Item = BuildItem(_currentResults[e.ItemIndex]);
    }

    private void Results_CacheVirtualItems(object? sender, CacheVirtualItemsEventArgs e)
    {
        if (_itemCache is not null && e.StartIndex >= _cacheStart && e.EndIndex < _cacheStart + _itemCache.Length) return;
        _cacheStart = e.StartIndex;
        int length = e.EndIndex - e.StartIndex + 1;
        _itemCache = new ListViewItem[length];
        for (int i = 0; i < length; i++) _itemCache[i] = BuildItem(_currentResults[_cacheStart + i]);
    }

    private static ListViewItem BuildItem(FileMetadata f)
    {
        var item = new ListViewItem(f.FileName) { Tag = f };
        for (int i = 0; i < 5; i++) item.SubItems.Add(string.Empty);
        return item;
    }

    // -------- Drag-out to Explorer / other apps --------

    private void Results_ItemDrag(object? sender, ItemDragEventArgs e)
    {
        // Only left-button drag — right-button is for context menu.
        if (e.Button != MouseButtons.Left) return;

        var selected = _results.SelectedIndices;
        if (selected.Count == 0) return;

        var paths = new List<string>(selected.Count);
        foreach (int idx in selected)
        {
            if (idx < 0 || idx >= _currentResults.Count) continue;
            var f = _currentResults[idx];
            if (!string.IsNullOrEmpty(f.FullPath) &&
                (File.Exists(f.FullPath) || Directory.Exists(f.FullPath)))
            {
                paths.Add(f.FullPath);
            }
        }
        if (paths.Count == 0) return;

        var data = new DataObject(DataFormats.FileDrop, paths.ToArray());
        // Copy is the safe default; Explorer honors Ctrl→Copy, Shift→Move, Ctrl+Shift→Link.
        _results.DoDragDrop(data, DragDropEffects.Copy | DragDropEffects.Link | DragDropEffects.Move);
    }

    // -------- Preview pane & selection --------

    private void OnSelectionChanged()
    {
        if (!_previewVisible) return;
        _preview.Show(SelectedFile());
    }

    private void TogglePreviewPane()
    {
        _previewVisible = !_previewVisible;
        _preview.Visible = _previewVisible;
        _splitter.Visible = _previewVisible;
        if (_previewVisible) _preview.Show(SelectedFile() ?? (_currentResults.Count > 0 ? _currentResults[0] : null));
    }

    // -------- Spotlight mode --------

    private void ToggleSpotlightMode()
    {
        if (!_spotlightMode)
        {
            _preSpotlightBounds = Bounds;
            _preSpotlightBorder = FormBorderStyle;
            FormBorderStyle = FormBorderStyle.None;
            var screen = Screen.FromControl(this).WorkingArea;
            int w = Math.Min(820, screen.Width - 160);
            int h = Math.Min(560, screen.Height - 200);
            Bounds = new Rectangle(
                screen.X + (screen.Width - w) / 2,
                screen.Y + (screen.Height - h) / 3,
                w, h);
            _spotlightMode = true;
        }
        else
        {
            FormBorderStyle = _preSpotlightBorder;
            Bounds = _preSpotlightBounds;
            _spotlightMode = false;
            ApplyWindowChrome();
        }
    }

    // -------- Keyboard shortcuts --------

    private void MainForm_KeyDown(object? sender, KeyEventArgs e)
    {
        // F1 → help
        if (e.KeyCode == Keys.F1) { ShowHelp(); e.Handled = true; return; }

        // Ctrl+L or Ctrl+F → focus search
        if (e.Control && (e.KeyCode == Keys.L || e.KeyCode == Keys.F))
        { _searchBox.FocusInput(); e.Handled = true; return; }

        // Ctrl+Shift+S → spotlight
        if (e.Control && e.Shift && e.KeyCode == Keys.S)
        { ToggleSpotlightMode(); e.Handled = true; return; }

        // Ctrl+Shift+P → preview
        if (e.Control && e.Shift && e.KeyCode == Keys.P)
        { TogglePreviewPane(); e.Handled = true; return; }

        // Ctrl+Shift+T → theme toggle
        if (e.Control && e.Shift && e.KeyCode == Keys.T)
        { ToggleTheme(); e.Handled = true; return; }

        // Ctrl+I → index stats
        if (e.Control && !e.Shift && e.KeyCode == Keys.I)
        { ShowStats(); e.Handled = true; return; }

        // Esc → clear search; if empty, exit Spotlight; if normal, lose focus
        if (e.KeyCode == Keys.Escape)
        {
            if (!string.IsNullOrEmpty(_searchBox.Query)) { _searchBox.Query = string.Empty; }
            else if (_spotlightMode) { ToggleSpotlightMode(); }
            e.Handled = true; return;
        }

        // Enter — only when results list has focus
        if (e.KeyCode == Keys.Enter && _results.Focused)
        {
            if (e.Shift) OpenContainingFolder(); else OpenSelected();
            e.Handled = true; return;
        }

        // Ctrl+C in results → copy path
        if (e.Control && e.KeyCode == Keys.C && _results.Focused)
        { CopyPath(); e.Handled = true; }
    }

    private void ShowHelp()
    {
        using var dlg = new HelpDialog();
        dlg.ShowDialog(this);
    }

    // -------- Context menu actions --------

    // -------- Removable-drive handling (WM_DEVICECHANGE) --------

    // Window messages and DBT codes — narrow enough to keep here instead of in Native.
    private const int WM_DEVICECHANGE          = 0x0219;
    private const int DBT_DEVICEARRIVAL        = 0x8000;
    private const int DBT_DEVICEREMOVECOMPLETE = 0x8004;
    private const int DBT_DEVTYP_VOLUME        = 0x00000002;

    [System.Runtime.InteropServices.StructLayout(System.Runtime.InteropServices.LayoutKind.Sequential)]
    private struct DEV_BROADCAST_VOLUME
    {
        public int dbcv_size;
        public int dbcv_devicetype;
        public int dbcv_reserved;
        public int dbcv_unitmask;   // bitmask: bit 0 = A:, bit 1 = B:, ...
        public short dbcv_flags;
    }

    protected override void WndProc(ref Message m)
    {
        if (m.Msg == WM_DEVICECHANGE && Program.Settings.AutoIndexRemovable)
        {
            int evt = m.WParam.ToInt32();
            if ((evt == DBT_DEVICEARRIVAL || evt == DBT_DEVICEREMOVECOMPLETE) && m.LParam != IntPtr.Zero)
            {
                var hdr = System.Runtime.InteropServices.Marshal.PtrToStructure<DEV_BROADCAST_VOLUME>(m.LParam);
                if (hdr.dbcv_devicetype == DBT_DEVTYP_VOLUME)
                {
                    foreach (char d in DrivesFromMask(hdr.dbcv_unitmask))
                    {
                        if (evt == DBT_DEVICEARRIVAL) HandleDriveArrival(d);
                        else                          HandleDriveRemoval(d);
                    }
                }
            }
        }
        base.WndProc(ref m);
    }

    private static IEnumerable<char> DrivesFromMask(int mask)
    {
        for (int i = 0; i < 26; i++)
            if ((mask & (1 << i)) != 0) yield return (char)('A' + i);
    }

    private void HandleDriveArrival(char drive)
    {
        if (_indexManager is null) return;
        try
        {
            var di = new DriveInfo(drive + ":\\");
            if (!di.IsReady) return;
            if (string.Equals(di.DriveFormat, "NTFS", StringComparison.OrdinalIgnoreCase))
            {
                _status.SetStatus($"Indexing {drive}: (just connected)…");
                _ = _indexManager.StartAsync(new[] { drive }, _appShutdown.Token);
            }
            else
            {
                // Removable FAT/exFAT/etc. — go through the enumeration path.
                _status.SetStatus($"Scanning {drive}:\\ (non-NTFS removable)…");
                _ = _indexManager.AddEnumerationRootAsync(drive + ":\\",
                    FileIndex.VolumeKind.Removable, _appShutdown.Token);
            }
            _indexedDrives.Add(drive);
        }
        catch (Exception ex) { Debug.WriteLine($"[ArrivalNtfs {drive}] {ex.Message}"); }
    }

    private void HandleDriveRemoval(char drive)
    {
        if (_indexManager is null) return;
        try
        {
            // Drop NTFS-indexed entries for this drive letter.
            _index.RemoveVolume(drive);
            _indexedDrives.Remove(drive);
            // Also drop any enumeration root that pointed at this drive letter.
            _indexManager.DropExtraRoot(drive + ":\\");
            _status.SetStatus($"{drive}: ejected — entries removed", $"{_index.ApproximateCount:N0} entries");
        }
        catch (Exception ex) { Debug.WriteLine($"[Removal {drive}] {ex.Message}"); }
    }

    private FileMetadata? SelectedFile()
    {
        if (_results.SelectedIndices.Count == 0) return null;
        int idx = _results.SelectedIndices[0];
        return idx >= 0 && idx < _currentResults.Count ? _currentResults[idx] : null;
    }

    private void OpenSelected()
    {
        var f = SelectedFile() ?? (_currentResults.Count > 0 ? _currentResults[0] : null);
        if (f is null || string.IsNullOrEmpty(f.FullPath)) return;
        try { Process.Start(new ProcessStartInfo(f.FullPath) { UseShellExecute = true }); }
        catch (Exception ex) { MessageBox.Show(this, ex.Message, "Open failed"); }
    }

    private void OpenContainingFolder()
    {
        var f = SelectedFile(); if (f is null || string.IsNullOrEmpty(f.FullPath)) return;
        try { Process.Start("explorer.exe", $"/select,\"{f.FullPath}\""); }
        catch (Exception ex) { MessageBox.Show(this, ex.Message, "Open failed"); }
    }

    private void CopyPath()
    {
        var f = SelectedFile(); if (f is null || string.IsNullOrEmpty(f.FullPath)) return;
        Clipboard.SetText(f.FullPath);
    }

    protected override void OnFormClosing(FormClosingEventArgs e)
    {
        base.OnFormClosing(e);
        try { _appShutdown.Cancel(); } catch { }

        // Persist user prefs (theme + preview visibility) alongside the index. Cheap
        // and idempotent; we also save inside ToggleTheme() so a crash doesn't lose
        // the user's most recent intent.
        Program.Settings.Theme = Theme.VariantName;
        Program.Settings.PreviewVisible = _previewVisible;
        Program.Settings.Save();

        // Persist the index so the next launch can skip the full MFT walk. Only
        // save when the initial scan completed — partial caches would silently drop
        // entries (IndexManager.SaveAsync already guards this per-volume, but the
        // wait below is wasted otherwise).
        if (_indexManager is not null && _indexComplete && _indexedDrives.Count > 0)
        {
            try { _indexManager.SaveAsync(_indexedDrives).Wait(TimeSpan.FromSeconds(30)); }
            catch (Exception ex) { Debug.WriteLine($"[Persist] {ex.Message}"); }
        }
        _icons.Dispose();
    }
}

