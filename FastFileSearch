/// </summary>
public sealed class SearchTerm
{
    public string Text { get; set; } = string.Empty;
    /// <summary>0 = exact substring; &gt;0 = max Levenshtein distance for fuzzy match.</summary>
    public int MaxFuzzyDistance { get; set; }
}

