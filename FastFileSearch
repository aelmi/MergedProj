using FastFileSearch.Native;

namespace FastFileSearch.Ui;

/// <summary>
/// Extension-keyed cache for both icons and friendly type names.
/// First lookup for ".docx" calls Shell32; every subsequent ".docx" hit is O(1).
/// </summary>
internal sealed class IconCache : IDisposable
{
    private readonly Dictionary<string, Icon?> _icons = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, string> _typeNames = new(StringComparer.OrdinalIgnoreCase);
    private readonly Icon? _folderIcon;
    private readonly Icon? _defaultIcon;
    private readonly string _folderTypeName;
    private readonly string _defaultTypeName;
    private readonly object _lock = new();

    public IconCache()
    {
        _folderIcon = ShellApi.GetFolderIcon();
        _defaultIcon = ShellApi.GetIconForExtension("");
        _folderTypeName = ShellApi.GetFolderTypeName() ?? "File folder";
        _defaultTypeName = "File";
    }

    public Icon? GetForFile(string fileName, bool isDirectory)
    {
        if (isDirectory) return _folderIcon;

        int dot = fileName.LastIndexOf('.');
        if (dot < 0 || dot == fileName.Length - 1) return _defaultIcon;
        string ext = fileName.Substring(dot);

        lock (_lock)
        {
            if (_icons.TryGetValue(ext, out var cached)) return cached ?? _defaultIcon;
            var icon = ShellApi.GetIconForExtension(ext);
            _icons[ext] = icon;
            return icon ?? _defaultIcon;
        }
    }

    /// <summary>
    /// Returns Windows' display name for the file's type — "Microsoft Excel Worksheet",
    /// "PNG File", "Shortcut", etc. Falls back to "{EXT} File" when the shell has no name.
    /// </summary>
    public string GetTypeName(string fileName, bool isDirectory)
    {
        if (isDirectory) return _folderTypeName;

        int dot = fileName.LastIndexOf('.');
        if (dot < 0 || dot == fileName.Length - 1) return _defaultTypeName;
        string ext = fileName.Substring(dot);

        lock (_lock)
        {
            if (_typeNames.TryGetValue(ext, out var cached)) return cached;
            var name = ShellApi.GetTypeNameForExtension(ext)
                       ?? (ext.Length > 1 ? ext.Substring(1).ToUpperInvariant() + " File" : _defaultTypeName);
            _typeNames[ext] = name;
            return name;
        }
    }

    public void Dispose()
    {
        lock (_lock)
        {
            foreach (var icon in _icons.Values) icon?.Dispose();
            _icons.Clear();
            _typeNames.Clear();
            _folderIcon?.Dispose();
            _defaultIcon?.Dispose();
        }
    }
}




