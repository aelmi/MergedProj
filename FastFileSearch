namespace FastFileSearch;

/// <summary>
/// Palette + metrics. A single mutable <see cref="Current"/> swap re-themes the
/// whole app — every UI control reads colours through these properties (no captured
/// values), so a repaint after <see cref="SetVariant"/> is enough to reflect a
/// change.
/// </summary>
internal static class Theme
{
    public enum Variant { Dark, Light }

    private static Variant _variant = Variant.Dark;
    public static Variant Current => _variant;
    public static bool IsLight => _variant == Variant.Light;

    /// <summary>Raised after a successful variant change. Forms subscribe and Invalidate.</summary>
    public static event EventHandler? Changed;

    public static void SetVariant(Variant v)
    {
        if (_variant == v) return;
        _variant = v;
        Changed?.Invoke(null, EventArgs.Empty);
    }

    public static void SetVariantFromName(string? name)
    {
        if (string.Equals(name, "Light", StringComparison.OrdinalIgnoreCase))
            SetVariant(Variant.Light);
        else
            SetVariant(Variant.Dark);
    }

    public static string VariantName => _variant == Variant.Light ? "Light" : "Dark";

    // ---- Surfaces (palette-switched) ----
    public static Color Background       => IsLight ? Color.FromArgb(0xFB, 0xFB, 0xFB) : Color.FromArgb(0x1E, 0x1E, 0x1E);
    public static Color Surface          => IsLight ? Color.FromArgb(0xF3, 0xF3, 0xF3) : Color.FromArgb(0x25, 0x25, 0x25);
    public static Color SurfaceElevated  => IsLight ? Color.FromArgb(0xFF, 0xFF, 0xFF) : Color.FromArgb(0x2D, 0x2D, 0x2D);
    public static Color SurfaceAlt       => IsLight ? Color.FromArgb(0xF7, 0xF7, 0xF7) : Color.FromArgb(0x23, 0x23, 0x23);
    public static Color HoverOverlay     => IsLight ? Color.FromArgb(0xEA, 0xEA, 0xEA) : Color.FromArgb(0x2F, 0x2F, 0x2F);
    public static Color Selected         => IsLight ? Color.FromArgb(0xCC, 0xE4, 0xF7) : Color.FromArgb(0x0A, 0x47, 0x6F);
    public static Color SelectedInactive => IsLight ? Color.FromArgb(0xE0, 0xE0, 0xE0) : Color.FromArgb(0x37, 0x37, 0x3D);
    public static Color Divider          => IsLight ? Color.FromArgb(0xDD, 0xDD, 0xDD) : Color.FromArgb(0x33, 0x33, 0x33);

    // ---- Text ----
    public static Color TextPrimary      => IsLight ? Color.FromArgb(0x1A, 0x1A, 0x1A) : Color.FromArgb(0xF5, 0xF5, 0xF5);
    public static Color TextSecondary    => IsLight ? Color.FromArgb(0x55, 0x55, 0x55) : Color.FromArgb(0xA0, 0xA0, 0xA0);
    public static Color TextTertiary     => IsLight ? Color.FromArgb(0x90, 0x90, 0x90) : Color.FromArgb(0x70, 0x70, 0x70);
    public static Color TextOnAccent     => IsLight ? Color.FromArgb(0x10, 0x33, 0x4D) : Color.FromArgb(0xFF, 0xFF, 0xFF);

    // ---- Accents ----
    public static Color Accent           => IsLight ? Color.FromArgb(0x00, 0x5A, 0x9E) : Color.FromArgb(0x60, 0xCD, 0xFF);
    public static Color AccentMuted      => IsLight ? Color.FromArgb(0xB5, 0xD8, 0xEC) : Color.FromArgb(0x3A, 0x6A, 0x8C);
    public static Color Success          => IsLight ? Color.FromArgb(0x2E, 0x7D, 0x32) : Color.FromArgb(0x6C, 0xCB, 0x5F);
    public static Color Warning          => IsLight ? Color.FromArgb(0xC7, 0x8D, 0x0E) : Color.FromArgb(0xF2, 0xC8, 0x4B);

    // ---- Metrics ----
    public const int HeaderHeight = 76;
    public const int StatusHeight = 32;
    public const int RowHeight    = 28;
    public const int Padding      = 16;
    public const int SearchHeight = 44;
    public const int CornerRadius = 8;

    // ---- Fonts ----
    public const string UiFontFamily   = "Segoe UI Variable Display";
    public const string UiFontFallback = "Segoe UI";
    public const string IconFontFamily = "Segoe Fluent Icons";
    public const string IconFontFallback = "Segoe MDL2 Assets";

    public static Font UiFont(float size, FontStyle style = FontStyle.Regular)
    {
        try { return new Font(UiFontFamily, size, style); }
        catch { return new Font(UiFontFallback, size, style); }
    }

    public static Font IconFont(float size)
    {
        try { return new Font(IconFontFamily, size); }
        catch { return new Font(IconFontFallback, size); }
    }

    /// <summary>
    /// Subscribe a control to theme changes. <paramref name="refresh"/> re-applies any
    /// colours captured at construction time and typically calls Invalidate. Handler is
    /// auto-marshalled to the UI thread and auto-unsubscribed on control disposal, so
    /// callers don't have to remember either.
    /// </summary>
    public static void OnChange(Control control, Action refresh)
    {
        EventHandler handler = (_, _) =>
        {
            if (control.IsDisposed) return;
            if (control.InvokeRequired) control.BeginInvoke(refresh);
            else refresh();
        };
        Changed += handler;
        control.Disposed += (_, _) => Changed -= handler;
    }
}

