using System;
using System.Drawing;
using System.Runtime.InteropServices;

namespace FastFileSearch.Native;

/// <summary>
/// Shell32 and DWM interop for native Windows visual integration:
///   - File-type icons via SHGetFileInfo (matches Explorer)
///   - Dark title bar via DwmSetWindowAttribute
///   - Rounded window corners (Win11) via the same
/// </summary>
internal static partial class ShellApi
{
    // ---- SHGetFileInfo ----

    private const uint SHGFI_ICON              = 0x000000100;
    private const uint SHGFI_SMALLICON         = 0x000000001;
    private const uint SHGFI_LARGEICON         = 0x000000000;
    private const uint SHGFI_USEFILEATTRIBUTES = 0x000000010;
    private const uint SHGFI_TYPENAME          = 0x000000400;
    private const uint FILE_ATTRIBUTE_NORMAL    = 0x00000080;
    private const uint FILE_ATTRIBUTE_DIRECTORY = 0x00000010;

    [StructLayout(LayoutKind.Sequential, CharSet = CharSet.Unicode)]
    private struct SHFILEINFO
    {
        public IntPtr hIcon;
        public int iIcon;
        public uint dwAttributes;
        [MarshalAs(UnmanagedType.ByValTStr, SizeConst = 260)] public string szDisplayName;
        [MarshalAs(UnmanagedType.ByValTStr, SizeConst = 80)] public string szTypeName;
    }

    [DllImport("shell32.dll", CharSet = CharSet.Unicode)]
    private static extern IntPtr SHGetFileInfo(
        string pszPath, uint dwFileAttributes,
        ref SHFILEINFO psfi, uint cbFileInfo, uint uFlags);

    [DllImport("user32.dll", SetLastError = true)]
    [return: MarshalAs(UnmanagedType.Bool)]
    private static extern bool DestroyIcon(IntPtr hIcon);

    /// <summary>
    /// Get the icon Windows uses for a file with this extension. Doesn't touch disk —
    /// uses SHGFI_USEFILEATTRIBUTES so the path is just a hint about the extension.
    /// </summary>
    public static Icon? GetIconForExtension(string extension, bool small = true)
    {
        var sfi = new SHFILEINFO();
        uint flags = SHGFI_ICON | SHGFI_USEFILEATTRIBUTES | (small ? SHGFI_SMALLICON : SHGFI_LARGEICON);
        // Path is synthetic; only its extension matters.
        var hr = SHGetFileInfo($"dummy{extension}", FILE_ATTRIBUTE_NORMAL, ref sfi,
            (uint)Marshal.SizeOf<SHFILEINFO>(), flags);
        if (hr == IntPtr.Zero || sfi.hIcon == IntPtr.Zero) return null;

        // Clone into a managed Icon so we can DestroyIcon the native handle right away
        // (best practice — Icon.FromHandle does NOT take ownership).
        try
        {
            using var native = Icon.FromHandle(sfi.hIcon);
            return (Icon)native.Clone();
        }
        finally { DestroyIcon(sfi.hIcon); }
    }

    public static Icon? GetFolderIcon(bool small = true)
    {
        var sfi = new SHFILEINFO();
        uint flags = SHGFI_ICON | SHGFI_USEFILEATTRIBUTES | (small ? SHGFI_SMALLICON : SHGFI_LARGEICON);
        var hr = SHGetFileInfo("dummy", FILE_ATTRIBUTE_DIRECTORY, ref sfi,
            (uint)Marshal.SizeOf<SHFILEINFO>(), flags);
        if (hr == IntPtr.Zero || sfi.hIcon == IntPtr.Zero) return null;
        try
        {
            using var native = Icon.FromHandle(sfi.hIcon);
            return (Icon)native.Clone();
        }
        finally { DestroyIcon(sfi.hIcon); }
    }

    /// <summary>
    /// Get the friendly type name Windows displays for files with this extension
    /// (e.g. "Microsoft Excel Worksheet" for .xlsx). Synthetic path; doesn't touch disk.
    /// </summary>
    public static string? GetTypeNameForExtension(string extension)
    {
        var sfi = new SHFILEINFO();
        uint flags = SHGFI_TYPENAME | SHGFI_USEFILEATTRIBUTES;
        var hr = SHGetFileInfo($"dummy{extension}", FILE_ATTRIBUTE_NORMAL, ref sfi,
            (uint)Marshal.SizeOf<SHFILEINFO>(), flags);
        if (hr == IntPtr.Zero) return null;
        return string.IsNullOrEmpty(sfi.szTypeName) ? null : sfi.szTypeName;
    }

    public static string? GetFolderTypeName()
    {
        var sfi = new SHFILEINFO();
        uint flags = SHGFI_TYPENAME | SHGFI_USEFILEATTRIBUTES;
        var hr = SHGetFileInfo("dummy", FILE_ATTRIBUTE_DIRECTORY, ref sfi,
            (uint)Marshal.SizeOf<SHFILEINFO>(), flags);
        if (hr == IntPtr.Zero) return null;
        return string.IsNullOrEmpty(sfi.szTypeName) ? null : sfi.szTypeName;
    }

