using System;
using System.Collections.Generic;
using System.Globalization;
using System.Text;
using FastFileSearch.Models;

namespace FastFileSearch.Indexing;

/// <summary>
/// Parses a user-typed query string into a populated <see cref="SearchQuery"/>.
/// Supports the common Everything-style operators plus free text:
///
///   ext:pdf;docx          extensions (semicolon-separated)
///   size:>10mb            sizes with K/M/G suffix; operators &lt; &gt; &lt;= &gt;= or N..M range
///   dm:today              date modified: today, yesterday, thisweek, thismonth, thisyear,
///                         lastweek, lastmonth, lastyear, or ISO yyyy-MM-dd with &lt;/&gt;/.. compare
///   path:downloads        path-contains filter
///   kind:folder|file      restrict to one
///   folder: / file:       same as above (short form)
///   regex:                switch the whole query into regex mode
///   case:                 case-sensitive flag
///   "quoted phrase"       treat as one literal term
///
/// Everything else becomes a free-text term that the file name must contain.
/// Multiple free-text terms are AND'd: `report annual` matches names containing
/// BOTH "report" AND "annual" (in any order). Wildcards `*` / `?` in a term
/// auto-promote that term to glob matching.
/// </summary>
public static class QueryParser
{
    public static SearchQuery Parse(string raw)
    {
        var q = new SearchQuery { QueryText = raw ?? string.Empty, MaxResults = 50_000 };
        if (string.IsNullOrWhiteSpace(raw)) return q;

        var terms = new List<string>();
        var fuzzyDistances = new List<int>();
        bool caseSensitive = false;
        bool regex = false;
        bool anyFuzzy = false;
        string raw2 = raw!;

        foreach (var token in Tokenize(raw2))
        {
            // Excluded-path operator: -path:value (also accepts -p:value as a shortcut).
            // Tokens starting with '-' before a known operator subtract from the result
            // set rather than constraining what it positively matches.
            if (token.Length > 1 && token[0] == '-')
            {
                int negColon = token.IndexOf(':', 1);
                if (negColon > 1 && negColon < token.Length - 1)
                {
                    string negKey = token.Substring(1, negColon - 1).ToLowerInvariant();
                    string negVal = token.Substring(negColon + 1);
                    if (negKey is "path" or "p" or "folder")
                    {
                        q.Filter.ExcludePathContains.Add(negVal);
                        continue;
                    }
                }
            }

            // operator:value pattern, where the prefix is one of our known keys
            int colon = token.IndexOf(':');
            if (colon > 0 && colon < token.Length - 1)
            {
                string key = token.Substring(0, colon).ToLowerInvariant();
                string value = token.Substring(colon + 1);

                if (ApplyOperator(key, value, q.Filter, ref caseSensitive, ref regex))
                    continue;
            }
            else if (token.EndsWith(':'))
            {
                // Bare flags like "folder:" / "file:" / "regex:" / "case:"
                string key = token.Substring(0, token.Length - 1).ToLowerInvariant();
                if (ApplyOperator(key, string.Empty, q.Filter, ref caseSensitive, ref regex))
                    continue;
            }

            // Free-text term: extract trailing fuzzy modifier "~" or "~N".
            //   "report~"   → fuzzy, distance 2 (default)
            //   "report~3"  → fuzzy, distance 3
            string t = token;
            int dist = 0;
            int tilde = t.LastIndexOf('~');
            if (tilde > 0 && tilde >= t.Length - 3)  // ~ or ~N (single digit) at the tail
            {
                string suffix = t.Substring(tilde + 1);
                if (suffix.Length == 0)
                {
                    dist = 2;
                    t = t.Substring(0, tilde);
                }
                else if (int.TryParse(suffix, out var n) && n >= 1 && n <= 5)
                {
                    dist = n;
                    t = t.Substring(0, tilde);
                }
            }

            if (t.Length == 0) continue;
            terms.Add(t);
            fuzzyDistances.Add(dist);
            if (dist > 0) anyFuzzy = true;
        }

        q.MatchMode = (caseSensitive ? MatchMode.CaseSensitive : 0)
                    | (regex ? MatchMode.Regex
                            : anyFuzzy ? MatchMode.Fuzzy
                            : terms.Exists(HasWildcards) ? MatchMode.Wildcard
                            : MatchMode.Substring);

        q.Terms = terms;
        q.TermFuzzyDistances = fuzzyDistances;
        return q;
    }

    private static bool HasWildcards(string s) => s.IndexOfAny(new[] { '*', '?' }) >= 0;

    /// <summary>
    /// Split the input into whitespace-separated tokens, respecting "double-quoted phrases".
    /// </summary>
    private static IEnumerable<string> Tokenize(string s)
    {
        var current = new StringBuilder();
        bool inQuotes = false;
        for (int i = 0; i < s.Length; i++)
        {
            char c = s[i];
            if (c == '"') { inQuotes = !inQuotes; continue; }
            if (!inQuotes && char.IsWhiteSpace(c))
            {
                if (current.Length > 0) { yield return current.ToString(); current.Clear(); }
                continue;
            }
            current.Append(c);
        }
        if (current.Length > 0) yield return current.ToString();
    }

    private static bool ApplyOperator(string key, string value,
        FilterCriteria f, ref bool caseSensitive, ref bool regex)
    {
        switch (key)
        {
            case "ext":
            case "extension":
                foreach (var part in value.Split(';', StringSplitOptions.RemoveEmptyEntries))
                    f.Extensions.Add(part.TrimStart('.').ToLowerInvariant());
                return true;

            case "size":
                return TryParseSizeExpression(value, f);

            case "dm":
            case "datemodified":
            case "modified":
                return TryParseDateExpression(value, f);

            case "path":
            case "folder" when value.Length > 0: // "folder:downloads" — same as path
                f.PathContains = value;
                return true;

            case "folder":
            case "dir":
                f.OnlyDirectories = true;
                return true;

            case "file":
                f.OnlyFiles = true;
                return true;

            case "kind":
            case "type":
                if (value.Equals("folder", StringComparison.OrdinalIgnoreCase) ||
                    value.Equals("dir", StringComparison.OrdinalIgnoreCase))
                {
                    f.OnlyDirectories = true; return true;
                }
                if (value.Equals("file", StringComparison.OrdinalIgnoreCase))
                {
                    f.OnlyFiles = true; return true;
                }
                return false;

            case "case":
                caseSensitive = true;
                return true;

            case "regex":
                regex = true;
                // The value is the regex itself when written as `regex:foo` — push back as a term.
                // The engine's RegexMatcher takes one combined pattern, so put it into Terms.
                return value.Length == 0; // bare `regex:` flag = handled here; `regex:expr` falls through

            default:
                return false;
        }
    }

    // -------- size --------

    private static bool TryParseSizeExpression(string v, FilterCriteria f)
    {
        if (string.IsNullOrEmpty(v)) return false;
        // Range: 1mb..100mb
        int rangeIdx = v.IndexOf("..", StringComparison.Ordinal);
        if (rangeIdx > 0)
        {
            if (TryParseSize(v.Substring(0, rangeIdx), out var lo) &&
                TryParseSize(v.Substring(rangeIdx + 2), out var hi))
            {
                f.MinSize = lo; f.MaxSize = hi; return true;
            }
            return false;
        }
        // Comparison operators
        if (v.StartsWith(">=")) { if (TryParseSize(v.Substring(2), out var n)) { f.MinSize = n; return true; } return false; }
        if (v.StartsWith("<=")) { if (TryParseSize(v.Substring(2), out var n)) { f.MaxSize = n; return true; } return false; }
        if (v.StartsWith(">"))  { if (TryParseSize(v.Substring(1), out var n)) { f.MinSize = n + 1; return true; } return false; }
        if (v.StartsWith("<"))  { if (TryParseSize(v.Substring(1), out var n)) { f.MaxSize = n - 1; return true; } return false; }
        // Plain number: exact match (set both bounds).
        if (TryParseSize(v, out var exact)) { f.MinSize = exact; f.MaxSize = exact; return true; }
        return false;
    }

    private static bool TryParseSize(string v, out long bytes)
    {
        bytes = 0;
        if (string.IsNullOrWhiteSpace(v)) return false;
        v = v.Trim().ToLowerInvariant();
        long mult = 1;
        if      (v.EndsWith("kb")) { mult = 1024L;                   v = v[..^2]; }
        else if (v.EndsWith("mb")) { mult = 1024L * 1024;            v = v[..^2]; }
        else if (v.EndsWith("gb")) { mult = 1024L * 1024 * 1024;     v = v[..^2]; }
        else if (v.EndsWith("tb")) { mult = 1024L * 1024 * 1024 * 1024; v = v[..^2]; }
        else if (v.EndsWith("k"))  { mult = 1024L;                   v = v[..^1]; }
        else if (v.EndsWith("m"))  { mult = 1024L * 1024;            v = v[..^1]; }
        else if (v.EndsWith("g"))  { mult = 1024L * 1024 * 1024;     v = v[..^1]; }
        else if (v.EndsWith("b"))  { mult = 1;                       v = v[..^1]; }
        if (!double.TryParse(v, NumberStyles.Any, CultureInfo.InvariantCulture, out var num)) return false;
        bytes = (long)(num * mult);
        return true;
    }

    // -------- date --------

    private static bool TryParseDateExpression(string v, FilterCriteria f)
    {
        if (string.IsNullOrEmpty(v)) return false;
        var now = DateTime.Now;

        // Keyword shortcuts → resolve to (after, before) range in local time, then to UTC ticks.
        (DateTime? after, DateTime? before) range = v.ToLowerInvariant() switch
        {
            "today"     => (now.Date, now.Date.AddDays(1)),
            "yesterday" => (now.Date.AddDays(-1), now.Date),
            "thisweek"  => (StartOfWeek(now), StartOfWeek(now).AddDays(7)),
            "lastweek"  => (StartOfWeek(now).AddDays(-7), StartOfWeek(now)),
            "thismonth" => (new DateTime(now.Year, now.Month, 1), new DateTime(now.Year, now.Month, 1).AddMonths(1)),
            "lastmonth" => (new DateTime(now.Year, now.Month, 1).AddMonths(-1), new DateTime(now.Year, now.Month, 1)),
            "thisyear"  => (new DateTime(now.Year, 1, 1), new DateTime(now.Year + 1, 1, 1)),
            "lastyear"  => (new DateTime(now.Year - 1, 1, 1), new DateTime(now.Year, 1, 1)),
            _ => (null, null),
        };

        if (range.after.HasValue)
        {
            f.ModifiedAfterTicks  = range.after.Value.ToUniversalTime().Ticks;
            f.ModifiedBeforeTicks = range.before!.Value.ToUniversalTime().Ticks;
            return true;
        }

        // Comparison: dm:>2024-01-01 / dm:<2024-01-01 / dm:2024-01-01..2024-12-31
        int rangeIdx = v.IndexOf("..", StringComparison.Ordinal);
        if (rangeIdx > 0
            && DateTime.TryParse(v.Substring(0, rangeIdx), CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var lo)
            && DateTime.TryParse(v.Substring(rangeIdx + 2), CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var hi))
        {
            f.ModifiedAfterTicks  = lo.ToUniversalTime().Ticks;
            f.ModifiedBeforeTicks = hi.ToUniversalTime().Ticks;
            return true;
        }

        if ((v.StartsWith(">=") || v.StartsWith(">"))
            && DateTime.TryParse(v.TrimStart('>', '='), CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var gt))
        {
            f.ModifiedAfterTicks = gt.ToUniversalTime().Ticks;
            return true;
        }

        if ((v.StartsWith("<=") || v.StartsWith("<"))
            && DateTime.TryParse(v.TrimStart('<', '='), CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var lt))
        {
            f.ModifiedBeforeTicks = lt.ToUniversalTime().Ticks;
            return true;
        }

        // Bare ISO date = whole day of that date.
        if (DateTime.TryParse(v, CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var day))
        {
            f.ModifiedAfterTicks  = day.Date.ToUniversalTime().Ticks;
            f.ModifiedBeforeTicks = day.Date.AddDays(1).ToUniversalTime().Ticks;
            return true;
        }
        return false;
    }

    private static DateTime StartOfWeek(DateTime d)
    {
        int diff = (7 + (int)d.DayOfWeek - (int)DayOfWeek.Monday) % 7;
        return d.Date.AddDays(-diff);
    }
