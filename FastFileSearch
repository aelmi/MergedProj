using System;
using System.Collections.Generic;
using System.Drawing;
using System.Drawing.Drawing2D;
using System.Drawing.Text;
using System.Windows.Forms;

namespace FastFileSearch.Ui;

/// <summary>Filter category — corresponds to a chip button in the UI.</summary>
internal enum QuickFilter
{
    All,
    Documents,
    Images,
    Videos,
    Audio,
    Code,
    Archives,
    Folders,
}

/// <summary>
/// Row of pill-shaped chip buttons under the search box. Single-select — clicking a
/// chip activates that filter; clicking the active chip again deactivates and falls
/// back to "All". When active, the host appends matching syntax (e.g. `ext:pdf;docx`)
/// to the query before sending it to the engine.
/// </summary>
internal sealed class QuickFilterBar : Control
{
    private static readonly (QuickFilter F, string Label)[] Chips =
    {
        (QuickFilter.All,       "All"),
        (QuickFilter.Documents, "Documents"),
        (QuickFilter.Images,    "Images"),
        (QuickFilter.Videos,    "Videos"),
        (QuickFilter.Audio,     "Audio"),
        (QuickFilter.Code,      "Code"),
        (QuickFilter.Archives,  "Archives"),
        (QuickFilter.Folders,   "Folders"),
    };

    public event EventHandler<QuickFilter>? FilterChanged;

    private QuickFilter _active = QuickFilter.All;
    private int _hover = -1;
    private readonly List<Rectangle> _chipBounds = new();

    public QuickFilterBar()
    {
        SetStyle(ControlStyles.AllPaintingInWmPaint
               | ControlStyles.OptimizedDoubleBuffer
               | ControlStyles.ResizeRedraw
               | ControlStyles.UserPaint, true);
        Height = 36;
        BackColor = Theme.Background;
        Theme.OnChange(this, () => { BackColor = Theme.Background; Invalidate(); });
    }

    public QuickFilter Active => _active;

    /// <summary>
    /// Returns the operator string this filter contributes to a query, e.g.
    /// "ext:pdf;docx" or "folder:". Empty when the filter is <see cref="QuickFilter.All"/>.
    /// </summary>
    public static string FilterToQueryFragment(QuickFilter f) => f switch
    {
        QuickFilter.Documents => "ext:pdf;doc;docx;xls;xlsx;ppt;pptx;txt;md;rtf;odt;ods;odp;tex;csv;epub",
        QuickFilter.Images    => "ext:jpg;jpeg;png;gif;bmp;webp;svg;ico;tif;tiff;heic;raw",
        QuickFilter.Videos    => "ext:mp4;mkv;avi;mov;wmv;webm;m4v;flv;mpg;mpeg",
        QuickFilter.Audio     => "ext:mp3;wav;flac;ogg;m4a;aac;wma;opus",
        QuickFilter.Code      => "ext:cs;py;js;ts;tsx;jsx;go;rs;java;cpp;cc;c;h;hpp;rb;php;swift;kt;sql;sh;ps1;yml;yaml;json;xml;html;css;scss;vue",
        QuickFilter.Archives  => "ext:zip;rar;7z;tar;gz;bz2;xz;iso;cab",
        QuickFilter.Folders   => "folder:",
        _ => "",
    };

    public void SetActive(QuickFilter f, bool raiseEvent = true)
    {
        if (_active == f) return;
        _active = f;
        Invalidate();
        if (raiseEvent) FilterChanged?.Invoke(this, f);
    }

    protected override void OnPaint(PaintEventArgs e)
    {
        var g = e.Graphics;
        g.SmoothingMode    = SmoothingMode.AntiAlias;
        g.TextRenderingHint = TextRenderingHint.ClearTypeGridFit;

        using var bg = new SolidBrush(Theme.Background);
        g.FillRectangle(bg, ClientRectangle);

        _chipBounds.Clear();
        int x = Theme.Padding;
        int y = (Height - 26) / 2;
        var font = Theme.UiFont(9f, FontStyle.Bold);

        for (int i = 0; i < Chips.Length; i++)
        {
            var (filter, label) = Chips[i];
            int textW = TextRenderer.MeasureText(g, label, font).Width;
            var rect = new Rectangle(x, y, textW + 24, 26);
            _chipBounds.Add(rect);

            bool active = filter == _active;
            bool hot = i == _hover;
            Color fill = active ? Theme.AccentMuted : (hot ? Theme.HoverOverlay : Theme.Surface);
            Color border = active ? Theme.Accent : Theme.Divider;
            Color textColor = active ? Theme.TextPrimary : Theme.TextSecondary;

            using (var path = Pill(rect))
            using (var fb = new SolidBrush(fill))
            using (var pen = new Pen(border, 1f))
            {
                g.FillPath(fb, path);
                g.DrawPath(pen, path);
            }

            TextRenderer.DrawText(g, label, font, rect, textColor,
                TextFormatFlags.HorizontalCenter | TextFormatFlags.VerticalCenter | TextFormatFlags.NoPrefix);

            x += rect.Width + 6;
        }

        // Bottom divider continuing the visual band into the results list.
        using (var pen = new Pen(Theme.Divider))
            g.DrawLine(pen, 0, Height - 1, Width, Height - 1);
    }

    protected override void OnMouseMove(MouseEventArgs e)
    {
        int newHover = -1;
        for (int i = 0; i < _chipBounds.Count; i++)
            if (_chipBounds[i].Contains(e.Location)) { newHover = i; break; }
        if (newHover != _hover) { _hover = newHover; Invalidate(); }
        Cursor = newHover >= 0 ? Cursors.Hand : Cursors.Default;
    }

    protected override void OnMouseLeave(EventArgs e)
    {
        if (_hover >= 0) { _hover = -1; Invalidate(); }
    }

    protected override void OnMouseClick(MouseEventArgs e)
    {
        for (int i = 0; i < _chipBounds.Count; i++)
        {
            if (_chipBounds[i].Contains(e.Location))
            {
                var chosen = Chips[i].F;
                // Toggle off back to All if user clicks the already-active chip.
                SetActive(chosen == _active && chosen != QuickFilter.All ? QuickFilter.All : chosen);
                return;
            }
        }
    }

    private static GraphicsPath Pill(Rectangle r)
    {
        int radius = r.Height / 2;
        int d = radius * 2;
        var path = new GraphicsPath();
        path.AddArc(r.X, r.Y, d, d, 90, 180);
        path.AddArc(r.Right - d, r.Y, d, d, 270, 180);
        path.CloseFigure();
        return path;
    }
}




