using System;
using System.ComponentModel;
using System.Runtime.InteropServices;
using static FastFileSearch.Native.NativeMethods;

namespace FastFileSearch.Native;

/// <summary>
/// Enables SE_BACKUP_NAME / SE_RESTORE_NAME on the current process token, which is
/// required for FILE_FLAG_BACKUP_SEMANTICS to bypass ACLs when opening volumes for
/// MFT enumeration.
///
/// Requires the process to be running elevated (Administrator). Because our manifest
/// requests requireAdministrator, the user has already consented to UAC by the time
/// we reach this code.
/// </summary>
internal static class PrivilegeHelper
{
    public const string SeBackupPrivilege  = "SeBackupPrivilege";
    public const string SeRestorePrivilege = "SeRestorePrivilege";

    public static void EnableForCurrentProcess(Action<string>? log = null)
    {
        Enable(SeBackupPrivilege, log);
        Enable(SeRestorePrivilege, log);
    }

    private static void Enable(string privilegeName, Action<string>? log)
    {
        IntPtr token = IntPtr.Zero;
        try
        {
            if (!OpenProcessToken(GetCurrentProcess(),
                TOKEN_ADJUST_PRIVILEGES | TOKEN_QUERY, out token))
            {
                throw new Win32Exception(Marshal.GetLastWin32Error(), "OpenProcessToken failed");
            }

            if (!LookupPrivilegeValue(null, privilegeName, out var luid))
            {
                throw new Win32Exception(Marshal.GetLastWin32Error(),
                    $"LookupPrivilegeValue({privilegeName}) failed");
            }

            var tp = new TOKEN_PRIVILEGES
            {
                PrivilegeCount = 1,
                Privilege = new LUID_AND_ATTRIBUTES
                {
                    Luid = luid,
                    Attributes = SE_PRIVILEGE_ENABLED,
                }
            };

            if (!AdjustTokenPrivileges(token, false, ref tp,
                (uint)Marshal.SizeOf<TOKEN_PRIVILEGES>(), IntPtr.Zero, IntPtr.Zero))
            {
                throw new Win32Exception(Marshal.GetLastWin32Error(), "AdjustTokenPrivileges failed");
            }

            // AdjustTokenPrivileges returns success even on partial application.
            // The only reliable check is GetLastWin32Error == ERROR_NOT_ALL_ASSIGNED.
            int err = Marshal.GetLastWin32Error();
            if (err == ERROR_NOT_ALL_ASSIGNED)
            {
                throw new InvalidOperationException(
                    $"Privilege {privilegeName} was not assignable. " +
                    "Run the application as Administrator.");
            }

            log?.Invoke($"Enabled {privilegeName}.");
        }
        finally
        {
            if (token != IntPtr.Zero) CloseHandle(token);
        }
    }
}




