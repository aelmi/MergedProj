using System;
using System.Buffers;
using System.Collections.Generic;
using System.ComponentModel;
using System.Runtime.InteropServices;
using System.Threading;
using FastFileSearch.Models;
using Microsoft.Win32.SafeHandles;
using static FastFileSearch.Native.NativeMethods;

namespace FastFileSearch.Indexing;

/// <summary>
/// Streams every USN record currently on a volume's Master File Table by repeatedly
/// calling DeviceIoControl(FSCTL_ENUM_USN_DATA). Typical throughput on SSD:
/// 200k–500k records/second.
///
/// STRUCTURE NOTE: C# does not allow iterator method bodies to contain unsafe code
/// (the state machine the compiler generates around `yield return` is incompatible
/// with `fixed` pinning across yields). So the public method <see cref="Enumerate"/>
/// is a plain iterator that calls into the static unsafe helper <see cref="ReadBatch"/>
/// — all pointer work lives there.
/// </summary>
public sealed class MftReader
{
    private const int OutputBufferSize = 64 * 1024; // 64 KB per MSDN guidance

    /// <summary>
    /// Enumerates every USN record on the volume. Yields each exactly once.
    /// </summary>
    /// <param name="driveLetter">Single letter, e.g. 'C'.</param>
    public IEnumerable<FileMetadata> Enumerate(char driveLetter, CancellationToken ct)
    {
        string volumePath = $@"\\.\{driveLetter}:";
        using var handle = OpenVolume(volumePath);

        // Shared mutable cursor between iterator turns. A class (not struct) so
        // ReadBatch can mutate it without ref parameters.
        var state = new EnumState();

        byte[] outputBuffer = ArrayPool<byte>.Shared.Rent(OutputBufferSize);
        try
        {
            while (!ct.IsCancellationRequested)
            {
                var batch = ReadBatch(handle, state, outputBuffer);
                if (batch is null) yield break;        // ERROR_HANDLE_EOF
                foreach (var rec in batch)
                    yield return rec;
            }
        }
        finally
        {
            ArrayPool<byte>.Shared.Return(outputBuffer);
        }
    }

    /// <summary>State carried between successive FSCTL_ENUM_USN_DATA calls.</summary>
    private sealed class EnumState
    {
        public ulong StartFrn;  // updated to the "next FRN" from each batch
    }

    /// <summary>
    /// One FSCTL_ENUM_USN_DATA call: issue the IOCTL, parse out the records,
    /// advance <see cref="EnumState.StartFrn"/>. Returns null on EOF.
    /// All pointer code is contained here — it's a regular (non-iterator) method,
    /// so the unsafe context is legal.
    /// </summary>
    private static unsafe List<FileMetadata>? ReadBatch(
        SafeFileHandle handle, EnumState state, byte[] outputBuffer)
    {
        var input = new MFT_ENUM_DATA_V0
        {
            StartFileReferenceNumber = state.StartFrn,
            LowUsn = 0,
            HighUsn = long.MaxValue,
        };

        uint bytesReturned;
        fixed (byte* pOut = outputBuffer)
        {
            bool ok = DeviceIoControl(
                handle,
                FSCTL_ENUM_USN_DATA,
                &input, (uint)sizeof(MFT_ENUM_DATA_V0),
                pOut, OutputBufferSize,
                out bytesReturned,
                IntPtr.Zero);

            if (!ok)
            {
                int err = Marshal.GetLastWin32Error();
                if (err == ERROR_HANDLE_EOF) return null;
                throw new Win32Exception(err, "FSCTL_ENUM_USN_DATA failed");
            }

            // First 8 bytes of the output buffer are the next StartFRN; records follow.
            ulong nextFrn = *(ulong*)pOut;
            int offset = sizeof(ulong);
            var results = new List<FileMetadata>(capacity: 256);

            while (offset < bytesReturned)
            {
                var rec = ReadRecordV2(pOut + offset, out int consumed);
                offset += consumed;
                if (rec is not null) results.Add(rec);
            }

            state.StartFrn = nextFrn;
            return results;
        }
    }

    /// <summary>
    /// Opens the raw volume with FILE_FLAG_BACKUP_SEMANTICS. Caller must have
    /// SE_BACKUP_NAME enabled (done at startup by PrivilegeHelper).
    /// </summary>
    public static SafeFileHandle OpenVolume(string volumePath)
    {
        var h = CreateFile(
            volumePath,
            GENERIC_READ,
            FILE_SHARE_READ | FILE_SHARE_WRITE | FILE_SHARE_DELETE,
            IntPtr.Zero,
            OPEN_EXISTING,
            FILE_FLAG_BACKUP_SEMANTICS,
            IntPtr.Zero);

        if (h.IsInvalid)
        {
            int err = Marshal.GetLastWin32Error();
            h.Dispose();
            throw new Win32Exception(err, $"CreateFile({volumePath}) failed");
        }
        return h;
    }

    /// <summary>
    /// Decode one USN_RECORD_V2 from a pointer. Returns the constructed metadata and
    /// the bytes consumed (RecordLength). Returns null for unknown versions.
    /// </summary>
    private static unsafe FileMetadata? ReadRecordV2(byte* p, out int consumed)
    {
        uint recordLength   = *(uint*)(p + 0);
        ushort majorVersion = *(ushort*)(p + 4);
        consumed = (int)recordLength;

        if (majorVersion != 2) return null;

        ulong frn          = *(ulong*)(p + 8);
        ulong parentFrn    = *(ulong*)(p + 16);
        // p + 24 : USN  (int64)
        long timeStamp     = *(long*)(p + 32);
        // p + 40 : Reason (uint32)
        // p + 44 : SourceInfo (uint32)
        // p + 48 : SecurityId (uint32)
        uint fileAttributes  = *(uint*)(p + 52);
        ushort fileNameLength = *(ushort*)(p + 56); // BYTES, not chars
        ushort fileNameOffset = *(ushort*)(p + 58);

        string name = new((char*)(p + fileNameOffset), 0, fileNameLength / 2);

        return new FileMetadata
        {
            FileReferenceNumber = frn,
            ParentFileReferenceNumber = parentFrn,
            FileName = name,
            Attributes = fileAttributes,
            LastModifiedTicks = timeStamp,
            Size = 0,
        };
    }
}




