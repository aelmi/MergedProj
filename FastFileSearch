using System;
using System.Drawing;
using System.Drawing.Drawing2D;
using System.IO;
using System.Threading;
using System.Threading.Tasks;
using System.Windows.Forms;
using FastFileSearch.Models;

namespace FastFileSearch.Ui;

/// <summary>
/// Right-docked panel showing a quick preview of the currently selected file.
///   - Images (.png/.jpg/.gif/.bmp/.webp/.ico/.tif): scaled-down rendering
///   - Text/code (under a size cap): up to ~64 KB of UTF-8 text
///   - Anything else: just file info (path, size, modified, attributes)
///
/// Preview loading runs on a thread-pool task so the UI never blocks on disk.
/// Cancellation tokens prevent stale previews from overwriting newer ones.
/// </summary>
internal sealed class PreviewPane : Panel
{
    private const int TextPreviewMaxBytes = 64 * 1024;
    private static readonly HashSet<string> ImageExt = new(StringComparer.OrdinalIgnoreCase)
    {
        ".png", ".jpg", ".jpeg", ".gif", ".bmp", ".webp", ".ico", ".tif", ".tiff",
    };
    private static readonly HashSet<string> TextExt = new(StringComparer.OrdinalIgnoreCase)
    {
        ".txt", ".md", ".log", ".ini", ".cfg", ".conf", ".csv", ".tsv",
        ".cs", ".py", ".js", ".ts", ".tsx", ".jsx", ".java", ".cpp", ".cc", ".c", ".h", ".hpp",
        ".go", ".rs", ".rb", ".php", ".kt", ".swift", ".sql", ".sh", ".ps1", ".bat",
        ".html", ".htm", ".css", ".scss", ".sass", ".less", ".xml", ".json", ".yaml", ".yml",
        ".gitignore", ".env", ".dockerfile", ".makefile",
    };

    private readonly Label _title;
    private readonly Label _info;
    private readonly PictureBox _image;
    private readonly TextBox _text;
    private CancellationTokenSource? _loadCts;
    private FileMetadata? _current;

    public PreviewPane()
    {
        BackColor = Theme.Surface;
        Padding = new Padding(16);
        BorderStyle = BorderStyle.None;
        DoubleBuffered = true;

        _title = new Label
        {
            Dock = DockStyle.Top,
            Font = Theme.UiFont(11f, FontStyle.Bold),
            ForeColor = Theme.TextPrimary,
            BackColor = Theme.Surface,
            Height = 28,
            AutoEllipsis = true,
            Text = "Preview",
        };
        _info = new Label
        {
            Dock = DockStyle.Top,
            Font = Theme.UiFont(9f),
            ForeColor = Theme.TextSecondary,
            BackColor = Theme.Surface,
            Height = 60,
            AutoEllipsis = true,
            Text = "Select a file to preview.",
        };
        _image = new PictureBox
        {
            Dock = DockStyle.Fill,
            SizeMode = PictureBoxSizeMode.Zoom,
            BackColor = Theme.Surface,
            Visible = false,
        };
        _text = new TextBox
        {
            Dock = DockStyle.Fill,
            Multiline = true,
            ReadOnly = true,
            ScrollBars = ScrollBars.Vertical,
            BorderStyle = BorderStyle.None,
            Font = new Font("Consolas", 9f),
            BackColor = Theme.Background,
            ForeColor = Theme.TextPrimary,
            Visible = false,
            WordWrap = false,
        };

        Controls.Add(_image);
        Controls.Add(_text);
        Controls.Add(_info);
        Controls.Add(_title);

        Theme.OnChange(this, () =>
        {
            BackColor        = Theme.Surface;
            _title.BackColor = Theme.Surface;  _title.ForeColor = Theme.TextPrimary;
            _info.BackColor  = Theme.Surface;  _info.ForeColor  = Theme.TextSecondary;
            _image.BackColor = Theme.Surface;
            _text.BackColor  = Theme.Background; _text.ForeColor = Theme.TextPrimary;
            Invalidate();
        });
    }

    protected override void OnPaint(PaintEventArgs e)
    {
        base.OnPaint(e);
        // Subtle left edge separator so the pane visually detaches from the list.
        using var pen = new Pen(Theme.Divider);
        e.Graphics.DrawLine(pen, 0, 0, 0, Height);
    }

    public async void Show(FileMetadata? f)
    {
        _current = f;
        // Cancel any in-flight preview load.
        try { _loadCts?.Cancel(); } catch { }
        _loadCts = new CancellationTokenSource();
        var ct = _loadCts.Token;

        if (f is null || string.IsNullOrEmpty(f.FullPath))
        {
            _title.Text = "Preview";
            _info.Text  = "Select a file to preview.";
            _image.Visible = false;
            _text.Visible = false;
            return;
        }

        _title.Text = f.FileName;
        _info.Text  = $"{f.FullPath}\r\n{FormatSize(f.Size)}    {FormatModified(f.LastModifiedTicks)}";

        string ext = Path.GetExtension(f.FileName);
        try
        {
            if (ImageExt.Contains(ext))
            {
                await LoadImageAsync(f.FullPath, ct);
            }
            else if (TextExt.Contains(ext) || string.IsNullOrEmpty(ext) || (f.Size > 0 && f.Size < TextPreviewMaxBytes && LooksTexty(ext)))
            {
                await LoadTextAsync(f.FullPath, ct);
            }
            else
            {
                _image.Visible = false;
                _text.Visible = false;
            }
        }
        catch (OperationCanceledException) { /* superseded */ }
        catch (Exception ex)
        {
            if (!ct.IsCancellationRequested)
            {
                _image.Visible = false;
                _text.Text = $"(could not preview: {ex.Message})";
                _text.Visible = true;
            }
        }
    }

    private async Task LoadImageAsync(string path, CancellationToken ct)
    {
        var bytes = await Task.Run(() => File.ReadAllBytes(path), ct).ConfigureAwait(true);
        if (ct.IsCancellationRequested) return;
        using var ms = new MemoryStream(bytes);
        var img = Image.FromStream(ms);
        _image.Image?.Dispose();
        _image.Image = img;
        _image.Visible = true;
        _text.Visible = false;
    }

    private async Task LoadTextAsync(string path, CancellationToken ct)
    {
        string content = await Task.Run(() =>
        {
            using var fs = new FileStream(path, FileMode.Open, FileAccess.Read, FileShare.ReadWrite);
            int len = (int)Math.Min(TextPreviewMaxBytes, fs.Length);
            var buf = new byte[len];
            int read = fs.Read(buf, 0, len);
            return System.Text.Encoding.UTF8.GetString(buf, 0, read);
        }, ct).ConfigureAwait(true);
        if (ct.IsCancellationRequested) return;
        _text.Text = content;
        _text.Visible = true;
        _image.Visible = false;
    }

    private static bool LooksTexty(string ext) => string.IsNullOrEmpty(ext) || TextExt.Contains(ext);

    private static string FormatSize(long bytes)
    {
        if (bytes <= 0) return "—";
        string[] units = { "B", "KB", "MB", "GB", "TB" };
        double v = bytes; int u = 0;
        while (v >= 1024 && u < units.Length - 1) { v /= 1024; u++; }
        return $"{v:0.##} {units[u]}";
    }

    private static string FormatModified(long ticks)
    {
        if (ticks <= 0) return "—";
        try { return new DateTime(ticks, DateTimeKind.Utc).ToLocalTime().ToString("yyyy-MM-dd HH:mm"); }
        catch { return "—"; }
    }
}




