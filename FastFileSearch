using System;
using System.Buffers;
using System.Collections.Generic;
using System.ComponentModel;
using System.Runtime.InteropServices;
using System.Threading;
using System.Threading.Tasks;
using Microsoft.Win32.SafeHandles;
using static FastFileSearch.Native.NativeMethods;

namespace FastFileSearch.Indexing;

/// <summary>One change event derived from a USN_RECORD_V2.</summary>
public readonly struct UsnChangeEvent
{
    public readonly ulong FileReferenceNumber;
    public readonly ulong ParentFileReferenceNumber;
    public readonly string FileName;
    public readonly uint Reason;
    public readonly uint Attributes;
    public readonly long TimeStampTicks;
    public readonly long Usn;

    public UsnChangeEvent(ulong frn, ulong parent, string name, uint reason, uint attrs, long ts, long usn)
    {
        FileReferenceNumber = frn; ParentFileReferenceNumber = parent;
        FileName = name; Reason = reason; Attributes = attrs;
        TimeStampTicks = ts; Usn = usn;
    }

    public bool IsCreate    => (Reason & USN_REASON_FILE_CREATE) != 0;
    public bool IsDelete    => (Reason & USN_REASON_FILE_DELETE) != 0;
    public bool IsRenameNew => (Reason & USN_REASON_RENAME_NEW_NAME) != 0;
    public bool IsRenameOld => (Reason & USN_REASON_RENAME_OLD_NAME) != 0;
    public bool IsClose     => (Reason & USN_REASON_CLOSE) != 0;
}

/// <summary>
/// Long-running monitor for one volume's USN change journal. Blocks inside the kernel
/// (via BytesToWaitFor=1) until new entries arrive — ~zero CPU when idle.
///
/// SAME STRUCTURE NOTE AS MftReader: the public async iterator method
/// <see cref="WatchAsync"/> contains no unsafe code; the pointer-using helper
/// <see cref="ReadOneBatch"/> is a regular static method.
/// </summary>
public sealed class UsnJournalMonitor
{
    private const int OutputBufferSize = 64 * 1024;
    private const uint AllReasons = 0xFFFFFFFF;

    /// <summary>State that survives between successive FSCTL_READ_USN_JOURNAL calls.</summary>
    private sealed class WatchState
    {
        public long CurrentUsn;
        public ulong JournalId;
    }

    private readonly struct Batch
    {
        public readonly List<UsnChangeEvent> Events;
        public readonly long NextUsn;
        public Batch(List<UsnChangeEvent> e, long n) { Events = e; NextUsn = n; }
    }

    /// <summary>
    /// Stream change events for the given volume until cancellation.
    /// </summary>
    /// <param name="driveLetter">Single letter, e.g. 'C'.</param>
    /// <param name="startUsn">Where to resume reading. 0 = "now".</param>
    public async IAsyncEnumerable<UsnChangeEvent> WatchAsync(
        char driveLetter,
        long startUsn,
        [System.Runtime.CompilerServices.EnumeratorCancellation] CancellationToken ct)
    {
        using var handle = MftReader.OpenVolume($@"\\.\{driveLetter}:");
        var journalData = QueryJournal(handle);

        var state = new WatchState
        {
            CurrentUsn = startUsn > 0 ? startUsn : journalData.NextUsn,
            JournalId  = journalData.UsnJournalID,
        };

        byte[] outputBuffer = ArrayPool<byte>.Shared.Rent(OutputBufferSize);
        try
        {
            while (!ct.IsCancellationRequested)
            {
                // ReadOneBatch is synchronous; offload to thread pool so we don't
                // tie up an awaiter. The DeviceIoControl call inside blocks in the
                // kernel until BytesToWaitFor bytes are available.
                // We pass `state` (a class) rather than ref-locals to keep this
                // legal inside an async iterator + lambda.
                var batch = await Task.Run(
                    () => ReadOneBatch(handle, state, outputBuffer), ct)
                    .ConfigureAwait(false);

                foreach (var ev in batch.Events)
                    yield return ev;

                state.CurrentUsn = batch.NextUsn;
            }
        }
        finally
        {
            ArrayPool<byte>.Shared.Return(outputBuffer);
        }
    }

    private static unsafe Batch ReadOneBatch(
        SafeFileHandle handle, WatchState state, byte[] outputBuffer)
    {
        var input = new READ_USN_JOURNAL_DATA_V1
        {
            StartUsn = state.CurrentUsn,
            ReasonMask = AllReasons,
            ReturnOnlyOnClose = 0,
            Timeout = 0,
            BytesToWaitFor = 1,
            UsnJournalID = state.JournalId,
            MinMajorVersion = 2,
            MaxMajorVersion = 2,
        };

        uint bytesReturned;
        fixed (byte* pOut = outputBuffer)
        {
            bool ok = DeviceIoControl(
                handle,
                FSCTL_READ_USN_JOURNAL,
                &input, (uint)sizeof(READ_USN_JOURNAL_DATA_V1),
                pOut, OutputBufferSize,
                out bytesReturned,
                IntPtr.Zero);

            if (!ok)
            {
                int err = Marshal.GetLastWin32Error();
                if (err == ERROR_JOURNAL_ENTRY_DELETED)
                    throw new UsnJournalTrimmedException();
                throw new Win32Exception(err, "FSCTL_READ_USN_JOURNAL failed");
            }

            long nextUsn = *(long*)pOut;
            int offset = sizeof(long);
            var events = new List<UsnChangeEvent>(capacity: 256);

            while (offset < bytesReturned)
            {
                byte* p = pOut + offset;
                uint recordLength   = *(uint*)(p + 0);
                ushort majorVersion = *(ushort*)(p + 4);
                offset += (int)recordLength;
                if (majorVersion != 2) continue;

                ulong frn       = *(ulong*)(p + 8);
                ulong parentFrn = *(ulong*)(p + 16);
                long usn        = *(long*)(p + 24);
                long ts         = *(long*)(p + 32);
                uint reason     = *(uint*)(p + 40);
                uint attributes = *(uint*)(p + 52);
                ushort nameLen  = *(ushort*)(p + 56);
                ushort nameOff  = *(ushort*)(p + 58);

                string name = new((char*)(p + nameOff), 0, nameLen / 2);
                events.Add(new UsnChangeEvent(frn, parentFrn, name, reason, attributes, ts, usn));
            }

            return new Batch(events, nextUsn);
        }
    }

    private static unsafe USN_JOURNAL_DATA_V0 QueryJournal(SafeFileHandle handle)
    {
        USN_JOURNAL_DATA_V0 data;
        uint bytesReturned;
        bool ok = DeviceIoControl(
            handle, FSCTL_QUERY_USN_JOURNAL,
            null, 0,
            &data, (uint)sizeof(USN_JOURNAL_DATA_V0),
            out bytesReturned,
            IntPtr.Zero);

        if (!ok) throw new Win32Exception(Marshal.GetLastWin32Error(), "FSCTL_QUERY_USN_JOURNAL failed");
        return data;
    }
}

public sealed class UsnJournalTrimmedException : Exception
{
    public UsnJournalTrimmedException()
        : base("USN journal entries between our last read and now have been deleted. " +
               "Re-enumerate the MFT and resume from the current journal head.") { }
}




