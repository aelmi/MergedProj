using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Runtime.InteropServices;
using System.Text;
using FastFileSearch.Models;

namespace FastFileSearch.Ui;

/// <summary>
/// Reads the user's "Recent Items" folder (the same one Windows fills when you open
/// a file from anywhere), resolves each .lnk shortcut to its real target via the
/// IShellLink COM interface, and returns the most recent files as <see cref="FileMetadata"/>
/// suitable for displaying in the results list.
///
/// COM interop note: we use the in-process Shell objects, which are cheap, but you
/// must call this from an STA thread (the WinForms UI thread already is one).
/// </summary>
internal static class RecentFilesProvider
{
    public static List<FileMetadata> Load(int max = 50)
    {
        var result = new List<FileMetadata>();
        string recent = Environment.GetFolderPath(Environment.SpecialFolder.Recent);
        if (string.IsNullOrEmpty(recent) || !Directory.Exists(recent)) return result;

        DirectoryInfo dir;
        try { dir = new DirectoryInfo(recent); }
        catch { return result; }

        // Most recently written shortcuts first — that's when they were last "used".
        var lnks = dir.EnumerateFiles("*.lnk", SearchOption.TopDirectoryOnly)
                      .OrderByDescending(f => f.LastWriteTimeUtc)
                      .Take(max * 2) // overscan; some .lnks won't resolve
                      .ToList();

        IShellLink? link = null;
        IPersistFile? file = null;
        try
        {
            link = (IShellLink)Activator.CreateInstance(Type.GetTypeFromCLSID(CLSID_ShellLink)!)!;
            file = (IPersistFile)link;
        }
        catch
        {
            // No shell COM available; bail gracefully.
            return result;
        }

        var sb = new StringBuilder(260);
        foreach (var lnk in lnks)
        {
            string? target = TryResolve(file, link, lnk.FullName, sb);
            if (string.IsNullOrEmpty(target)) continue;
            if (!File.Exists(target) && !Directory.Exists(target)) continue;

            FileMetadata meta;
            try
            {
                bool isDir = Directory.Exists(target);
                var info = isDir ? (FileSystemInfo)new DirectoryInfo(target) : new FileInfo(target);
                meta = new FileMetadata
                {
                    FileName = info.Name,
                    FullPath = info.FullName,
                    Size = isDir ? 0 : ((FileInfo)info).Length,
                    LastModifiedTicks = info.LastWriteTimeUtc.Ticks,
                    Attributes = (uint)info.Attributes,
                };
            }
            catch { continue; }

            result.Add(meta);
            if (result.Count >= max) break;
        }
        return result;
    }

    private static string? TryResolve(IPersistFile file, IShellLink link, string lnkPath, StringBuilder sb)
    {
        try
        {
            file.Load(lnkPath, 0);
            sb.Clear(); sb.Capacity = 260;
            link.GetPath(sb, sb.Capacity, IntPtr.Zero, 0);
            var p = sb.ToString();
            return string.IsNullOrWhiteSpace(p) ? null : p;
        }
        catch { return null; }
    }

    // ---- COM interop ----

    private static readonly Guid CLSID_ShellLink = new("00021401-0000-0000-C000-000000000046");

    [ComImport, Guid("000214F9-0000-0000-C000-000000000046"),
     InterfaceType(ComInterfaceType.InterfaceIsIUnknown)]
    private interface IShellLink
    {
        void GetPath([Out, MarshalAs(UnmanagedType.LPWStr)] StringBuilder pszFile,
                     int cchMaxPath, IntPtr pfd, uint fFlags);
        void GetIDList(out IntPtr ppidl);
        void SetIDList(IntPtr pidl);
        void GetDescription([Out, MarshalAs(UnmanagedType.LPWStr)] StringBuilder name, int cch);
        void SetDescription([MarshalAs(UnmanagedType.LPWStr)] string name);
        void GetWorkingDirectory([Out, MarshalAs(UnmanagedType.LPWStr)] StringBuilder dir, int cch);
        void SetWorkingDirectory([MarshalAs(UnmanagedType.LPWStr)] string dir);
        void GetArguments([Out, MarshalAs(UnmanagedType.LPWStr)] StringBuilder args, int cch);
        void SetArguments([MarshalAs(UnmanagedType.LPWStr)] string args);
        void GetHotkey(out short pwHotkey);
        void SetHotkey(short wHotkey);
        void GetShowCmd(out int piShowCmd);
        void SetShowCmd(int iShowCmd);
        void GetIconLocation([Out, MarshalAs(UnmanagedType.LPWStr)] StringBuilder path, int cch, out int piIcon);
        void SetIconLocation([MarshalAs(UnmanagedType.LPWStr)] string path, int iIcon);
        void SetRelativePath([MarshalAs(UnmanagedType.LPWStr)] string pszPathRel, uint reserved);
        void Resolve(IntPtr hwnd, uint fFlags);
        void SetPath([MarshalAs(UnmanagedType.LPWStr)] string pszFile);
    }

    [ComImport, Guid("0000010b-0000-0000-C000-000000000046"),
     InterfaceType(ComInterfaceType.InterfaceIsIUnknown)]
    private interface IPersistFile
    {
        void GetClassID(out Guid pClassID);
        [PreserveSig] int IsDirty();
        void Load([MarshalAs(UnmanagedType.LPWStr)] string pszFileName, uint dwMode);
        void Save([MarshalAs(UnmanagedType.LPWStr)] string pszFileName,
                  [MarshalAs(UnmanagedType.Bool)] bool fRemember);
        void SaveCompleted([MarshalAs(UnmanagedType.LPWStr)] string pszFileName);
        void GetCurFile([MarshalAs(UnmanagedType.LPWStr)] out string ppszFileName);
