using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Diagnostics;
using System.IO;
using System.Linq;
using System.Runtime.InteropServices;
using System.Threading;
using System.Threading.Tasks;
using FastFileSearch.Models;
using static FastFileSearch.Native.NativeMethods;

namespace FastFileSearch.Indexing;

/// <summary>
/// Owns the lifecycle of indexing for a set of volumes. For each volume:
///   1. Snapshot the USN journal head (so we know where to resume monitoring).
///   2. Stream every record from the MFT and populate the FileIndex.
///   3. Switch to incremental USN journal monitoring from the snapshot point.
///
/// Snapshotting the journal head BEFORE the MFT walk is critical — otherwise we'd
/// miss any changes that happened during the (potentially minute-long) initial scan.
///
/// Progress is reported via IProgress&lt;IndexingProgress&gt;, which marshals to the
/// UI thread automatically when constructed on the UI thread (Progress&lt;T&gt; captures
/// the current SynchronizationContext).
/// </summary>
public sealed class IndexManager
{
    private readonly FileIndex _index;
    private readonly MftReader _mftReader;
    private readonly UsnJournalMonitor _usnMonitor;
    private readonly EnumerationIndexer _enumIndexer;
    private readonly IProgress<IndexingProgress>? _progress;
    private readonly Action<string>? _log;

    /// <summary>UNC / WSL root path → synthetic volume key, so we can drop it later.</summary>
    private readonly Dictionary<string, char> _enumRootKeys = new(StringComparer.OrdinalIgnoreCase);

    /// <summary>
    /// Raised when a USN journal becomes unreadable (trimmed or recreated). The arg
    /// is a human-readable explanation suitable for the status bar; the manager will
    /// already have begun a background MFT re-enumeration by the time this fires.
    /// </summary>
    public event EventHandler<string>? JournalReset;

    public IndexManager(
        FileIndex index,
        MftReader mftReader,
        UsnJournalMonitor usnMonitor,
        IProgress<IndexingProgress>? progress = null,
        Action<string>? log = null)
    {
        _index = index;
        _mftReader = mftReader;
        _usnMonitor = usnMonitor;
        _progress = progress;
        _log = log;
        _enumIndexer = new EnumerationIndexer(index, log);
    }

    /// <summary>
    /// Index a non-NTFS root (UNC share, removable FAT/exFAT, WSL distro). Tracks the
    /// returned synthetic key so the caller can later drop it via <see cref="DropExtraRoot"/>.
    /// </summary>
    public async Task<char> AddEnumerationRootAsync(string rootPath, FileIndex.VolumeKind kind, CancellationToken ct)
    {
        if (_enumRootKeys.ContainsKey(rootPath)) return _enumRootKeys[rootPath];
        var key = await _enumIndexer.IndexRootAsync(rootPath, kind, ct).ConfigureAwait(false);
        if (key != '\0') _enumRootKeys[rootPath] = key;
        return key;
    }

    /// <summary>Drop a root added via <see cref="AddEnumerationRootAsync"/>.</summary>
    public void DropExtraRoot(string rootPath)
    {
        if (_enumRootKeys.TryGetValue(rootPath, out var key))
        {
            _enumIndexer.DropRoot(key);
            _enumRootKeys.Remove(rootPath);
        }
    }

    /// <summary>
    /// Discover WSL distros mounted under \\wsl$\ (or \\wsl.localhost\). Probes
    /// directory listings non-recursively; failure means WSL isn't running and is
    /// silently swallowed.
    /// </summary>
    public static IReadOnlyList<string> DiscoverWslRoots()
    {
        var roots = new List<string>();
        foreach (var hostPath in new[] { @"\\wsl$", @"\\wsl.localhost" })
        {
            try
            {
                if (!Directory.Exists(hostPath)) continue;
                foreach (var distro in Directory.EnumerateDirectories(hostPath))
                {
                    roots.Add(distro);
                }
            }
            catch { /* WSL not installed / not running */ }
        }
        return roots;
    }

    /// <summary>
    /// Begin indexing every drive. Returns a Task that completes when initial scans
    /// finish; journal monitors keep running in background until the token cancels.
    /// </summary>
    public Task StartAsync(IEnumerable<char> drives, CancellationToken ct)
    {
        var tasks = new List<Task>();
        foreach (var d in drives)
            tasks.Add(Task.Run(() => IndexVolumeAsync(d, ct), ct));
        // Periodic LRU trim when a cap is configured. Runs alongside the per-volume
        // tasks so the cap is enforced even while indexing is still growing.
        tasks.Add(Task.Run(() => MemoryCapLoopAsync(ct), ct));
        return Task.WhenAll(tasks);
    }

    private async Task MemoryCapLoopAsync(CancellationToken ct)
    {
        while (!ct.IsCancellationRequested)
        {
            long cap = Program.Settings.MaxIndexEntries;
            if (cap > 0 && _index.ApproximateCount > cap)
            {
                int n = _index.TrimTo(cap);
                if (n > 0) _log?.Invoke($"Memory cap: evicted {n:N0} cold entries (now {_index.ApproximateCount:N0} / cap {cap:N0})");
            }
            try { await Task.Delay(TimeSpan.FromSeconds(15), ct).ConfigureAwait(false); }
            catch (OperationCanceledException) { return; }
        }
    }

    private async Task IndexVolumeAsync(char drive, CancellationToken ct)
    {
        try
        {
            long resumeUsn = 0;
            bool restored = false;

            var cached = IndexPersistence.TryLoad(drive);
            if (cached is not null)
            {
                var journal = QueryJournal(drive);
                // A cache is reusable only if it points at the SAME journal (catches
                // reformat / journal recreate) AND the LastUsn we saved still lives
                // inside the journal's surviving window (catches trim while we were
                // closed).
                if (journal is { } j
                    && j.UsnJournalID == cached.JournalId
                    && cached.LastUsn >= j.LowestValidUsn
                    && cached.LastUsn <= j.NextUsn)
                {
                    _index.BulkLoad(drive, cached.JournalId, cached.LastUsn, cached.Entries);
                    resumeUsn = cached.LastUsn;
                    restored = true;
                    _log?.Invoke($"Volume {drive}: restored {cached.Entries.Count:N0} entries from cache");
                    Report(100, $"Restored {cached.Entries.Count:N0} entries on {drive}:", isComplete: true);
                }
                else
                {
                    _log?.Invoke($"Volume {drive}: cache invalid (journal changed or trimmed), full rescan");
                }
            }

            if (!restored)
            {
                _log?.Invoke($"Indexing {drive}: initial MFT scan starting");
                Report(0, $"Scanning {drive}: ...");

                var journal = QueryJournal(drive);
                long startUsn = journal?.NextUsn ?? 0;
                ulong journalId = journal?.UsnJournalID ?? 0;

                long count = 0;
                var sw = Stopwatch.StartNew();
                foreach (var meta in _mftReader.Enumerate(drive, ct))
                {
                    _index.AddOrUpdate(drive, new IndexEntry
                    {
                        FileReferenceNumber = meta.FileReferenceNumber,
                        ParentFileReferenceNumber = meta.ParentFileReferenceNumber,
                        FileName = meta.FileName,
                        Attributes = meta.Attributes,
                        LastModifiedTicks = meta.LastModifiedTicks,
                        Size = meta.Size,
                    });

                    if ((++count & 0xFFFF) == 0)
                    {
                        Report((int)Math.Min(99, count / 10_000),
                            $"Indexing {drive}: {count:N0} entries");
                    }
                }
                sw.Stop();
                _log?.Invoke($"Volume {drive}: indexed {count:N0} entries in {sw.ElapsedMilliseconds}ms");

                _index.SetJournalId(drive, journalId);
                _index.SetLastUsn(drive, startUsn);
                resumeUsn = startUsn;
                Report(100, $"Indexed {count:N0} entries on {drive}:", isComplete: true);
            }

            // Low-priority size-fill before tailing the journal. USN records don't
            // carry file size, so freshly-walked entries land with Size=0; we patch
            // them up with cheap GetFileAttributesEx stats on a background loop.
            _ = Task.Run(() => BackfillSizesAsync(drive, ct), ct);

            // Tail the journal forever.
            await MonitorVolumeAsync(drive, resumeUsn, ct).ConfigureAwait(false);
        }
        catch (OperationCanceledException) { /* shutdown */ }
        catch (Exception ex)
        {
            _log?.Invoke($"Indexing {drive}: failed — {ex.Message}");
        }
    }

    /// <summary>
    /// Walks the volume's entries and fills in <see cref="IndexEntry.Size"/> /
    /// <see cref="IndexEntry.LastModifiedTicks"/> wherever they're missing. Single-
    /// threaded on purpose: the goal is steady, low-impact backfill, not throughput.
    /// Yielding every ~256 stats keeps interactive search responsive.
    /// </summary>
    private async Task BackfillSizesAsync(char drive, CancellationToken ct)
    {
        try
        {
            int filled = 0;
            int seen = 0;
            foreach (var entry in _index.EnumerateVolume(drive))
            {
                if (ct.IsCancellationRequested) return;
                seen++;
                if (entry.Size != 0 && entry.LastModifiedTicks != 0) continue;
                if (entry.IsDirectory) continue;

                string fullPath = _index.ResolveFullPath(drive, entry);
                if (string.IsNullOrEmpty(fullPath)) continue;

                if (GetFileAttributesEx(fullPath, GetFileExInfoStandard, out var data))
                {
                    if (entry.Size == 0) entry.Size = data.FileSize;
                    long ft = data.LastWriteFileTime;
                    if (entry.LastModifiedTicks == 0 && ft > 0)
                    {
                        try { entry.LastModifiedTicks = DateTime.FromFileTimeUtc(ft).Ticks; }
                        catch { /* out of range — leave 0 */ }
                    }
                    filled++;
                }

                if ((seen & 0xFF) == 0) await Task.Delay(10, ct).ConfigureAwait(false);
            }
            _log?.Invoke($"Volume {drive}: size backfill filled {filled:N0} / scanned {seen:N0}");
        }
        catch (OperationCanceledException) { /* shutdown */ }
        catch (Exception ex)
        {
            _log?.Invoke($"Volume {drive}: size backfill failed — {ex.Message}");
        }
    }

    /// <summary>
    /// Persist every volume's index to disk. Safe to call after <c>StartAsync</c>'s
    /// cancellation token has been signalled — the monitor stops applying changes,
    /// and <c>ConcurrentDictionary</c> enumeration is snapshot-safe regardless.
    /// </summary>
    public Task SaveAsync(IEnumerable<char> drives)
    {
        var list = drives.ToArray();
        return Task.WhenAll(list.Select(d => Task.Run(() =>
        {
            try
            {
                ulong journalId = _index.GetJournalId(d);
                long lastUsn = _index.GetLastUsn(d);
                // Skip volumes we never finished indexing (no journal ID was captured)
                // — partial caches would silently drop entries on next launch.
                if (journalId == 0) return;
                IndexPersistence.Save(d, journalId, lastUsn, _index.EnumerateVolume(d));
                _log?.Invoke($"Volume {d}: cache saved");
            }
            catch (Exception ex)
            {
                _log?.Invoke($"Volume {d}: cache save failed — {ex.Message}");
            }
        })));
    }

    private async Task MonitorVolumeAsync(char drive, long startUsn, CancellationToken ct)
    {
        long currentUsn = startUsn;
        ulong currentJournalId = _index.GetJournalId(drive);
        while (!ct.IsCancellationRequested)
        {
            try
            {
                await foreach (var ev in _usnMonitor.WatchAsync(drive, currentUsn, ct).ConfigureAwait(false))
                {
                    ApplyChange(drive, ev);
                    currentUsn = ev.Usn + 1;
                    _index.SetLastUsn(drive, currentUsn);
                }
            }
            catch (UsnJournalTrimmedException)
            {
                // The journal trimmed entries we hadn't read yet — events between our
                // last checkpoint and the new lowest-valid USN are lost. Re-walk the
                // MFT and resume from the journal's current head.
                await ReindexAfterJournalLossAsync(drive,
                    "Journal trimmed — re-indexing", ct).ConfigureAwait(false);
                currentUsn = _index.GetLastUsn(drive);
                currentJournalId = _index.GetJournalId(drive);
            }
            catch (Exception ex) when (ex is System.ComponentModel.Win32Exception)
            {
                // A journal recreate (fsutil usn deletejournal / createjournal) leaves
                // ReadUsnJournal failing with INVALID_PARAMETER because our cached
                // JournalId no longer matches. Detect via QueryJournal and reset.
                var fresh = QueryJournal(drive);
                if (fresh is { } j && j.UsnJournalID != currentJournalId)
                {
                    await ReindexAfterJournalLossAsync(drive,
                        "USN journal recreated — re-indexing", ct).ConfigureAwait(false);
                    currentUsn = _index.GetLastUsn(drive);
                    currentJournalId = _index.GetJournalId(drive);
                }
                else
                {
                    _log?.Invoke($"Volume {drive}: monitor IOCTL failed — {ex.Message}");
                    await Task.Delay(2000, ct).ConfigureAwait(false);
                }
            }
        }
    }

    /// <summary>
    /// Re-walk the MFT after losing journal continuity (trim or recreate), then
    /// re-anchor LastUsn / JournalId. Fires <see cref="JournalReset"/> so the UI can
    /// flag the event in the status bar.
    /// </summary>
    private async Task ReindexAfterJournalLossAsync(char drive, string reason, CancellationToken ct)
    {
        _log?.Invoke($"Volume {drive}: {reason}");
        JournalReset?.Invoke(this, $"{drive}: {reason}");
        var journal = QueryJournal(drive);
        long checkpoint = journal?.NextUsn ?? 0;
        ulong journalId = journal?.UsnJournalID ?? 0;

        await Task.Run(() =>
        {
            foreach (var meta in _mftReader.Enumerate(drive, ct))
            {
                _index.AddOrUpdate(drive, new IndexEntry
                {
                    FileReferenceNumber = meta.FileReferenceNumber,
                    ParentFileReferenceNumber = meta.ParentFileReferenceNumber,
                    FileName = meta.FileName,
                    Attributes = meta.Attributes,
                    LastModifiedTicks = meta.LastModifiedTicks,
                    Size = meta.Size,
                });
            }
        }, ct).ConfigureAwait(false);

        _index.SetJournalId(drive, journalId);
        _index.SetLastUsn(drive, checkpoint);
    }

    private void ApplyChange(char drive, UsnChangeEvent ev)
    {
        if (ev.IsDelete)
        {
            _index.Remove(drive, ev.FileReferenceNumber);
            return;
        }

        // Renames manifest as in-place name updates on the existing FRN-keyed entry.
        _index.AddOrUpdate(drive, new IndexEntry
        {
            FileReferenceNumber = ev.FileReferenceNumber,
            ParentFileReferenceNumber = ev.ParentFileReferenceNumber,
            FileName = ev.FileName,
            Attributes = ev.Attributes,
            LastModifiedTicks = ev.TimeStampTicks,
            Size = 0, // not in USN records
        });
    }

    /// <summary>
    /// Snapshot the volume's USN journal. Returns null when the journal isn't enabled
    /// (logged once). Callers that only want the resume point use <c>?.NextUsn</c>;
    /// the cache validator additionally needs the journal ID and valid-range bounds.
    /// </summary>
    private USN_JOURNAL_DATA_V0? QueryJournal(char drive)
    {
        using var h = MftReader.OpenVolume($@"\\.\{drive}:");
        unsafe
        {
            USN_JOURNAL_DATA_V0 data;
            uint bytesReturned;
            bool ok = DeviceIoControl(
                h,
                FSCTL_QUERY_USN_JOURNAL,
                null, 0,
                &data, (uint)sizeof(USN_JOURNAL_DATA_V0),
                out bytesReturned,
                IntPtr.Zero);
            if (!ok)
            {
                int err = Marshal.GetLastWin32Error();
                if (err == ERROR_JOURNAL_NOT_ACTIVE)
                {
                    _log?.Invoke($"USN journal not active on {drive}: — run 'fsutil usn createjournal m=1000000000 a=100000000 {drive}:' for real-time updates");
                    return null;
                }
                throw new Win32Exception(err, "FSCTL_QUERY_USN_JOURNAL failed");
            }
            return data;
        }
    }

    private void Report(int pct, string msg, bool isComplete = false)
    {
        _progress?.Report(new IndexingProgress
        {
            Percentage = pct,
            StatusMessage = msg,
            FilesIndexed = _index.ApproximateCount,
            IsComplete = isComplete,
        });
    }
}




