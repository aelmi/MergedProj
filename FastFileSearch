using System;
using System.Buffers;
using System.Collections.Generic;
using System.IO;
using System.Runtime.InteropServices;

namespace FastFileSearch.Indexing;

/// <summary>
/// Disk persistence for one volume's index. Custom binary format optimised for
/// sequential write/read — no JSON, no per-entry allocations beyond the names.
///
/// File layout:
///   Magic (4) | Version (4) | DriveLetter (1) | reserved (7)
///   JournalId (8) | LastUsn (8) | EntryCount (8)
///   { FRN(8) ParentFRN(8) Attrs(4) Modified(8) Size(8) NameChars(2) NameUtf16(NameChars*2) }*
///
/// Validity on load is the join of three signals: matching magic+version, same
/// USN journal ID (catches reformat / journal recreation), and LastUsn still inside
/// [LowestValidUsn, NextUsn] (catches journal trim while we were closed).
/// </summary>
internal static class IndexPersistence
{
    private const uint Magic = 0x58534646; // "FFSX"
    private const int Version = 1;
    private const int HeaderBytes = 4 + 4 + 1 + 7 + 8 + 8 + 8;

    public static string CacheDirectory =>
        Path.Combine(
            Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData),
            "FastFileSearch", "index");

    public static string PathFor(char drive) =>
        Path.Combine(CacheDirectory, $"vol-{char.ToUpperInvariant(drive)}.idx");

    public sealed class LoadResult
    {
        public ulong JournalId { get; init; }
        public long LastUsn { get; init; }
        public required IReadOnlyList<IndexEntry> Entries { get; init; }
    }

    /// <summary>Returns null when the cache is missing, corrupt, or for a different drive.</summary>
    public static LoadResult? TryLoad(char drive)
    {
        var path = PathFor(drive);
        if (!File.Exists(path)) return null;

        try
        {
            using var fs = new FileStream(path, FileMode.Open, FileAccess.Read, FileShare.Read,
                bufferSize: 1 << 16, FileOptions.SequentialScan);
            using var br = new BinaryReader(fs);

            if (fs.Length < HeaderBytes) return null;

            uint magic   = br.ReadUInt32();
            int version  = br.ReadInt32();
            byte stored  = br.ReadByte();
            br.ReadBytes(7); // reserved

            if (magic != Magic || version != Version ||
                char.ToUpperInvariant((char)stored) != char.ToUpperInvariant(drive))
                return null;

            ulong journalId = br.ReadUInt64();
            long lastUsn    = br.ReadInt64();
            long count      = br.ReadInt64();
            if (count < 0 || count > int.MaxValue) return null;

            var list = new List<IndexEntry>((int)Math.Min(count, 4_000_000));
            byte[] nameBuf = ArrayPool<byte>.Shared.Rent(1024);
            try
            {
                for (long i = 0; i < count; i++)
                {
                    ulong frn       = br.ReadUInt64();
                    ulong parentFrn = br.ReadUInt64();
                    uint attrs      = br.ReadUInt32();
                    long modified   = br.ReadInt64();
                    long size       = br.ReadInt64();
                    ushort nameLen  = br.ReadUInt16();

                    int nameBytes = nameLen * 2;
                    if (nameBytes > nameBuf.Length)
                    {
                        ArrayPool<byte>.Shared.Return(nameBuf);
                        nameBuf = ArrayPool<byte>.Shared.Rent(nameBytes);
                    }

                    string name = string.Empty;
                    if (nameBytes > 0)
                    {
                        int read = 0;
                        while (read < nameBytes)
                        {
                            int n = fs.Read(nameBuf, read, nameBytes - read);
                            if (n <= 0) return null;
                            read += n;
                        }
                        name = MemoryMarshal.Cast<byte, char>(nameBuf.AsSpan(0, nameBytes)).ToString();
                    }

                    list.Add(new IndexEntry
                    {
                        FileReferenceNumber = frn,
                        ParentFileReferenceNumber = parentFrn,
                        FileName = name,
                        Attributes = attrs,
                        LastModifiedTicks = modified,
                        Size = size,
                    });
                }
            }
            finally
            {
                ArrayPool<byte>.Shared.Return(nameBuf);
            }

            return new LoadResult { JournalId = journalId, LastUsn = lastUsn, Entries = list };
        }
        catch
        {
            // Corruption: drop the file so we don't retry it every launch.
            try { File.Delete(path); } catch { }
            return null;
        }
    }

    public static void Save(char drive, ulong journalId, long lastUsn, IEnumerable<IndexEntry> entries)
    {
        Directory.CreateDirectory(CacheDirectory);
        var path = PathFor(drive);
        var tmp = path + ".tmp";

        long written;
        using (var fs = new FileStream(tmp, FileMode.Create, FileAccess.Write, FileShare.None,
            bufferSize: 1 << 16, FileOptions.SequentialScan))
        using (var bw = new BinaryWriter(fs))
        {
            bw.Write(Magic);
            bw.Write(Version);
            bw.Write((byte)char.ToUpperInvariant(drive));
            Span<byte> pad = stackalloc byte[7];
            bw.Write(pad);
            bw.Write(journalId);
            bw.Write(lastUsn);

            long countOffset = fs.Position;
            bw.Write(0L); // patched after the loop

            written = 0;
            foreach (var e in entries)
            {
                bw.Write(e.FileReferenceNumber);
                bw.Write(e.ParentFileReferenceNumber);
                bw.Write(e.Attributes);
                bw.Write(e.LastModifiedTicks);
                bw.Write(e.Size);

                ReadOnlySpan<char> name = e.FileName.AsSpan();
                if (name.Length > ushort.MaxValue) name = name[..ushort.MaxValue];
                bw.Write((ushort)name.Length);
                if (name.Length > 0)
                    bw.Write(MemoryMarshal.AsBytes(name));
                written++;
            }

            bw.Flush();
            fs.Position = countOffset;
            bw.Write(written);
            bw.Flush();
        }

        if (File.Exists(path)) File.Delete(path);
        File.Move(tmp, path);
    }
}




